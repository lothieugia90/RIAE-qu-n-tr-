<style>
.sig-box { border:1px solid var(--border); border-radius:10px; background:var(--card); overflow:hidden; }
.sig-box-header { padding:10px 16px; background:var(--bg); border-bottom:1px solid var(--border); font-weight:600; font-size:13px; display:flex; align-items:center; justify-content:space-between; }
.info-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--border); font-size:13px; }
.info-row:last-child { border-bottom:none; }
</style>

<div class="page-header">
  <div class="page-header-title">
    <h2><i class="fas fa-undo"></i> Ký xác nhận thu hồi vật tư</h2>
    <p><%= assignment.item_name %> · <%= assignment.quantity %> <%= assignment.unit %></p>
  </div>
  <div class="page-header-actions">
    <a href="/warehouse/assignments/<%= assignment.id %>" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
  </div>
</div>

<% if (existingSig) { %>
<div style="background:#E8F5E9;border:1px solid #A5D6A7;border-radius:10px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:14px">
  <i class="fas fa-check-circle" style="font-size:28px;color:#2E7D32"></i>
  <div>
    <div style="font-weight:700;color:#1B5E20;font-size:15px">Đã ký xác nhận thu hồi</div>
    <div style="font-size:12px;color:#2E7D32">Người ký: <strong><%= existingSig.full_name %></strong> · Lúc: <%= new Date(existingSig.signed_at).toLocaleString('vi-VN') %></div>
  </div>
</div>
<% } %>

<div class="grid-70-30">
  <div>
    <!-- Assignment details -->
    <div class="card mb-4">
      <div class="card-header"><span class="card-title">Thông tin vật tư thu hồi</span></div>
      <div class="card-body">
        <div class="info-row"><span style="color:var(--text-3)">Vật tư</span><strong><%= assignment.item_name %></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Số lượng</span><strong><%= assignment.quantity %> <%= assignment.unit %></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Người đang giữ</span><strong><%= assignment.assignee_name || '—' %></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Bộ phận</span><span><%= assignment.assignee_dept || '—' %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Ngày xuất</span><span><%= assignment.assigned_at ? new Date(assignment.assigned_at).toLocaleDateString('vi-VN') : '—' %></span></div>
        <% const daysHeld = Math.floor((Date.now() - new Date(assignment.assigned_at).getTime()) / 86400000); %>
        <div class="info-row"><span style="color:var(--text-3)">Số ngày sử dụng</span><strong style="color:<%= daysHeld>30?'var(--danger)':'var(--text)' %>"><%= daysHeld %> ngày</strong></div>
        <% if (assignment.notes) { %>
        <div class="info-row"><span style="color:var(--text-3)">Ghi chú</span><span><%= assignment.notes %></span></div>
        <% } %>
      </div>
    </div>

    <!-- Recipient signature (read-only) -->
    <div class="sig-box mb-4">
      <div class="sig-box-header">
        <span><i class="fas fa-user"></i> Chữ ký người nhận (<%= assignment.assignee_name || 'Người nhận' %>)</span>
        <% if (recipientSig) { %>
        <span style="color:#15803d;font-size:11px"><i class="fas fa-check-circle"></i> Đã ký <%= new Date(recipientSig.signed_at).toLocaleDateString('vi-VN') %></span>
        <% } else { %>
        <span style="color:var(--text-3);font-size:11px"><i class="fas fa-clock"></i> Chưa ký nhận</span>
        <% } %>
      </div>
      <div style="padding:14px;min-height:80px;display:flex;align-items:center;justify-content:center;background:#fafafa">
        <% if (recipientSig && recipientSig.signature_data) { %>
        <img src="<%= recipientSig.signature_data %>" style="max-width:240px;max-height:90px;object-fit:contain">
        <% } else { %>
        <span style="color:var(--text-3);font-size:13px"><i class="fas fa-minus"></i> Không có chữ ký</span>
        <% } %>
      </div>
    </div>

    <% if (!existingSig) { %>
    <!-- Warehouse return signature form -->
    <% if (['admin','director','warehouse','warehouse_keeper'].includes(locals.userRole)) { %>
    <div class="sig-box">
      <div class="sig-box-header">
        <span><i class="fas fa-warehouse"></i> Chữ ký kho xác nhận đã nhận lại</span>
      </div>
      <div style="padding:20px">
        <p style="font-size:13px;color:var(--text-2);margin-bottom:16px">
          <i class="fas fa-info-circle" style="color:var(--primary)"></i>
          Ký xác nhận đã kiểm tra và nhận lại vật tư từ <strong><%= assignment.assignee_name || 'người nhận' %></strong>.
          Sau khi ký, trạng thái phiếu sẽ chuyển sang <strong>Đã trả</strong>.
        </p>

        <form action="/signatures/warehouse-return/<%= assignment.id %>/sign" method="POST" id="returnSignForm" onsubmit="return window.captureAndSubmit(event)">
          <input type="hidden" name="signature_data" id="sigData">

          <div style="margin-bottom:16px">
            <label style="font-size:12px;font-weight:600;color:var(--text-2);display:block;margin-bottom:6px">Chữ ký của bạn <span style="color:var(--danger)">*</span></label>
            <div id="sigWrap" style="position:relative;border:2px dashed var(--border);border-radius:10px;background:#fff;overflow:hidden">
              <canvas id="sigCanvas" style="display:block;cursor:crosshair;width:100%;height:140px"></canvas>
              <button type="button" onclick="window.clearSig()" style="position:absolute;top:8px;right:8px;background:rgba(255,255,255,.85);border:1px solid var(--border);border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;color:var(--text-3)">
                <i class="fas fa-eraser"></i> Xóa
              </button>
            </div>
            <div id="sigHint" style="font-size:11px;color:var(--text-3);margin-top:4px"><i class="fas fa-pen"></i> Vẽ chữ ký vào ô trên</div>
          </div>

          <div class="form-group" style="max-width:340px">
            <label class="form-label">Mật khẩu xác nhận <span style="color:var(--danger)">*</span></label>
            <input type="password" name="pin" class="form-control" placeholder="Nhập mật khẩu của bạn" required autocomplete="current-password">
            <div style="font-size:11px;color:var(--text-3);margin-top:4px"><i class="fas fa-shield-alt"></i> Xác thực danh tính trước khi ký số</div>
          </div>

          <div style="margin-top:20px;display:flex;gap:10px;align-items:center">
            <button type="submit" class="btn btn-primary" style="min-width:200px">
              <i class="fas fa-check-double"></i> Xác nhận thu hồi & Ký số
            </button>
            <a href="/warehouse/assignments/<%= assignment.id %>" class="btn btn-outline">Hủy</a>
          </div>
        </form>
      </div>
    </div>
    <% } else { %>
    <div class="card">
      <div class="card-body" style="text-align:center;padding:32px">
        <i class="fas fa-lock" style="font-size:32px;color:var(--text-3);margin-bottom:12px;display:block"></i>
        <p style="color:var(--text-3);font-size:13px">Chỉ nhân viên kho hoặc quản lý mới có thể ký xác nhận thu hồi.</p>
        <p style="color:var(--text-3);font-size:12px;margin-top:6px">Vui lòng đến quầy kho để nhân viên kho ký nhận.</p>
      </div>
    </div>
    <% } %>
    <% } %>
  </div>

  <!-- Right sidebar -->
  <div>
    <div class="card mb-4" style="border-top:3px solid var(--warning)">
      <div class="card-body" style="text-align:center;padding:20px">
        <div style="font-size:11px;color:var(--text-3);margin-bottom:6px">TRẠNG THÁI</div>
        <% if (assignment.status === 'pending_return') { %>
        <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:14px;font-size:13px;font-weight:600;background:#FFF8E1;color:#F57F17">
          <i class="fas fa-hourglass-half" style="font-size:8px"></i> Chờ kho xác nhận
        </span>
        <% } else { %>
        <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:14px;font-size:13px;font-weight:600;background:#E3F2FD;color:#1565C0">
          <i class="fas fa-circle" style="font-size:8px"></i> Đang giao
        </span>
        <% } %>
        <% if (assignment.recipient_signed_at) { %>
        <div style="margin-top:12px;font-size:12px;color:#15803d"><i class="fas fa-check-circle"></i> Người nhận đã ký xác nhận</div>
        <% } else { %>
        <div style="margin-top:12px;font-size:12px;color:var(--text-3)"><i class="fas fa-clock"></i> Người nhận chưa ký nhận</div>
        <% } %>
      </div>
    </div>

    <div class="card" style="border-top:3px solid var(--primary)">
      <div class="card-body">
        <div style="font-size:11px;font-weight:700;color:var(--text-3);margin-bottom:12px;letter-spacing:.5px">QUY TRÌNH KÝ</div>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:<%= recipientSig ? '#E8F5E9' : '#F5F5F5' %>;color:<%= recipientSig ? '#2E7D32' : 'var(--text-3)' %>">
              <i class="fas fa-<%= recipientSig ? 'check' : 'user' %>" style="font-size:12px"></i>
            </div>
            <div>
              <div style="font-size:12px;font-weight:600">Người nhận ký nhận</div>
              <div style="font-size:11px;color:var(--text-3)"><%= recipientSig ? 'Đã ký' : 'Chưa ký' %></div>
            </div>
          </div>
          <div style="width:1px;height:16px;background:var(--border);margin-left:14px"></div>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:<%= existingSig ? '#E8F5E9' : '#E3F2FD' %>;color:<%= existingSig ? '#2E7D32' : 'var(--primary)' %>">
              <i class="fas fa-<%= existingSig ? 'check' : 'warehouse' %>" style="font-size:12px"></i>
            </div>
            <div>
              <div style="font-size:12px;font-weight:600">Kho ký thu hồi</div>
              <div style="font-size:11px;color:var(--text-3)"><%= existingSig ? 'Đã ký' : 'Chờ ký' %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/signature-pad-js', { canvasId: 'sigCanvas', wrapId: 'sigWrap', hintId: 'sigHint', dataId: 'sigData', formId: 'returnSignForm' }) %>
