<div class="page-header">
  <div class="page-header-title">
    <h2><i class="fas fa-file-signature"></i> Chữ ký điện tử</h2>
    <p>Quản lý và xác minh chữ ký số nội bộ</p>
  </div>
  <div class="page-header-actions">
    <a href="/signatures/verify" class="btn btn-outline"><i class="fas fa-search"></i> Kiểm tra hash</a>
  </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-bottom:24px">
  <div class="card" style="border-top:3px solid var(--primary)">
    <div class="card-body" style="display:flex;align-items:center;gap:14px">
      <span style="width:46px;height:46px;border-radius:12px;background:rgba(59,130,246,.1);display:flex;align-items:center;justify-content:center">
        <i class="fas fa-file-invoice-dollar" style="font-size:20px;color:var(--primary)"></i>
      </span>
      <div>
        <div style="font-size:22px;font-weight:800;color:var(--text)"><%= stats.payroll_signed || 0 %></div>
        <div style="font-size:12px;color:var(--text-2)">Phiếu lương đã ký</div>
      </div>
    </div>
  </div>
  <div class="card" style="border-top:3px solid #7c3aed">
    <div class="card-body" style="display:flex;align-items:center;gap:14px">
      <span style="width:46px;height:46px;border-radius:12px;background:rgba(124,58,237,.1);display:flex;align-items:center;justify-content:center">
        <i class="fas fa-boxes" style="font-size:20px;color:#7c3aed"></i>
      </span>
      <div>
        <div style="font-size:22px;font-weight:800;color:var(--text)"><%= stats.warehouse_signed || 0 %></div>
        <div style="font-size:12px;color:var(--text-2)">Phiếu kho đã ký</div>
      </div>
    </div>
  </div>
  <div class="card" style="border-top:3px solid #0369a1">
    <div class="card-body" style="display:flex;align-items:center;gap:14px">
      <span style="width:46px;height:46px;border-radius:12px;background:rgba(3,105,161,.1);display:flex;align-items:center;justify-content:center">
        <i class="fas fa-stamp" style="font-size:20px;color:#0369a1"></i>
      </span>
      <div>
        <div style="font-size:22px;font-weight:800;color:var(--text)"><%= stats.request_signed || 0 %></div>
        <div style="font-size:12px;color:var(--text-2)">Yêu cầu đã ký phê duyệt</div>
      </div>
    </div>
  </div>
</div>

<!-- Recent signatures -->
<div class="card">
  <div class="card-header">
    <span class="card-title">Nhật ký chữ ký gần đây</span>
  </div>
  <div style="overflow-x:auto">
    <table style="font-size:13px">
      <thead>
        <tr>
          <th>Người ký</th>
          <th>Loại tài liệu</th>
          <th>Thời gian</th>
          <th>Địa chỉ IP</th>
          <th>Hash</th>
          <th>PDF</th>
        </tr>
      </thead>
      <tbody>
      <% if (!recentSigs || recentSigs.length === 0) { %>
      <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:24px">Chưa có chữ ký nào</td></tr>
      <% } else { recentSigs.forEach(s => { %>
      <tr>
        <td style="font-weight:600"><%= s.full_name %></td>
        <td>
          <span style="display:inline-flex;align-items:center;gap:5px;padding:2px 8px;border-radius:6px;font-size:11px;font-weight:600;
                background:<%= s.document_type==='payroll'?'#eff6ff':s.document_type==='warehouse_assignment'?'#f5f3ff':'#f0fdf4' %>;
                color:<%= s.document_type==='payroll'?'#1d4ed8':s.document_type==='warehouse_assignment'?'#6d28d9':'#15803d' %>">
            <i class="fas fa-<%= s.document_type==='payroll'?'file-invoice-dollar':s.document_type==='warehouse_assignment'?'boxes':'stamp' %>"></i>
            <%= s.document_type==='payroll'?'Phiếu lương':s.document_type==='warehouse_assignment'?'Phiếu kho':'Yêu cầu' %>
          </span>
        </td>
        <td style="white-space:nowrap"><%= new Date(s.signed_at).toLocaleString('vi-VN') %></td>
        <td style="color:var(--text-3);font-size:11px"><%= s.ip_address || '—' %></td>
        <td>
          <a href="/signatures/verify?hash=<%= s.signature_hash %>" style="font-size:10px;font-family:monospace;color:var(--primary)" title="<%= s.signature_hash %>">
            <%= s.signature_hash.substring(0,16) %>…
          </a>
        </td>
        <td>
          <% if (s.pdf_url) { %>
          <a href="<%= s.pdf_url %>" target="_blank" class="btn btn-sm btn-outline" style="font-size:11px;padding:2px 8px"><i class="fas fa-file-pdf"></i></a>
          <% } else { %>
          <span style="color:var(--text-3);font-size:11px">—</span>
          <% } %>
        </td>
      </tr>
      <% }) } %>
      </tbody>
    </table>
  </div>
</div>
