<div style="max-width:640px;margin:0 auto">
  <div style="margin-bottom:20px">
    <h2 style="font-size:20px;font-weight:800;color:var(--text);margin-bottom:6px"><i class="fas fa-search-plus" style="color:var(--primary)"></i> Kiểm tra chữ ký số</h2>
    <p style="color:var(--text-2);font-size:13px">Nhập mã hash để xác minh tính hợp lệ của một chữ ký điện tử.</p>
  </div>

  <div class="card" style="margin-bottom:20px">
    <div class="card-body">
      <form action="/signatures/verify" method="GET" style="display:flex;gap:8px">
        <input type="text" name="hash" class="form-control" placeholder="Nhập SHA-256 hash (64 ký tự hex)..." value="<%= hash %>" style="font-family:monospace;font-size:12px">
        <button type="submit" class="btn btn-primary" style="white-space:nowrap"><i class="fas fa-search"></i> Kiểm tra</button>
      </form>
    </div>
  </div>

  <% if (hash && !result) { %>
  <div style="background:#fef2f2;border:1.5px solid #fca5a5;border-radius:12px;padding:20px;text-align:center">
    <i class="fas fa-times-circle" style="font-size:36px;color:#dc2626;margin-bottom:10px"></i>
    <div style="font-size:16px;font-weight:700;color:#dc2626">Không tìm thấy chữ ký</div>
    <div style="font-size:13px;color:#b91c1c;margin-top:6px">Hash này không khớp với bất kỳ chữ ký nào trong hệ thống hoặc tài liệu đã bị can thiệp.</div>
  </div>
  <% } else if (result) { %>
  <div style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1.5px solid #86efac;border-radius:12px;padding:24px">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px">
      <span style="width:52px;height:52px;border-radius:50%;background:#22c55e;display:flex;align-items:center;justify-content:center;flex-shrink:0">
        <i class="fas fa-shield-check" style="color:#fff;font-size:22px"></i>
      </span>
      <div>
        <div style="font-size:18px;font-weight:800;color:#15803d">Chữ ký hợp lệ</div>
        <div style="font-size:13px;color:#166534">Tài liệu chưa bị sửa đổi sau khi ký</div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:13px">
      <div style="padding:10px 14px;background:white;border-radius:8px;border:1px solid #bbf7d0">
        <div style="font-size:10px;color:#166534;font-weight:700;text-transform:uppercase;margin-bottom:4px">Người ký</div>
        <div style="font-weight:600;color:#14532d"><%= result.full_name %></div>
      </div>
      <div style="padding:10px 14px;background:white;border-radius:8px;border:1px solid #bbf7d0">
        <div style="font-size:10px;color:#166534;font-weight:700;text-transform:uppercase;margin-bottom:4px">Loại tài liệu</div>
        <div style="font-weight:600;color:#14532d"><%= result.document_type %></div>
      </div>
      <div style="padding:10px 14px;background:white;border-radius:8px;border:1px solid #bbf7d0">
        <div style="font-size:10px;color:#166534;font-weight:700;text-transform:uppercase;margin-bottom:4px">Thời gian ký</div>
        <div style="font-weight:600;color:#14532d"><%= new Date(result.signed_at).toLocaleString('vi-VN') %></div>
      </div>
      <div style="padding:10px 14px;background:white;border-radius:8px;border:1px solid #bbf7d0">
        <div style="font-size:10px;color:#166534;font-weight:700;text-transform:uppercase;margin-bottom:4px">Địa chỉ IP</div>
        <div style="font-weight:600;color:#14532d"><%= result.ip_address || '—' %></div>
      </div>
    </div>
    <% if (result.signature_data) { %>
    <div style="margin-top:14px;padding:12px;background:white;border-radius:8px;border:1px solid #bbf7d0;display:flex;align-items:center;gap:12px">
      <div>
        <div style="font-size:10px;color:#166534;font-weight:700;text-transform:uppercase;margin-bottom:6px">Ảnh chữ ký</div>
        <div style="border:1.5px solid #bbf7d0;border-radius:6px;overflow:hidden;background:#f9fffe;width:200px;height:75px;display:flex;align-items:center;justify-content:center">
          <img src="<%= result.signature_data %>" style="max-width:100%;max-height:100%;object-fit:contain">
        </div>
      </div>
      <div style="flex:1">
        <div style="font-size:10px;color:#166534;font-weight:700;text-transform:uppercase;margin-bottom:4px">Hash (SHA-256)</div>
        <div style="font-size:10px;font-family:monospace;background:var(--bg);padding:6px 8px;border-radius:6px;border:1px solid #bbf7d0;word-break:break-all;color:#166534"><%= result.signature_hash %></div>
      </div>
    </div>
    <% } %>
    <% if (result.pdf_url) { %>
    <div style="margin-top:14px">
      <a href="<%= result.pdf_url %>" target="_blank" class="btn btn-sm" style="background:#15803d;color:#fff;border:none">
        <i class="fas fa-file-pdf"></i> Tải PDF đã ký
      </a>
    </div>
    <% } %>
  </div>
  <% } else { %>
  <div style="text-align:center;padding:40px;color:var(--text-3)">
    <i class="fas fa-fingerprint" style="font-size:48px;opacity:0.3;margin-bottom:12px"></i>
    <div style="font-size:14px">Nhập hash để kiểm tra tính hợp lệ của chữ ký</div>
  </div>
  <% } %>
</div>
