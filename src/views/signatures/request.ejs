<div style="max-width:660px;margin:0 auto">

<% if (existingSig) { %>
<div style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1.5px solid #86efac;border-radius:12px;padding:18px 22px;margin-bottom:20px;display:flex;align-items:center;gap:14px">
  <span style="width:44px;height:44px;border-radius:50%;background:#22c55e;display:flex;align-items:center;justify-content:center;flex-shrink:0">
    <i class="fas fa-stamp" style="color:#fff;font-size:18px"></i>
  </span>
  <div>
    <div style="font-weight:700;font-size:15px;color:#15803d">Đã ký phê duyệt</div>
    <div style="font-size:13px;color:#166534;margin-top:3px">
      Vào <%= new Date(existingSig.signed_at).toLocaleString('vi-VN') %>
    </div>
    <% if (existingSig.pdf_url) { %>
    <a href="<%= existingSig.pdf_url %>" target="_blank" class="btn btn-sm" style="margin-top:8px;background:#15803d;color:#fff;border:none">
      <i class="fas fa-file-pdf"></i> Phiếu phê duyệt (PDF)
    </a>
    <% } %>
  </div>
</div>
<% } %>

<!-- Request preview -->
<div class="card" style="margin-bottom:20px">
  <div class="card-header" style="background:linear-gradient(135deg,#0369a1,#0284c7);color:#fff;border-radius:12px 12px 0 0">
    <div style="display:flex;align-items:center;gap:10px">
      <i class="fas fa-file-signature" style="font-size:20px"></i>
      <div>
        <div style="font-size:14px;font-weight:700">PHIẾU <%= (request.form_title||'YÊU CẦU').toUpperCase() %></div>
        <div style="font-size:11px;opacity:0.85"><%= new Date(request.created_at).toLocaleDateString('vi-VN') %></div>
      </div>
      <span class="badge badge-<%= request.status %>" style="margin-left:auto"><%= request.status %></span>
    </div>
  </div>
  <div class="card-body">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;font-size:13px;margin-bottom:14px">
      <div style="padding:10px 14px;background:var(--bg);border-radius:8px;border:1px solid var(--border)">
        <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;font-weight:700;margin-bottom:4px">Người gửi</div>
        <div style="font-weight:600"><%= request.submitter_name %></div>
        <div style="font-size:11px;color:var(--text-3)"><%= request.department || '' %></div>
      </div>
      <div style="padding:10px 14px;background:var(--bg);border-radius:8px;border:1px solid var(--border)">
        <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;font-weight:700;margin-bottom:4px">Loại phiếu</div>
        <div style="font-weight:600"><%= request.form_title || '—' %></div>
      </div>
    </div>
    <% if (request.content) { %>
    <div style="padding:12px 14px;background:var(--bg);border-radius:8px;border:1px solid var(--border);font-size:13px;line-height:1.6">
      <div style="font-size:10px;color:var(--text-3);text-transform:uppercase;font-weight:700;margin-bottom:6px">Nội dung</div>
      <%= request.content %>
    </div>
    <% } %>
  </div>
</div>

<% if (!existingSig) { %>
<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-stamp" style="color:#0369a1"></i> Ký phê duyệt</span>
  </div>
  <div class="card-body">
    <div style="margin-bottom:18px">
      <label class="form-label">Chữ ký phê duyệt <span style="color:var(--danger)">*</span></label>
      <div id="sigWrap" style="position:relative;border:2px dashed var(--border);border-radius:10px;overflow:hidden;background:var(--bg);cursor:crosshair;touch-action:none">
        <canvas id="sigCanvas" style="display:block;width:100%;height:160px"></canvas>
        <div id="sigHint" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-3);font-size:13px;pointer-events:none;gap:8px">
          <i class="fas fa-signature" style="font-size:20px;opacity:0.4"></i> Ký phê duyệt tại đây
        </div>
      </div>
      <button type="button" onclick="clearSig()" class="btn btn-sm btn-outline" style="margin-top:8px"><i class="fas fa-eraser"></i> Xóa</button>
    </div>

    <form id="signForm" action="/signatures/request/<%= request.id %>/sign" method="POST" onsubmit="return captureAndSubmit(event)">
      <input type="hidden" name="signature_data" id="sigData">
      <div style="padding:14px 16px;background:#fffbeb;border:1px solid #fcd34d;border-radius:10px;margin-bottom:16px">
        <div style="font-size:12px;font-weight:700;color:#92400e;margin-bottom:10px"><i class="fas fa-shield-alt"></i> Xác thực danh tính</div>
        <div class="form-group" style="margin:0">
          <label class="form-label" style="font-size:12px">Mật khẩu đăng nhập <span style="color:var(--danger)">*</span></label>
          <input type="password" name="pin" class="form-control" required placeholder="Nhập mật khẩu để ký phê duyệt...">
        </div>
      </div>
      <div style="display:flex;gap:10px">
        <button type="submit" class="btn btn-primary" style="flex:1;background:linear-gradient(135deg,#0369a1,#0284c7);border-color:transparent">
          <i class="fas fa-check-circle"></i> Ký phê duyệt
        </button>
        <a href="/requests/<%= request.id %>" class="btn btn-outline">Hủy</a>
      </div>
    </form>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-signature" style="color:#22c55e"></i> Dấu phê duyệt</span>
  </div>
  <div class="card-body" style="display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start">
    <div style="border:1.5px solid var(--border);border-radius:8px;overflow:hidden;background:#f8f9ff;width:240px;height:90px;display:flex;align-items:center;justify-content:center">
      <img src="<%= existingSig.signature_data %>" style="max-width:100%;max-height:100%;object-fit:contain">
    </div>
    <div style="font-size:12px;flex:1">
      <div style="margin-bottom:6px"><span style="color:var(--text-3)">Thời gian:</span> <strong><%= new Date(existingSig.signed_at).toLocaleString('vi-VN') %></strong></div>
      <div style="font-size:10px;font-family:monospace;background:var(--bg);padding:5px 8px;border-radius:6px;border:1px solid var(--border);word-break:break-all;color:var(--text-2);margin-top:8px"><%= existingSig.signature_hash %></div>
      <a href="/signatures/verify?hash=<%= existingSig.signature_hash %>" class="btn btn-sm btn-outline" style="margin-top:8px;font-size:11px"><i class="fas fa-search"></i> Kiểm tra</a>
    </div>
  </div>
</div>
<% } %>
</div>

<%- include('../partials/signature-pad-js', { canvasId: 'sigCanvas', wrapId: 'sigWrap', hintId: 'sigHint', dataId: 'sigData', formId: 'signForm' }) %>
