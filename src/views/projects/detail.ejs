<div class="page-header">
  <div class="page-header-title">
    <h1><span class="project-code" style="font-size:13px"><%= project.code %></span> <%= project.name %></h1>
    <p>
      <span class="badge badge-<%= project.status %>"><%= PROJECT_STATUS_LABELS[project.status] %></span>
      <span class="badge badge-<%= project.priority %>"><%= PRIORITY_LABELS[project.priority] %></span>
      <% if (project.manager_name) { %> · PM: <%= project.manager_name %><% } %>
    </p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <a href="/projects/<%= project.id %>/kanban" class="btn btn-primary"><i class="fas fa-columns"></i> Kanban</a>
    <% if (['edit','full'].includes(permLevel)) { %>
    <a href="/projects/<%= project.id %>/edit" class="btn btn-outline"><i class="fas fa-pen"></i> Sửa</a>
    <% } %>
    <% if (permLevel === 'full' && project.status !== 'cancelled') { %>
    <form action="/projects/<%= project.id %>/cancel" method="POST" style="display:inline"
          data-confirm="Hủy dự án này? Task và dữ liệu vẫn được giữ lại.">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-outline" style="color:var(--danger)"><i class="fas fa-ban"></i> Hủy dự án</button>
    </form>
    <% } %>
  </div>
</div>

<div class="detail-grid">
  <div class="detail-main">
    <div class="card">
      <div class="card-header">
        <h3>Tiến độ · <%= project.progress_percent || 0 %>%</h3>
        <small style="color:var(--text-3)"><%= taskStats.done %>/<%= taskStats.total %> task hoàn thành<% if (taskStats.overdue > 0) { %> · <span style="color:var(--danger)"><%= taskStats.overdue %> quá hạn</span><% } %></small>
      </div>
      <div class="card-body">
        <div class="progress-track" style="height:10px"><div class="progress-fill" style="width:<%= project.progress_percent || 0 %>%"></div></div>
        <div class="pd-info-grid">
          <% if (project.client_name) { %><div><label>Khách hàng</label><span><%= project.client_name %></span></div><% } %>
          <% if (project.client_contact) { %><div><label>Liên hệ</label><span><%= project.client_contact %></span></div><% } %>
          <div><label>Bắt đầu</label><span><%= fmtDate(project.start_date) %></span></div>
          <div><label>Hạn hoàn thành</label><span><%= fmtDate(project.end_date) %></span></div>
          <% if (project.budget) { %><div><label>Ngân sách</label><span><%= Number(project.budget).toLocaleString('vi-VN') %> ₫</span></div><% } %>
          <% if (project.location) { %><div><label>Địa điểm</label><span><%= project.location %></span></div><% } %>
        </div>
        <% if (project.description) { %><p class="pd-desc"><%= project.description %></p><% } %>
      </div>
    </div>

    <div class="card" style="margin-top:20px">
      <div class="card-header" style="display:flex;justify-content:space-between;align-items:center">
        <h3>Công việc (<%= tasks.length %>)</h3>
        <button class="btn btn-primary btn-sm" onclick="document.getElementById('createTaskModal').showModal()">
          <i class="fas fa-plus"></i> Thêm task
        </button>
      </div>
      <div class="card-body" style="padding:0">
        <% if (tasks.length === 0) { %>
        <p style="text-align:center;padding:32px;color:var(--text-3)">Chưa có task nào — bấm "Thêm task" hoặc dùng <a href="/projects/<%= project.id %>/kanban">bảng Kanban</a></p>
        <% } else { %>
        <table class="table">
          <thead><tr><th>Task</th><th>Người làm</th><th>Ưu tiên</th><th>Hạn</th><th>Trạng thái</th></tr></thead>
          <tbody>
            <% tasks.forEach(t => { %>
            <tr>
              <td><a href="/tasks/<%= t.id %>" style="font-weight:500;color:var(--text);text-decoration:none"><%= t.title %></a></td>
              <td><%= t.assignee_name || '—' %></td>
              <td><span class="badge badge-<%= t.priority %>"><%= PRIORITY_LABELS[t.priority] %></span></td>
              <td style="white-space:nowrap;<%= t.due_date && new Date(t.due_date) < new Date() && t.status !== 'done' ? 'color:var(--danger);font-weight:600' : '' %>"><%= fmtDate(t.due_date) %></td>
              <td><span class="badge badge-<%= t.status %>"><%= STATUS_LABELS[t.status] %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <div class="detail-side">
    <div class="card">
      <div class="card-header"><h3>Thành viên (<%= members.length %>)</h3></div>
      <div class="card-body">
        <% members.forEach(m => { %>
        <div class="member-row">
          <div class="member-avatar">
            <% if (m.avatar_url) { %><img src="<%= m.avatar_url %>" alt=""><% } else { %><span><%= m.full_name.charAt(0).toUpperCase() %></span><% } %>
          </div>
          <div class="member-info">
            <strong><%= m.full_name %></strong>
            <small><%= m.project_role === 'manager' ? 'Quản lý' : 'Thành viên' %><% if (m.position) { %> · <%= m.position %><% } %></small>
          </div>
          <% if (['edit','full'].includes(permLevel) && m.id !== project.manager_id) { %>
          <form action="/projects/<%= project.id %>/members/remove" method="POST" data-confirm="Xóa <%= m.full_name %> khỏi dự án?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="user_id" value="<%= m.id %>">
            <button type="submit" class="member-remove" title="Xóa khỏi dự án"><i class="fas fa-times"></i></button>
          </form>
          <% } %>
        </div>
        <% }) %>

        <% if (['edit','full'].includes(permLevel)) { %>
        <form action="/projects/<%= project.id %>/members" method="POST" class="add-member-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="user_id" class="form-control" required>
            <option value="">— Thêm thành viên —</option>
            <% allUsers.filter(u => !members.some(m => m.id === u.id)).forEach(u => { %>
            <option value="<%= u.id %>"><%= u.full_name %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i></button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Modal tạo task -->
<dialog id="createTaskModal" class="modal">
  <form action="/tasks" method="POST" class="modal-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="project_id" value="<%= project.id %>">
    <input type="hidden" name="redirect_to" value="/projects/<%= project.id %>">
    <h3>Thêm task mới</h3>
    <div class="form-group">
      <label>Tiêu đề *</label>
      <input type="text" name="title" class="form-control" required maxlength="300">
    </div>
    <div class="form-group">
      <label>Mô tả</label>
      <textarea name="description" class="form-control" rows="3"></textarea>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Giao cho</label>
        <select name="assignee_id" class="form-control">
          <option value="">— Chưa giao —</option>
          <% allUsers.forEach(u => { %><option value="<%= u.id %>"><%= u.full_name %></option><% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Ưu tiên</label>
        <select name="priority" class="form-control">
          <% Object.entries(PRIORITY_LABELS).forEach(([v, l]) => { %>
          <option value="<%= v %>" <%= v === 'medium' ? 'selected' : '' %>><%= l %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Hạn hoàn thành</label>
        <input type="date" name="due_date" class="form-control">
      </div>
      <div class="form-group">
        <label>Ước tính (giờ)</label>
        <input type="number" name="estimated_hours" class="form-control" min="0" step="0.5">
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="this.closest('dialog').close()">Hủy</button>
      <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo task</button>
    </div>
  </form>
</dialog>

<style>
.detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 20px; align-items: start; }
.modal { border: none; border-radius: var(--radius-lg); padding: 0; width: 100%; max-width: 520px; box-shadow: var(--shadow-lg); }
.modal::backdrop { background: rgba(13,27,62,.5); }
.modal-form { padding: 26px; }
.modal-form h3 { margin-bottom: 20px; font-size: 17px; color: var(--text); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
.modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 22px; }
@media (max-width: 1000px) { .detail-grid { grid-template-columns: 1fr; } }
.progress-track { background: var(--border-light); border-radius: 6px; overflow: hidden; }
.progress-fill { height: 100%; background: var(--primary); border-radius: 6px; }
.pd-info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 14px; margin-top: 18px; }
.pd-info-grid label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-3); margin-bottom: 3px; }
.pd-info-grid span { font-size: 13.5px; color: var(--text); }
.pd-desc { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-light); font-size: 13.5px; color: var(--text-2); line-height: 1.65; white-space: pre-line; }
.member-row { display: flex; align-items: center; gap: 11px; padding: 8px 0; }
.member-row + .member-row { border-top: 1px solid var(--border-light); }
.member-avatar { width: 36px; height: 36px; border-radius: 50%; overflow: hidden; flex-shrink: 0; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; }
.member-avatar img { width: 100%; height: 100%; object-fit: cover; }
.member-info { flex: 1; display: flex; flex-direction: column; }
.member-info strong { font-size: 13.5px; color: var(--text); }
.member-info small { font-size: 11.5px; color: var(--text-3); }
.member-remove { border: none; background: transparent; color: var(--text-3); cursor: pointer; width: 28px; height: 28px; border-radius: 6px; }
.member-remove:hover { background: var(--danger-bg); color: var(--danger); }
.add-member-form { display: flex; gap: 8px; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border); }
</style>
