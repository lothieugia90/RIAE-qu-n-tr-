<%
const autoProgress = project.progress_percent || 0;
const now = new Date();
const endDate = project.end_date ? new Date(project.end_date) : null;
const daysLeft = endDate ? Math.ceil((endDate - now) / (1000*60*60*24)) : null;
const isOverdue = endDate && endDate < now && project.status !== 'completed';
%>

<!-- Project Hero -->
<div class="pj-hero">
  <div class="pj-hero-left">
    <div class="pj-breadcrumb"><a href="/projects">Dự án</a> <i class="fas fa-chevron-right"></i> <%= project.name %></div>
    <h1 class="pj-title"><%= project.name %></h1>
    <div class="pj-badges">
      <span class="badge badge-<%= project.status %>"><%= project.status %></span>
      <span class="badge badge-<%= project.priority %>"><%= project.priority %></span>
      <span style="font-size:12px;color:var(--text-3);padding:3px 8px;background:var(--bg);border-radius:6px;border:1px solid var(--border)"><i class="fas fa-code" style="margin-right:4px"></i><%= project.code %></span>
      <% if (project.client_name) { %><span style="font-size:12px;color:var(--text-3)"><i class="fas fa-building" style="margin-right:4px"></i><%= project.client_name %></span><% } %>
    </div>
  </div>
  <div class="pj-hero-actions">
    <a href="/projects/<%= project.id %>/kanban" class="btn btn-primary"><i class="fas fa-columns"></i> Kanban</a>
    <a href="/projects/<%= project.id %>/gantt" class="btn btn-outline"><i class="fas fa-chart-gantt"></i> Gantt</a>
    <% if (['admin','director','pm'].includes(locals.userRole)) { %>
    <a href="/projects/<%= project.id %>/edit" class="btn btn-outline"><i class="fas fa-edit"></i></a>
    <% } %>
  </div>
</div>

<!-- KPI strip -->
<div class="pj-kpi-strip">
  <div class="pj-kpi">
    <div class="pj-kpi-val" style="color:var(--primary)"><%= autoProgress %>%</div>
    <div class="pj-kpi-label">Tiến độ</div>
  </div>
  <div class="pj-kpi-divider"></div>
  <div class="pj-kpi">
    <div class="pj-kpi-val"><%= taskStats.total %></div>
    <div class="pj-kpi-label">Tổng task</div>
  </div>
  <div class="pj-kpi-divider"></div>
  <div class="pj-kpi">
    <div class="pj-kpi-val" style="color:#16a34a"><%= taskStats.done %></div>
    <div class="pj-kpi-label">Hoàn thành</div>
  </div>
  <div class="pj-kpi-divider"></div>
  <div class="pj-kpi">
    <div class="pj-kpi-val" style="color:#3b82f6"><%= taskStats.in_progress %></div>
    <div class="pj-kpi-label">Đang làm</div>
  </div>
  <% if (taskStats.overdue > 0) { %>
  <div class="pj-kpi-divider"></div>
  <div class="pj-kpi">
    <div class="pj-kpi-val" style="color:#dc2626"><%= taskStats.overdue %></div>
    <div class="pj-kpi-label">Quá hạn</div>
  </div>
  <% } %>
  <div class="pj-kpi-divider"></div>
  <div class="pj-kpi">
    <div class="pj-kpi-val <%= isOverdue ? 'text-danger' : daysLeft !== null && daysLeft < 7 ? 'text-warning' : '' %>">
      <% if (daysLeft === null) { %>—<% } else if (isOverdue) { %>Trễ <%= Math.abs(daysLeft) %>n<% } else { %><%= daysLeft %>n<% } %>
    </div>
    <div class="pj-kpi-label">Còn lại</div>
  </div>
  <div class="pj-kpi-divider"></div>
  <div class="pj-kpi">
    <div class="pj-kpi-val"><%= members.length %></div>
    <div class="pj-kpi-label">Thành viên</div>
  </div>
</div>

<!-- Auto progress bar -->
<div class="card mb-4" style="padding:16px 20px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
    <span style="font-size:13px;font-weight:600;color:var(--text)">Tiến độ tổng thể <span style="font-weight:400;color:var(--text-3);font-size:11px">(tự động từ task)</span></span>
    <span style="font-size:18px;font-weight:700;color:var(--primary)"><%= autoProgress %>%</span>
  </div>
  <div style="height:8px;background:var(--border);border-radius:4px;overflow:hidden">
    <div style="height:100%;width:<%= autoProgress %>%;background:linear-gradient(90deg,var(--primary),#60a5fa);border-radius:4px;transition:width .6s ease"></div>
  </div>
  <div style="display:flex;gap:12px;margin-top:10px;flex-wrap:wrap">
    <% [
      {s:'todo', label:'Cần làm', color:'#94a3b8'},
      {s:'in_progress', label:'Đang làm', color:'#3b82f6'},
      {s:'review', label:'Kiểm tra', color:'#d97706'},
      {s:'done', label:'Hoàn thành', color:'#16a34a'},
    ].forEach(item => { const cnt = tasks.filter(t=>t.status===item.s).length; if(cnt===0) return; %>
    <span style="font-size:11px;color:var(--text-3);display:flex;align-items:center;gap:4px">
      <span style="width:6px;height:6px;border-radius:50%;background:<%= item.color %>"></span>
      <%= item.label %>: <strong style="color:var(--text)"><%= cnt %></strong>
    </span>
    <% }) %>
  </div>
</div>

<!-- Tab Navigation -->
<div class="pj-tabs" id="pjTabs">
  <button class="pj-tab <%= activeTab==='overview' ? 'active':'' %>" onclick="switchTab('overview')">
    <i class="fas fa-info-circle"></i> Tổng quan
  </button>
  <button class="pj-tab <%= activeTab==='tasks' ? 'active':'' %>" onclick="switchTab('tasks')">
    <i class="fas fa-tasks"></i> Công việc
    <% if (taskStats.overdue > 0) { %><span class="tab-badge tab-badge-danger"><%= taskStats.overdue %></span><% } else if (taskStats.in_progress > 0) { %><span class="tab-badge"><%= taskStats.in_progress %></span><% } %>
  </button>
  <button class="pj-tab <%= activeTab==='documents' ? 'active':'' %>" onclick="switchTab('documents')">
    <i class="fas fa-paperclip"></i> Tài liệu
    <% if (documents.length > 0) { %><span class="tab-badge"><%= documents.length %></span><% } %>
  </button>
  <button class="pj-tab <%= activeTab==='members' ? 'active':'' %>" onclick="switchTab('members')">
    <i class="fas fa-users"></i> Thành viên
    <span class="tab-badge"><%= members.length %></span>
  </button>
</div>

<!-- ===== TAB: OVERVIEW ===== -->
<div id="tab-overview" class="pj-tab-pane" style="display:<%= activeTab==='overview' ? 'block':'none' %>">
  <div class="grid-70-30">
    <div>
      <div class="card mb-4">
        <div class="card-header"><span class="card-title">Thông tin dự án</span></div>
        <div class="card-body">
          <div class="pj-info-grid">
            <div class="pj-info-item"><span class="pj-info-label">Mã dự án</span><span class="pj-info-val"><%= project.code %></span></div>
            <div class="pj-info-item"><span class="pj-info-label">Khách hàng</span><span class="pj-info-val"><%= project.client_name || '—' %></span></div>
            <div class="pj-info-item"><span class="pj-info-label">Quản lý dự án</span><span class="pj-info-val"><strong><%= project.manager_name || '—' %></strong></span></div>
            <div class="pj-info-item"><span class="pj-info-label">Địa điểm</span><span class="pj-info-val"><%= project.location || '—' %></span></div>
            <div class="pj-info-item"><span class="pj-info-label">Ngày bắt đầu</span><span class="pj-info-val"><%= project.start_date ? new Date(project.start_date).toLocaleDateString('vi-VN') : '—' %></span></div>
            <div class="pj-info-item"><span class="pj-info-label">Ngày kết thúc</span>
              <span class="pj-info-val <%= isOverdue ? 'text-danger' : daysLeft !== null && daysLeft < 7 ? 'text-warning' : '' %>">
                <%= project.end_date ? new Date(project.end_date).toLocaleDateString('vi-VN') : '—' %>
                <% if (daysLeft !== null) { %>
                  <% if (isOverdue) { %><small class="text-danger"> (Trễ <%= Math.abs(daysLeft) %> ngày)</small>
                  <% } else if (daysLeft < 7) { %><small class="text-warning"> (Còn <%= daysLeft %> ngày)</small>
                  <% } %><% } %>
              </span>
            </div>
            <% if (project.budget) { %>
            <div class="pj-info-item"><span class="pj-info-label">Ngân sách</span><span class="pj-info-val"><strong><%= Number(project.budget).toLocaleString('vi-VN') %> đ</strong></span></div>
            <% } %>
          </div>
          <% if (project.description) { %>
          <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
            <div style="font-size:12px;font-weight:600;color:var(--text-3);margin-bottom:8px">MÔ TẢ</div>
            <p style="font-size:13px;color:var(--text);line-height:1.7"><%= project.description %></p>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <div>
      <!-- Quick task stats -->
      <div class="card mb-4">
        <div class="card-header"><span class="card-title">Task theo trạng thái</span></div>
        <div class="card-body" style="padding:12px">
          <% [
            {s:'todo',        label:'Cần làm',    color:'#94a3b8'},
            {s:'in_progress', label:'Đang làm',   color:'#3b82f6'},
            {s:'review',      label:'Kiểm tra',   color:'#d97706'},
            {s:'done',        label:'Hoàn thành', color:'#16a34a'},
          ].forEach(item => { const cnt = tasks.filter(t=>t.status===item.s).length; %>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border)">
            <div style="display:flex;align-items:center;gap:8px">
              <span style="width:8px;height:8px;border-radius:50%;background:<%= item.color %>;flex-shrink:0"></span>
              <span style="font-size:13px;color:var(--text-2)"><%= item.label %></span>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:60px;height:4px;background:var(--border);border-radius:2px;overflow:hidden">
                <div style="height:100%;width:<%= taskStats.total > 0 ? Math.round(cnt/taskStats.total*100) : 0 %>%;background:<%= item.color %>"></div>
              </div>
              <span style="font-size:13px;font-weight:600;color:var(--text);min-width:20px;text-align:right"><%= cnt %></span>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% if (['admin','director','pm'].includes(locals.userRole)) { %>
      <div class="card">
        <div class="card-body" style="display:flex;flex-direction:column;gap:8px">
          <a href="/projects/<%= project.id %>/kanban" class="btn btn-primary btn-full"><i class="fas fa-columns"></i> Mở Kanban Board</a>
          <a href="/projects/<%= project.id %>/edit" class="btn btn-outline btn-full"><i class="fas fa-edit"></i> Chỉnh sửa dự án</a>
          <form action="/projects/<%= project.id %>?_method=DELETE" method="POST">
            <input type="hidden" name="_method" value="DELETE">
            <button type="submit" class="btn btn-danger btn-full" onclick="return confirm('Hủy dự án này?')"><i class="fas fa-times"></i> Hủy dự án</button>
          </form>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ===== TAB: TASKS ===== -->
<div id="tab-tasks" class="pj-tab-pane" style="display:<%= activeTab==='tasks' ? 'block':'none' %>">
  <div class="card">
    <div class="card-header">
      <span class="card-title">Danh sách Task (<%= tasks.length %>)</span>
      <div style="display:flex;gap:8px">
        <select id="taskStatusFilter" class="form-input" style="width:140px;font-size:12px" onchange="filterTasks()">
          <option value="">Tất cả</option>
          <option value="todo">Cần làm</option>
          <option value="in_progress">Đang làm</option>
          <option value="review">Kiểm tra</option>
          <option value="done">Hoàn thành</option>
        </select>
        <a href="/projects/<%= project.id %>/kanban" class="btn btn-sm btn-primary"><i class="fas fa-plus"></i> Thêm task</a>
      </div>
    </div>
    <% if (!tasks.length) { %>
    <div class="empty-state" style="padding:40px">
      <div class="empty-state-icon"><i class="fas fa-tasks"></i></div>
      <h3>Chưa có task nào</h3>
      <a href="/projects/<%= project.id %>/kanban" class="btn btn-primary">Tạo task đầu tiên</a>
    </div>
    <% } else { %>
    <!-- Desktop table -->
    <div class="task-table-wrap">
      <table id="tasksTable">
        <thead><tr>
          <th>Task</th><th style="width:160px">Người thực hiện</th>
          <th style="width:120px">Trạng thái</th><th style="width:100px">Ưu tiên</th>
          <th style="width:110px">Hạn chót</th><th style="width:80px"></th>
        </tr></thead>
        <tbody>
        <% tasks.forEach(t => {
          const tDue = t.due_date ? new Date(t.due_date) : null;
          const tOverdue = tDue && tDue < now && t.status !== 'done';
          const tSoon = tDue && !tOverdue && (tDue - now) < 3*24*60*60*1000;
        %>
        <tr class="task-tr" data-status="<%= t.status %>">
          <td>
            <div style="font-weight:500;color:var(--text)"><%= t.title %></div>
            <% if (t.description) { %><div style="font-size:11px;color:var(--text-3);margin-top:2px"><%= t.description.substring(0,60) %></div><% } %>
          </td>
          <td>
            <% if (t.assignee_name) { %>
            <div style="display:flex;align-items:center;gap:7px">
              <div style="width:24px;height:24px;border-radius:50%;overflow:hidden;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0">
                <% if (t.assignee_avatar) { %><img src="<%= t.assignee_avatar %>" alt="" style="width:100%;height:100%;object-fit:cover"><% } else { %><%= t.assignee_name.charAt(0).toUpperCase() %><% } %>
              </div>
              <span style="font-size:12px"><%= t.assignee_name %></span>
            </div>
            <% } else { %><span style="font-size:12px;color:var(--text-3)">—</span><% } %>
          </td>
          <td><span class="badge badge-<%= t.status %>"><%= t.status %></span></td>
          <td><span class="badge badge-<%= t.priority %>"><%= t.priority %></span></td>
          <td>
            <span style="font-size:12px;font-weight:<%= tOverdue ? '600':'400' %>;color:<%= tOverdue ? 'var(--danger)' : tSoon ? 'var(--warning)' : 'var(--text-3)' %>">
              <% if (tOverdue) { %><i class="fas fa-exclamation-triangle" style="margin-right:3px"></i><% } %>
              <%= tDue ? tDue.toLocaleDateString('vi-VN') : '—' %>
            </span>
          </td>
          <td>
            <a href="/tasks/<%= t.id %>/edit" class="btn btn-sm btn-outline" style="padding:4px 8px"><i class="fas fa-edit"></i></a>
          </td>
        </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
    <!-- Mobile cards -->
    <div class="task-card-wrap" style="padding:12px">
      <% tasks.forEach(t => {
        const tDue = t.due_date ? new Date(t.due_date) : null;
        const tOverdue = tDue && tDue < now && t.status !== 'done';
      %>
      <div style="padding:12px;border:1px solid var(--border);border-left:3px solid <%= tOverdue ? '#dc2626' : t.status==='done' ? '#16a34a' : 'var(--border)' %>;border-radius:8px;margin-bottom:8px;background:var(--card)">
        <div style="font-weight:600;font-size:13px"><%= t.title %></div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px">
          <span class="badge badge-<%= t.status %>" style="font-size:10px"><%= t.status %></span>
          <span class="badge badge-<%= t.priority %>" style="font-size:10px"><%= t.priority %></span>
          <% if (tDue) { %><span style="font-size:11px;color:<%= tOverdue ? 'var(--danger)':'var(--text-3)' %>"><i class="fas fa-calendar-alt"></i> <%= tDue.toLocaleDateString('vi-VN') %></span><% } %>
        </div>
        <% if (t.assignee_name) { %><div style="font-size:11px;color:var(--text-3);margin-top:4px"><i class="fas fa-user" style="margin-right:4px"></i><%= t.assignee_name %></div><% } %>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- ===== TAB: DOCUMENTS ===== -->
<div id="tab-documents" class="pj-tab-pane" style="display:<%= activeTab==='documents' ? 'block':'none' %>">
  <% if (['admin','director','pm'].includes(locals.userRole)) { %>
  <div class="card mb-4">
    <div class="card-header"><span class="card-title"><i class="fas fa-cloud-upload-alt" style="margin-right:6px"></i>Tải tài liệu lên</span></div>
    <div class="card-body">
      <form action="/projects/<%= project.id %>/documents" method="POST" enctype="multipart/form-data" id="docUploadForm">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;align-items:end;flex-wrap:wrap">
          <div class="form-group" style="margin:0">
            <label class="form-label">Tên tài liệu</label>
            <input type="text" name="name" class="form-input" placeholder="Ví dụ: Bản vẽ thi công A1">
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Loại</label>
            <select name="doc_type" class="form-input">
              <option value="drawing">Bản vẽ</option>
              <option value="contract">Hợp đồng</option>
              <option value="report">Báo cáo</option>
              <option value="photo">Hình ảnh</option>
              <option value="other">Khác</option>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">File <span style="color:var(--danger)">*</span></label>
            <div style="display:flex;gap:8px">
              <input type="file" name="file" class="form-input" required id="docFileInput" onchange="previewDocName(this)" style="flex:1">
            </div>
          </div>
        </div>
        <div style="margin-top:10px;display:flex;justify-content:flex-end">
          <button type="submit" class="btn btn-primary"><i class="fas fa-upload" style="margin-right:6px"></i>Tải lên</button>
        </div>
      </form>
    </div>
  </div>
  <% } %>

  <div class="card">
    <div class="card-header">
      <span class="card-title">Tài liệu dự án (<%= documents.length %>)</span>
    </div>
    <% if (!documents.length) { %>
    <div class="empty-state" style="padding:40px">
      <div class="empty-state-icon"><i class="fas fa-file-alt"></i></div>
      <h3>Chưa có tài liệu</h3>
      <p>Tải lên bản vẽ, hợp đồng, báo cáo...</p>
    </div>
    <% } else { %>
    <div class="card-body" style="padding:0">
      <% const docTypeColors = { drawing:'#3b82f6',contract:'#16a34a',report:'#d97706',photo:'#8b5cf6',other:'#94a3b8' };
         const docTypeIcons = { drawing:'drafting-compass',contract:'file-signature',report:'chart-bar',photo:'image',other:'paperclip' };
         const docTypeLabels = { drawing:'Bản vẽ',contract:'Hợp đồng',report:'Báo cáo',photo:'Hình ảnh',other:'Khác' };
      %>
      <% documents.forEach(doc => {
        const ext = (doc.file_name||'').split('.').pop().toLowerCase();
        const isImg = ['jpg','jpeg','png','gif','webp'].includes(ext);
        const isPdf = ext === 'pdf';
        const color = docTypeColors[doc.doc_type]||'#94a3b8';
        const icon = docTypeIcons[doc.doc_type]||'paperclip';
      %>
      <div class="doc-row">
        <div class="doc-icon" style="background:rgba(<%= color.replace('#','').match(/.{2}/g).map(h=>parseInt(h,16)).join(',') %>,.12);color:<%= color %>">
          <i class="fas fa-<%= isImg ? 'image' : isPdf ? 'file-pdf' : icon %>"></i>
        </div>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= doc.name %></div>
          <div style="font-size:11px;color:var(--text-3);margin-top:2px">
            <span style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:1px 6px;font-size:10px"><%= docTypeLabels[doc.doc_type]||doc.doc_type %></span>
            <% if (doc.file_size) { %> · <%= Math.round(doc.file_size/1024) %>KB<% } %>
            · <% if (doc.uploader_name) { %><%= doc.uploader_name %> · <% } %>
            <%= new Date(doc.created_at).toLocaleDateString('vi-VN') %>
          </div>
        </div>
        <div style="display:flex;gap:6px;flex-shrink:0">
          <a href="<%= doc.file_url %>" target="_blank" class="btn btn-sm btn-outline" title="Xem/Tải xuống"><i class="fas fa-download"></i></a>
          <% if (['admin','director','pm'].includes(locals.userRole)) { %>
          <form action="/projects/<%= project.id %>/documents/<%= doc.id %>/delete" method="POST" style="display:inline">
            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa tài liệu này?')" title="Xóa"><i class="fas fa-trash"></i></button>
          </form>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- ===== TAB: MEMBERS ===== -->
<div id="tab-members" class="pj-tab-pane" style="display:<%= activeTab==='members' ? 'block':'none' %>">
  <div class="card">
    <div class="card-header">
      <span class="card-title">Thành viên dự án (<%= members.length %>)</span>
      <% if (['admin','director','pm'].includes(locals.userRole)) { %>
      <button onclick="document.getElementById('addMemberModal').style.display='flex'" class="btn btn-sm btn-primary"><i class="fas fa-plus"></i> Thêm thành viên</button>
      <% } %>
    </div>
    <div class="card-body" style="padding:12px">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px">
        <% members.forEach(m => { %>
        <div style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid var(--border);border-radius:10px;background:var(--bg)">
          <div style="width:42px;height:42px;border-radius:50%;overflow:hidden;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;flex-shrink:0">
            <% if (m.avatar_url) { %><img src="<%= m.avatar_url %>" alt="" style="width:100%;height:100%;object-fit:cover"><% } else { %><%= m.full_name.charAt(0).toUpperCase() %><% } %>
          </div>
          <div style="flex:1;min-width:0">
            <a href="/hr/<%= m.id %>" style="font-weight:600;font-size:13px;color:var(--text);text-decoration:none"><%= m.full_name %></a>
            <div style="font-size:11px;color:var(--text-3);margin-top:2px"><%= m.position || m.role %></div>
            <div style="margin-top:4px"><span class="badge badge-<%= m.project_role %>"><%= m.project_role %></span></div>
          </div>
          <% if (['admin','director','pm'].includes(locals.userRole)) { %>
          <form action="/projects/<%= project.id %>/members/remove" method="POST" style="display:inline">
            <input type="hidden" name="_method" value="DELETE">
            <input type="hidden" name="user_id" value="<%= m.id %>">
            <button type="submit" class="btn btn-sm" style="background:none;border:none;color:var(--text-3);cursor:pointer;padding:4px" onclick="return confirm('Xóa thành viên?')" title="Xóa khỏi dự án"><i class="fas fa-times"></i></button>
          </form>
          <% } %>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- Add Member Modal -->
<div id="addMemberModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal-box" style="max-width:420px;width:92%">
    <div class="modal-header">
      <h3 style="margin:0;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px">
        <span style="width:30px;height:30px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="fas fa-user-plus" style="color:#fff;font-size:12px"></i>
        </span>
        Thêm thành viên
      </h3>
      <button class="modal-close" onclick="document.getElementById('addMemberModal').style.display='none'"><i class="fas fa-times"></i></button>
    </div>
    <form action="/projects/<%= project.id %>/members" method="POST">
      <div class="modal-body" style="display:grid;gap:14px">
        <div class="form-group" style="margin:0">
          <label class="form-label">Nhân viên</label>
          <select name="user_id" class="form-input" required>
            <option value="">— Chọn nhân viên —</option>
            <% allUsers.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.full_name %> (<%= u.role %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Vai trò trong dự án</label>
          <select name="role" class="form-input">
            <option value="member">Thành viên</option>
            <option value="leader">Trưởng nhóm</option>
            <option value="reviewer">Kiểm tra</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="document.getElementById('addMemberModal').style.display='none'"
          style="padding:9px 18px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:transparent;color:var(--text-2);font-size:13.5px;font-weight:500;cursor:pointer">
          Hủy
        </button>
        <button type="submit"
          style="padding:9px 22px;border-radius:var(--radius-sm);border:none;background:var(--primary);color:#fff;font-size:13.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:7px;box-shadow:0 2px 8px rgba(21,101,192,.3)">
          <i class="fas fa-plus"></i> Thêm
        </button>
      </div>
    </form>
  </div>
</div>

<style>
/* ===== Hero ===== */
.pj-hero { display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:16px;flex-wrap:wrap; }
.pj-breadcrumb { font-size:12px;color:var(--text-3);margin-bottom:6px;display:flex;align-items:center;gap:6px; }
.pj-breadcrumb a { color:var(--text-3);text-decoration:none; } .pj-breadcrumb a:hover { color:var(--primary); }
.pj-breadcrumb i { font-size:9px; }
.pj-title { font-size:24px;font-weight:700;color:var(--text);margin:0 0 8px; }
.pj-badges { display:flex;align-items:center;gap:8px;flex-wrap:wrap; }
.pj-hero-actions { display:flex;gap:8px;flex-wrap:wrap; }

/* ===== KPI Strip ===== */
.pj-kpi-strip { display:flex;align-items:center;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 20px;margin-bottom:16px;flex-wrap:wrap;gap:4px; }
.pj-kpi { text-align:center;padding:0 16px;min-width:60px; }
.pj-kpi-val { font-size:20px;font-weight:700;color:var(--text);line-height:1.2; }
.pj-kpi-label { font-size:11px;color:var(--text-3);margin-top:2px; }
.pj-kpi-divider { width:1px;height:36px;background:var(--border); }

/* ===== Tabs ===== */
.pj-tabs { display:flex;gap:2px;margin-bottom:16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:4px; }
.pj-tab { background:none;border:none;padding:8px 16px;border-radius:7px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-2);display:flex;align-items:center;gap:6px;transition:all .15s;white-space:nowrap; }
.pj-tab.active { background:var(--card);color:var(--text);box-shadow:0 1px 4px rgba(0,0,0,.08); }
.pj-tab:hover:not(.active) { color:var(--text); }
.tab-badge { background:var(--primary);color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;min-width:18px;text-align:center; }
.tab-badge-danger { background:#dc2626; }

/* ===== Info grid ===== */
.pj-info-grid { display:grid;grid-template-columns:1fr 1fr;gap:0; }
.pj-info-item { padding:10px 0;border-bottom:1px solid var(--border);display:flex;flex-direction:column;gap:3px; }
.pj-info-item:nth-last-child(-n+2) { border-bottom:none; }
.pj-info-label { font-size:11px;color:var(--text-3);font-weight:500; }
.pj-info-val { font-size:13px;color:var(--text); }

/* ===== Documents ===== */
.doc-row { display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border); }
.doc-row:last-child { border-bottom:none; }
.doc-icon { width:38px;height:38px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0; }

/* ===== Table/card toggle ===== */
.task-table-wrap { display:block; }
.task-card-wrap { display:none; }
@media(max-width:768px) { .task-table-wrap { display:none; } .task-card-wrap { display:block; } }
@media(max-width:640px) {
  .pj-kpi-strip { gap:8px; }
  .pj-kpi { padding:0 8px; }
  .pj-tabs { overflow-x:auto; }
  .pj-info-grid { grid-template-columns:1fr; }
  .pj-info-item:nth-last-child(-n+2) { border-bottom:1px solid var(--border); }
  .pj-info-item:last-child { border-bottom:none; }
}
</style>

<script>
function switchTab(tab) {
  document.querySelectorAll('.pj-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.pj-tab-pane').forEach(p => p.style.display = 'none');
  document.querySelector(`.pj-tab[onclick*="${tab}"]`).classList.add('active');
  document.getElementById('tab-' + tab).style.display = 'block';
  history.replaceState(null,'',`?tab=${tab}`);
}

function filterTasks() {
  const val = document.getElementById('taskStatusFilter').value;
  document.querySelectorAll('.task-tr').forEach(tr => {
    tr.style.display = (!val || tr.dataset.status === val) ? '' : 'none';
  });
}

function previewDocName(input) {
  if (input.files[0]) {
    const nameInput = document.querySelector('input[name=name]');
    if (!nameInput.value) nameInput.value = input.files[0].name.replace(/\.[^.]+$/, '');
  }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.modal-overlay').forEach(m => m.style.display='none');
});
</script>
