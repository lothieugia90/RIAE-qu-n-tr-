<div class="page-header">
  <div class="page-header-title">
    <h1><a href="/projects/<%= project.id %>" style="color:inherit;text-decoration:none"><span class="project-code" style="font-size:13px"><%= project.code %></span> <%= project.name %></a></h1>
    <p>Kéo thả task giữa các cột để đổi trạng thái</p>
  </div>
  <button class="btn btn-primary" onclick="document.getElementById('createTaskModal').showModal()">
    <i class="fas fa-plus"></i> Thêm task
  </button>
</div>

<div class="kanban-board">
  <% columns.forEach(col => { %>
  <div class="kanban-col" data-status="<%= col.id %>">
    <div class="kanban-col-head" style="--col-color:<%= col.color %>">
      <span class="kanban-col-name"><%= col.name %></span>
      <span class="kanban-col-count"><%= col.tasks.length %></span>
    </div>
    <div class="kanban-col-body" data-status="<%= col.id %>">
      <% col.tasks.forEach(t => { %>
      <div class="kanban-card" draggable="true" data-task-id="<%= t.id %>">
        <div class="kc-top">
          <span class="badge badge-<%= t.priority %>"><%= PRIORITY_LABELS[t.priority] %></span>
          <a href="/tasks/<%= t.id %>" class="kc-open" title="Mở chi tiết"><i class="fas fa-expand-alt"></i></a>
        </div>
        <a href="/tasks/<%= t.id %>" class="kc-title"><%= t.title %></a>
        <div class="kc-meta">
          <% if (t.due_date) { %>
          <span class="<%= new Date(t.due_date) < new Date() && t.status !== 'done' ? 'kc-overdue' : '' %>">
            <i class="fas fa-calendar"></i> <%= fmtDate(t.due_date) %>
          </span>
          <% } %>
          <% if (t.checklist_total > 0) { %>
          <span><i class="fas fa-list-check"></i> <%= t.checklist_done %>/<%= t.checklist_total %></span>
          <% } %>
          <% if (t.comment_count > 0) { %>
          <span><i class="fas fa-comment"></i> <%= t.comment_count %></span>
          <% } %>
        </div>
        <% if (t.assignee_name) { %>
        <div class="kc-assignee">
          <span class="kc-avatar"><% if (t.assignee_avatar) { %><img src="<%= t.assignee_avatar %>" alt=""><% } else { %><%= t.assignee_name.charAt(0).toUpperCase() %><% } %></span>
          <%= t.assignee_name %>
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
  <% }) %>
</div>

<!-- Modal tạo task -->
<dialog id="createTaskModal" class="modal">
  <button type="button" class="modal-x" onclick="this.closest('dialog').close()" aria-label="Đóng">&times;</button>
  <form action="/tasks" method="POST" class="modal-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="project_id" value="<%= project.id %>">
    <h3>Thêm task mới</h3>
    <div class="form-group">
      <label>Tiêu đề *</label>
      <input type="text" name="title" class="form-control" required maxlength="300">
    </div>
    <div class="form-group">
      <label>Mô tả</label>
      <textarea name="description" class="form-control" rows="3"></textarea>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Giao cho</label>
        <select name="assignee_id" class="form-control">
          <option value="">— Chưa giao —</option>
          <% members.forEach(u => { %><option value="<%= u.id %>"><%= u.full_name %></option><% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Ưu tiên</label>
        <select name="priority" class="form-control">
          <% Object.entries(PRIORITY_LABELS).forEach(([v, l]) => { %>
          <option value="<%= v %>" <%= v === 'medium' ? 'selected' : '' %>><%= l %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Hạn hoàn thành</label>
        <input type="date" name="due_date" class="form-control">
      </div>
      <div class="form-group">
        <label>Ước tính (giờ)</label>
        <input type="number" name="estimated_hours" class="form-control" min="0" step="0.5">
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="this.closest('dialog').close()">Hủy</button>
      <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo task</button>
    </div>
  </form>
</dialog>

<script>
(function() {
  const csrf = document.querySelector('meta[name="csrf-token"]').content;
  let dragged = null;

  document.querySelectorAll('.kanban-card').forEach(card => {
    card.addEventListener('dragstart', () => { dragged = card; card.classList.add('dragging'); });
    card.addEventListener('dragend', () => { card.classList.remove('dragging'); dragged = null; });
  });

  document.querySelectorAll('.kanban-col-body').forEach(colBody => {
    colBody.addEventListener('dragover', e => { e.preventDefault(); colBody.classList.add('drag-over'); });
    colBody.addEventListener('dragleave', () => colBody.classList.remove('drag-over'));
    colBody.addEventListener('drop', async e => {
      e.preventDefault();
      colBody.classList.remove('drag-over');
      if (!dragged) return;
      const newStatus = colBody.dataset.status;
      const taskId = dragged.dataset.taskId;
      const originCol = dragged.parentElement;
      colBody.prepend(dragged);
      try {
        const resp = await fetch('/tasks/' + taskId + '/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrf, 'Accept': 'application/json' },
          body: JSON.stringify({ status: newStatus })
        });
        if (!resp.ok) throw new Error((await resp.json()).error || 'Lỗi cập nhật');
        updateCounts();
      } catch (err) {
        originCol.prepend(dragged); // trả về cột cũ nếu lỗi
        updateCounts();
        alert(err.message);
      }
    });
  });

  function updateCounts() {
    document.querySelectorAll('.kanban-col').forEach(col => {
      col.querySelector('.kanban-col-count').textContent = col.querySelectorAll('.kanban-card').length;
    });
  }
})();
</script>

<style>
.kanban-board {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
  align-items: start;
}
@media (max-width: 1100px) { .kanban-board { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px)  { .kanban-board { grid-template-columns: 1fr; } }
.kanban-col { background: var(--border-light); border-radius: var(--radius); min-height: 200px; }
.kanban-col-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 14px; border-bottom: 3px solid var(--col-color);
}
.kanban-col-name { font-size: 13px; font-weight: 700; color: var(--text); text-transform: uppercase; letter-spacing: .04em; }
.kanban-col-count {
  background: var(--card); color: var(--text-2); font-size: 11.5px; font-weight: 700;
  border-radius: 10px; padding: 2px 9px;
}
.kanban-col-body { padding: 10px; display: flex; flex-direction: column; gap: 10px; min-height: 120px; }
.kanban-col-body.drag-over { background: var(--primary-50); border-radius: 0 0 var(--radius) var(--radius); }
.kanban-card {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-sm);
  padding: 12px; cursor: grab; box-shadow: var(--shadow); transition: box-shadow .15s;
}
.kanban-card:hover { box-shadow: var(--shadow-md); }
.kanban-card.dragging { opacity: .5; cursor: grabbing; }
.kc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
.kc-open { color: var(--text-3); font-size: 11px; }
.kc-open:hover { color: var(--primary); }
.kc-title { display: block; font-size: 13.5px; font-weight: 600; color: var(--text); text-decoration: none; line-height: 1.4; margin-bottom: 8px; }
.kc-title:hover { color: var(--primary); }
.kc-meta { display: flex; gap: 12px; font-size: 11.5px; color: var(--text-3); flex-wrap: wrap; }
.kc-meta i { margin-right: 3px; }
.kc-overdue { color: var(--danger); font-weight: 600; }
.kc-assignee { display: flex; align-items: center; gap: 7px; margin-top: 9px; padding-top: 9px; border-top: 1px solid var(--border-light); font-size: 12px; color: var(--text-2); }
.kc-avatar {
  width: 22px; height: 22px; border-radius: 50%; overflow: hidden; flex-shrink: 0;
  background: var(--primary); color: #fff; display: inline-flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700;
}
.kc-avatar img { width: 100%; height: 100%; object-fit: cover; }
.modal { border: none; border-radius: var(--radius-lg); padding: 0; width: 100%; max-width: 520px; box-shadow: var(--shadow-lg); }
.modal::backdrop { background: rgba(13,27,62,.5); }
.modal-form { padding: 26px; }
.modal-form h3 { margin-bottom: 20px; font-size: 17px; color: var(--text); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
.modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 22px; }
</style>
