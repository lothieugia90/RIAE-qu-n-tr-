<!-- Pipeline stats bar -->
<% const totalTasks = tasks.length; const doneTasks = tasks.filter(t=>t.status==='done').length; %>
<div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap">
  <a href="/projects/<%= project.id %>" style="color:var(--text-3);font-size:13px;text-decoration:none;display:flex;align-items:center;gap:5px">
    <i class="fas fa-folder-open"></i><%= project.name %>
  </a>
  <i class="fas fa-chevron-right" style="font-size:10px;color:var(--text-3)"></i>
  <span style="font-size:13px;font-weight:600;color:var(--text)">Kanban Board</span>
  <% if (isWorkflow) { %>
  <span style="display:flex;align-items:center;gap:4px;padding:2px 8px;background:rgba(59,130,246,.1);border-radius:10px;font-size:11px;font-weight:600;color:var(--primary)">
    <i class="fas fa-project-diagram"></i> <%= project.workflow_name %>
  </span>
  <% } %>
</div>

<!-- Stats bar -->
<div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center">
  <% columns.forEach((col,i) => { %>
  <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-2)">
    <span style="width:8px;height:8px;border-radius:50%;background:<%= col.color || '#94a3b8' %>;flex-shrink:0"></span>
    <span><%= col.name %></span>
    <span style="font-weight:700;color:var(--text)"><%= col.tasks ? col.tasks.length : 0 %></span>
    <% if (i < columns.length-1) { %><span style="color:var(--border)">·</span><% } %>
  </div>
  <% }) %>
  <div style="flex:1;min-width:120px;height:5px;background:var(--border);border-radius:3px;overflow:hidden">
    <div style="height:100%;width:<%= totalTasks > 0 ? Math.round(doneTasks/totalTasks*100) : 0 %>%;background:var(--success,#22c55e);border-radius:3px;transition:width .4s"></div>
  </div>
  <span style="font-size:11px;color:var(--text-3);white-space:nowrap"><%= doneTasks %>/<%= totalTasks %> hoàn thành</span>
</div>

<!-- Header controls -->
<div class="kb-header">
  <!-- Smart filters -->
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <input type="text" id="searchFilter" class="form-input" style="width:180px;font-size:12px" placeholder="🔍 Tìm task..." oninput="filterCards()">
    <select id="assigneeFilter" class="form-input" style="width:150px;font-size:12px" onchange="filterCards()">
      <option value="">Tất cả người thực hiện</option>
      <% members.forEach(m => { %>
      <option value="<%= m.id %>"><%= m.full_name %></option>
      <% }) %>
    </select>
    <select id="priorityFilter" class="form-input" style="width:130px;font-size:12px" onchange="filterCards()">
      <option value="">Tất cả ưu tiên</option>
      <option value="urgent">🔴 Khẩn cấp</option>
      <option value="high">🟠 Cao</option>
      <option value="medium">🟡 Bình thường</option>
      <option value="low">🔵 Thấp</option>
    </select>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <!-- Workflow selector -->
    <div style="position:relative">
      <button class="btn btn-outline btn-sm" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block'" style="font-size:12px">
        <i class="fas fa-project-diagram"></i> Quy trình <i class="fas fa-chevron-down" style="font-size:9px"></i>
      </button>
      <div style="display:none;position:absolute;right:0;top:calc(100% + 4px);background:var(--card);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.15);min-width:220px;z-index:50;padding:8px">
        <form action="/projects/<%= project.id %>/set-workflow" method="POST">
          <div style="padding:6px 8px;font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.05em">Chọn Quy trình</div>
          <% workflows.forEach(wf => { %>
          <label style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;font-size:13px" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background=''">
            <input type="radio" name="workflow_id" value="<%= wf.id %>" <%= project.workflow_id===wf.id ? 'checked' : '' %> onchange="this.closest('form').submit()">
            <span><%= wf.name %></span>
          </label>
          <% }) %>
          <div style="border-top:1px solid var(--border);margin:6px 0 4px"></div>
          <label style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;font-size:13px;color:var(--text-3)" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background=''">
            <input type="radio" name="workflow_id" value="" <%= !project.workflow_id ? 'checked' : '' %> onchange="this.closest('form').submit()">
            <span>Mặc định (4 cột)</span>
          </label>
        </form>
      </div>
    </div>
    <button class="btn btn-primary btn-sm" onclick="openAddTask(null)">
      <i class="fas fa-plus"></i> Thêm Task
    </button>
    <a href="/projects/<%= project.id %>" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i></a>
  </div>
</div>

<!-- Kanban Board -->
<div class="kb-board" id="kbBoard" style="grid-template-columns:repeat(<%= columns.length %>,1fr)">

<% columns.forEach((col) => {
   const colId   = col.id || col.maps_to_status || 'col-' + col.stage_order;
   const colKey  = isWorkflow ? (col.id + '') : col.id;
   const colTasks = col.tasks || [];
%>
<div class="kb-col" id="col-<%= colKey %>"
     data-colkey="<%= colKey %>"
     data-is-workflow="<%= isWorkflow ? '1' : '0' %>"
     data-maps-status="<%= col.maps_to_status || col.id %>"
     ondragover="colDragOver(event,this)" ondragleave="colDragLeave(this)" ondrop="colDrop(event,this)">

  <div class="kb-col-head" style="--col-color:<%= col.color || '#94a3b8' %>">
    <div style="display:flex;align-items:center;gap:7px;min-width:0">
      <span class="kb-col-dot" style="background:<%= col.color || '#94a3b8' %>"></span>
      <span class="kb-col-label"><%= col.name %></span>
      <% if (col.is_approval_gate) { %>
      <span title="Cần phê duyệt để qua bước này" style="color:#d97706;font-size:11px"><i class="fas fa-lock"></i></span>
      <% } %>
      <span class="kb-col-badge" id="badge-<%= colKey %>"><%= colTasks.length %></span>
    </div>
    <button class="kb-col-add" onclick="openAddTask('<%= isWorkflow ? '' : col.id %>','<%= isWorkflow ? col.id : '' %>')" title="Thêm task">
      <i class="fas fa-plus"></i>
    </button>
  </div>

  <div class="kb-cards" id="cards-<%= colKey %>">
  <% colTasks.forEach(task => {
    const now = new Date();
    const due = task.due_date ? new Date(task.due_date) : null;
    const isOverdue = due && due < now && task.status !== 'done';
    const isDueSoon = due && !isOverdue && (due - now) < 3*24*60*60*1000;
    const dueClass = isOverdue ? 'due-overdue' : isDueSoon ? 'due-soon' : 'due-ok';
    const checkTotal = task.checklist_total || 0;
    const checkDone  = task.checklist_done  || 0;
  %>
  <div class="kb-card" draggable="true" id="card-<%= task.id %>"
       data-id="<%= task.id %>"
       data-status="<%= task.status %>"
       data-stage="<%= task.workflow_stage_id || '' %>"
       data-assignee="<%= task.assignee_id || '' %>"
       data-priority="<%= task.priority %>"
       data-title="<%= task.title.toLowerCase() %>"
       ondragstart="cardDragStart(event)"
       ondragend="cardDragEnd(event)"
       onclick="openTaskDetail('<%= task.id %>')">

    <div class="kb-card-priority-bar priority-bar-<%= task.priority %>"></div>

    <div class="kb-card-body">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:6px;margin-bottom:5px">
        <div class="kb-card-title"><%= task.title %></div>
        <span class="kb-priority-badge kb-priority-<%= task.priority %>"><%= task.priority==='urgent'?'🔴':task.priority==='high'?'🟠':task.priority==='medium'?'🟡':'🔵' %></span>
      </div>

      <% if (task.description) { %>
      <div class="kb-card-desc"><%= task.description.substring(0,70) %><%= task.description.length>70?'…':'' %></div>
      <% } %>

      <!-- Checklist progress badge -->
      <% if (checkTotal > 0) { %>
      <div style="display:flex;align-items:center;gap:5px;margin-bottom:5px">
        <div style="flex:1;height:3px;background:var(--border);border-radius:2px;overflow:hidden">
          <div style="height:100%;width:<%= Math.round(checkDone/checkTotal*100) %>%;background:<%= checkDone===checkTotal?'#22c55e':'#3b82f6' %>;border-radius:2px"></div>
        </div>
        <span style="font-size:10px;color:<%= checkDone===checkTotal?'#22c55e':'var(--text-3)' %>;font-weight:600;white-space:nowrap"><%= checkDone %>/<%= checkTotal %> <i class="fas fa-check-square"></i></span>
      </div>
      <% } %>

      <!-- Approval gate lock indicator -->
      <% if (col.is_approval_gate && task.status !== 'done') { %>
      <div style="display:inline-flex;align-items:center;gap:4px;font-size:10px;color:#d97706;background:rgba(245,158,11,.1);padding:2px 6px;border-radius:5px;margin-bottom:5px">
        <i class="fas fa-lock"></i> Chờ phê duyệt
      </div>
      <% } %>

      <div class="kb-card-footer">
        <div style="display:flex;align-items:center;gap:5px;min-width:0">
          <% if (task.assignee_name) { %>
          <div class="kb-assignee" title="<%= task.assignee_name %>">
            <% if (task.assignee_avatar) { %><img src="<%= task.assignee_avatar %>" alt="">
            <% } else { %><span><%= task.assignee_name.charAt(0).toUpperCase() %></span><% } %>
          </div>
          <span class="kb-assignee-name"><%= task.assignee_name.split(' ').pop() %></span>
          <% } else { %>
          <span class="kb-unassigned"><i class="fas fa-user-plus"></i> Chưa giao</span>
          <% } %>
        </div>
        <div style="display:flex;align-items:center;gap:5px">
          <% if (due) { %>
          <span class="kb-due <%= dueClass %>">
            <i class="fas fa-<%= isOverdue?'exclamation-triangle':'calendar-alt' %>"></i>
            <%= due.toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'}) %>
          </span>
          <% } %>
          <% if (isWorkflow) { %>
          <button class="kb-move-btn" onclick="event.stopPropagation();openMoveStage('<%= task.id %>','<%= col.id %>','<%= task.title.replace(/'/g,"\\'") %>')" title="Chuyển bước">
            <i class="fas fa-arrows-alt-h"></i>
          </button>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% }) %>

  <div class="kb-empty-col" id="empty-<%= colKey %>" style="display:<%= colTasks.length===0?'flex':'none' %>">
    <i class="fas fa-inbox" style="font-size:18px;opacity:0.3;margin-bottom:5px"></i>
    <span>Kéo task vào đây</span>
  </div>
  </div>
</div>
<% }) %>
</div>

<!-- ===== ADD TASK MODAL ===== -->
<div id="taskModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeTaskModal()">
  <div class="modal-box" style="max-width:560px;width:94%">
    <div class="modal-header">
      <h3 style="margin:0;font-size:16px;font-weight:700">Tạo Task mới</h3>
      <button class="modal-close" onclick="closeTaskModal()"><i class="fas fa-times"></i></button>
    </div>
    <form action="/tasks/create" method="POST">
      <input type="hidden" name="project_id" value="<%= project.id %>">
      <input type="hidden" name="status" id="taskInitialStatus" value="todo">
      <input type="hidden" name="workflow_stage_id" id="taskInitialStage" value="">
      <div class="modal-body" style="padding:20px;display:grid;gap:14px">
        <div class="form-group" style="margin:0">
          <label class="form-label">Tiêu đề <span style="color:var(--danger)">*</span></label>
          <input type="text" name="title" class="form-input" placeholder="Nhập tiêu đề task..." required autofocus>
        </div>
        <div class="form-group" style="margin:0">
          <label class="form-label">Mô tả</label>
          <textarea name="description" class="form-input" rows="2" placeholder="Mô tả chi tiết..."></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="form-group" style="margin:0">
            <label class="form-label">Người thực hiện</label>
            <select name="assignee_id" class="form-input">
              <option value="">— Chưa giao —</option>
              <% members.forEach(m => { %>
              <option value="<%= m.id %>"><%= m.full_name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Ưu tiên</label>
            <select name="priority" class="form-input">
              <option value="low">🔵 Thấp</option>
              <option value="medium" selected>🟡 Bình thường</option>
              <option value="high">🟠 Cao</option>
              <option value="urgent">🔴 Khẩn cấp</option>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Hạn chót</label>
            <input type="date" name="due_date" class="form-input">
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Ước tính (giờ)</label>
            <input type="number" name="estimated_hours" class="form-input" min="0" step="0.5" placeholder="0">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="closeTaskModal()" class="btn btn-outline">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> Tạo Task</button>
      </div>
    </form>
  </div>
</div>

<!-- ===== MOVE STAGE MODAL (Workflow only) ===== -->
<% if (isWorkflow) { %>
<div id="moveStageModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeMoveStage()">
  <div class="modal-box" style="max-width:420px;width:94%">
    <div class="modal-header">
      <h3 style="margin:0;font-size:15px;font-weight:700"><i class="fas fa-arrows-alt-h"></i> Chuyển bước quy trình</h3>
      <button class="modal-close" onclick="closeMoveStage()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" style="padding:16px 20px">
      <div style="font-size:13px;color:var(--text-2);margin-bottom:14px" id="moveStageTaskName"></div>
      <div style="display:flex;flex-direction:column;gap:6px" id="moveStageList">
        <% stages.forEach(s => { %>
        <button class="kb-stage-opt" data-stage-id="<%= s.id %>" onclick="doMoveStage(this)"
                style="display:flex;align-items:center;gap:10px;padding:9px 13px;border-radius:8px;border:1.5px solid var(--border);background:var(--bg);cursor:pointer;transition:all .15s;text-align:left">
          <span style="width:10px;height:10px;border-radius:50%;background:<%= s.color %>;flex-shrink:0"></span>
          <span style="font-size:13px;font-weight:500;color:var(--text);flex:1"><%= s.name %></span>
          <% if (s.is_approval_gate) { %><span style="font-size:10px;color:#d97706"><i class="fas fa-lock"></i> Cần duyệt</span><% } %>
        </button>
        <% }) %>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- ===== TASK DETAIL PANEL ===== -->
<div id="taskPanel" class="task-panel" style="display:none">
  <div class="task-panel-inner">
    <div class="task-panel-head">
      <span style="font-size:14px;font-weight:600">Chi tiết Task</span>
      <div style="display:flex;gap:6px">
        <a id="taskPanelEditBtn" class="btn btn-sm btn-outline" href="#"><i class="fas fa-edit"></i> Chỉnh sửa</a>
        <button class="btn btn-sm btn-outline" onclick="closeTaskPanel()"><i class="fas fa-times"></i></button>
      </div>
    </div>
    <div id="taskPanelBody" style="padding:16px;overflow-y:auto;flex:1">
      <div style="text-align:center;padding:32px;color:var(--text-3)"><i class="fas fa-spinner fa-spin fa-2x"></i></div>
    </div>
  </div>
</div>
<div id="taskPanelOverlay" style="display:none;position:fixed;inset:0;z-index:89" onclick="closeTaskPanel()"></div>

<style>
.kb-header { display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:14px;flex-wrap:wrap; }
.kb-board { display:grid;gap:12px;align-items:start;min-height:500px;overflow-x:auto; }
@media(max-width:900px) { .kb-board { grid-template-columns:repeat(2,minmax(200px,1fr)) !important; } }
@media(max-width:560px) { .kb-board { grid-template-columns:minmax(200px,1fr) !important; } }

.kb-col { background:var(--bg);border-radius:12px;border:1px solid var(--border);min-height:200px;display:flex;flex-direction:column;transition:background .15s; }
.kb-col.drag-over { background:rgba(59,130,246,.06);border-color:var(--primary); }
.kb-col-head { padding:11px 13px;display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid var(--col-color,var(--border));border-radius:12px 12px 0 0; }
.kb-col-dot { width:8px;height:8px;border-radius:50%;flex-shrink:0; }
.kb-col-label { font-size:13px;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap; }
.kb-col-badge { background:var(--card);border:1px solid var(--border);color:var(--text-2);font-size:11px;font-weight:700;padding:1px 7px;border-radius:10px;flex-shrink:0; }
.kb-col-add { background:none;border:none;cursor:pointer;color:var(--text-3);padding:4px 6px;border-radius:6px;font-size:12px;transition:all .15s; }
.kb-col-add:hover { background:var(--primary);color:#fff; }
.kb-cards { padding:10px;display:flex;flex-direction:column;gap:8px;min-height:60px;flex:1; }
.kb-empty-col { flex-direction:column;align-items:center;justify-content:center;color:var(--text-3);font-size:12px;padding:20px;border:1.5px dashed var(--border);border-radius:8px;min-height:80px; }
.kb-card { background:var(--card);border-radius:10px;border:1px solid var(--border);cursor:grab;position:relative;overflow:hidden;transition:box-shadow .15s,transform .1s,opacity .15s;box-shadow:0 1px 3px rgba(0,0,0,.06); }
.kb-card:hover { box-shadow:0 4px 16px rgba(0,0,0,.12);transform:translateY(-1px); }
.kb-card.dragging { opacity:0.4;cursor:grabbing;transform:scale(0.97); }
.kb-card-priority-bar { position:absolute;left:0;top:0;bottom:0;width:3px; }
.priority-bar-urgent{background:#dc2626}.priority-bar-high{background:#d97706}.priority-bar-medium{background:#3b82f6}.priority-bar-low{background:#94a3b8}
.kb-card-body { padding:10px 10px 10px 13px; }
.kb-card-title { font-size:13px;font-weight:600;color:var(--text);line-height:1.4;flex:1; }
.kb-card-desc { font-size:11px;color:var(--text-3);line-height:1.4;margin-bottom:5px; }
.kb-priority-badge { font-size:13px;flex-shrink:0;user-select:none; }
.kb-card-footer { display:flex;justify-content:space-between;align-items:center;margin-top:7px;padding-top:7px;border-top:1px solid var(--border); }
.kb-assignee { width:22px;height:22px;border-radius:50%;overflow:hidden;flex-shrink:0;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff; }
.kb-assignee img { width:100%;height:100%;object-fit:cover; }
.kb-assignee-name { font-size:11px;color:var(--text-2); }
.kb-unassigned { font-size:11px;color:var(--text-3);display:flex;align-items:center;gap:4px; }
.kb-due { font-size:10px;font-weight:600;display:flex;align-items:center;gap:3px;padding:2px 6px;border-radius:5px; }
.due-ok{color:var(--text-3)}.due-soon{color:#d97706;background:rgba(245,158,11,.1)}.due-overdue{color:#dc2626;background:rgba(220,38,38,.1)}
.kb-move-btn { background:none;border:1px solid var(--border);border-radius:5px;padding:2px 5px;cursor:pointer;color:var(--text-3);font-size:10px;transition:all .15s; }
.kb-move-btn:hover { background:var(--primary);color:#fff;border-color:var(--primary); }
.kb-stage-opt:hover { background:var(--primary) !important;border-color:var(--primary) !important;color:#fff !important; }
.kb-stage-opt:hover span { color:#fff !important; }
.task-panel { position:fixed;right:0;top:0;bottom:0;width:440px;max-width:100vw;z-index:90;background:var(--card);border-left:1px solid var(--border);box-shadow:-4px 0 24px rgba(0,0,0,.12);display:flex;flex-direction:column;animation:slideInRight .2s ease; }
@keyframes slideInRight{from{transform:translateX(100%)}to{transform:translateX(0)}}
.task-panel-inner{display:flex;flex-direction:column;height:100%}
.task-panel-head{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.tp-label{font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
</style>

<script>
const IS_WORKFLOW = <%- isWorkflow ? 'true' : 'false' %>;

// Build column map for status labels
const colLabels = {};
<% columns.forEach(col => { %>
colLabels['<%= col.id %>'] = '<%= col.name %>';
<% }) %>

/* ===== DRAG & DROP ===== */
let draggingId=null, draggingEl=null, dragSourceColKey=null;

function cardDragStart(e) {
  draggingId = e.currentTarget.dataset.id;
  draggingEl = e.currentTarget;
  dragSourceColKey = e.currentTarget.closest('.kb-col').dataset.colkey;
  e.currentTarget.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', draggingId);
}

function cardDragEnd(e) {
  e.currentTarget.classList.remove('dragging');
  draggingId = null; draggingEl = null;
}

function colDragOver(e, col) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  col.classList.add('drag-over');
}

function colDragLeave(col) { col.classList.remove('drag-over'); }

async function colDrop(e, col) {
  e.preventDefault();
  col.classList.remove('drag-over');
  if (!draggingId) return;
  const newColKey = col.dataset.colkey;
  if (newColKey === dragSourceColKey) return;

  const card = document.getElementById('card-' + draggingId);
  const oldColKey = dragSourceColKey;

  // Optimistic move
  col.querySelector('.kb-cards').appendChild(card);
  updateColCounts();

  if (IS_WORKFLOW) {
    // Move stage via workflow API
    try {
      const r = await fetch('/tasks/' + draggingId + '/move-stage', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ stage_id: newColKey })
      });
      const d = await r.json();
      if (!d.success) throw new Error(d.error || 'Lỗi chuyển bước');
      card.dataset.stage = newColKey;
      showKbToast('✅ Đã chuyển: ' + (colLabels[newColKey] || newColKey));
    } catch (err) {
      // Rollback
      document.getElementById('cards-' + oldColKey)?.appendChild(card);
      updateColCounts();
      showKbToast(err.message, 'error');
    }
  } else {
    // Regular status update
    const newStatus = col.dataset.mapsStatus || newColKey;
    const oldStatus = card.dataset.status;
    try {
      const r = await fetch('/tasks/' + draggingId + '/status', {
        method: 'PUT',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ status: newStatus })
      });
      const d = await r.json();
      if (!d.success) throw new Error(d.error);
      card.dataset.status = newStatus;
      showKbToast('✅ Đã chuyển: ' + (colLabels[newColKey] || newStatus));
    } catch (err) {
      document.getElementById('cards-' + oldColKey)?.appendChild(card);
      card.dataset.status = oldStatus;
      updateColCounts();
      showKbToast(err.message, 'error');
    }
  }
}

function updateColCounts() {
  document.querySelectorAll('.kb-col').forEach(col => {
    const key = col.dataset.colkey;
    const count = col.querySelectorAll('.kb-card').length;
    const badge = document.getElementById('badge-' + key);
    const empty = document.getElementById('empty-' + key);
    if (badge) badge.textContent = count;
    if (empty) empty.style.display = count === 0 ? 'flex' : 'none';
  });
}

/* ===== FILTERS ===== */
function filterCards() {
  const search   = (document.getElementById('searchFilter')?.value || '').toLowerCase();
  const assignee = document.getElementById('assigneeFilter')?.value || '';
  const priority = document.getElementById('priorityFilter')?.value || '';
  document.querySelectorAll('.kb-card').forEach(card => {
    const matchSearch   = !search   || card.dataset.title.includes(search);
    const matchAssignee = !assignee || card.dataset.assignee === assignee;
    const matchPriority = !priority || card.dataset.priority === priority;
    card.style.display = (matchSearch && matchAssignee && matchPriority) ? '' : 'none';
  });
  updateColCounts();
}

/* ===== ADD TASK MODAL ===== */
function openAddTask(status, stageId) {
  document.getElementById('taskInitialStatus').value = status || 'todo';
  document.getElementById('taskInitialStage').value  = stageId || '';
  document.getElementById('taskModal').style.display = 'flex';
  setTimeout(() => document.querySelector('#taskModal input[name=title]')?.focus(), 50);
}
function closeTaskModal() { document.getElementById('taskModal').style.display = 'none'; }

/* ===== MOVE STAGE MODAL ===== */
let movingTaskId = null;
function openMoveStage(taskId, currentStageId, taskTitle) {
  movingTaskId = taskId;
  document.getElementById('moveStageTaskName').textContent = taskTitle;
  // Highlight current stage
  document.querySelectorAll('.kb-stage-opt').forEach(btn => {
    const isCurrent = btn.dataset.stageId === currentStageId;
    btn.style.borderColor = isCurrent ? 'var(--primary)' : 'var(--border)';
    btn.style.background  = isCurrent ? 'rgba(59,130,246,.08)' : 'var(--bg)';
  });
  document.getElementById('moveStageModal').style.display = 'flex';
}
function closeMoveStage() {
  document.getElementById('moveStageModal').style.display = 'none';
  movingTaskId = null;
}
async function doMoveStage(btn) {
  if (!movingTaskId) return;
  const stageId = btn.dataset.stageId;
  try {
    const r = await fetch('/tasks/' + movingTaskId + '/move-stage', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ stage_id: stageId })
    });
    const d = await r.json();
    if (d.success) {
      closeMoveStage();
      showKbToast('✅ ' + (d.message || 'Đã chuyển bước'));
      setTimeout(() => location.reload(), 800);
    } else {
      showKbToast(d.error || 'Không thể chuyển bước', 'error');
    }
  } catch (err) { showKbToast('Lỗi kết nối', 'error'); }
}

/* ===== TASK DETAIL PANEL ===== */
async function openTaskDetail(taskId) {
  if (draggingId) return;
  document.getElementById('taskPanel').style.display = 'flex';
  document.getElementById('taskPanelOverlay').style.display = 'block';
  document.getElementById('taskPanelEditBtn').href = '/tasks/' + taskId + '/edit';

  const card = document.getElementById('card-' + taskId);
  if (!card) return;
  const title    = card.querySelector('.kb-card-title')?.textContent?.trim();
  const desc     = card.querySelector('.kb-card-desc')?.textContent?.trim();
  const assignee = card.querySelector('.kb-assignee-name')?.textContent?.trim();
  const due      = card.querySelector('.kb-due')?.textContent?.trim();
  const status   = card.dataset.status;
  const statusLabels = { todo:'Cần làm', in_progress:'Đang làm', review:'Kiểm tra', done:'Hoàn thành' };

  document.getElementById('taskPanelBody').innerHTML = `
    <div style="margin-bottom:14px">
      <div style="font-size:16px;font-weight:700;color:var(--text);line-height:1.4;margin-bottom:6px">${title||'—'}</div>
      ${desc ? `<div style="font-size:13px;color:var(--text-2);line-height:1.6">${desc}</div>` : ''}
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
      <div><div class="tp-label">Trạng thái</div><span class="badge badge-${status}">${statusLabels[status]||status}</span></div>
      <div><div class="tp-label">Người thực hiện</div><div style="font-size:13px;color:var(--text)">${assignee||'—'}</div></div>
      <div><div class="tp-label">Hạn chót</div><div style="font-size:13px;color:var(--text)">${due||'—'}</div></div>
    </div>
    <div><div class="tp-label" style="margin-bottom:8px">Chuyển trạng thái</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        ${['todo','in_progress','review','done'].map(s =>
          `<button class="btn btn-sm ${s===status?'btn-primary':'btn-outline'}" onclick="quickStatus('${taskId}','${s}',this)" data-status="${s}">${statusLabels[s]}</button>`
        ).join('')}
      </div>
    </div>
  `;
}

async function quickStatus(taskId, status, btn) {
  try {
    const r = await fetch('/tasks/' + taskId + '/status', {
      method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({status})
    });
    const d = await r.json();
    if (d.success) {
      const card = document.getElementById('card-' + taskId);
      if (card) { card.dataset.status = status; updateColCounts(); }
      btn.closest('div').querySelectorAll('button').forEach(b => {
        b.className = 'btn btn-sm ' + (b.dataset.status === status ? 'btn-primary' : 'btn-outline');
      });
      showKbToast('✅ Đã cập nhật');
    }
  } catch(e) { showKbToast('Lỗi', 'error'); }
}

function closeTaskPanel() {
  document.getElementById('taskPanel').style.display = 'none';
  document.getElementById('taskPanelOverlay').style.display = 'none';
}

/* ===== TOAST ===== */
function showKbToast(msg, type='success') {
  let c = document.getElementById('kbToast');
  if (!c) { c=document.createElement('div'); c.id='kbToast'; c.style.cssText='position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:999'; document.body.appendChild(c); }
  c.innerHTML = `<div style="background:var(--card);border:1px solid var(--border);border-left:3px solid ${type==='error'?'#dc2626':'#22c55e'};padding:10px 18px;border-radius:8px;font-size:13px;color:var(--text);box-shadow:0 4px 16px rgba(0,0,0,.15)">${msg}</div>`;
  setTimeout(()=>{ if(c) c.innerHTML=''; }, 2500);
}

document.addEventListener('keydown', e => {
  if (e.key==='Escape') { closeTaskModal(); closeTaskPanel(); closeMoveStage?.(); }
});

// Close workflow dropdown on outside click
document.addEventListener('click', e => {
  if (!e.target.closest('.kb-header [style*="position:relative"]')) {
    document.querySelectorAll('.kb-header [style*="position:absolute"]').forEach(d => d.style.display='none');
  }
});
</script>
