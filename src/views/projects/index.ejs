<div class="page-header">
  <div class="page-header-title">
    <h1>Quản lý Dự án</h1>
    <p><%= stats.total %> dự án · <%= stats.active %> đang chạy</p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <% if (projects.length > 0) { %>
    <button class="btn btn-outline" onclick="document.getElementById('createTaskModal').showModal()">
      <i class="fas fa-list-check"></i> Thêm task
    </button>
    <% } %>
    <% if (['edit','full'].includes(permLevel)) { %>
    <a href="/projects/create" data-modal class="btn btn-primary"><i class="fas fa-plus"></i> Tạo dự án</a>
    <% } %>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--primary-50);color:var(--primary)"><i class="fas fa-folder-open"></i></div>
    <div class="stat-value"><%= stats.active %></div>
    <div class="stat-label">Đang chạy</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--info-bg);color:var(--info)"><i class="fas fa-drafting-compass"></i></div>
    <div class="stat-value"><%= stats.planning %></div>
    <div class="stat-label">Chuẩn bị</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--warning-bg);color:var(--warning)"><i class="fas fa-pause-circle"></i></div>
    <div class="stat-value"><%= stats.on_hold %></div>
    <div class="stat-label">Tạm dừng</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--success-bg);color:var(--success)"><i class="fas fa-check-circle"></i></div>
    <div class="stat-value"><%= stats.completed %></div>
    <div class="stat-label">Hoàn thành</div>
  </div>
</div>

<form method="GET" action="/projects" class="filter-bar">
  <input type="text" name="search" class="form-control" placeholder="Tìm theo tên, mã, khách hàng..."
         value="<%= filters.search || '' %>" style="max-width:260px">
  <select name="status" class="form-control" style="max-width:160px">
    <option value="">Mọi trạng thái</option>
    <% Object.entries(PROJECT_STATUS_LABELS).forEach(([v, l]) => { %>
    <option value="<%= v %>" <%= filters.status === v ? 'selected' : '' %>><%= l %></option>
    <% }) %>
  </select>
  <select name="priority" class="form-control" style="max-width:150px">
    <option value="">Mọi ưu tiên</option>
    <% Object.entries(PRIORITY_LABELS).forEach(([v, l]) => { %>
    <option value="<%= v %>" <%= filters.priority === v ? 'selected' : '' %>><%= l %></option>
    <% }) %>
  </select>
  <button type="submit" class="btn btn-outline"><i class="fas fa-filter"></i> Lọc</button>
</form>

<% if (projects.length === 0) { %>
<div class="card"><div class="card-body" style="text-align:center;padding:48px;color:var(--text-3)">
  <i class="fas fa-folder-open" style="font-size:36px;margin-bottom:12px;display:block"></i>
  Chưa có dự án nào<% if (['edit','full'].includes(permLevel)) { %> — <a href="/projects/create">tạo dự án đầu tiên</a><% } %>
</div></div>
<% } %>

<div class="project-grid">
  <% projects.forEach(p => { %>
  <a href="/projects/<%= p.id %>" class="project-card card">
    <div class="pc-top">
      <span class="project-code"><%= p.code %></span>
      <span class="badge badge-<%= p.status %>"><%= PROJECT_STATUS_LABELS[p.status] %></span>
    </div>
    <h3 class="pc-name"><%= p.name %></h3>
    <% if (p.client_name) { %><div class="project-client"><i class="fas fa-building"></i> <%= p.client_name %></div><% } %>
    <div class="pc-progress">
      <div class="progress-track"><div class="progress-fill" style="width:<%= p.progress_percent || 0 %>%"></div></div>
      <span class="pc-progress-num"><%= p.progress_percent || 0 %>%</span>
    </div>
    <div class="pc-meta">
      <span title="Công việc"><i class="fas fa-list-check"></i> <%= p.done_count %>/<%= p.task_count %></span>
      <span title="Thành viên"><i class="fas fa-users"></i> <%= p.member_count %></span>
      <% if (p.end_date) { %><span title="Hạn chót"><i class="fas fa-calendar"></i> <%= fmtDate(p.end_date) %></span><% } %>
    </div>
    <% if (p.manager_name) { %><div class="pc-manager">PM: <%= p.manager_name %></div><% } %>
  </a>
  <% }) %>
</div>

<!-- Modal tạo task nhanh (chọn dự án) -->
<% if (projects.length > 0) { %>
<dialog id="createTaskModal" class="modal">
  <button type="button" class="modal-x" onclick="this.closest('dialog').close()" aria-label="Đóng">&times;</button>
  <form action="/tasks" method="POST" class="modal-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="redirect_to" value="/projects">
    <h3>Thêm task mới</h3>
    <div class="form-group">
      <label>Dự án *</label>
      <select name="project_id" class="form-control" required>
        <% projects.filter(p => !['completed','cancelled'].includes(p.status)).forEach(p => { %>
        <option value="<%= p.id %>"><%= p.code %> — <%= p.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Tiêu đề *</label>
      <input type="text" name="title" class="form-control" required maxlength="300">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Giao cho</label>
        <select name="assignee_id" class="form-control">
          <option value="">— Chưa giao —</option>
          <% users.forEach(u => { %><option value="<%= u.id %>"><%= u.full_name %></option><% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Ưu tiên</label>
        <select name="priority" class="form-control">
          <% Object.entries(PRIORITY_LABELS).forEach(([v, l]) => { %>
          <option value="<%= v %>" <%= v === 'medium' ? 'selected' : '' %>><%= l %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>Hạn hoàn thành</label>
      <input type="date" name="due_date" class="form-control">
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="this.closest('dialog').close()">Hủy</button>
      <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo task</button>
    </div>
  </form>
</dialog>
<% } %>

<style>
.filter-bar { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
.modal { border: none; border-radius: var(--radius-lg); padding: 0; width: 100%; max-width: 520px; box-shadow: var(--shadow-lg); }
.modal::backdrop { background: rgba(13,27,62,.5); }
.modal-form { padding: 26px; }
.modal-form h3 { margin-bottom: 20px; font-size: 17px; color: var(--text); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
.modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 22px; }
.project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.project-card { display: block; padding: 18px; text-decoration: none; transition: var(--transition); }
.project-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: var(--primary); }
.pc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.pc-name { font-size: 15.5px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
.pc-progress { display: flex; align-items: center; gap: 10px; margin: 12px 0 10px; }
.progress-track { flex: 1; height: 6px; background: var(--border-light); border-radius: 4px; overflow: hidden; }
.progress-fill { height: 100%; background: var(--primary); border-radius: 4px; }
.pc-progress-num { font-size: 12px; font-weight: 600; color: var(--text-2); min-width: 34px; text-align: right; }
.pc-meta { display: flex; gap: 16px; font-size: 12.5px; color: var(--text-3); }
.pc-meta i { margin-right: 4px; }
.pc-manager { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border-light); font-size: 12px; color: var(--text-2); }
</style>
