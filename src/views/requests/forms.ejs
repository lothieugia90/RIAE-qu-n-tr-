<style>
.forms-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:16px; }
.form-card { background:var(--card); border:1px solid var(--border); border-radius:10px; overflow:hidden; transition:box-shadow .15s; }
.form-card:hover { box-shadow:0 4px 16px rgba(0,0,0,.06); }
.form-card-header { padding:16px 18px 12px; }
.form-card-top { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:8px; }
.form-card-name { font-size:15px; font-weight:600; color:var(--text-1); }
.form-card-desc { font-size:12px; color:var(--text-3); margin-top:4px; }
.form-card-meta { display:flex; gap:12px; padding:10px 18px; border-top:1px solid var(--border); background:var(--bg); }
.form-meta-item { display:flex; align-items:center; gap:4px; font-size:11px; color:var(--text-3); }
.form-card-actions { padding:10px 18px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; }
.cat-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 8px; border-radius:12px; font-size:11px; font-weight:600; }
/* Modal */
.fm-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:1000; align-items:center; justify-content:center; }
.fm-modal-overlay.open { display:flex; }
.fm-modal { background:var(--card); border-radius:12px; width:680px; max-width:95vw; max-height:88vh; display:flex; flex-direction:column; box-shadow:0 20px 60px rgba(0,0,0,.2); }
.fm-modal-header { padding:18px 22px 14px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
.fm-modal-body { padding:20px 22px; overflow-y:auto; flex:1; }
.fm-modal-footer { padding:14px 22px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:10px; flex-shrink:0; }
.field-row { display:flex; gap:6px; margin-bottom:8px; align-items:flex-start; }
.field-row-main { flex:1; }
.options-row { margin-top:4px; }
.options-textarea { width:100%; padding:6px 8px; border:1px solid var(--border); border-radius:5px; font-size:12px; background:var(--bg); color:var(--text-1); resize:vertical; min-height:50px; display:none; box-sizing:border-box; }
.section-header { font-weight:600; font-size:13px; margin-bottom:10px; display:flex; align-items:center; justify-content:space-between; }
.section-header span { display:flex; align-items:center; gap:6px; }
</style>

<div class="page-header">
  <div class="page-header-title"><h2><i class="fas fa-project-diagram" style="margin-right:8px;color:var(--primary)"></i>Quản lý Quy trình duyệt</h2></div>
  <div class="page-header-actions">
    <button onclick="document.getElementById('newFormModal').classList.add('open')" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo quy trình</button>
    <a href="/requests" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
  </div>
</div>

<%
  const catLabels = { admin:'Hành chính', finance:'Tài chính', project:'Dự án', other:'Khác' };
  const catIcons  = { admin:'fa-user-clock', finance:'fa-coins', project:'fa-project-diagram', other:'fa-file-alt' };
  const catColors = { admin:'#2563EB', finance:'#16A34A', project:'#7C3AED', other:'#6B7280' };
  const catBgs    = { admin:'#EFF6FF', finance:'#F0FDF4', project:'#FAF5FF', other:'#F9FAFB' };
%>

<% if (forms.length === 0) { %>
<div class="card">
  <div class="empty-state" style="padding:56px">
    <div class="empty-state-icon"><i class="fas fa-project-diagram"></i></div>
    <h3>Chưa có quy trình nào</h3>
    <p>Tạo quy trình phê duyệt đầu tiên để bắt đầu</p>
  </div>
</div>
<% } else { %>
<div class="forms-grid">
  <% forms.forEach(function(f) {
    const cat = f.category || 'other';
    let fieldCount = 0, stepCount = 0;
    try { fieldCount = (Array.isArray(f.fields) ? f.fields : JSON.parse(f.fields || '[]')).length; } catch(e){}
    try { stepCount = (Array.isArray(f.approval_steps) ? f.approval_steps : JSON.parse(f.approval_steps || '[]')).length; } catch(e){}
  %>
  <div class="form-card">
    <div class="form-card-header">
      <div class="form-card-top">
        <div>
          <div class="form-card-name"><%= f.name %></div>
          <div class="form-card-desc"><%= f.description || 'Không có mô tả' %></div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
          <span class="cat-badge" style="background:<%= catBgs[cat] %>;color:<%= catColors[cat] %>">
            <i class="fas <%= catIcons[cat] %>"></i> <%= catLabels[cat] %>
          </span>
          <span class="badge" style="background:<%= f.is_active ? 'var(--success-bg,#DCFCE7)' : 'var(--border)' %>;color:<%= f.is_active ? 'var(--success,#15803D)' : 'var(--text-3)' %>">
            <%= f.is_active ? 'Đang dùng' : 'Ẩn' %>
          </span>
        </div>
      </div>
      <% if (f.creator_name) { %>
      <div style="font-size:11px;color:var(--text-3)"><i class="fas fa-user" style="margin-right:3px"></i>Tạo bởi: <%= f.creator_name %></div>
      <% } %>
    </div>
    <div class="form-card-meta">
      <span class="form-meta-item"><i class="fas fa-list"></i> <%= fieldCount %> trường</span>
      <span class="form-meta-item"><i class="fas fa-check-double"></i> <%= stepCount %> bước</span>
      <span class="form-meta-item"><i class="fas fa-file-alt"></i> <%= f.request_count %> yêu cầu</span>
    </div>
    <div class="form-card-actions" style="justify-content:space-between">
      <button onclick="openEditModal('<%= f.id %>')" class="btn btn-sm btn-outline"><i class="fas fa-edit"></i> Sửa</button>
      <div style="display:flex;gap:6px">
        <form action="/requests/forms/<%= f.id %>/toggle" method="POST" style="display:inline">
          <% if (f.is_active) { %>
          <button type="submit" class="btn btn-sm btn-outline" style="color:#F59E0B;border-color:#F59E0B" title="Ẩn khỏi danh sách"><i class="fas fa-eye-slash"></i> Ẩn</button>
          <% } else { %>
          <button type="submit" class="btn btn-sm btn-outline" style="color:#16A34A;border-color:#16A34A" title="Hiện lại"><i class="fas fa-eye"></i> Hiện</button>
          <% } %>
        </form>
        <form action="/requests/forms/<%= f.id %>/delete" method="POST" style="display:inline">
          <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa vĩnh viễn quy trình này? Không thể hoàn tác!')"><i class="fas fa-trash"></i></button>
        </form>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } %>

<!-- Edit Form Modal -->
<div class="fm-modal-overlay" id="editFormModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="fm-modal">
    <div class="fm-modal-header">
      <strong style="font-size:16px">Sửa Quy trình duyệt</strong>
      <button class="btn-icon-sm" onclick="document.getElementById('editFormModal').classList.remove('open')" style="width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-2);cursor:pointer"><i class="fas fa-times"></i></button>
    </div>
    <form id="editFormEl" action="" method="POST">
      <div class="fm-modal-body">

        <div class="form-group mb-3">
          <label class="form-label">Tên quy trình <span style="color:var(--danger)">*</span></label>
          <input type="text" name="name" id="edit_name" class="form-control" required>
        </div>

        <div class="form-group mb-3">
          <label class="form-label">Danh mục</label>
          <select name="category" id="edit_category" class="form-control">
            <option value="admin">Hành chính</option>
            <option value="finance">Tài chính</option>
            <option value="project">Dự án</option>
            <option value="other">Khác</option>
          </select>
        </div>

        <div class="form-group mb-4">
          <label class="form-label">Mô tả</label>
          <textarea name="description" id="edit_desc" class="form-control" rows="2"></textarea>
        </div>

        <div class="section-header">
          <span><i class="fas fa-list" style="color:var(--primary)"></i> Các trường thông tin</span>
          <button type="button" onclick="addEditField()" class="btn btn-sm btn-outline"><i class="fas fa-plus"></i> Thêm trường</button>
        </div>
        <div id="editFieldsContainer" style="margin-bottom:20px"></div>

        <div class="section-header">
          <span><i class="fas fa-check-double" style="color:var(--success)"></i> Bước phê duyệt</span>
          <button type="button" onclick="addEditStep()" class="btn btn-sm btn-outline"><i class="fas fa-plus"></i> Thêm bước</button>
        </div>
        <div id="editStepsContainer"></div>

      </div>
      <div class="fm-modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('editFormModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu thay đổi</button>
      </div>
    </form>
  </div>
</div>

<!-- Create Form Modal -->
<div class="fm-modal-overlay" id="newFormModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="fm-modal">
    <div class="fm-modal-header">
      <strong style="font-size:16px">Tạo Quy trình duyệt mới</strong>
      <button class="btn-icon-sm" onclick="document.getElementById('newFormModal').classList.remove('open')" style="width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-2);cursor:pointer"><i class="fas fa-times"></i></button>
    </div>
    <form action="/requests/forms" method="POST">
      <div class="fm-modal-body">

        <div class="form-group mb-3">
          <label class="form-label">Tên quy trình <span style="color:var(--danger)">*</span></label>
          <input type="text" name="name" class="form-control" required placeholder="VD: Đề nghị mua hàng, Xin nghỉ phép...">
        </div>

        <div class="form-group mb-3">
          <label class="form-label">Danh mục</label>
          <select name="category" class="form-control">
            <option value="admin">Hành chính</option>
            <option value="finance">Tài chính</option>
            <option value="project">Dự án</option>
            <option value="other" selected>Khác</option>
          </select>
        </div>

        <div class="form-group mb-4">
          <label class="form-label">Mô tả</label>
          <textarea name="description" class="form-control" rows="2" placeholder="Mô tả ngắn về mục đích quy trình..."></textarea>
        </div>

        <div class="section-header">
          <span><i class="fas fa-list" style="color:var(--primary)"></i> Các trường thông tin</span>
          <button type="button" onclick="addField()" class="btn btn-sm btn-outline"><i class="fas fa-plus"></i> Thêm trường</button>
        </div>
        <div id="fieldsContainer" style="margin-bottom:20px">
          <div class="field-row">
            <div class="field-row-main">
              <div style="display:flex;gap:6px;align-items:center">
                <input type="text" name="fields[]" class="form-control" placeholder="Tên trường" style="flex:2" value="Lý do">
                <select name="ftypes[]" class="form-control" style="flex:1" onchange="toggleOptions(this)">
                  <option value="text">Văn bản</option>
                  <option value="textarea">Đoạn văn</option>
                  <option value="number">Số</option>
                  <option value="date">Ngày</option>
                  <option value="select">Lựa chọn</option>
                </select>
                <select name="freqs[]" class="form-control" style="flex:1">
                  <option value="true">Bắt buộc</option>
                  <option value="false">Tuỳ chọn</option>
                </select>
                <button type="button" onclick="this.closest('.field-row').remove()" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button>
              </div>
              <div class="options-row">
                <textarea name="foptions[]" class="options-textarea" placeholder="Các lựa chọn, mỗi dòng một giá trị..."></textarea>
              </div>
            </div>
          </div>
        </div>

        <div class="section-header">
          <span><i class="fas fa-check-double" style="color:var(--success)"></i> Bước phê duyệt</span>
          <button type="button" onclick="addStep()" class="btn btn-sm btn-outline"><i class="fas fa-plus"></i> Thêm bước</button>
        </div>
        <div id="stepsContainer">
          <div style="font-size:12px;color:var(--text-3);padding:10px;border:1px dashed var(--border);border-radius:6px;text-align:center">Nhấn "Thêm bước" để thêm người phê duyệt</div>
        </div>

      </div>
      <div class="fm-modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('newFormModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Tạo quy trình</button>
      </div>
    </form>
  </div>
</div>

<script>
const allUsers = <%- JSON.stringify(users.map(u => ({id:u.id, name:u.full_name, role:u.role}))) %>;
const allForms = <%- JSON.stringify(forms) %>;

function toggleOptions(sel) {
  const row = sel.closest('.field-row');
  const ta = row.querySelector('.options-textarea');
  if (sel.value === 'select') {
    ta.style.display = 'block';
    ta.required = true;
  } else {
    ta.style.display = 'none';
    ta.required = false;
  }
}

function addField() {
  const c = document.getElementById('fieldsContainer');
  const div = document.createElement('div');
  div.className = 'field-row';
  div.innerHTML = `<div class="field-row-main">
    <div style="display:flex;gap:6px;align-items:center">
      <input type="text" name="fields[]" class="form-control" placeholder="Tên trường" style="flex:2">
      <select name="ftypes[]" class="form-control" style="flex:1" onchange="toggleOptions(this)">
        <option value="text">Văn bản</option>
        <option value="textarea">Đoạn văn</option>
        <option value="number">Số</option>
        <option value="date">Ngày</option>
        <option value="select">Lựa chọn</option>
      </select>
      <select name="freqs[]" class="form-control" style="flex:1">
        <option value="true">Bắt buộc</option>
        <option value="false">Tuỳ chọn</option>
      </select>
      <button type="button" onclick="this.closest('.field-row').remove()" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button>
    </div>
    <div class="options-row">
      <textarea name="foptions[]" class="options-textarea" placeholder="Các lựa chọn, mỗi dòng một giá trị..."></textarea>
    </div>
  </div>`;
  c.appendChild(div);
}

let editStepCount = 0;

function openEditModal(id) {
  const f = allForms.find(function(x) { return x.id === id; });
  if (!f) return;
  document.getElementById('edit_name').value = f.name || '';
  document.getElementById('edit_desc').value = f.description || '';
  document.getElementById('edit_category').value = f.category || 'other';
  document.getElementById('editFormEl').action = '/requests/forms/' + f.id + '/edit';

  // Populate fields — handle array (JSONB), string (TEXT), or object
  const fc = document.getElementById('editFieldsContainer');
  fc.innerHTML = '';
  var fields = [];
  try {
    if (Array.isArray(f.fields)) { fields = f.fields; }
    else if (typeof f.fields === 'string' && f.fields.trim()) { fields = JSON.parse(f.fields); }
    else if (f.fields && typeof f.fields === 'object') { fields = Object.values(f.fields); }
  } catch(e) { fields = []; }
  if (fields.length === 0) {
    fc.innerHTML = '<div style="font-size:12px;color:var(--text-3);padding:10px;border:1px dashed var(--border);border-radius:6px;text-align:center;margin-bottom:8px">Chưa có trường nào</div>';
  } else {
    fields.forEach(function(fld) { addEditField(fld); });
  }

  // Populate steps — same handling
  const sc = document.getElementById('editStepsContainer');
  sc.innerHTML = '';
  editStepCount = 0;
  var steps = [];
  try {
    if (Array.isArray(f.approval_steps)) { steps = f.approval_steps; }
    else if (typeof f.approval_steps === 'string' && f.approval_steps.trim()) { steps = JSON.parse(f.approval_steps); }
    else if (f.approval_steps && typeof f.approval_steps === 'object') { steps = Object.values(f.approval_steps); }
  } catch(e) { steps = []; }
  if (steps.length === 0) {
    sc.innerHTML = '<div style="font-size:12px;color:var(--text-3);padding:10px;border:1px dashed var(--border);border-radius:6px;text-align:center">Nhấn "Thêm bước" để thêm người phê duyệt</div>';
  } else {
    steps.forEach(function(s) { addEditStep(s); });
  }

  document.getElementById('editFormModal').classList.add('open');
}

function addEditField(data) {
  const c = document.getElementById('editFieldsContainer');
  const fld = data || {};
  const typeOpts = ['text','textarea','number','date','select'].map(function(t) {
    return '<option value="' + t + '"' + (fld.type === t ? ' selected' : '') + '>' + {text:'Văn bản',textarea:'Đoạn văn',number:'Số',date:'Ngày',select:'Lựa chọn'}[t] + '</option>';
  }).join('');
  const div = document.createElement('div');
  div.className = 'field-row';
  const showOpts = fld.type === 'select' ? 'block' : 'none';
  const optVal = (fld.options || []).join('\n');
  div.innerHTML = '<div class="field-row-main">' +
    '<div style="display:flex;gap:6px;align-items:center">' +
      '<input type="text" name="fields[]" class="form-control" placeholder="Tên trường" style="flex:2" value="' + (fld.label||'').replace(/"/g,'&quot;') + '">' +
      '<select name="ftypes[]" class="form-control" style="flex:1" onchange="toggleOptions(this)">' + typeOpts + '</select>' +
      '<select name="freqs[]" class="form-control" style="flex:1">' +
        '<option value="true"' + (fld.required ? ' selected' : '') + '>Bắt buộc</option>' +
        '<option value="false"' + (!fld.required ? ' selected' : '') + '>Tuỳ chọn</option>' +
      '</select>' +
      '<button type="button" onclick="this.closest(\'.field-row\').remove()" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button>' +
    '</div>' +
    '<div class="options-row"><textarea name="foptions[]" class="options-textarea" placeholder="Các lựa chọn, mỗi dòng một giá trị..." style="display:' + showOpts + '">' + optVal + '</textarea></div>' +
  '</div>';
  c.appendChild(div);
}

function addEditStep(data) {
  const c = document.getElementById('editStepsContainer');
  // Remove placeholder if present
  if (editStepCount === 0) {
    const placeholder = c.querySelector('div[style*="dashed"]');
    if (placeholder) c.innerHTML = '';
  }
  editStepCount++;
  const s = data || {};
  const opts = allUsers.map(function(u) {
    return '<option value="' + u.id + '"' + (s.approver_id === u.id ? ' selected' : '') + '>' + u.name + ' (' + u.role + ')</option>';
  }).join('');
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:8px;margin-bottom:8px;align-items:center';
  div.innerHTML = '<div style="width:26px;height:26px;background:var(--primary);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">' + editStepCount + '</div>' +
    '<input type="text" name="step_name[]" class="form-control" placeholder="Tên bước" style="flex:1" value="' + (s.name||'').replace(/"/g,'&quot;') + '">' +
    '<select name="step_approver[]" class="form-control" style="flex:2"><option value="">— Chọn người duyệt —</option>' + opts + '</select>' +
    '<button type="button" onclick="this.closest(\'div\').remove();editStepCount--" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button>';
  c.appendChild(div);
}

let stepCount = 0;
function addStep() {
  const c = document.getElementById('stepsContainer');
  if (stepCount === 0) c.innerHTML = '';
  stepCount++;
  const opts = allUsers.map(u => `<option value="${u.id}">${u.name} (${u.role})</option>`).join('');
  const div = document.createElement('div');
  div.style.cssText = 'display:flex;gap:8px;margin-bottom:8px;align-items:center';
  div.innerHTML = `<div style="width:26px;height:26px;background:var(--primary);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">${stepCount}</div>
    <input type="text" name="step_name[]" class="form-control" placeholder="Tên bước (VD: Trưởng phòng)" style="flex:1">
    <select name="step_approver[]" class="form-control" style="flex:2">
      <option value="">— Chọn người duyệt —</option>${opts}
    </select>
    <button type="button" onclick="this.closest('div').remove();stepCount--" class="btn btn-sm btn-danger"><i class="fas fa-times"></i></button>`;
  c.appendChild(div);
}
</script>
