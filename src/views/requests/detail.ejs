<style>
.detail-grid { display:grid; grid-template-columns:1fr 320px; gap:24px; align-items:start; }
.detail-main { display:flex; flex-direction:column; gap:16px; }
.detail-side { display:flex; flex-direction:column; gap:16px; }
.d-card { background:var(--card); border:1px solid var(--border); border-radius:10px; overflow:hidden; }
.d-card-header { padding:14px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:8px; font-size:14px; font-weight:600; color:var(--text-1); }
.d-card-body { padding:20px; }
.cat-badge-lg { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; border-radius:20px; font-size:12px; font-weight:600; }
.priority-badge { display:inline-block; padding:3px 10px; border-radius:10px; font-size:12px; font-weight:600; }
.priority-urgent { background:#FEE2E2; color:#DC2626; }
.priority-high { background:#FEF3C7; color:#D97706; }
.priority-normal { background:#F3F4F6; color:#6B7280; }
.priority-low { background:#F0FDF4; color:#16A34A; }
.status-badge-lg { display:inline-flex; align-items:center; gap:6px; padding:6px 14px; border-radius:20px; font-size:13px; font-weight:700; }
.status-pending  { background:#FEF9C3; color:#B45309; }
.status-approved { background:#DCFCE7; color:#15803D; }
.status-rejected { background:#FEE2E2; color:#DC2626; }
.field-pair { margin-bottom:14px; }
.field-pair:last-child { margin-bottom:0; }
.field-key { font-size:11px; font-weight:600; color:var(--text-3); text-transform:uppercase; letter-spacing:.4px; margin-bottom:4px; }
.field-val { font-size:14px; color:var(--text-1); line-height:1.5; }
/* Approval timeline */
.timeline { display:flex; flex-direction:column; }
.tl-step { display:flex; gap:14px; padding-bottom:0; }
.tl-step:not(:last-child) .tl-line { flex:1; width:2px; background:var(--border); margin:4px auto; min-height:20px; }
.tl-left { display:flex; flex-direction:column; align-items:center; width:32px; flex-shrink:0; }
.tl-icon { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; flex-shrink:0; border:2px solid var(--border); background:var(--card); }
.tl-icon.approved { background:#DCFCE7; color:#15803D; border-color:#86EFAC; }
.tl-icon.rejected { background:#FEE2E2; color:#DC2626; border-color:#FCA5A5; }
.tl-icon.pending  { background:#FEF9C3; color:#B45309; border-color:#FDE68A; }
.tl-right { padding-bottom:20px; flex:1; }
.tl-step:last-child .tl-right { padding-bottom:0; }
.tl-step-name { font-size:13px; font-weight:600; color:var(--text-1); }
.tl-approver { font-size:12px; color:var(--text-2); margin-top:2px; }
.tl-status { font-size:11px; font-weight:600; margin-top:4px; }
.tl-comment { font-size:12px; color:var(--text-2); margin-top:6px; font-style:italic; background:var(--bg); padding:8px 10px; border-radius:6px; border-left:3px solid var(--border); }
.tl-reject-reason { font-size:12px; color:#DC2626; margin-top:6px; background:#FEF2F2; padding:8px 10px; border-radius:6px; border-left:3px solid #FCA5A5; }
.tl-date { font-size:11px; color:var(--text-3); margin-top:3px; }
/* Attachments */
.attach-grid { display:flex; flex-wrap:wrap; gap:10px; }
.attach-item { position:relative; }
.attach-img { width:80px; height:80px; object-fit:cover; border-radius:8px; border:1px solid var(--border); display:block; cursor:pointer; }
.attach-chip { display:inline-flex; align-items:center; gap:6px; padding:6px 12px; background:var(--bg); border:1px solid var(--border); border-radius:8px; font-size:12px; color:var(--text-2); text-decoration:none; transition:all .15s; }
.attach-chip:hover { border-color:var(--primary); color:var(--primary); }
/* Submitter avatar */
.submitter-row { display:flex; align-items:center; gap:10px; }
.avatar-initial { width:36px; height:36px; border-radius:50%; background:var(--primary); color:#fff; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; flex-shrink:0; }
.side-info-item { display:flex; flex-direction:column; gap:2px; padding:10px 0; border-bottom:1px solid var(--border); }
.side-info-item:last-child { border-bottom:none; }
.side-info-label { font-size:11px; color:var(--text-3); font-weight:600; text-transform:uppercase; letter-spacing:.4px; }
.side-info-val { font-size:13px; color:var(--text-1); font-weight:500; }
/* Action area */
.action-area { display:flex; flex-direction:column; gap:10px; }
.approve-form textarea { width:100%; padding:8px 10px; border:1px solid var(--border); border-radius:6px; font-size:13px; background:var(--bg); color:var(--text-1); resize:vertical; min-height:60px; outline:none; box-sizing:border-box; margin-top:6px; }
.approve-form textarea:focus { border-color:var(--primary); }
/* Rejection reason modal */
.reject-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:1000; align-items:center; justify-content:center; }
.reject-modal-overlay.open { display:flex; }
.reject-modal { background:var(--card); border-radius:12px; width:420px; max-width:95vw; box-shadow:0 20px 60px rgba(0,0,0,.2); }
.reject-modal-header { padding:18px 20px 14px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
.reject-modal-body { padding:18px 20px; }
.btn-icon-sm { width:28px; height:28px; border-radius:6px; border:1px solid var(--border); background:transparent; color:var(--text-2); display:inline-flex; align-items:center; justify-content:center; font-size:12px; cursor:pointer; }
@media(max-width:768px){ .detail-grid{grid-template-columns:1fr} }
</style>

<%
  const cat = request.category || 'other';
  const catLabels = { admin:'Hành chính', finance:'Tài chính', project:'Dự án', other:'Khác' };
  const catIcons  = { admin:'fa-user-clock', finance:'fa-coins', project:'fa-project-diagram', other:'fa-file-alt' };
  const catColors = { admin:'#2563EB', finance:'#16A34A', project:'#7C3AED', other:'#6B7280' };
  const catBgs    = { admin:'#EFF6FF', finance:'#F0FDF4', project:'#FAF5FF', other:'#F9FAFB' };
  const prioLabel = { urgent:'Khẩn cấp', high:'Cao', normal:'Bình thường', low:'Thấp' };
  const prioClass = { urgent:'priority-urgent', high:'priority-high', normal:'priority-normal', low:'priority-low' };
  const statusLabel = { pending:'Chờ duyệt', approved:'Đã phê duyệt', rejected:'Từ chối' };
  const statusClass = { pending:'status-pending', approved:'status-approved', rejected:'status-rejected' };
  const statusIcon  = { pending:'fa-clock', approved:'fa-check-circle', rejected:'fa-times-circle' };
%>

<div class="page-header">
  <div class="page-header-title">
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
      <span class="cat-badge-lg" style="background:<%= catBgs[cat] %>;color:<%= catColors[cat] %>">
        <i class="fas <%= catIcons[cat] %>"></i> <%= catLabels[cat] %>
      </span>
      <span class="priority-badge <%= prioClass[request.priority || 'normal'] %>"><%= prioLabel[request.priority || 'normal'] %></span>
    </div>
    <h2 style="margin:0"><%= request.title %></h2>
    <div style="font-size:12px;color:var(--text-3);margin-top:4px"><i class="fas fa-file-alt" style="margin-right:4px"></i><%= request.form_name %></div>
  </div>
  <div class="page-header-actions">
    <a href="/requests" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
    <% if (isAdmin && request.status === 'rejected') { %>
    <form method="POST" action="/requests/<%= request.id %>/reopen" style="display:inline">
      <button type="submit" class="btn btn-outline" onclick="return confirm('Mở lại yêu cầu này?')"><i class="fas fa-redo"></i> Mở lại</button>
    </form>
    <% } %>
  </div>
</div>

<div class="detail-grid">
  <!-- Left column -->
  <div class="detail-main">

    <!-- Request data fields -->
    <div class="d-card">
      <div class="d-card-header"><i class="fas fa-clipboard-list" style="color:var(--primary)"></i> Nội dung yêu cầu</div>
      <div class="d-card-body">
        <%
          let fields; try { fields = Array.isArray(request.fields) ? request.fields : JSON.parse(request.fields || '[]'); } catch(e){ fields=[]; }
          const data = (typeof request.data === 'object' && request.data !== null) ? request.data : (request.data ? JSON.parse(request.data) : {});
        %>
        <% fields.forEach(function(field, idx) { %>
        <div class="field-pair">
          <div class="field-key"><%= field.label %></div>
          <div class="field-val"><%= data['field_' + idx] || data[field.label] || '—' %></div>
        </div>
        <% }) %>
        <% if (fields.length === 0) { %>
        <p style="color:var(--text-3);font-size:13px">Không có dữ liệu form.</p>
        <% } %>
      </div>
    </div>

    <!-- Payment info (finance only) -->
    <% if (request.category === 'finance' && (request.payment_recipient || request.payment_amount)) { %>
    <div class="d-card" style="border:2px solid #86efac">
      <div class="d-card-header" style="background:#f0fdf4;color:#15803d">
        <i class="fas fa-university"></i> Thông tin thanh toán
      </div>
      <div class="d-card-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px 24px">
          <div class="field-pair">
            <div class="field-key">Người nhận</div>
            <div class="field-val" style="font-weight:600"><%= request.payment_recipient || '—' %></div>
          </div>
          <div class="field-pair">
            <div class="field-key">Số tiền</div>
            <div class="field-val" style="font-weight:700;color:#15803d;font-size:16px">
              <%= request.payment_amount ? Number(request.payment_amount).toLocaleString('vi-VN') + ' đ' : '—' %>
            </div>
          </div>
          <div class="field-pair">
            <div class="field-key">Số tài khoản</div>
            <div class="field-val" style="font-family:monospace;font-size:15px"><%= request.payment_account || '—' %></div>
          </div>
          <div class="field-pair">
            <div class="field-key">Ngân hàng / Chi nhánh</div>
            <div class="field-val"><%= request.payment_bank || '—' %></div>
          </div>
          <% if (request.payment_note) { %>
          <div class="field-pair" style="grid-column:1/-1">
            <div class="field-key">Nội dung chuyển khoản</div>
            <div class="field-val"><%= request.payment_note %></div>
          </div>
          <% } %>
        </div>
        <% if (request.status === 'approved') { %>
        <div style="margin-top:12px;padding:10px 14px;background:#dcfce7;border-radius:8px;display:flex;align-items:center;gap:8px;font-size:13px;color:#15803d;font-weight:600">
          <i class="fas fa-check-circle"></i> Đã được phê duyệt đầy đủ — Kế toán có thể thực hiện thanh toán
        </div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Attachments -->
    <% let attachments; try { attachments = Array.isArray(request.attachment_urls) ? request.attachment_urls : JSON.parse(request.attachment_urls || '[]'); } catch(e){ attachments=[]; } %>
    <% if (attachments.length > 0) { %>
    <div class="d-card">
      <div class="d-card-header"><i class="fas fa-paperclip" style="color:var(--primary)"></i> Tệp đính kèm (<%= attachments.length %>)</div>
      <div class="d-card-body">
        <div class="attach-grid">
          <% attachments.forEach(function(url) {
            const ext = url.split('.').pop().toLowerCase();
            const isImg = ['jpg','jpeg','png','webp'].includes(ext);
            const docIcons = { pdf:'fa-file-pdf', doc:'fa-file-word', docx:'fa-file-word', xls:'fa-file-excel', xlsx:'fa-file-excel' };
            const iconCls = docIcons[ext] || 'fa-file';
          %>
          <div class="attach-item">
            <% if (isImg) { %>
            <a href="<%= url %>" target="_blank"><img class="attach-img" src="<%= url %>" alt="attachment"></a>
            <% } else { %>
            <a href="<%= url %>" target="_blank" class="attach-chip"><i class="fas <%= iconCls %>"></i> <%= url.split('/').pop() %></a>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Approval timeline -->
    <div class="d-card">
      <div class="d-card-header"><i class="fas fa-route" style="color:var(--primary)"></i> Quy trình phê duyệt</div>
      <div class="d-card-body">
        <% if (approvals.length === 0) { %>
        <p style="color:var(--text-3);font-size:13px">Không có bước phê duyệt nào.</p>
        <% } else { %>
        <div class="timeline">
          <% approvals.forEach(function(a, i) { %>
          <div class="tl-step">
            <div class="tl-left">
              <div class="tl-icon <%= a.status %>">
                <% if (a.status === 'approved') { %><i class="fas fa-check"></i>
                <% } else if (a.status === 'rejected') { %><i class="fas fa-times"></i>
                <% } else { %><i class="fas fa-clock"></i><% } %>
              </div>
              <% if (i < approvals.length - 1) { %><div class="tl-line"></div><% } %>
            </div>
            <div class="tl-right">
              <div class="tl-step-name">
                <%= a.step_name || ('Bước ' + (a.step_order + 1)) %>
              </div>
              <div class="tl-approver"><i class="fas fa-user" style="margin-right:4px"></i><%= a.approver_name %>
                <% if (a.approver_dept) { %><span style="color:var(--text-3)"> · <%= a.approver_dept %></span><% } %>
              </div>
              <% if (a.status === 'approved') { %>
                <div class="tl-status" style="color:#15803D"><i class="fas fa-check-circle"></i> Đã phê duyệt</div>
              <% } else if (a.status === 'rejected') { %>
                <div class="tl-status" style="color:#DC2626"><i class="fas fa-times-circle"></i> Từ chối</div>
              <% } else { %>
                <div class="tl-status" style="color:#B45309"><i class="fas fa-clock"></i> Chờ duyệt</div>
              <% } %>
              <% if (a.rejection_reason) { %>
              <div class="tl-reject-reason"><i class="fas fa-exclamation-circle" style="margin-right:4px"></i><%= a.rejection_reason %></div>
              <% } %>
              <% if (a.comment) { %>
              <div class="tl-comment"><i class="fas fa-comment" style="margin-right:4px"></i><%= a.comment %></div>
              <% } %>
              <% if (a.signed_at) { %>
              <div class="tl-date"><i class="fas fa-calendar-check" style="margin-right:4px"></i><%= new Date(a.signed_at).toLocaleString('vi-VN') %></div>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Approve/Reject actions -->
    <% if (canApprove) { %>
    <div class="d-card">
      <div class="d-card-header"><i class="fas fa-gavel" style="color:var(--primary)"></i> Hành động phê duyệt</div>
      <div class="d-card-body">
        <form method="POST" action="/requests/<%= request.id %>/approve" class="approve-form">
          <input type="hidden" name="action" id="actionField" value="approve">
          <div style="margin-bottom:12px">
            <label style="font-size:13px;font-weight:500;color:var(--text-2);display:block;margin-bottom:6px">Ghi chú (tùy chọn)</label>
            <textarea name="comment" placeholder="Nhập ghi chú hoặc nhận xét..."></textarea>
          </div>
          <div style="display:flex;gap:10px">
            <button type="submit" class="btn btn-success" onclick="document.getElementById('actionField').value='approve'" style="flex:1">
              <i class="fas fa-check"></i> Phê duyệt
            </button>
            <button type="button" class="btn btn-danger" onclick="document.getElementById('rejectModal').classList.add('open')" style="flex:1">
              <i class="fas fa-times"></i> Từ chối
            </button>
          </div>
        </form>
      </div>
    </div>
    <% } %>

  </div>

  <!-- Right sidebar -->
  <div class="detail-side">

    <!-- Status card -->
    <div class="d-card">
      <div class="d-card-header"><i class="fas fa-info-circle" style="color:var(--primary)"></i> Trạng thái</div>
      <div class="d-card-body">
        <div style="text-align:center;padding:10px 0">
          <span class="status-badge-lg <%= statusClass[request.status] %>">
            <i class="fas <%= statusIcon[request.status] %>"></i> <%= statusLabel[request.status] || request.status %>
          </span>
        </div>
        <% if (request.rejection_reason) { %>
        <div style="margin-top:12px;padding:10px;background:#FEF2F2;border-radius:6px;border-left:3px solid #FCA5A5;font-size:12px;color:#DC2626">
          <strong>Lý do từ chối:</strong> <%= request.rejection_reason %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Info card -->
    <div class="d-card">
      <div class="d-card-header"><i class="fas fa-user-circle" style="color:var(--primary)"></i> Chi tiết</div>
      <div class="d-card-body" style="padding:12px 20px">

        <div class="side-info-item">
          <div class="side-info-label">Người gửi</div>
          <div class="submitter-row">
            <div class="avatar-initial"><%= (request.submitter_name || '?').charAt(0).toUpperCase() %></div>
            <div>
              <div class="side-info-val"><%= request.submitter_name %></div>
              <% if (request.submitter_dept) { %><div style="font-size:11px;color:var(--text-3)"><%= request.submitter_dept %></div><% } %>
            </div>
          </div>
        </div>

        <div class="side-info-item">
          <div class="side-info-label">Danh mục</div>
          <div>
            <span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:12px;font-size:12px;font-weight:600;background:<%= catBgs[cat] %>;color:<%= catColors[cat] %>">
              <i class="fas <%= catIcons[cat] %>"></i> <%= catLabels[cat] %>
            </span>
          </div>
        </div>

        <div class="side-info-item">
          <div class="side-info-label">Ưu tiên</div>
          <div><span class="priority-badge <%= prioClass[request.priority || 'normal'] %>"><%= prioLabel[request.priority || 'normal'] %></span></div>
        </div>

        <div class="side-info-item">
          <div class="side-info-label">Ngày gửi</div>
          <div class="side-info-val"><%= new Date(request.created_at).toLocaleString('vi-VN') %></div>
        </div>

        <% if (request.updated_at && request.updated_at !== request.created_at) { %>
        <div class="side-info-item">
          <div class="side-info-label">Cập nhật lần cuối</div>
          <div class="side-info-val"><%= new Date(request.updated_at).toLocaleString('vi-VN') %></div>
        </div>
        <% } %>

        <div class="side-info-item">
          <div class="side-info-label">Quy trình</div>
          <div class="side-info-val"><%= request.form_name %></div>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- Reject Modal -->
<% if (canApprove) { %>
<div class="reject-modal-overlay" id="rejectModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="reject-modal">
    <div class="reject-modal-header">
      <strong style="font-size:15px;color:var(--danger)"><i class="fas fa-times-circle" style="margin-right:6px"></i>Từ chối yêu cầu</strong>
      <button class="btn-icon-sm" onclick="document.getElementById('rejectModal').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
    <div class="reject-modal-body">
      <form method="POST" action="/requests/<%= request.id %>/approve">
        <input type="hidden" name="action" value="reject">
        <div style="margin-bottom:14px">
          <label style="font-size:13px;font-weight:600;color:var(--text-1);display:block;margin-bottom:8px">
            Lý do từ chối <span style="color:var(--danger)">*</span>
          </label>
          <textarea name="rejection_reason" required placeholder="Vui lòng nhập lý do từ chối yêu cầu này..." style="width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:6px;font-size:13px;background:var(--bg);color:var(--text-1);resize:vertical;min-height:90px;outline:none;box-sizing:border-box" oninvalid="this.setCustomValidity('Vui lòng nhập lý do từ chối')" oninput="this.setCustomValidity('')"></textarea>
        </div>
        <div style="font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:8px">
          Ghi chú thêm (tùy chọn)
        </div>
        <textarea name="comment" placeholder="Ghi chú thêm..." style="width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:6px;font-size:13px;background:var(--bg);color:var(--text-1);resize:vertical;min-height:60px;outline:none;box-sizing:border-box;margin-bottom:16px"></textarea>
        <div style="display:flex;gap:10px;justify-content:flex-end">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('rejectModal').classList.remove('open')">Hủy</button>
          <button type="submit" class="btn btn-danger"><i class="fas fa-times"></i> Xác nhận từ chối</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>
