<div class="page-header">
  <div class="page-header-title">
    <h1>Yêu cầu & Phê duyệt</h1>
    <p><%= stats.pending %> chờ duyệt · <%= stats.approved %> đã duyệt · <%= stats.rejected %> từ chối</p>
  </div>
  <% if (isAdmin) { %>
  <a href="/requests/forms" class="btn btn-outline"><i class="fas fa-cogs"></i> Quản lý quy trình</a>
  <% } %>
</div>

<!-- Tạo yêu cầu mới từ form có sẵn -->
<div class="card">
  <div class="card-header"><h3>Tạo yêu cầu mới</h3></div>
  <div class="card-body">
    <div class="req-form-grid">
      <% forms.forEach(f => { const m = categoryMeta[f.category] || categoryMeta.other; %>
      <a href="/requests/new/<%= f.id %>" data-modal class="req-form-card">
        <span class="rf-icon" style="background:<%= m.bg %>;color:<%= m.color %>"><i class="fas <%= m.icon %>"></i></span>
        <span class="rf-text">
          <strong><%= f.name %></strong>
          <small><%= f.description || m.label %></small>
        </span>
      </a>
      <% }) %>
    </div>
  </div>
</div>

<!-- Tabs -->
<div class="tabs-container" style="margin-top:20px">
  <div class="req-tabs">
    <button class="tab-btn <%= activeTab === 'my' ? 'active' : '' %>" data-tab="tab-my">Yêu cầu của tôi (<%= myRequests.length %>)</button>
    <button class="tab-btn <%= activeTab === 'pending' ? 'active' : '' %>" data-tab="tab-pending">
      Chờ tôi duyệt
      <% if (pendingRequests.length > 0) { %><span class="nav-badge" style="position:static;margin-left:6px"><%= pendingRequests.length %></span><% } %>
    </button>
    <% if (isAdmin) { %>
    <button class="tab-btn <%= activeTab === 'all' ? 'active' : '' %>" data-tab="tab-all">Tất cả (<%= allRequests.length %>)</button>
    <% } %>
  </div>

  <%
  function reqTable(rows, showSubmitter) { %>
    <% if (rows.length === 0) { %>
    <p style="text-align:center;padding:32px;color:var(--text-3)">Không có yêu cầu nào</p>
    <% } else { %>
    <table class="table">
      <thead><tr><th>Yêu cầu</th><th>Loại</th><% if (showSubmitter) { %><th>Người gửi</th><% } %><th>Ngày gửi</th><th>Trạng thái</th></tr></thead>
      <tbody>
        <% rows.forEach(r => { const m = categoryMeta[r.category] || categoryMeta.other; %>
        <tr>
          <td><a href="/requests/<%= r.id %>" style="font-weight:500"><%= r.title %></a>
            <% if (r.priority === 'urgent' || r.priority === 'high') { %>
            <span class="badge badge-<%= r.priority %>" style="margin-left:6px"><%= r.priority === 'urgent' ? 'Khẩn' : 'Cao' %></span>
            <% } %>
          </td>
          <td><span class="badge" style="background:<%= m.bg %>;color:<%= m.color %>"><%= r.form_name %></span></td>
          <% if (showSubmitter) { %><td><%= r.submitter_name %></td><% } %>
          <td style="white-space:nowrap"><%= fmtDate(r.created_at) %></td>
          <td>
            <% if (r.status === 'approved') { %><span class="badge badge-success">Đã duyệt</span>
            <% } else if (r.status === 'rejected') { %><span class="badge badge-danger">Từ chối</span>
            <% } else { %><span class="badge badge-warning">Chờ duyệt</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  <% } %>

  <div class="card tab-pane <%= activeTab === 'my' ? 'active' : '' %>" id="tab-my">
    <div class="card-body" style="padding:0"><% reqTable(myRequests, false) %></div>
  </div>
  <div class="card tab-pane <%= activeTab === 'pending' ? 'active' : '' %>" id="tab-pending">
    <div class="card-body" style="padding:0"><% reqTable(pendingRequests, true) %></div>
  </div>
  <% if (isAdmin) { %>
  <div class="card tab-pane <%= activeTab === 'all' ? 'active' : '' %>" id="tab-all">
    <div class="card-body" style="padding:0"><% reqTable(allRequests, true) %></div>
  </div>
  <% } %>
</div>

<style>
.req-form-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 12px; }
.req-form-card {
  display: flex; align-items: center; gap: 12px; padding: 14px; border: 1.5px solid var(--border);
  border-radius: var(--radius); text-decoration: none; transition: var(--transition);
}
.req-form-card:hover { border-color: var(--primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
.rf-icon { width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.rf-text { display: flex; flex-direction: column; gap: 2px; }
.rf-text strong { font-size: 13.5px; color: var(--text); }
.rf-text small { font-size: 11.5px; color: var(--text-3); }
.req-tabs { display: flex; gap: 4px; margin-bottom: 14px; border-bottom: 2px solid var(--border); }
.tab-btn {
  border: none; background: transparent; padding: 10px 16px; font-size: 13.5px; font-weight: 600;
  color: var(--text-3); cursor: pointer; border-bottom: 2.5px solid transparent; margin-bottom: -2px;
  font-family: inherit; display: flex; align-items: center;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); }
.tab-pane { display: none; }
.tab-pane.active { display: block; }
</style>
