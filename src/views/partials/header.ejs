<header class="top-header">
  <div class="header-left">
    <button class="menu-btn" id="menuBtn">
      <i class="fas fa-bars"></i>
    </button>
    <nav class="breadcrumb-nav" aria-label="breadcrumb">
      <span class="page-heading"><%= title %></span>
    </nav>
  </div>
  <div class="header-right">

    <!-- Announcement bell: link to page -->
    <a href="/announcements" class="header-icon-btn" title="Bảng tin công ty">
      <i class="fas fa-bullhorn"></i>
      <% if (locals.unreadAnnouncements > 0) { %>
      <span class="header-badge"><%= unreadAnnouncements %></span>
      <% } %>
    </a>

    <!-- Personal notification bell: dropdown -->
    <div class="notif-bell-wrap" id="notifWrap">
      <button class="header-icon-btn" id="notifBtn" title="Thông báo cá nhân" onclick="toggleNotifPanel()">
        <i class="fas fa-bell"></i>
        <% if (locals.unreadNotifications > 0) { %>
        <span class="header-badge header-badge-red" id="notifBadge"><%= unreadNotifications %></span>
        <% } %>
      </button>

      <!-- Dropdown panel -->
      <div class="notif-panel" id="notifPanel" style="display:none">
        <div class="notif-panel-head">
          <span style="font-size:14px;font-weight:700;color:var(--text)">Thông báo</span>
          <button onclick="markAllNotifRead()" id="markAllBtn" style="background:none;border:none;font-size:12px;color:var(--primary);cursor:pointer;font-weight:500">Đánh dấu tất cả đã đọc</button>
        </div>
        <!-- Tabs -->
        <div class="notif-tabs">
          <button class="notif-tab active" data-tab="all"    onclick="switchNotifTab('all',this)">Tất cả</button>
          <button class="notif-tab"        data-tab="work"   onclick="switchNotifTab('work',this)">Công việc</button>
          <button class="notif-tab"        data-tab="personal" onclick="switchNotifTab('personal',this)">Cá nhân</button>
        </div>
        <div class="notif-list" id="notifList">
          <div style="padding:32px;text-align:center;color:var(--text-3)">
            <i class="fas fa-spinner fa-spin fa-lg"></i>
          </div>
        </div>
        <div class="notif-panel-foot">
          <a href="/announcements" style="font-size:13px;color:var(--primary);text-decoration:none;font-weight:500">Xem bảng tin công ty <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>

    <a href="/auth/profile" class="header-user-btn" title="Hồ sơ cá nhân">
      <% if (locals.currentUser && currentUser.avatar_url) { %>
        <img src="<%= currentUser.avatar_url %>" class="header-avatar-img" alt="">
      <% } else { %>
        <div class="header-avatar">
          <%= locals.currentUser ? currentUser.full_name.charAt(0).toUpperCase() : 'U' %>
        </div>
      <% } %>
    </a>
  </div>
</header>

<style>
.header-avatar-img { width:34px;height:34px;border-radius:50%;object-fit:cover }
.header-badge-red { background:var(--danger) !important }

.notif-bell-wrap { position:relative }
.notif-panel {
  position:absolute;top:calc(100% + 10px);right:0;
  width:380px;max-width:96vw;
  background:var(--card);
  border:1.5px solid var(--border);
  border-radius:var(--radius-lg);
  box-shadow:0 20px 40px rgba(0,0,0,.15);
  z-index:2000;overflow:hidden;
  animation:notifIn .18s ease;
}
@keyframes notifIn { from{opacity:0;transform:translateY(-8px)} to{opacity:1;transform:translateY(0)} }

.notif-panel-head { display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--border) }
.notif-tabs { display:flex;padding:10px 16px 0;gap:4px;border-bottom:1px solid var(--border) }
.notif-tab { padding:6px 14px;font-size:13px;font-weight:500;border:none;background:none;cursor:pointer;color:var(--text-3);border-bottom:2px solid transparent;margin-bottom:-1px;transition:var(--transition) }
.notif-tab.active,.notif-tab:hover { color:var(--primary) }
.notif-tab.active { border-bottom-color:var(--primary);font-weight:600 }

.notif-list { max-height:380px;overflow-y:auto }
.notif-item { display:flex;gap:12px;padding:12px 16px;cursor:pointer;text-decoration:none;border-bottom:1px solid var(--border);transition:var(--transition) }
.notif-item:hover { background:var(--border-light) }
.notif-item.unread { background:var(--primary-50) }
.notif-item:last-child { border-bottom:none }
.notif-icon-wrap { width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px }
.notif-item-body { flex:1;min-width:0 }
.notif-item-title { font-size:13px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:2px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden }
.notif-item.unread .notif-item-title { color:var(--text) }
.notif-item-body-text { font-size:12px;color:var(--text-3);display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden }
.notif-item-time { font-size:11px;color:var(--text-3);margin-top:4px }
.notif-unread-dot { width:8px;height:8px;border-radius:50%;background:var(--primary);flex-shrink:0;align-self:center }
.notif-panel-foot { padding:10px 16px;border-top:1px solid var(--border);text-align:center }
.notif-empty { padding:32px 16px;text-align:center;color:var(--text-3) }
.notif-empty i { font-size:28px;margin-bottom:8px;display:block;opacity:.4 }
</style>

<script>
let notifOpen = false;
let currentNotifTab = 'all';

function toggleNotifPanel() {
  const panel = document.getElementById('notifPanel');
  notifOpen = !notifOpen;
  panel.style.display = notifOpen ? 'block' : 'none';
  if (notifOpen) loadNotifications(currentNotifTab);
}

document.addEventListener('click', function(e) {
  const wrap = document.getElementById('notifWrap');
  if (wrap && !wrap.contains(e.target)) {
    document.getElementById('notifPanel').style.display = 'none';
    notifOpen = false;
  }
});

function switchNotifTab(tab, el) {
  currentNotifTab = tab;
  document.querySelectorAll('.notif-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  loadNotifications(tab);
}

const typeConfig = {
  task_assigned:  {icon:'tasks',     color:'#dbeafe', icolor:'var(--primary)'},
  task_deadline:  {icon:'clock',     color:'#fee2e2', icolor:'var(--danger)'},
  task_update:    {icon:'sync-alt',  color:'#fef3c7', icolor:'var(--warning)'},
  message:        {icon:'comment',   color:'#dcfce7', icolor:'var(--success)'},
  approval:       {icon:'check-circle',color:'#ede9fe',icolor:'#7c3aed'},
  announcement:   {icon:'bullhorn',  color:'#e0f2fe', icolor:'#0891b2'},
  default:        {icon:'bell',      color:'var(--border-light)', icolor:'var(--text-3)'}
};

function timeAgo(dateStr) {
  const diff = Date.now() - new Date(dateStr);
  const m = Math.floor(diff/60000);
  if (m < 1) return 'vừa xong';
  if (m < 60) return m + ' phút trước';
  const h = Math.floor(m/60);
  if (h < 24) return h + ' giờ trước';
  const d = Math.floor(h/24);
  if (d < 7) return d + ' ngày trước';
  return new Date(dateStr).toLocaleDateString('vi-VN');
}

async function loadNotifications(tab) {
  const list = document.getElementById('notifList');
  list.innerHTML = '<div style="padding:32px;text-align:center;color:var(--text-3)"><i class="fas fa-spinner fa-spin fa-lg"></i></div>';
  try {
    const r = await fetch('/notifications/dropdown?tab=' + tab);
    const data = await r.json();
    const items = data.notifications || [];

    if (!items.length) {
      list.innerHTML = '<div class="notif-empty"><i class="fas fa-bell-slash"></i><p style="font-size:13px;font-weight:500">Không có thông báo nào</p></div>';
      return;
    }

    list.innerHTML = items.map(n => {
      const cfg = typeConfig[n.type] || typeConfig.default;
      const href = n.link || '#';
      return `<a class="notif-item ${n.is_read ? '' : 'unread'}" href="${href}"
                onclick="readNotif(event,'${n.id}','${href}')">
        <div class="notif-icon-wrap" style="background:${cfg.color}">
          <i class="fas fa-${cfg.icon}" style="color:${cfg.icolor}"></i>
        </div>
        <div class="notif-item-body">
          <div class="notif-item-title">${n.title}</div>
          ${n.body ? `<div class="notif-item-body-text">${n.body}</div>` : ''}
          <div class="notif-item-time">${timeAgo(n.created_at)}</div>
        </div>
        ${!n.is_read ? '<div class="notif-unread-dot"></div>' : ''}
      </a>`;
    }).join('');

    // Update badge
    const total = data.counts ? data.counts.total : 0;
    updateBadge(total);
  } catch(e) {
    list.innerHTML = '<div class="notif-empty"><i class="fas fa-exclamation-triangle"></i><p>Lỗi tải thông báo</p></div>';
  }
}

async function readNotif(e, id, href) {
  e.preventDefault();
  try { await fetch('/notifications/' + id + '/read', {method:'POST'}); } catch(_) {}
  // Remove unread style
  const el = e.currentTarget;
  el.classList.remove('unread');
  const dot = el.querySelector('.notif-unread-dot');
  if (dot) dot.remove();
  // Navigate
  if (href && href !== '#') window.location.href = href;
}

async function markAllNotifRead() {
  try {
    await fetch('/notifications/read-all', {method:'POST'});
    document.querySelectorAll('.notif-item').forEach(el => {
      el.classList.remove('unread');
      const dot = el.querySelector('.notif-unread-dot');
      if (dot) dot.remove();
    });
    updateBadge(0);
  } catch(_) {}
}

function updateBadge(count) {
  let badge = document.getElementById('notifBadge');
  if (!badge && count > 0) {
    badge = document.createElement('span');
    badge.id = 'notifBadge';
    badge.className = 'header-badge header-badge-red';
    document.getElementById('notifBtn').appendChild(badge);
  }
  if (badge) {
    badge.textContent = count > 99 ? '99+' : count;
    badge.style.display = count > 0 ? '' : 'none';
  }
}
</script>
