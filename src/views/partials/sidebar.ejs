<% const roleLabels = {
  admin:'Quản trị viên', director:'Ban lãnh đạo', pm:'Quản lý Dự án',
  head_tech:'Trưởng phòng KT', head_hr:'Trưởng phòng NS', head_sales:'Trưởng phòng KD',
  engineer:'Kỹ sư', field_supervisor:'Giám sát hiện trường', tech_deploy:'Kỹ thuật triển khai',
  hr:'Nhân sự', warehouse:'Nhân viên Kho', warehouse_keeper:'Thủ kho', accountant:'Kế toán'
}; %>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <a href="/dashboard" class="brand-mark" aria-label="RiAE Management — về Dashboard">
      <svg class="bm-dome" viewBox="0 0 120 40" aria-hidden="true">
        <!-- Nét gốc liền mạch như logo -->
        <path class="bm-arc" d="M6 38 A54 54 0 0 1 114 38" pathLength="100"/>
        <path class="bm-net" d="M32 26 L52 14 L72 24 L92 12" pathLength="100"/>
        <!-- Vệt sáng chạy dọc nét (overlay, không phá nét gốc) -->
        <path class="bm-arc-glow" d="M6 38 A54 54 0 0 1 114 38" pathLength="100"/>
        <path class="bm-net-glow" d="M32 26 L52 14 L72 24 L92 12" pathLength="100"/>
        <circle class="bm-node" cx="32" cy="26" r="2.6" fill="#42A5F5"/>
        <circle class="bm-node" cx="52" cy="14" r="3.2" fill="#7EC3F7"/>
        <circle class="bm-node" cx="72" cy="24" r="2.6" fill="#42A5F5"/>
        <circle class="bm-node" cx="92" cy="12" r="2.8" fill="#7EC3F7"/>
      </svg>
      <span class="bm-word" role="img" aria-label="RiAE"><span>R</span><span class="bm-i">&#305;</span><span class="bm-a">A</span><span>E</span></span>
      <span class="bm-sub">MANAGEMENT</span>
    </a>
    <button class="sidebar-close-btn" id="sidebarCloseBtn"><i class="fas fa-times"></i></button>
  </div>
  <style>
  .brand-mark {
    display: flex; flex-direction: column; align-items: center; gap: 1px;
    text-decoration: none; padding: 6px 0 2px; margin: 0 auto;
  }
  .bm-dome { width: 92px; height: auto; display: block; margin-bottom: -5px; }
  .bm-word {
    font-family: 'Chakra Petch', 'Inter', sans-serif; font-weight: 700;
    font-size: 30px; line-height: 1; color: #fff; letter-spacing: .01em;
    display: flex; align-items: baseline;
  }
  .bm-word .bm-a { color: #42A5F5; }
  /* Chữ ı không chấm (U+0131) + chấm vẽ tay — tránh chấm của font bị nhân đôi */
  .bm-word .bm-i { position: relative; }
  .bm-word .bm-i::after {
    content: ''; position: absolute; left: 50%; transform: translateX(-50%);
    top: .06em; width: .17em; height: .17em; border-radius: 50%;
    background: #42A5F5;
  }
  .bm-sub {
    font-family: 'Chakra Petch', 'Inter', sans-serif; font-weight: 500;
    font-size: 8.5px; letter-spacing: .42em; text-indent: .42em;
    color: var(--sidebar-text); margin-top: 5px;
  }
  .sidebar.collapsed .bm-dome, .sidebar.collapsed .bm-sub { display: none; }
  .sidebar.collapsed .bm-word { font-size: 20px; }

  /* Nét gốc: liền mạch đúng logo */
  .bm-arc { stroke: #7EC3F7; stroke-width: 2; fill: none; stroke-linecap: round; opacity: .9; }
  .bm-net { stroke: #42A5F5; stroke-width: 1.2; fill: none; opacity: .8; }
  /* Vệt sáng: mặc định ẩn, chỉ chạy khi cho phép chuyển động */
  .bm-arc-glow, .bm-net-glow { fill: none; stroke-linecap: round; opacity: 0; }

  /* Logo động lặp liên tục (tắt khi người dùng bật reduced-motion) */
  @media (prefers-reduced-motion: no-preference) {
    .bm-arc-glow {
      stroke: #E3F2FD; stroke-width: 2.2; opacity: 1;
      stroke-dasharray: 12 88; /* pathLength=100: đoạn sáng 12%, lặp khép kín */
      animation: bmComet 4.5s linear infinite;
    }
    .bm-net-glow {
      stroke: #B3DBFF; stroke-width: 1.6; opacity: 1;
      stroke-dasharray: 18 82;
      animation: bmComet 3s linear infinite;
    }
    .bm-node { animation: bmTwinkle 2.4s ease-in-out infinite; }
    .bm-node:nth-of-type(2) { animation-delay: .6s; }
    .bm-node:nth-of-type(3) { animation-delay: 1.2s; }
    .bm-node:nth-of-type(4) { animation-delay: 1.8s; }
    .bm-word .bm-i::after { animation: bmPulse 2.4s ease-in-out infinite; }
    @keyframes bmComet   { to { stroke-dashoffset: -100; } }
    @keyframes bmTwinkle { 0%, 100% { opacity: .45; } 50% { opacity: 1; } }
    @keyframes bmPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(66,165,245,.55); }
      50%      { box-shadow: 0 0 8px 2px rgba(66,165,245,.75); }
    }
  }
  </style>

  <nav class="sidebar-nav">
    <div class="nav-group">
      <span class="nav-group-label">TỔNG QUAN</span>
      <a href="/dashboard" class="nav-link <%= path === '/dashboard' ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-th-large"></i></span>
        <span class="nav-text">Dashboard</span>
      </a>
      <a href="/announcements" class="nav-link <%= path.startsWith('/announcements') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-bullhorn"></i></span>
        <span class="nav-text">Bảng tin công ty</span>
        <% if (locals.unreadAnnouncements > 0) { %>
        <span class="nav-badge"><%= unreadAnnouncements %></span>
        <% } %>
      </a>
    </div>

    <div class="nav-group">
      <span class="nav-group-label">QUẢN LÝ</span>
      <a href="/projects" class="nav-link <%= path.startsWith('/projects') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-folder-open"></i></span>
        <span class="nav-text">Dự án</span>
      </a>
      <a href="/tasks/my-tasks" class="nav-link <%= path.startsWith('/tasks/my-tasks') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-list-check"></i></span>
        <span class="nav-text">Việc của tôi</span>
        <% if (locals.myWorkCount > 0) { %>
        <span class="nav-badge"><%= myWorkCount %></span>
        <% } %>
      </a>
      <a href="/notifications" class="nav-link <%= path.startsWith('/notifications') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-bell"></i></span>
        <span class="nav-text">Thông báo</span>
        <% if (locals.unreadNotifications > 0) { %>
        <span class="nav-badge"><%= unreadNotifications %></span>
        <% } %>
      </a>
      <a href="/requests" class="nav-link <%= path.startsWith('/requests') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-stamp"></i></span>
        <span class="nav-text">Phê duyệt</span>
        <% if (locals.pendingApprovals > 0) { %>
        <span class="nav-badge"><%= pendingApprovals %></span>
        <% } %>
      </a>
      <a href="/attendance" class="nav-link <%= path.startsWith('/attendance') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-calendar-check"></i></span>
        <span class="nav-text">Chấm công</span>
      </a>
      <% if (['admin','director','hr','head_hr'].includes(locals.userRole)) { %>
      <a href="/hr" class="nav-link <%= path.startsWith('/hr') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-users"></i></span>
        <span class="nav-text">Nhân sự</span>
      </a>
      <% } %>
    </div>

    <div class="nav-group">
      <span class="nav-group-label">NGHIỆP VỤ</span>
      <a href="/chat" class="nav-link <%= path.startsWith('/chat') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-comments"></i></span>
        <span class="nav-text">Chat</span>
        <% if (locals.unreadChats > 0) { %>
        <span class="nav-badge"><%= unreadChats %></span>
        <% } %>
      </a>
      <a href="/warehouse" class="nav-link <%= path.startsWith('/warehouse') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-boxes"></i></span>
        <span class="nav-text">Kho vật tư</span>
      </a>
      <% if (['admin','director','pm','head_sales','accountant'].includes(locals.userRole)) { %>
      <a href="/partners" class="nav-link <%= path.startsWith('/partners') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-handshake"></i></span>
        <span class="nav-text">Đối tác</span>
      </a>
      <a href="/quotes" class="nav-link <%= path.startsWith('/quotes') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-file-invoice-dollar"></i></span>
        <span class="nav-text">Báo giá</span>
      </a>
      <% } %>
    </div>

    <% if (['admin','director','hr','head_hr'].includes(locals.userRole)) { %>
    <div class="nav-group">
      <span class="nav-group-label">HỆ THỐNG</span>
      <a href="/admin/users" class="nav-link <%= path.startsWith('/admin/users') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-users-cog"></i></span>
        <span class="nav-text">Người dùng</span>
      </a>
      <% if (locals.userRole === 'admin') { %>
      <a href="/admin/permissions" class="nav-link <%= path.startsWith('/admin/permissions') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-shield-alt"></i></span>
        <span class="nav-text">Phân quyền</span>
      </a>
      <% } %>
      <% if (['admin','director'].includes(locals.userRole)) { %>
      <a href="/admin/audit" class="nav-link <%= path.startsWith('/admin/audit') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-history"></i></span>
        <span class="nav-text">Nhật ký</span>
      </a>
      <% } %>
      <% if (['admin','director','hr','head_hr'].includes(locals.userRole)) { %>
      <a href="/payroll-settings" class="nav-link <%= path.startsWith('/payroll-settings') ? 'active' : '' %>">
        <span class="nav-icon"><i class="fas fa-sliders-h"></i></span>
        <span class="nav-text">Cấu hình Lương</span>
      </a>
      <% } %>
    </div>
    <% } %>
  </nav>

  <div class="sidebar-user-panel">
    <a href="/auth/profile" class="sidebar-avatar-link" title="Hồ sơ cá nhân">
      <div class="sidebar-avatar-ring">
        <% if (locals.currentUser && currentUser.avatar_url) { %>
          <img src="<%= currentUser.avatar_url %>" alt="<%= currentUser.full_name %>">
        <% } else { %>
          <span><%= locals.currentUser ? currentUser.full_name.charAt(0).toUpperCase() : 'U' %></span>
        <% } %>
      </div>
    </a>
    <div class="sidebar-user-info">
      <a href="/auth/profile" class="sidebar-user-name"><%= locals.currentUser ? currentUser.full_name : '' %></a>
      <span class="sidebar-user-title">
        <% if (locals.currentUser) { %>
          <%= roleLabels[currentUser.role] || currentUser.role %>
          <% if (currentUser.position) { %> · <%= currentUser.position %><% } %>
        <% } %>
      </span>
    </div>
    <div class="sidebar-user-actions">
      <a href="/auth/profile" class="sidebar-action-btn" title="Hồ sơ"><i class="fas fa-cog"></i></a>
      <a href="/auth/logout" class="sidebar-action-btn sidebar-logout-btn" title="Đăng xuất"><i class="fas fa-sign-out-alt"></i></a>
    </div>
  </div>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
