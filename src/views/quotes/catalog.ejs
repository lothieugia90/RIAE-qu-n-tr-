<style>
.cat-table td { vertical-align: middle; }
.cat-badge { display:inline-flex;align-items:center;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;background:var(--border);color:var(--text-3) }
</style>

<div class="page-header">
  <div class="page-header-title">
    <h2><i class="fas fa-boxes" style="color:var(--primary);margin-right:8px"></i>Danh mục Vật tư / Dịch vụ</h2>
    <p><%= items.length %> mục</p>
  </div>
  <div class="page-header-actions">
    <button onclick="document.getElementById('addModal').classList.add('open')" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm vật tư</button>
    <a href="/quotes" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
  </div>
</div>

<form method="GET" class="filter-bar" style="margin-bottom:16px">
  <input type="text" name="search" class="form-control" placeholder="Tìm tên, mã hàng..." value="<%= filters.search||'' %>" style="flex:1;max-width:280px">
  <select name="category" class="form-control" style="width:160px">
    <option value="">Tất cả danh mục</option>
    <option value="general" <%= filters.category==='general'?'selected':'' %>>Chung</option>
    <option value="elv" <%= filters.category==='elv'?'selected':'' %>>ELV</option>
    <option value="fa" <%= filters.category==='fa'?'selected':'' %>>FA / Tự động hóa</option>
    <option value="civil" <%= filters.category==='civil'?'selected':'' %>>Xây dựng</option>
    <option value="service" <%= filters.category==='service'?'selected':'' %>>Dịch vụ</option>
  </select>
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
  <a href="/quotes/catalog" class="btn btn-outline">Reset</a>
</form>

<% if (items.length === 0) { %>
<div class="card">
  <div class="empty-state" style="padding:48px">
    <div class="empty-state-icon"><i class="fas fa-boxes"></i></div>
    <h3>Chưa có vật tư nào</h3>
    <p>Thêm vật tư để dùng khi lập báo giá</p>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="table-wrap" style="border:none">
    <table class="cat-table">
      <thead>
        <tr>
          <th>Mã hàng</th>
          <th>Tên vật tư / Dịch vụ</th>
          <th>Danh mục</th>
          <th>ĐVT</th>
          <th style="text-align:right">Đơn giá</th>
          <th>Mô tả</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
      <% const catLabel = {general:'Chung',elv:'ELV',fa:'FA',civil:'Xây dựng',service:'Dịch vụ'}; %>
      <% items.forEach(item => { %>
      <tr>
        <td style="font-size:11px;color:var(--text-3);font-weight:600"><%= item.code || '—' %></td>
        <td style="font-weight:500;max-width:260px"><%= item.name %></td>
        <td><span class="cat-badge"><%= catLabel[item.category] || item.category %></span></td>
        <td style="font-size:13px"><%= item.unit %></td>
        <td style="text-align:right;font-weight:600;color:var(--primary)"><%= Number(item.unit_price||0).toLocaleString('vi-VN') %> đ</td>
        <td style="font-size:12px;color:var(--text-3);max-width:200px"><%= item.description || '—' %></td>
        <td>
          <button onclick="openEdit('<%= item.id %>')" class="btn btn-sm btn-outline"><i class="fas fa-edit"></i></button>
          <form action="/quotes/catalog/<%= item.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Ẩn vật tư này?')">
            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Add Modal -->
<div class="modal-overlay" id="addModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal" style="max-width:560px">
    <div class="modal-header">
      <span class="modal-title">Thêm Vật tư / Dịch vụ</span>
      <button class="modal-close" onclick="document.getElementById('addModal').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
    <form action="/quotes/catalog" method="POST">
      <div class="modal-body">
        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">Mã hàng</label>
            <input type="text" name="code" class="form-control" placeholder="VD: ELV-CAM-001">
          </div>
          <div class="form-group">
            <label class="form-label">Danh mục</label>
            <select name="category" class="form-control">
              <option value="general">Chung</option>
              <option value="elv">ELV</option>
              <option value="fa">FA / Tự động hóa</option>
              <option value="civil">Xây dựng</option>
              <option value="service">Dịch vụ</option>
            </select>
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Tên vật tư / Dịch vụ <span style="color:var(--danger)">*</span></label>
            <input type="text" name="name" class="form-control" required placeholder="VD: Camera IP 2MP Hikvision">
          </div>
          <div class="form-group">
            <label class="form-label">Đơn vị tính</label>
            <input type="text" name="unit" class="form-control" value="cái" placeholder="cái, bộ, m, m2...">
          </div>
          <div class="form-group">
            <label class="form-label">Đơn giá (đ)</label>
            <input type="number" name="unit_price" class="form-control" value="0" min="0" step="1000">
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Mô tả thêm</label>
            <input type="text" name="description" class="form-control" placeholder="Thông số kỹ thuật, xuất xứ...">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('addModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Thêm</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="editModal" onclick="if(event.target===this)this.classList.remove('open')">
  <div class="modal" style="max-width:560px">
    <div class="modal-header">
      <span class="modal-title">Sửa Vật tư</span>
      <button class="modal-close" onclick="document.getElementById('editModal').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
    <form id="editForm" action="" method="POST">
      <div class="modal-body">
        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">Mã hàng</label>
            <input type="text" name="code" id="e_code" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Danh mục</label>
            <select name="category" id="e_category" class="form-control">
              <option value="general">Chung</option>
              <option value="elv">ELV</option>
              <option value="fa">FA / Tự động hóa</option>
              <option value="civil">Xây dựng</option>
              <option value="service">Dịch vụ</option>
            </select>
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Tên vật tư *</label>
            <input type="text" name="name" id="e_name" class="form-control" required>
          </div>
          <div class="form-group">
            <label class="form-label">Đơn vị tính</label>
            <input type="text" name="unit" id="e_unit" class="form-control">
          </div>
          <div class="form-group">
            <label class="form-label">Đơn giá (đ)</label>
            <input type="number" name="unit_price" id="e_price" class="form-control" min="0">
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Mô tả</label>
            <input type="text" name="description" id="e_desc" class="form-control">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('editModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
      </div>
    </form>
  </div>
</div>

<script>
const allCatalogItems = <%- JSON.stringify(items) %>;
function openEdit(id) {
  var item = allCatalogItems.find(function(x){ return x.id === id; });
  if (!item) return;
  document.getElementById('editForm').action = '/quotes/catalog/' + id + '/edit';
  document.getElementById('e_code').value = item.code || '';
  document.getElementById('e_name').value = item.name || '';
  document.getElementById('e_unit').value = item.unit || '';
  document.getElementById('e_price').value = item.unit_price || 0;
  document.getElementById('e_category').value = item.category || 'general';
  document.getElementById('e_desc').value = item.description || '';
  document.getElementById('editModal').classList.add('open');
}
</script>
