<div class="page-header">
  <div class="page-header-title">
    <div style="font-size:12px;color:var(--text-3);margin-bottom:4px"><%= quote.code %></div>
    <h2><%= quote.title %></h2>
    <div style="display:flex;gap:8px;margin-top:4px">
      <span class="badge" style="background:<%= quote.status==='approved'?'var(--success-bg)':quote.status==='rejected'?'var(--danger-bg)':quote.status==='sent'?'var(--info-bg)':'var(--border)' %>;color:<%= quote.status==='approved'?'var(--success)':quote.status==='rejected'?'var(--danger)':quote.status==='sent'?'var(--info)':'var(--text-3)' %>">
        <%= quote.status==='draft'?'Nháp':quote.status==='sent'?'Đã gửi':quote.status==='approved'?'Đã duyệt':'Từ chối' %>
      </span>
    </div>
  </div>
  <div class="page-header-actions">
    <% if (['admin','director','pm'].includes(locals.userRole)) { %>
    <a href="/quotes/<%= quote.id %>/edit" class="btn btn-outline"><i class="fas fa-edit"></i> Sửa</a>
    <button onclick="document.getElementById('addItemModal').classList.add('open')" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm hạng mục</button>
    <% } %>
    <a href="/quotes" class="btn btn-outline"><i class="fas fa-arrow-left"></i></a>
  </div>
</div>

<div class="grid-70-30">
  <div>
    <!-- Items Table -->
    <div class="card mb-4">
      <div class="card-header">
        <span class="card-title">Chi tiết Báo giá</span>
        <span style="font-size:15px;font-weight:700;color:var(--primary)"><%= Number(quote.total_amount||0).toLocaleString('vi-VN') %> đ</span>
      </div>
      <div style="overflow-x:auto">
        <% if (items.length === 0) { %>
        <div class="empty-state" style="padding:32px"><p>Chưa có hạng mục nào</p></div>
        <% } else { %>
        <table>
          <thead><tr><th>STT</th><th>Mô tả / Hạng mục</th><th>ĐVT</th><th>SL</th><th>Đơn giá</th><th>CK%</th><th>Thành tiền</th><th></th></tr></thead>
          <tbody>
          <% let total = 0; %>
          <% items.forEach((item, idx) => { const amt = Number(item.amount||0); total += amt; %>
          <tr>
            <td style="font-size:12px;color:var(--text-3)"><%= idx+1 %></td>
            <td style="font-weight:500"><%= item.description %><% if (item.notes) { %><div style="font-size:11px;color:var(--text-3)"><%= item.notes %></div><% } %></td>
            <td style="font-size:12px"><%= item.unit||'—' %></td>
            <td style="font-size:13px"><%= item.quantity %></td>
            <td style="font-size:13px"><%= Number(item.unit_price||0).toLocaleString('vi-VN') %></td>
            <td style="font-size:12px"><%= item.discount_percent>0 ? item.discount_percent+'%' : '—' %></td>
            <td style="font-weight:600;color:var(--primary)"><%= amt.toLocaleString('vi-VN') %> đ</td>
            <td>
              <% if (['admin','director','pm'].includes(locals.userRole)) { %>
              <form action="/quotes/<%= quote.id %>/items/<%= item.id %>/delete" method="POST" style="display:inline">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa?')"><i class="fas fa-trash"></i></button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <tr style="background:#F8FAFC">
            <td colspan="6" style="text-align:right;font-weight:700;font-size:14px">TỔNG CỘNG:</td>
            <td style="font-weight:800;font-size:15px;color:var(--primary)"><%= Number(quote.total_amount||0).toLocaleString('vi-VN') %> đ</td>
            <td></td>
          </tr>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right -->
  <div>
    <div class="card mb-4">
      <div class="card-header"><span class="card-title">Thông tin báo giá</span></div>
      <div class="card-body">
        <div style="display:flex;flex-direction:column;gap:10px;font-size:13px">
          <div><span style="color:var(--text-3)">Khách hàng:</span><br><strong><%= quote.client_name||'—' %></strong></div>
          <div><span style="color:var(--text-3)">Liên hệ:</span><br><%= quote.client_contact||'—' %></div>
          <div><span style="color:var(--text-3)">Dự án:</span><br><%= quote.project_name||'—' %></div>
          <div><span style="color:var(--text-3)">Hiệu lực:</span><br><%= quote.valid_until ? new Date(quote.valid_until).toLocaleDateString('vi-VN') : '—' %></div>
          <div><span style="color:var(--text-3)">Người tạo:</span><br><%= quote.creator_name %></div>
          <div><span style="color:var(--text-3)">Ngày tạo:</span><br><%= new Date(quote.created_at).toLocaleDateString('vi-VN') %></div>
          <% if (quote.notes) { %><div class="divider"></div><div style="color:var(--text-3)"><%= quote.notes %></div><% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Item Modal -->
<div class="modal-overlay" id="addItemModal">
  <div class="modal" style="max-width:620px">
    <div class="modal-header">
      <span class="modal-title">Thêm hạng mục</span>
      <button class="modal-close" onclick="document.getElementById('addItemModal').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
    <form action="/quotes/<%= quote.id %>/items" method="POST">
      <div class="modal-body">
        <div class="form-group mb-3">
          <label class="form-label">Mô tả / Hạng mục <span class="req">*</span></label>
          <input type="text" name="description" class="form-control" required>
        </div>
        <div class="form-grid-2">
          <div class="form-group"><label class="form-label">ĐVT</label><input type="text" name="unit" class="form-control" placeholder="m, cái, bộ..."></div>
          <div class="form-group"><label class="form-label">Số lượng</label><input type="number" name="quantity" class="form-control" value="1" min="0" step="0.001"></div>
          <div class="form-group"><label class="form-label">Đơn giá (đ)</label><input type="number" name="unit_price" class="form-control" min="0"></div>
          <div class="form-group"><label class="form-label">Chiết khấu (%)</label><input type="number" name="discount_percent" class="form-control" value="0" min="0" max="100" step="0.1"></div>
        </div>
        <div class="form-group mt-3"><label class="form-label">Ghi chú</label><input type="text" name="notes" class="form-control"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('addItemModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary">Thêm</button>
      </div>
    </form>
  </div>
</div>
