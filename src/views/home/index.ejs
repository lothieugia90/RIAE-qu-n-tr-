        Xem tất cả <i class="fas fa-arrow-right"></i>
      </a>
    </div>
    <div class="projects-grid">
      <% if (projects && projects.length > 0) { %>
        <% projects.forEach(p => { %>
        <div class="project-card">
          <div class="project-thumb">
            <% if (p.thumbnail) { %>
              <img src="<%= p.thumbnail %>" alt="<%= p.title %>">
            <% } else { %>
              <span class="project-thumb-placeholder">🏗️</span>
            <% } %>
            <% if (p.tags && p.tags[0]) { %><span class="project-type"><%= p.tags[0] %></span><% } %>
          </div>
          <div class="project-body">
            <h3><%= p.title %></h3>
            <p><%= p.description ? p.description.slice(0,100) + '...' : '' %></p>
            <div class="project-meta">
              <% if (p.client) { %><span><i class="fas fa-building"></i> <%= p.client %></span><% } %>
              <% if (p.location) { %><span><i class="fas fa-map-marker-alt"></i> <%= p.location %></span><% } %>
            </div>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <!-- Default showcase projects -->
        <div class="project-card">
          <div class="project-thumb"><span class="project-thumb-placeholder">🏨</span><span class="project-type">Khách sạn 5★</span></div>
          <div class="project-body"><h3>Hệ thống tích hợp Resort Phú Quốc</h3><p>Thiết kế và thi công toàn bộ hệ thống ELV, PCCC, camera và mạng cho khu nghỉ dưỡng 300 phòng.</p><div class="project-meta"><span><i class="fas fa-map-marker-alt"></i> Phú Quốc</span></div></div>
        </div>
        <div class="project-card">
          <div class="project-thumb"><span class="project-thumb-placeholder">🏢</span><span class="project-type">Văn phòng</span></div>
          <div class="project-body"><h3>Trung tâm dữ liệu doanh nghiệp</h3><p>Xây dựng data center Tier II với hệ thống ảo hóa, lưu trữ và bảo mật toàn diện cho tập đoàn lớn.</p><div class="project-meta"><span><i class="fas fa-map-marker-alt"></i> TP.HCM</span></div></div>
        </div>
        <div class="project-card">
          <div class="project-thumb"><span class="project-thumb-placeholder">🏫</span><span class="project-type">Giáo dục</span></div>
          <div class="project-body"><h3>Hệ thống trường học thông minh</h3><p>Triển khai hệ thống camera, kiểm soát ra vào, PA và mạng wifi toàn khuôn viên trường.</p><div class="project-meta"><span><i class="fas fa-map-marker-alt"></i> Hà Nội</span></div></div>
