<%
const isOverdue = task.due_date && new Date(task.due_date) < new Date() && task.status !== 'done';
const priorityColor = { urgent:'#dc2626', high:'#d97706', medium:'#3b82f6', low:'#94a3b8' };
const statusLabel  = { todo:'Chưa làm', in_progress:'Đang làm', review:'Chờ duyệt', done:'Hoàn thành' };
const statusColor  = { todo:'#94a3b8', in_progress:'#3b82f6', review:'#d97706', done:'#16a34a' };
function fmtDate(d){ return d ? new Date(d).toLocaleDateString('vi-VN') : '—'; }
function fmtSize(bytes){
  if(!bytes) return '';
  if(bytes>1024*1024) return (bytes/1024/1024).toFixed(1)+'MB';
  return Math.round(bytes/1024)+'KB';
}
function fileIcon(name){
  const ext=(name||'').split('.').pop().toLowerCase();
  if(['jpg','jpeg','png','webp','gif'].includes(ext)) return 'fas fa-image';
  if(['pdf'].includes(ext)) return 'fas fa-file-pdf';
  if(['doc','docx'].includes(ext)) return 'fas fa-file-word';
  if(['xls','xlsx'].includes(ext)) return 'fas fa-file-excel';
  if(['zip','rar'].includes(ext)) return 'fas fa-file-archive';
  return 'fas fa-file';
}
%>

<style>
.te-layout { display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start; }
@media(max-width:900px){ .te-layout { grid-template-columns:1fr; } }

.te-card { background:var(--card);border:1px solid var(--border);border-radius:12px;margin-bottom:16px;overflow:hidden; }
.te-card-head { display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);background:var(--bg); }
.te-card-head h3 { font-size:13px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.04em;margin:0;display:flex;align-items:center;gap:7px; }
.te-card-body { padding:18px; }

.te-task-title { font-size:20px;font-weight:800;color:var(--text);line-height:1.3;margin-bottom:12px; }
.te-meta-row { display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px; }
.te-chip { display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;border-radius:8px;padding:4px 12px;border:1px solid transparent; }
.te-overdue-banner { background:#fef2f2;border:1px solid #fecaca;border-left:4px solid #dc2626;border-radius:8px;padding:10px 14px;margin-bottom:16px;color:#b91c1c;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px; }

.te-comment { display:flex;gap:10px;margin-bottom:14px; }
.te-comment-avatar { width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0; }
.te-comment-bubble { flex:1;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 12px; }
.te-comment-author { font-size:11px;font-weight:700;color:var(--text);margin-bottom:3px; }
.te-comment-time { font-size:10px;color:var(--text-3);margin-left:6px; }
.te-comment-text { font-size:13px;color:var(--text-2);line-height:1.5; }

.te-attach-item { display:flex;align-items:center;gap:10px;padding:9px 12px;border:1px solid var(--border);border-radius:8px;margin-bottom:8px;background:var(--bg); }
.te-attach-icon { font-size:20px;flex-shrink:0; }
.te-attach-info { flex:1;min-width:0; }
.te-attach-name { font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.te-attach-meta { font-size:11px;color:var(--text-3); }

.te-timelog-row { display:grid;grid-template-columns:40px 1fr 1fr;gap:4px;align-items:start;padding:8px 12px;border-bottom:1px solid var(--border);font-size:12px; }
.te-timelog-row:last-child { border-bottom:none; }
.te-timelog-hours { font-size:16px;font-weight:800;color:var(--primary);text-align:center;line-height:1; }
.te-timelog-h-label { font-size:10px;color:var(--text-3);text-align:center; }
</style>

<!-- Breadcrumb -->
<div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text-3);margin-bottom:16px;flex-wrap:wrap">
  <a href="/projects" style="color:var(--text-3);text-decoration:none"><i class="fas fa-folder-open"></i> Dự án</a>
  <i class="fas fa-chevron-right" style="font-size:10px"></i>
  <a href="/projects/<%= task.project_id %>" style="color:var(--text-3);text-decoration:none"><%= task.project_name %></a>
  <i class="fas fa-chevron-right" style="font-size:10px"></i>
  <a href="/projects/<%= task.project_id %>/kanban" style="color:var(--text-3);text-decoration:none">Kanban</a>
  <i class="fas fa-chevron-right" style="font-size:10px"></i>
  <span style="color:var(--text);font-weight:600">Chi tiết Task</span>
</div>

<div class="te-layout">
  <!-- LEFT: Main content -->
  <div>
    <!-- Task info card -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-tasks" style="color:var(--primary)"></i> Chi tiết Task</h3>
        <div style="display:flex;gap:6px">
          <a href="/projects/<%= task.project_id %>/kanban" class="btn btn-sm btn-outline"><i class="fas fa-columns"></i> Kanban</a>
        </div>
      </div>
      <div class="te-card-body">
        <% if (isOverdue) { %>
        <div class="te-overdue-banner">
          <i class="fas fa-exclamation-triangle"></i>
          Task này đã quá hạn từ <%= fmtDate(task.due_date) %>
        </div>
        <% } %>

        <div class="te-task-title"><%= task.title %></div>
        <div class="te-meta-row">
          <span class="te-chip" style="background:<%= statusColor[task.status] %>22;color:<%= statusColor[task.status] %>;border-color:<%= statusColor[task.status] %>44">
            <i class="fas fa-circle" style="font-size:7px"></i>
            <%= statusLabel[task.status] || task.status %>
          </span>
          <span class="te-chip" style="background:<%= priorityColor[task.priority] %>22;color:<%= priorityColor[task.priority] %>">
            <i class="fas fa-flag"></i> <%= ({urgent:'Khẩn cấp',high:'Cao',medium:'Trung bình',low:'Thấp'})[task.priority] || task.priority %>
          </span>
          <% if (task.due_date) { %>
          <span class="te-chip" style="background:<%= isOverdue ? '#fef2f2' : 'var(--bg)' %>;color:<%= isOverdue ? '#dc2626' : 'var(--text-2)' %>;border-color:<%= isOverdue ? '#fecaca' : 'var(--border)' %>">
            <i class="fas fa-calendar-alt"></i> <%= fmtDate(task.due_date) %>
          </span>
          <% } %>
          <% if (task.estimated_hours) { %>
          <span class="te-chip" style="background:var(--bg);color:var(--text-2);border-color:var(--border)">
            <i class="fas fa-clock"></i> Ước tính: <%= task.estimated_hours %>h
          </span>
          <% } %>
          <% if (task.actual_hours) { %>
          <span class="te-chip" style="background:#eff6ff;color:#1d4ed8;border-color:#bfdbfe">
            <i class="fas fa-stopwatch"></i> Thực tế: <%= parseFloat(task.actual_hours).toFixed(1) %>h
          </span>
          <% } %>
        </div>
        <% if (task.description) { %>
        <div style="font-size:14px;color:var(--text-2);line-height:1.7;padding:12px;background:var(--bg);border-radius:8px;border:1px solid var(--border);margin-bottom:16px">
          <%= task.description %>
        </div>
        <% } %>

        <!-- Edit form -->
        <form action="/tasks/<%= task.id %>/edit" method="POST" style="margin-top:8px">
          <div class="form-grid-2">
            <div class="form-group">
              <label class="form-label">Tiêu đề</label>
              <input type="text" name="title" class="form-control" value="<%= task.title %>" required>
            </div>
            <div class="form-group">
              <label class="form-label">Giao cho</label>
              <select name="assignee_id" class="form-control">
                <option value="">— Chưa phân công —</option>
                <% members.forEach(m => { %>
                <option value="<%= m.id %>" <%= task.assignee_id===m.id ? 'selected' : '' %>><%= m.full_name %><%= m.department ? ' — ' + m.department : '' %> (<%= m.role %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Trạng thái</label>
              <select name="status" class="form-control">
                <option value="todo" <%= task.status==='todo'?'selected':'' %>>Chưa làm</option>
                <option value="in_progress" <%= task.status==='in_progress'?'selected':'' %>>Đang làm</option>
                <option value="review" <%= task.status==='review'?'selected':'' %>>Chờ duyệt (Review)</option>
                <option value="done" <%= task.status==='done'?'selected':'' %>>Hoàn thành</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Độ ưu tiên</label>
              <select name="priority" class="form-control">
                <option value="low" <%= task.priority==='low'?'selected':'' %>>Thấp</option>
                <option value="medium" <%= task.priority==='medium'?'selected':'' %>>Trung bình</option>
                <option value="high" <%= task.priority==='high'?'selected':'' %>>Cao</option>
                <option value="urgent" <%= task.priority==='urgent'?'selected':'' %>>Khẩn cấp</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Hạn chót</label>
              <input type="date" name="due_date" class="form-control" value="<%= task.due_date ? new Date(task.due_date).toISOString().split('T')[0] : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label">Giờ ước tính</label>
              <input type="number" name="estimated_hours" class="form-control" value="<%= task.estimated_hours||'' %>" min="0" step="0.5">
            </div>
          </div>
          <div class="form-group" style="margin-top:8px">
            <label class="form-label">Mô tả</label>
            <textarea name="description" class="form-control" rows="3"><%= task.description||'' %></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Ghi chú</label>
            <textarea name="notes" class="form-control" rows="2"><%= task.notes||'' %></textarea>
          </div>
          <div style="margin-top:12px;display:flex;gap:8px">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu thay đổi</button>
            <a href="/projects/<%= task.project_id %>/kanban" class="btn btn-outline">Hủy</a>
          </div>
        </form>
      </div>
    </div>

    <!-- Checklist -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-check-square" style="color:#22c55e"></i> Checklist
          <% const checkTotal = (checklists||[]).length, checkDone = (checklists||[]).filter(c=>c.is_done).length; %>
          <% if (checkTotal > 0) { %>
          <span style="font-size:11px;font-weight:600;color:<%= checkDone===checkTotal?'#22c55e':'var(--text-3)' %>;margin-left:6px"><%= checkDone %>/<%= checkTotal %></span>
          <% } %>
        </h3>
      </div>
      <div class="te-card-body">
        <% if (checkTotal > 0) { %>
        <div style="height:4px;background:var(--border);border-radius:3px;overflow:hidden;margin-bottom:12px">
          <div style="height:100%;width:<%= Math.round(checkDone/checkTotal*100) %>%;background:#22c55e;border-radius:3px;transition:width .3s"></div>
        </div>
        <% } %>
        <div id="checklistItems" style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px">
          <% (checklists||[]).forEach(item => { %>
          <div class="cl-item" id="cl-<%= item.id %>" style="display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid var(--border);border-radius:8px;background:var(--bg)">
            <button onclick="toggleCheck('<%= item.id %>',this)" style="width:18px;height:18px;border-radius:4px;border:2px solid <%= item.is_done?'#22c55e':'var(--border)' %>;background:<%= item.is_done?'#22c55e':'transparent' %>;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s">
              <% if (item.is_done) { %><i class="fas fa-check" style="color:#fff;font-size:9px"></i><% } %>
            </button>
            <span style="flex:1;font-size:13px;color:var(--text);text-decoration:<%= item.is_done?'line-through':'none' %>;opacity:<%= item.is_done?'0.6':'1' %>"><%= item.title %></span>
            <button onclick="deleteCheck('<%= item.id %>')" style="background:none;border:none;cursor:pointer;color:var(--text-3);padding:2px 4px;border-radius:4px;font-size:11px;opacity:0.6" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.6"><i class="fas fa-times"></i></button>
          </div>
          <% }) %>
        </div>
        <div style="display:flex;gap:6px">
          <input type="text" id="newCheckItem" class="form-control form-control-sm" placeholder="Thêm mục checklist..." style="flex:1" onkeydown="if(event.key==='Enter'){event.preventDefault();addCheckItem()}">
          <button onclick="addCheckItem()" class="btn btn-sm btn-primary"><i class="fas fa-plus"></i></button>
        </div>
      </div>
    </div>

    <!-- Workflow stage move (only when project has workflow) -->
    <% if (workflowStages && workflowStages.length > 0) { %>
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-project-diagram" style="color:#8b5cf6"></i> Bước quy trình</h3>
        <% if (task.stage_name) { %>
        <span style="font-size:12px;padding:3px 10px;border-radius:8px;font-weight:600;background:<%= task.stage_color||'#6b7280' %>22;color:<%= task.stage_color||'#6b7280' %>"><%= task.stage_name %></span>
        <% } %>
      </div>
      <div class="te-card-body" style="display:flex;flex-direction:column;gap:6px">
        <% workflowStages.forEach(s => { %>
        <button data-sid="<%= s.id %>" data-sname="<%= s.name %>" onclick="moveToStage(this.dataset.sid,this.dataset.sname)"
          style="display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:8px;cursor:pointer;transition:all .15s;text-align:left;
                 border:1.5px solid <%= task.workflow_stage_id===s.id?s.color:'var(--border)' %>;
                 background:<%= task.workflow_stage_id===s.id ? (s.color||'#8b5cf6')+'22' : 'var(--bg)' %>">
          <span style="width:10px;height:10px;border-radius:50%;background:<%= s.color %>;flex-shrink:0"></span>
          <span style="font-size:13px;font-weight:<%= task.workflow_stage_id===s.id?'700':'500' %>;color:var(--text);flex:1"><%= s.name %></span>
          <% if (s.is_approval_gate) { %><span style="font-size:10px;color:#d97706"><i class="fas fa-lock"></i> Cần duyệt</span><% } %>
          <% if (task.workflow_stage_id===s.id) { %><i class="fas fa-check" style="color:<%= s.color %>;font-size:11px"></i><% } %>
        </button>
        <% }) %>
        <% if (!canApproveGate) { %>
        <p style="font-size:11px;color:var(--text-3);margin-top:4px"><i class="fas fa-info-circle"></i> Các bước có <i class="fas fa-lock"></i> cần PM hoặc quản lý phê duyệt.</p>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- File attachments -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-paperclip" style="color:#6366f1"></i> File đính kèm (<%= attachments.length %>)</h3>
      </div>
      <div class="te-card-body">
        <% if (attachments.length === 0) { %>
        <p style="color:var(--text-3);font-size:13px;text-align:center;padding:8px 0">Chưa có file đính kèm</p>
        <% } else { %>
        <% attachments.forEach(a => { %>
        <div class="te-attach-item">
          <i class="<%= fileIcon(a.original_name) %> te-attach-icon" style="color:#6366f1"></i>
          <div class="te-attach-info">
            <div class="te-attach-name"><a href="<%= a.file_url %>" target="_blank" style="color:var(--primary);text-decoration:none"><%= a.original_name %></a></div>
            <div class="te-attach-meta"><%= a.uploader_name %> · <%= fmtDate(a.created_at) %> · <%= fmtSize(a.file_size) %></div>
          </div>
          <form action="/tasks/<%= task.id %>/attach/<%= a.id %>/delete" method="POST" style="margin:0">
            <button type="submit" class="btn btn-sm btn-outline" style="color:#dc2626;border-color:#dc2626" onclick="return confirm('Xóa file này?')"><i class="fas fa-trash"></i></button>
          </form>
        </div>
        <% }) %>
        <% } %>
        <form action="/tasks/<%= task.id %>/attach" method="POST" enctype="multipart/form-data" style="margin-top:12px;display:flex;gap:8px;align-items:center">
          <input type="file" name="file" class="form-control" style="flex:1" required>
          <button type="submit" class="btn btn-primary btn-sm" style="white-space:nowrap"><i class="fas fa-upload"></i> Tải lên</button>
        </form>
      </div>
    </div>

    <!-- Comments -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-comments" style="color:#0891b2"></i> Bình luận (<%= comments.length %>)</h3>
      </div>
      <div class="te-card-body">
        <% if (comments.length === 0) { %>
        <p style="color:var(--text-3);font-size:13px;text-align:center;padding:4px 0 12px">Chưa có bình luận nào</p>
        <% } else { %>
        <div style="margin-bottom:16px">
        <% comments.forEach(c => { %>
        <div class="te-comment">
          <div class="te-comment-avatar">
            <% if (c.avatar_url) { %>
            <img src="<%= c.avatar_url %>" style="width:32px;height:32px;border-radius:50%;object-fit:cover">
            <% } else { %>
            <%= (c.full_name||'?').charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <div class="te-comment-bubble">
            <div class="te-comment-author">
              <%= c.full_name %>
              <span class="te-comment-time"><%= new Date(c.created_at).toLocaleString('vi-VN') %></span>
            </div>
            <div class="te-comment-text"><%= c.content %></div>
          </div>
        </div>
        <% }) %>
        </div>
        <% } %>
        <form action="/tasks/<%= task.id %>/comment" method="POST" style="display:flex;gap:8px">
          <textarea name="content" class="form-control" rows="2" placeholder="Thêm bình luận..." required style="flex:1;resize:none"></textarea>
          <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-end;white-space:nowrap"><i class="fas fa-paper-plane"></i></button>
        </form>
      </div>
    </div>
  </div>

  <!-- RIGHT: Sidebar -->
  <div>
    <!-- Quick status change -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-random" style="color:#8b5cf6"></i> Chuyển trạng thái</h3>
      </div>
      <div class="te-card-body" style="display:flex;flex-direction:column;gap:8px">
        <% const statuses = [{v:'todo',l:'Chưa làm',c:'#94a3b8'},{v:'in_progress',l:'Đang làm',c:'#3b82f6'},{v:'review',l:'Chờ Review',c:'#d97706'},{v:'done',l:'Hoàn thành',c:'#16a34a'}]; %>
        <% statuses.forEach(s => { %>
        <button onclick="updateStatus('<%= s.v %>')"
          class="btn btn-sm"
          style="justify-content:flex-start;gap:8px;text-align:left;
                 background:<%= task.status===s.v ? s.c+'22' : 'transparent' %>;
                 border-color:<%= task.status===s.v ? s.c : 'var(--border)' %>;
                 color:<%= task.status===s.v ? s.c : 'var(--text-2)' %>;
                 font-weight:<%= task.status===s.v ? '700' : '500' %>">
          <i class="fas fa-circle" style="font-size:7px"></i>
          <%= s.l %>
          <% if (task.status===s.v) { %><i class="fas fa-check" style="margin-left:auto"></i><% } %>
        </button>
        <% }) %>
        <p style="font-size:11px;color:var(--text-3);margin-top:4px;line-height:1.5">
          <i class="fas fa-info-circle"></i>
          Khi chuyển sang <strong>Chờ Review</strong>, PM sẽ nhận thông báo để kiểm tra.
        </p>
      </div>
    </div>

    <!-- Time logging -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-stopwatch" style="color:#0891b2"></i> Nhật ký giờ làm</h3>
        <% if (totalHours > 0) { %>
        <span style="font-size:12px;color:var(--primary);font-weight:700"><%= totalHours.toFixed(1) %>h tổng</span>
        <% } %>
      </div>
      <div class="te-card-body">
        <form action="/tasks/<%= task.id %>/log-time" method="POST" style="margin-bottom:12px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">
            <div>
              <label class="form-label" style="font-size:11px">Số giờ</label>
              <input type="number" name="hours_spent" class="form-control form-control-sm" min="0.25" max="24" step="0.25" placeholder="VD: 2.5" required>
            </div>
            <div>
              <label class="form-label" style="font-size:11px">Ngày</label>
              <input type="date" name="log_date" class="form-control form-control-sm" value="<%= new Date().toISOString().split('T')[0] %>">
            </div>
          </div>
          <div style="margin-bottom:8px">
            <input type="text" name="notes" class="form-control form-control-sm" placeholder="Ghi chú (không bắt buộc)">
          </div>
          <button type="submit" class="btn btn-primary btn-sm" style="width:100%"><i class="fas fa-plus"></i> Ghi nhận</button>
        </form>
        <% if (timeLogs.length > 0) { %>
        <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden">
        <% timeLogs.slice(0,5).forEach(tl => { %>
        <div class="te-timelog-row">
          <div>
            <div class="te-timelog-hours"><%= parseFloat(tl.hours_spent) %></div>
            <div class="te-timelog-h-label">giờ</div>
          </div>
          <div>
            <div style="font-size:12px;font-weight:600;color:var(--text)"><%= tl.full_name %></div>
            <div style="font-size:11px;color:var(--text-3)"><%= new Date(tl.log_date).toLocaleDateString('vi-VN') %></div>
          </div>
          <div style="font-size:11px;color:var(--text-3);line-height:1.4"><%= tl.notes||'' %></div>
        </div>
        <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Task info summary -->
    <div class="te-card">
      <div class="te-card-head">
        <h3><i class="fas fa-info-circle" style="color:var(--text-3)"></i> Thông tin</h3>
      </div>
      <div class="te-card-body" style="font-size:13px">
        <div style="display:grid;gap:10px">
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--text-3)">Dự án</span>
            <a href="/projects/<%= task.project_id %>" style="color:var(--primary);font-weight:600;text-decoration:none"><%= task.project_name %></a>
          </div>
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--text-3)">Ngày tạo</span>
            <span style="font-weight:500"><%= fmtDate(task.created_at) %></span>
          </div>
          <% if (task.completed_at) { %>
          <div style="display:flex;justify-content:space-between">
            <span style="color:var(--text-3)">Hoàn thành</span>
            <span style="font-weight:500;color:#16a34a"><%= fmtDate(task.completed_at) %></span>
          </div>
          <% } %>
          <% if (task.estimated_hours && task.actual_hours) { %>
          <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:4px">
              <span style="color:var(--text-3)">Tiến độ giờ</span>
              <span><%= parseFloat(task.actual_hours).toFixed(1) %>/<%= task.estimated_hours %>h</span>
            </div>
            <div style="height:5px;background:var(--border);border-radius:3px;overflow:hidden">
              <div style="height:100%;width:<%= Math.min(100, Math.round(task.actual_hours/task.estimated_hours*100)) %>%;background:var(--primary);border-radius:3px"></div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function updateStatus(status) {
  fetch('/tasks/<%= task.id %>/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  })
  .then(r => r.json())
  .then(d => { if (d.success) location.reload(); else alert('Lỗi: ' + d.error); })
  .catch(() => alert('Không thể cập nhật'));
}

/* ===== CHECKLIST ===== */
async function addCheckItem() {
  const input = document.getElementById('newCheckItem');
  const title = input.value.trim();
  if (!title) return;
  try {
    const r = await fetch('/tasks/<%= task.id %>/checklist', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ title })
    });
    const d = await r.json();
    if (!d.success) throw new Error(d.error);
    input.value = '';
    const item = d.item;
    const container = document.getElementById('checklistItems');
    const div = document.createElement('div');
    div.className = 'cl-item';
    div.id = 'cl-' + item.id;
    div.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px 10px;border:1px solid var(--border);border-radius:8px;background:var(--bg)';
    div.innerHTML =
      '<button onclick="toggleCheck(\'' + item.id + '\',this)" style="width:18px;height:18px;border-radius:4px;border:2px solid var(--border);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s"></button>' +
      '<span style="flex:1;font-size:13px;color:var(--text)">' + item.title + '</span>' +
      '<button onclick="deleteCheck(\'' + item.id + '\')" style="background:none;border:none;cursor:pointer;color:var(--text-3);padding:2px 4px;border-radius:4px;font-size:11px;opacity:0.6"><i class="fas fa-times"></i></button>';
    container.appendChild(div);
  } catch(err) { alert('Lỗi: ' + err.message); }
}

async function toggleCheck(id, btn) {
  try {
    const r = await fetch('/tasks/<%= task.id %>/checklist/' + id + '/toggle', {method:'POST'});
    const d = await r.json();
    if (!d.success) throw new Error(d.error);
    const isDone = d.item.is_done;
    btn.style.borderColor = isDone ? '#22c55e' : 'var(--border)';
    btn.style.background  = isDone ? '#22c55e' : 'transparent';
    btn.innerHTML = isDone ? '<i class="fas fa-check" style="color:#fff;font-size:9px"></i>' : '';
    const label = btn.nextElementSibling;
    if (label) { label.style.textDecoration = isDone ? 'line-through' : 'none'; label.style.opacity = isDone ? '0.6' : '1'; }
  } catch(err) { console.error(err); }
}

async function deleteCheck(id) {
  if (!confirm('Xóa mục này?')) return;
  try {
    const r = await fetch('/tasks/<%= task.id %>/checklist/' + id + '/delete', {method:'POST'});
    const d = await r.json();
    if (d.success) { document.getElementById('cl-' + id)?.remove(); }
  } catch(err) { console.error(err); }
}

/* ===== WORKFLOW STAGE ===== */
async function moveToStage(stageId, stageName) {
  if (!confirm('Chuyển task sang bước "' + stageName + '"?')) return;
  try {
    const r = await fetch('/tasks/<%= task.id %>/move-stage', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ stage_id: stageId })
    });
    const d = await r.json();
    if (d.success) { location.reload(); }
    else { alert(d.error || 'Không thể chuyển bước'); }
  } catch(err) { alert('Lỗi kết nối'); }
}

// Keyboard shortcut: Ctrl+Enter to submit comment form
document.addEventListener('keydown', e => {
  if (e.ctrlKey && e.key === 'Enter') {
    const ta = document.activeElement;
    if (ta && ta.tagName === 'TEXTAREA' && ta.name === 'content') {
      ta.closest('form')?.submit();
    }
  }
});
</script>
