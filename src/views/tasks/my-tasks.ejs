<div class="page-header">
  <div class="page-header-title">
    <h1>Việc của tôi</h1>
    <p><%= stats.pending %> việc đang chờ · <%= stats.done %> đã hoàn thành</p>
  </div>
  <button type="button" class="btn btn-primary" onclick="document.getElementById('personalTaskModal').showModal()">
    <i class="fas fa-plus"></i> Thêm công việc
  </button>
</div>

<!-- Modal thêm việc cá nhân -->
<dialog id="personalTaskModal" class="modal" style="max-width:480px">
  <button type="button" class="modal-x" onclick="this.closest('dialog').close()" aria-label="Đóng">&times;</button>
  <form action="/tasks/personal" method="POST" class="modal-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h3>Thêm công việc cá nhân</h3>
    <div class="form-group">
      <label>Tên công việc *</label>
      <input type="text" name="title" class="form-control" required maxlength="300" placeholder="vd: Soạn báo cáo tuần" autofocus>
    </div>
    <div class="form-group">
      <label>Mô tả</label>
      <textarea name="description" class="form-control" rows="3" placeholder="Chi tiết (không bắt buộc)"></textarea>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
      <div class="form-group">
        <label>Ưu tiên</label>
        <select name="priority" class="form-control">
          <option value="low">Thấp</option>
          <option value="medium" selected>Trung bình</option>
          <option value="high">Cao</option>
          <option value="urgent">Khẩn cấp</option>
        </select>
      </div>
      <div class="form-group">
        <label>Hạn hoàn thành</label>
        <input type="date" name="due_date" class="form-control">
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="this.closest('dialog').close()">Hủy</button>
      <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm việc</button>
    </div>
  </form>
</dialog>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--danger-bg);color:var(--danger)"><i class="fas fa-exclamation-triangle"></i></div>
    <div class="stat-value"><%= stats.overdue %></div>
    <div class="stat-label">Quá hạn</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--warning-bg);color:var(--warning)"><i class="fas fa-calendar-day"></i></div>
    <div class="stat-value"><%= stats.today %></div>
    <div class="stat-label">Hạn hôm nay</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--primary-50);color:var(--primary)"><i class="fas fa-list-check"></i></div>
    <div class="stat-value"><%= stats.pending %></div>
    <div class="stat-label">Đang chờ</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--success-bg);color:var(--success)"><i class="fas fa-check-circle"></i></div>
    <div class="stat-value"><%= stats.done %></div>
    <div class="stat-label">Hoàn thành</div>
  </div>
</div>

<%
function taskRow(t, showDone) { %>
  <a href="/tasks/<%= t.id %>" class="mt-row">
    <span class="badge badge-<%= t.priority %>"><%= PRIORITY_LABELS[t.priority] %></span>
    <span class="mt-title"><%= t.title %></span>
    <span class="mt-project"><i class="fas fa-folder"></i> <%= t.project_name %></span>
    <% if (showDone) { %>
      <span class="mt-due" style="color:var(--success)"><i class="fas fa-check"></i> <%= fmtDate(t.completed_at) %></span>
    <% } else if (t.due_date) { %>
      <span class="mt-due <%= new Date(t.due_date) < new Date(new Date().toDateString()) ? 'overdue' : '' %>">
        <i class="fas fa-calendar"></i> <%= fmtDate(t.due_date) %>
      </span>
    <% } else { %><span class="mt-due">—</span><% } %>
    <span class="badge badge-<%= t.status %>"><%= STATUS_LABELS[t.status] %></span>
  </a>
<% } %>

<% if (overdueTasks.length > 0) { %>
<div class="card mt-section" style="border-left:3px solid var(--danger)">
  <div class="card-header"><h3 style="color:var(--danger)"><i class="fas fa-exclamation-triangle"></i> Quá hạn (<%= overdueTasks.length %>)</h3></div>
  <div class="card-body mt-list"><% overdueTasks.forEach(t => taskRow(t)) %></div>
</div>
<% } %>

<% if (todayTasks.length > 0) { %>
<div class="card mt-section" style="border-left:3px solid var(--warning)">
  <div class="card-header"><h3 style="color:var(--warning)"><i class="fas fa-calendar-day"></i> Hôm nay (<%= todayTasks.length %>)</h3></div>
  <div class="card-body mt-list"><% todayTasks.forEach(t => taskRow(t)) %></div>
</div>
<% } %>

<div class="card mt-section">
  <div class="card-header"><h3><i class="fas fa-list"></i> Sắp tới (<%= upcomingTasks.length %>)</h3></div>
  <div class="card-body mt-list">
    <% if (upcomingTasks.length === 0) { %>
    <p style="text-align:center;padding:24px;color:var(--text-3)">Không có việc nào sắp tới 🎉</p>
    <% } else { upcomingTasks.forEach(t => taskRow(t)) } %>
  </div>
</div>

<% if (doneTasks.length > 0) { %>
<div class="card mt-section">
  <div class="card-header"><h3><i class="fas fa-check-circle"></i> Hoàn thành gần đây</h3></div>
  <div class="card-body mt-list"><% doneTasks.forEach(t => taskRow(t, true)) %></div>
</div>
<% } %>

<style>
.mt-section { margin-top: 20px; }
.mt-list { padding: 6px 0 !important; }
.mt-row {
  display: grid; grid-template-columns: 90px 1fr 180px 110px 100px;
  align-items: center; gap: 12px; padding: 11px 20px; text-decoration: none;
  transition: background .15s;
}
.mt-row:hover { background: var(--bg); }
.mt-row + .mt-row { border-top: 1px solid var(--border-light); }
.mt-title { font-size: 13.5px; font-weight: 500; color: var(--text); }
.mt-project { font-size: 12px; color: var(--text-3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.mt-due { font-size: 12px; color: var(--text-2); white-space: nowrap; }
.mt-due.overdue { color: var(--danger); font-weight: 600; }
@media (max-width: 800px) {
  .mt-row { grid-template-columns: 80px 1fr 90px; }
  .mt-project, .mt-due { display: none; }
}
</style>
