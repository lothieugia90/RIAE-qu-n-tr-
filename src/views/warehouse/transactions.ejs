<div class="page-header">
  <div class="page-header-title">
    <h2>Lịch sử Xuất/Nhập kho</h2>
    <p><%= transactions.length %> giao dịch</p>
  </div>
  <div class="page-header-actions">
    <a href="/warehouse" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Kho</a>
  </div>
</div>

<form method="GET" class="filter-bar">
  <select name="type" class="form-control">
    <option value="">Tất cả loại</option>
    <option value="import" <%= filters.type==='import'?'selected':'' %>>Nhập kho</option>
    <option value="export" <%= filters.type==='export'?'selected':'' %>>Xuất kho</option>
    <option value="adjust" <%= filters.type==='adjust'?'selected':'' %>>Điều chỉnh</option>
  </select>
  <input type="date" name="from_date" class="form-control" value="<%= filters.from_date || '' %>" title="Từ ngày">
  <input type="date" name="to_date" class="form-control" value="<%= filters.to_date || '' %>" title="Đến ngày">
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
  <a href="/warehouse/transactions" class="btn btn-outline">Reset</a>
</form>

<div class="card">
  <div class="table-wrap" style="border:none;border-radius:var(--radius)">
    <% if (transactions.length === 0) { %>
    <div class="empty-state" style="padding:48px">
      <div class="empty-state-icon"><i class="fas fa-exchange-alt"></i></div>
      <h3>Không có giao dịch nào</h3>
    </div>
    <% } else { %>
    <table>
      <thead><tr><th>Loại</th><th>Vật tư</th><th>Số lượng</th><th>Đơn giá</th><th>Dự án</th><th>Người thực hiện</th><th>Ngày</th></tr></thead>
      <tbody>
      <% transactions.forEach(tx => { %>
      <tr>
        <td>
          <span class="badge" style="background:<%= tx.transaction_type==='import' ? 'var(--success-bg)' : tx.transaction_type==='export' ? 'var(--danger-bg)' : 'var(--info-bg)' %>;color:<%= tx.transaction_type==='import' ? 'var(--success)' : tx.transaction_type==='export' ? 'var(--danger)' : 'var(--info)' %>">
            <%= tx.transaction_type==='import' ? '↑ Nhập' : tx.transaction_type==='export' ? '↓ Xuất' : '↔ Điều chỉnh' %>
          </span>
        </td>
        <td>
          <a href="/warehouse/items/<%= tx.item_id %>" style="font-weight:500"><%= tx.item_name %></a>
          <div style="font-size:11px;color:var(--text-3)"><%= tx.item_code %></div>
        </td>
        <td style="font-weight:600"><%= tx.quantity %> <%= tx.unit %></td>
        <td style="font-size:12px"><%= tx.unit_price ? Number(tx.unit_price).toLocaleString('vi-VN') + ' đ' : '—' %></td>
        <td style="font-size:12px"><%= tx.project_name || '—' %></td>
        <td style="font-size:12px"><%= tx.performer_name || '—' %></td>
        <td style="font-size:12px;color:var(--text-3);white-space:nowrap"><%= new Date(tx.transaction_date).toLocaleDateString('vi-VN') %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>
