<style>
.status-chip { display:inline-flex; align-items:center; gap:5px; padding:5px 14px; border-radius:14px; font-size:13px; font-weight:500; }
.chip-active { background:#E3F2FD; color:#1565C0; }
.chip-returned { background:#F5F5F5; color:#757575; }
.chip-signed { background:#E8F5E9; color:#2E7D32; }
.info-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--border); font-size:13px; }
.info-row:last-child { border-bottom:none; }
.sig-panel { border:1px solid var(--border); border-radius:10px; overflow:hidden; }
.sig-panel-header { padding:10px 16px; background:var(--bg); border-bottom:1px solid var(--border); font-size:13px; font-weight:600; display:flex; align-items:center; justify-content:space-between; }
.sig-panel-body { padding:14px; min-height:90px; display:flex; align-items:center; background:#fafafa; }
.return-banner { background:linear-gradient(135deg,#fff3e0,#fff8f0); border:2px solid #FFB74D; border-radius:12px; padding:18px 20px; margin-bottom:20px; display:flex; align-items:center; gap:16px; }
</style>

<div class="page-header">
  <div class="page-header-title">
    <h2>Chi tiết Phiếu giao</h2>
    <p><%= assignment.item_name %> · <%= assignment.item_code %></p>
  </div>
  <div class="page-header-actions">
    <a href="/warehouse/assignments" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Danh sách</a>
    <a href="/warehouse/items/<%= assignment.item_id %>" class="btn btn-outline"><i class="fas fa-boxes"></i> Xem vật tư</a>
  </div>
</div>

<%/* ── Banner trả về kho: hiển thị nổi bật cho người nhận khi vật tư đang active */%>
<% if (assignment.status === 'active') { %>
<div class="return-banner">
  <div style="width:44px;height:44px;border-radius:50%;background:#FF8F00;display:flex;align-items:center;justify-content:center;flex-shrink:0">
    <i class="fas fa-undo" style="color:#fff;font-size:18px"></i>
  </div>
  <div style="flex:1">
    <div style="font-weight:700;font-size:15px;color:#E65100">Cần trả vật tư? Ấn nút bên phải →</div>
    <div style="font-size:12px;color:#BF360C;margin-top:2px">Sau khi sử dụng xong, mang vật tư đến quầy kho và yêu cầu nhân viên kho ký xác nhận thu hồi.</div>
  </div>
  <a href="/signatures/warehouse-return/<%= assignment.id %>" class="btn btn-primary" style="background:#E65100;border-color:#E65100;white-space:nowrap;flex-shrink:0">
    <i class="fas fa-undo"></i> Trả về kho
  </a>
</div>
<% } %>

<div class="grid-70-30">
  <div>
    <!-- Assignment Info -->
    <div class="card mb-4">
      <div class="card-header">
        <span class="card-title">Thông tin phiếu giao</span>
        <% if (assignment.status === 'returned') { %>
        <span class="status-chip chip-returned"><i class="fas fa-check" style="font-size:9px"></i> Đã trả</span>
        <% } else if (assignment.recipient_signed_at) { %>
        <span class="status-chip chip-signed"><i class="fas fa-check-circle" style="font-size:9px"></i> Đã ký nhận</span>
        <% } else { %>
        <span class="status-chip chip-active"><i class="fas fa-circle" style="font-size:7px"></i> Đang giao</span>
        <% } %>
      </div>
      <div class="card-body">
        <div class="info-row"><span style="color:var(--text-3)">Vật tư</span><strong><a href="/warehouse/items/<%= assignment.item_id %>"><%= assignment.item_name %></a></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Mã vật tư</span><span><%= assignment.item_code %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Loại giao</span><span><%= assignment.assignment_type==='personal' ? 'Gán cá nhân' : 'Xuất dự án' %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Người nhận</span><strong><%= assignment.assignee_name || '—' %></strong></div>
        <% if (assignment.project_name) { %>
        <div class="info-row"><span style="color:var(--text-3)">Dự án</span><span><%= assignment.project_name %></span></div>
        <% } %>
        <div class="info-row"><span style="color:var(--text-3)">Số lượng</span><strong><%= assignment.quantity %> <%= assignment.unit %></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Người giao</span><span><%= assignment.assigner_name || '—' %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Ngày giao</span><span><%= assignment.assigned_at ? new Date(assignment.assigned_at).toLocaleString('vi-VN') : '—' %></span></div>
        <% if (assignment.status === 'returned') { %>
        <div class="info-row"><span style="color:var(--text-3)">Ngày trả</span><span><%= assignment.returned_at ? new Date(assignment.returned_at).toLocaleString('vi-VN') : '—' %></span></div>
        <% } %>
        <% if (assignment.notes) { %>
        <div class="info-row"><span style="color:var(--text-3)">Ghi chú</span><span><%= assignment.notes %></span></div>
        <% } %>
      </div>
    </div>

    <%/* ── 2 chữ ký: người nhận + kho thu hồi */%>
    <div class="card mb-4">
      <div class="card-header">
        <span class="card-title"><i class="fas fa-file-signature"></i> Chữ ký phiếu giao</span>
      </div>
      <div class="card-body" style="padding:0">

        <%/* Chữ ký 1: Người nhận */%>
        <div style="padding:14px 16px;border-bottom:1px solid var(--border)">
          <div style="font-size:12px;font-weight:700;color:var(--text-3);margin-bottom:10px;letter-spacing:.4px">① NGƯỜI NHẬN KÝ XÁC NHẬN</div>
          <% if (recipientSig) { %>
          <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap">
            <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden;background:#f8f9ff;width:200px;height:70px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <img src="<%= recipientSig.signature_data %>" style="max-width:100%;max-height:100%;object-fit:contain">
            </div>
            <div style="font-size:12px">
              <div style="font-weight:600;margin-bottom:3px"><i class="fas fa-check-circle" style="color:#22c55e"></i> <%= recipientSig.full_name %></div>
              <div style="color:var(--text-3)"><%= new Date(recipientSig.signed_at).toLocaleString('vi-VN') %></div>
              <% if (recipientSig.ip_address) { %><div style="color:var(--text-3)">IP: <%= recipientSig.ip_address %></div><% } %>
              <% if (assignment.recipient_signature_hash) { %>
              <a href="/signatures/verify?hash=<%= assignment.recipient_signature_hash %>" class="btn btn-sm btn-outline" style="margin-top:6px;font-size:11px"><i class="fas fa-search"></i> Xác minh</a>
              <% } %>
            </div>
          </div>
          <% } else if (assignment.status === 'active') { %>
          <div style="display:flex;align-items:center;gap:12px">
            <span style="color:var(--text-3);font-size:13px"><i class="fas fa-clock"></i> Chưa ký nhận</span>
            <a href="/signatures/warehouse/<%= assignment.id %>" class="btn btn-sm btn-primary"><i class="fas fa-signature"></i> Ký nhận ngay</a>
          </div>
          <% } else { %>
          <span style="color:var(--text-3);font-size:13px"><i class="fas fa-minus"></i> Không có chữ ký</span>
          <% } %>
        </div>

        <%/* Chữ ký 2: Kho thu hồi */%>
        <div style="padding:14px 16px">
          <div style="font-size:12px;font-weight:700;color:var(--text-3);margin-bottom:10px;letter-spacing:.4px">② KHO KÝ XÁC NHẬN THU HỒI</div>
          <% if (returnSig) { %>
          <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap">
            <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden;background:#f0fdf4;width:200px;height:70px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <img src="<%= returnSig.signature_data %>" style="max-width:100%;max-height:100%;object-fit:contain">
            </div>
            <div style="font-size:12px">
              <div style="font-weight:600;margin-bottom:3px"><i class="fas fa-check-circle" style="color:#22c55e"></i> <%= returnSig.full_name %></div>
              <div style="color:var(--text-3)"><%= new Date(returnSig.signed_at).toLocaleString('vi-VN') %></div>
              <% if (returnSig.ip_address) { %><div style="color:var(--text-3)">IP: <%= returnSig.ip_address %></div><% } %>
              <% if (assignment.return_signature_hash) { %>
              <a href="/signatures/verify?hash=<%= assignment.return_signature_hash %>" class="btn btn-sm btn-outline" style="margin-top:6px;font-size:11px"><i class="fas fa-search"></i> Xác minh</a>
              <% } %>
            </div>
          </div>
          <% } else if (assignment.status === 'active') { %>
          <div style="display:flex;align-items:center;gap:12px">
            <span style="color:var(--text-3);font-size:13px"><i class="fas fa-clock"></i> Chưa thu hồi</span>
            <% if (['admin','director','warehouse','warehouse_keeper'].includes(locals.userRole)) { %>
            <a href="/signatures/warehouse-return/<%= assignment.id %>" class="btn btn-sm btn-outline" style="color:var(--warning);border-color:var(--warning)"><i class="fas fa-undo"></i> Ký thu hồi</a>
            <% } %>
          </div>
          <% } else { %>
          <span style="color:var(--text-3);font-size:13px"><i class="fas fa-minus"></i> Không có chữ ký</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Right sidebar -->
  <div>
    <div class="card mb-4">
      <div class="card-body">
        <div style="text-align:center;padding:16px 0">
          <div style="font-size:36px;font-weight:800;color:var(--primary)"><%= assignment.quantity %></div>
          <div style="font-size:14px;color:var(--text-3)"><%= assignment.unit || '' %></div>
        </div>
        <div class="divider"></div>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:13px">
          <div>
            <div style="color:var(--text-3);font-size:11px">Loại vật tư</div>
            <% const typeLabel = assignment.item_type==='tool' ? '🔧 Dụng cụ' : assignment.item_type==='asset' ? '🏗️ Tài sản' : '📦 Vật tư'; %>
            <strong><%= typeLabel %></strong>
          </div>
          <% if (assignment.assigned_at) { %>
          <div>
            <div style="color:var(--text-3);font-size:11px">Ngày giao</div>
            <strong><%= new Date(assignment.assigned_at).toLocaleDateString('vi-VN') %></strong>
          </div>
          <% const daysHeld = Math.floor((Date.now() - new Date(assignment.assigned_at).getTime()) / 86400000); %>
          <div>
            <div style="color:var(--text-3);font-size:11px">Số ngày sử dụng</div>
            <strong style="color:<%= assignment.status==='active' && daysHeld>30 ? 'var(--danger)' : 'var(--text)' %>">
              <%= daysHeld %> ngày
              <% if (assignment.status==='active' && daysHeld>30) { %><br><span style="font-size:10px;color:var(--danger)">⚠ Quá hạn 30 ngày</span><% } %>
            </strong>
          </div>
          <% } %>
        </div>
        <% if (assignment.status === 'active') { %>
        <div class="divider"></div>
        <a href="/signatures/warehouse-return/<%= assignment.id %>" class="btn btn-outline" style="width:100%;color:#E65100;border-color:#E65100;justify-content:center">
          <i class="fas fa-undo"></i> Trả về kho
        </a>
        <% } %>
      </div>
    </div>

    <!-- Progress quy trình -->
    <div class="card">
      <div class="card-body">
        <div style="font-size:11px;font-weight:700;color:var(--text-3);margin-bottom:12px;letter-spacing:.5px">QUY TRÌNH</div>
        <div style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:#E8F5E9;color:#2E7D32">
              <i class="fas fa-check" style="font-size:11px"></i>
            </div>
            <div style="font-size:12px">
              <div style="font-weight:600">Kho xuất vật tư</div>
              <div style="color:var(--text-3)"><%= assignment.assigned_at ? new Date(assignment.assigned_at).toLocaleDateString('vi-VN') : '—' %></div>
            </div>
          </div>
          <div style="width:1px;height:12px;background:var(--border);margin-left:13px"></div>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;
                 background:<%= recipientSig ? '#E8F5E9' : '#F5F5F5' %>;color:<%= recipientSig ? '#2E7D32' : 'var(--text-3)' %>">
              <i class="fas fa-<%= recipientSig ? 'check' : 'user' %>" style="font-size:11px"></i>
            </div>
            <div style="font-size:12px">
              <div style="font-weight:600">Người nhận ký</div>
              <div style="color:var(--text-3)"><%= recipientSig ? new Date(recipientSig.signed_at).toLocaleDateString('vi-VN') : 'Chưa ký' %></div>
            </div>
          </div>
          <div style="width:1px;height:12px;background:var(--border);margin-left:13px"></div>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;
                 background:<%= returnSig ? '#E8F5E9' : '#F5F5F5' %>;color:<%= returnSig ? '#2E7D32' : 'var(--text-3)' %>">
              <i class="fas fa-<%= returnSig ? 'check' : 'warehouse' %>" style="font-size:11px"></i>
            </div>
            <div style="font-size:12px">
              <div style="font-weight:600">Kho ký thu hồi</div>
              <div style="color:var(--text-3)"><%= returnSig ? new Date(returnSig.signed_at).toLocaleDateString('vi-VN') : 'Chưa thu hồi' %></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
