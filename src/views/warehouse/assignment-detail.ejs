<style>
.status-chip { display:inline-flex; align-items:center; gap:5px; padding:5px 14px; border-radius:14px; font-size:13px; font-weight:500; }
.chip-active { background:#E3F2FD; color:#1565C0; }
.chip-returned { background:#F5F5F5; color:#757575; }
.info-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--border); font-size:13px; }
.info-row:last-child { border-bottom:none; }
.sig-widget { border:1px solid var(--border); border-radius:10px; padding:16px; }
</style>

<div class="page-header">
  <div class="page-header-title">
    <h2>Chi tiết Phiếu giao</h2>
    <p><%= assignment.item_name %> · <%= assignment.item_code %></p>
  </div>
  <div class="page-header-actions">
    <a href="/warehouse/assignments" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Danh sách</a>
    <a href="/warehouse/items/<%= assignment.item_id %>" class="btn btn-outline"><i class="fas fa-boxes"></i> Xem vật tư</a>
  </div>
</div>

<div class="grid-70-30">
  <div>
    <!-- Assignment Info -->
    <div class="card mb-4">
      <div class="card-header">
        <span class="card-title">Thông tin phiếu giao</span>
        <% if (assignment.status === 'active') { %>
        <span class="status-chip chip-active"><i class="fas fa-circle" style="font-size:7px"></i> Đang giao</span>
        <% } else { %>
        <span class="status-chip chip-returned"><i class="fas fa-check" style="font-size:9px"></i> Đã trả</span>
        <% } %>
      </div>
      <div class="card-body">
        <div class="info-row"><span style="color:var(--text-3)">Vật tư</span><strong><a href="/warehouse/items/<%= assignment.item_id %>"><%= assignment.item_name %></a></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Mã vật tư</span><span><%= assignment.item_code %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Loại giao</span><span><%= assignment.assignment_type==='personal' ? 'Gán cá nhân' : 'Xuất dự án' %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Người nhận</span><strong><%= assignment.assignee_name || '—' %></strong></div>
        <% if (assignment.project_name) { %>
        <div class="info-row"><span style="color:var(--text-3)">Dự án</span><span><%= assignment.project_name %></span></div>
        <% } %>
        <div class="info-row"><span style="color:var(--text-3)">Số lượng</span><strong><%= assignment.quantity %> <%= assignment.unit %></strong></div>
        <div class="info-row"><span style="color:var(--text-3)">Người giao</span><span><%= assignment.assigner_name || '—' %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Ngày giao</span><span><%= assignment.assigned_at ? new Date(assignment.assigned_at).toLocaleString('vi-VN') : '—' %></span></div>
        <% if (assignment.status === 'returned') { %>
        <div class="info-row"><span style="color:var(--text-3)">Người thu hồi</span><span><%= assignment.returner_name || '—' %></span></div>
        <div class="info-row"><span style="color:var(--text-3)">Ngày trả</span><span><%= assignment.returned_at ? new Date(assignment.returned_at).toLocaleString('vi-VN') : '—' %></span></div>
        <% } %>
        <% if (assignment.notes) { %>
        <div class="info-row"><span style="color:var(--text-3)">Ghi chú</span><span><%= assignment.notes %></span></div>
        <% } %>
      </div>
    </div>

    <!-- Signature Section -->
    <div class="card mb-4">
      <div class="card-header"><span class="card-title"><i class="fas fa-signature"></i> Chữ ký xác nhận</span></div>
      <div class="card-body">
        <% if (assignment.signature_data) { %>
        <div style="margin-bottom:12px">
          <img src="<%= assignment.signature_data %>" style="max-width:300px;border:1px solid var(--border);border-radius:6px;display:block">
        </div>
        <div style="font-size:12px;color:var(--text-3)">
          <i class="fas fa-check-circle" style="color:var(--success)"></i>
          Đã ký lúc: <%= assignment.signed_at ? new Date(assignment.signed_at).toLocaleString('vi-VN') : '—' %>
          <% if (assignment.signed_ip) { %> · IP: <%= assignment.signed_ip %><% } %>
        </div>
        <% } else if (assignment.status === 'active') { %>
        <div class="sig-widget">
          <div style="font-size:13px;color:var(--text-3);margin-bottom:10px">
            <i class="fas fa-info-circle"></i> Người nhận ký xác nhận đã nhận hàng
          </div>
          <canvas id="sigCanvas" width="400" height="150" style="border:2px solid var(--border);border-radius:8px;cursor:crosshair;touch-action:none;max-width:100%"></canvas>
          <div style="display:flex;gap:8px;margin-top:8px">
            <button onclick="clearSig()" class="btn btn-sm btn-outline"><i class="fas fa-undo"></i> Xóa</button>
            <button onclick="saveSig('<%= assignment.id %>')" class="btn btn-sm btn-primary"><i class="fas fa-save"></i> Lưu chữ ký</button>
          </div>
        </div>
        <% } else { %>
        <div style="color:var(--text-3);font-size:13px"><i class="fas fa-times-circle"></i> Không có chữ ký</div>
        <% } %>
      </div>
    </div>

    <!-- Return Form -->
    <% if (assignment.status === 'active' && ['admin','warehouse','director'].includes(locals.userRole)) { %>
    <div class="card">
      <div class="card-header"><span class="card-title"><i class="fas fa-undo"></i> Thu hồi vật tư</span></div>
      <div class="card-body">
        <form action="/warehouse/assignments/<%= assignment.id %>/return" method="POST" onsubmit="return confirm('Xác nhận thu hồi vật tư này?')">
          <div class="form-group">
            <label class="form-label">Ghi chú thu hồi</label>
            <textarea name="notes" class="form-control" rows="2" placeholder="Lý do thu hồi, tình trạng khi trả..."></textarea>
          </div>
          <div style="margin-top:12px">
            <button type="submit" class="btn btn-outline" style="color:var(--danger);border-color:var(--danger)">
              <i class="fas fa-undo"></i> Xác nhận thu hồi
            </button>
          </div>
        </form>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Right sidebar -->
  <div>
    <div class="card mb-4">
      <div class="card-body">
        <div style="text-align:center;padding:16px 0">
          <div style="font-size:36px;font-weight:800;color:var(--primary)"><%= assignment.quantity %></div>
          <div style="font-size:14px;color:var(--text-3)"><%= assignment.unit || '' %></div>
        </div>
        <div class="divider"></div>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:13px">
          <div>
            <div style="color:var(--text-3);font-size:11px">Loại vật tư</div>
            <% const typeLabel = assignment.item_type==='tool' ? '🔧 Dụng cụ' : assignment.item_type==='asset' ? '🏗️ Tài sản' : '📦 Vật tư'; %>
            <strong><%= typeLabel %></strong>
          </div>
          <% if (assignment.assigned_at) { %>
          <div>
            <div style="color:var(--text-3);font-size:11px">Ngày giao</div>
            <strong><%= new Date(assignment.assigned_at).toLocaleDateString('vi-VN') %></strong>
          </div>
          <% const daysHeld = Math.floor((Date.now() - new Date(assignment.assigned_at).getTime()) / 86400000); %>
          <div>
            <div style="color:var(--text-3);font-size:11px">Số ngày</div>
            <strong style="color:<%= assignment.status==='active' && daysHeld>30 ? 'var(--danger)' : 'var(--text)' %>">
              <%= daysHeld %> ngày
              <% if (assignment.status==='active' && daysHeld>30) { %><span style="font-size:10px;color:var(--danger)">(Quá hạn)</span><% } %>
            </strong>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const canvas = document.getElementById('sigCanvas');
if (canvas) {
  const ctx = canvas.getContext('2d');
  let drawing = false;
  ctx.strokeStyle = '#1a1a1a'; ctx.lineWidth = 2; ctx.lineCap = 'round';
  canvas.addEventListener('mousedown', e => { drawing=true; ctx.beginPath(); ctx.moveTo(e.offsetX,e.offsetY); });
  canvas.addEventListener('mousemove', e => { if(!drawing) return; ctx.lineTo(e.offsetX,e.offsetY); ctx.stroke(); });
  canvas.addEventListener('mouseup', () => drawing=false);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); drawing=true; const t=e.touches[0]; const r=canvas.getBoundingClientRect(); ctx.beginPath(); ctx.moveTo(t.clientX-r.left,t.clientY-r.top); }, {passive:false});
  canvas.addEventListener('touchmove', e => { e.preventDefault(); if(!drawing) return; const t=e.touches[0]; const r=canvas.getBoundingClientRect(); ctx.lineTo(t.clientX-r.left,t.clientY-r.top); ctx.stroke(); }, {passive:false});
  canvas.addEventListener('touchend', () => drawing=false);
}

function clearSig() { const c=document.getElementById('sigCanvas'); if(c) c.getContext('2d').clearRect(0,0,c.width,c.height); }

async function saveSig(assignId) {
  if (!assignId) return;
  const canvas = document.getElementById('sigCanvas');
  const data = canvas.toDataURL('image/png');
  const r = await fetch('/warehouse/assignments/'+assignId+'/sign', {
    method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({signature_data:data})
  });
  if ((await r.json()).success) { location.reload(); }
}
</script>
