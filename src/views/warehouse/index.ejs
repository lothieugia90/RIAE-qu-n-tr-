<div class="page-header">
  <div class="page-header-title">
    <h2>Quản lý Kho bãi</h2>
    <p>Tổng giá trị: <strong style="color:var(--primary)"><%= Number(stats.total_value||0).toLocaleString('vi-VN') %> đ</strong></p>
  </div>
  <div class="page-header-actions">
    <% if (['admin','warehouse'].includes(locals.userRole)) { %>
    <a href="/warehouse/items/create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm vật tư</a>
    <% } %>
  </div>
</div>

<!-- Stats Row -->
<div class="stats-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px">
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--primary-50)"><i class="fas fa-boxes" style="color:var(--primary)"></i></div>
    <div class="stat-body">
      <div class="stat-value"><%= stats.total_items %></div>
      <div class="stat-label">Tổng mặt hàng</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#FFF3E0"><i class="fas fa-exclamation-triangle" style="color:#FF9800"></i></div>
    <div class="stat-body">
      <div class="stat-value" style="color:#FF9800"><%= stats.low_stock %></div>
      <div class="stat-label">Sắp hết hàng</div>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#FFEBEE"><i class="fas fa-times-circle" style="color:#F44336"></i></div>
    <div class="stat-body">
      <div class="stat-value" style="color:#F44336"><%= stats.out_of_stock %></div>
      <div class="stat-label">Hết hàng</div>
    </div>
  </div>
  <a href="/warehouse/assignments" style="text-decoration:none" class="stat-card">
    <div class="stat-icon" style="background:#E3F2FD"><i class="fas fa-clipboard-list" style="color:#1565C0"></i></div>
    <div class="stat-body">
      <div class="stat-value" style="color:#1565C0"><%= typeof activeAssignments !== 'undefined' ? activeAssignments : 0 %></div>
      <div class="stat-label">Đang giao</div>
    </div>
  </a>
  <div class="stat-card">
    <div class="stat-icon" style="background:#E8F5E9"><i class="fas fa-layer-group" style="color:#4CAF50"></i></div>
    <div class="stat-body">
      <div class="stat-value" style="color:#4CAF50"><%= stats.category_count %></div>
      <div class="stat-label">Danh mục</div>
    </div>
  </div>
</div>

<!-- Overdue Assignments Alert -->
<% if (typeof overdueAssignments !== 'undefined' && overdueAssignments.length > 0) { %>
<div style="background:#FFF3E0;border:1px solid #FFB74D;border-radius:8px;padding:12px 16px;margin-bottom:16px">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
    <i class="fas fa-clock" style="color:#E65100"></i>
    <strong style="color:#E65100">Quá hạn 30 ngày (<%= overdueAssignments.length %> phiếu)</strong>
    <a href="/warehouse/assignments?status=active" style="margin-left:auto;font-size:12px;color:#1565C0"><i class="fas fa-arrow-right"></i> Xem phiếu giao</a>
  </div>
  <div style="display:flex;flex-wrap:wrap;gap:6px">
    <% overdueAssignments.forEach(a => { %>
    <span style="font-size:12px;background:#fff;padding:3px 10px;border-radius:10px;border:1px solid #FFB74D">
      <strong><%= a.item_name %></strong> — <%= a.assignee_name || 'Chưa rõ' %>
      (<%= Math.floor((Date.now() - new Date(a.assigned_at).getTime()) / 86400000) %> ngày)
    </span>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Tabs -->
<div class="tabs" style="margin-bottom:0">
  <button class="tab-btn" id="tab-vattu" onclick="switchTab('vattu')"><i class="fas fa-boxes"></i> Vật tư (<span id="cnt-vattu">0</span>)</button>
  <button class="tab-btn" id="tab-dungcu" onclick="switchTab('dungcu')"><i class="fas fa-tools"></i> Dụng cụ thi công (<span id="cnt-dungcu">0</span>)</button>
  <button class="tab-btn" id="tab-tx" onclick="switchTab('tx')"><i class="fas fa-exchange-alt"></i> Giao dịch gần đây</button>
</div>

<!-- Vật tư Tab -->
<div id="pane-vattu">
  <div class="card" style="border-top-left-radius:0">
    <div class="card-body" style="padding:12px">
      <div style="display:flex;gap:8px;margin-bottom:12px">
        <input type="text" id="search-vattu" class="form-control" placeholder="Tìm vật tư..." oninput="filterItems('vattu')" style="flex:1;max-width:280px">
        <select id="cat-vattu" class="form-control" onchange="filterItems('vattu')" style="max-width:220px">
          <option value="">Tất cả danh mục</option>
          <% categories.filter(c => c.name !== 'Dụng cụ thi công').forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div style="overflow-x:auto">
      <table id="tbl-vattu">
        <thead><tr><th>Mã</th><th>Tên vật tư</th><th>Danh mục</th><th>ĐVT</th><th>Tồn kho</th><th>Đơn giá</th><th>Giá trị</th><th>Vị trí</th><th></th></tr></thead>
        <tbody>
        <% items.filter(i => i.category_name !== 'Dụng cụ thi công').forEach(item => { %>
        <tr data-name="<%= item.name.toLowerCase() %>" data-cat="<%= item.category_id||'' %>">
          <td style="font-size:11px;font-weight:700;color:var(--text-3)"><%= item.code %></td>
          <td>
            <a href="/warehouse/items/<%= item.id %>" style="font-weight:500"><%= item.name %></a>
            <% if (item.quantity <= item.min_quantity && item.quantity > 0) { %>
            <span class="badge" style="background:#FFF3E0;color:#FF9800;font-size:10px;margin-left:4px">Sắp hết</span>
            <% } else if (item.quantity === 0) { %>
            <span class="badge" style="background:#FFEBEE;color:#F44336;font-size:10px;margin-left:4px">Hết hàng</span>
            <% } %>
          </td>
          <td style="font-size:12px;color:var(--text-3)"><%= item.category_name||'—' %></td>
          <td style="font-size:12px"><%= item.unit %></td>
          <td style="font-weight:600;color:<%= item.quantity===0 ? '#F44336' : item.quantity<=item.min_quantity ? '#FF9800' : 'var(--text)' %>"><%= Number(item.quantity).toLocaleString('vi-VN') %></td>
          <td style="font-size:13px"><%= item.unit_price ? Number(item.unit_price).toLocaleString('vi-VN') + ' đ' : '—' %></td>
          <td style="font-size:12px;color:var(--primary)"><%= item.unit_price ? (Number(item.quantity)*Number(item.unit_price)).toLocaleString('vi-VN') + ' đ' : '—' %></td>
          <td style="font-size:12px;color:var(--text-3)"><%= item.location||'—' %></td>
          <td style="white-space:nowrap">
            <a href="/warehouse/items/<%= item.id %>" class="btn btn-sm btn-outline"><i class="fas fa-eye"></i></a>
            <% if (['admin','warehouse'].includes(locals.userRole)) { %>
            <button onclick="openExport('<%= item.id %>','<%= item.name %>','<%= item.unit %>',<%= item.quantity %>)" class="btn btn-sm btn-primary" title="Xuất kho"><i class="fas fa-arrow-up"></i></button>
            <% } %>
          </td>
        </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Dụng cụ Tab -->
<div id="pane-dungcu" style="display:none">
  <div class="card" style="border-top-left-radius:0">
    <div class="card-body" style="padding:12px">
      <div style="display:flex;gap:8px;margin-bottom:12px">
        <input type="text" id="search-dungcu" class="form-control" placeholder="Tìm dụng cụ..." oninput="filterItems('dungcu')" style="flex:1;max-width:280px">
      </div>
    </div>
    <div style="overflow-x:auto">
      <table id="tbl-dungcu">
        <thead><tr><th>Mã</th><th>Tên dụng cụ</th><th>ĐVT</th><th>Số lượng</th><th>Tình trạng</th><th>Vị trí</th><th></th></tr></thead>
        <tbody>
        <% items.filter(i => i.category_name === 'Dụng cụ thi công').forEach(item => { %>
        <tr data-name="<%= item.name.toLowerCase() %>">
          <td style="font-size:11px;font-weight:700;color:var(--text-3)"><%= item.code %></td>
          <td><a href="/warehouse/items/<%= item.id %>" style="font-weight:500"><%= item.name %></a></td>
          <td style="font-size:12px"><%= item.unit %></td>
          <td style="font-weight:600"><%= Number(item.quantity).toLocaleString('vi-VN') %></td>
          <td>
            <% if (item.quantity === 0) { %>
            <span class="badge" style="background:#FFEBEE;color:#F44336">Đang sử dụng hết</span>
            <% } else { %>
            <span class="badge" style="background:#E8F5E9;color:#4CAF50">Có sẵn (<%= item.quantity %>)</span>
            <% } %>
          </td>
          <td style="font-size:12px;color:var(--text-3)"><%= item.location||'—' %></td>
          <td style="white-space:nowrap">
            <a href="/warehouse/items/<%= item.id %>" class="btn btn-sm btn-outline"><i class="fas fa-eye"></i></a>
            <% if (['admin','warehouse'].includes(locals.userRole)) { %>
            <button onclick="openExport('<%= item.id %>','<%= item.name %>','<%= item.unit %>',<%= item.quantity %>)" class="btn btn-sm btn-primary" title="Xuất/Giao dự án"><i class="fas fa-arrow-up"></i></button>
            <% } %>
          </td>
        </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Transactions Tab -->
<div id="pane-tx" style="display:none">
  <div class="card" style="border-top-left-radius:0">
    <div style="overflow-x:auto">
      <table>
        <thead><tr><th>Thời gian</th><th>Loại</th><th>Vật tư</th><th>SL</th><th>Dự án</th><th>Người thực hiện</th><th>Ghi chú</th></tr></thead>
        <tbody>
        <% if (!recentTransactions || recentTransactions.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:32px">Chưa có giao dịch</td></tr>
        <% } else { %>
        <% recentTransactions.forEach(tx => { %>
        <tr>
          <td style="font-size:12px;color:var(--text-3)"><%= new Date(tx.transaction_date).toLocaleDateString('vi-VN') %></td>
          <td><span class="badge" style="background:<%= tx.transaction_type==='in' ? '#E8F5E9' : tx.transaction_type==='out' ? '#FFEBEE' : '#E3F2FD' %>;color:<%= tx.transaction_type==='in' ? '#4CAF50' : tx.transaction_type==='out' ? '#F44336' : '#2196F3' %>"><%= tx.transaction_type==='in' ? '▲ Nhập' : tx.transaction_type==='out' ? '▼ Xuất' : '↔ Điều chỉnh' %></span></td>
          <td style="font-weight:500"><%= tx.item_name %> <span style="color:var(--text-3);font-size:11px">(<%= tx.item_code %>)</span></td>
          <td style="font-weight:600;color:<%= tx.transaction_type==='in' ? '#4CAF50' : '#F44336' %>"><%= tx.transaction_type==='in' ? '+' : '-' %><%= tx.quantity %> <%= tx.unit %></td>
          <td style="font-size:12px"><%= tx.project_name||'—' %></td>
          <td style="font-size:12px"><%= tx.performer_name||'—' %></td>
          <td style="font-size:12px;color:var(--text-3)"><%= tx.notes||'' %></td>
        </tr>
        <% }) %>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Low Stock Alert -->
<% if (lowStockItems && lowStockItems.length > 0) { %>
<div class="card mt-4" style="border-left:3px solid #FF9800">
  <div class="card-header" style="background:#FFF8E1">
    <span class="card-title" style="color:#FF9800"><i class="fas fa-exclamation-triangle"></i> Cảnh báo tồn kho thấp (<%= lowStockItems.length %> mặt hàng)</span>
  </div>
  <div style="display:flex;flex-wrap:wrap;gap:8px;padding:12px">
    <% lowStockItems.forEach(item => { %>
    <a href="/warehouse/items/<%= item.id %>" style="display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:6px;background:<%= item.quantity===0 ? '#FFEBEE' : '#FFF3E0' %>;color:<%= item.quantity===0 ? '#F44336' : '#FF9800' %>;font-size:12px;text-decoration:none;border:1px solid currentColor">
      <i class="fas fa-<%= item.quantity===0 ? 'times-circle' : 'exclamation-circle' %>"></i>
      <%= item.name %> (<%= item.quantity %> <%= item.unit %>)
    </a>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Export Modal -->
<div class="modal-overlay" id="exportModal">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">Xuất kho / Giao dự án</span>
      <button class="modal-close" onclick="document.getElementById('exportModal').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
    <form action="/warehouse/transactions" method="POST">
      <input type="hidden" name="item_id" id="exportItemId">
      <input type="hidden" name="transaction_type" value="out">
      <div class="modal-body">
        <div style="padding:10px;background:var(--border-light);border-radius:8px;margin-bottom:16px">
          <div style="font-weight:600" id="exportItemName"></div>
          <div style="font-size:12px;color:var(--text-3)">Tồn kho: <span id="exportItemStock"></span></div>
        </div>
        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">Số lượng xuất <span class="req">*</span></label>
            <input type="number" name="quantity" id="exportQty" class="form-control" min="1" required>
          </div>
          <div class="form-group">
            <label class="form-label">Đơn vị</label>
            <input type="text" name="unit" id="exportUnit" class="form-control" readonly>
          </div>
        </div>
        <div class="form-group mt-3">
          <label class="form-label">Xuất đến Dự án</label>
          <select name="project_id" class="form-control">
            <option value="">— Không gắn dự án —</option>
            <% if (typeof projects !== 'undefined') { projects.forEach(p => { %><option value="<%= p.id %>"><%= p.name %></option><% }) } %>
          </select>
        </div>
        <div class="form-group mt-3">
          <label class="form-label">Người phụ trách</label>
          <input type="text" name="notes" class="form-control" placeholder="Tên người nhận / ghi chú...">
        </div>
        <input type="hidden" name="transaction_date" value="<%= new Date().toISOString().split('T')[0] %>">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('exportModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-arrow-up"></i> Xuất kho</button>
      </div>
    </form>
  </div>
</div>

<script>
// Count items per tab
const vattuRows = document.querySelectorAll('#tbl-vattu tbody tr').length;
const dungcuRows = document.querySelectorAll('#tbl-dungcu tbody tr').length;
document.getElementById('cnt-vattu').textContent = vattuRows;
document.getElementById('cnt-dungcu').textContent = dungcuRows;

// Set initial active tab
switchTab('vattu');

function switchTab(tab) {
  ['vattu','dungcu','tx'].forEach(t => {
    document.getElementById('pane-' + t).style.display = t === tab ? 'block' : 'none';
    document.getElementById('tab-' + t).classList.toggle('active', t === tab);
  });
}

function filterItems(tab) {
  const search = document.getElementById('search-' + tab).value.toLowerCase();
  const cat = tab === 'vattu' ? document.getElementById('cat-vattu').value : '';
  const rows = document.querySelectorAll('#tbl-' + tab + ' tbody tr');
  rows.forEach(row => {
    const nameMatch = row.dataset.name.includes(search);
    const catMatch = !cat || row.dataset.cat === cat;
    row.style.display = nameMatch && catMatch ? '' : 'none';
  });
}

function openExport(id, name, unit, stock) {
  document.getElementById('exportItemId').value = id;
  document.getElementById('exportItemName').textContent = name;
  document.getElementById('exportItemStock').textContent = stock + ' ' + unit;
  document.getElementById('exportUnit').value = unit;
  document.getElementById('exportQty').value = 1;
  document.getElementById('exportQty').max = stock;
  document.getElementById('exportModal').classList.add('open');
}
</script>
