<style>
.status-chip { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:12px; font-size:12px; font-weight:500; }
.chip-active { background:#E3F2FD; color:#1565C0; }
.chip-returned { background:#F5F5F5; color:#757575; }
.chip-overdue { background:#FFEBEE; color:#C62828; }
.chip-signed { background:#E8F5E9; color:#2E7D32; }
.stat-strip { display:flex; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
.stat-strip-card { flex:1; min-width:140px; background:var(--card); border:1px solid var(--border); border-radius:10px; padding:14px 18px; }
.type-tabs { display:flex; gap:4px; margin-bottom:16px; }
.type-tab { padding:6px 16px; border-radius:20px; border:1px solid var(--border); background:var(--card); color:var(--text-3); font-size:13px; cursor:pointer; text-decoration:none; transition:all .15s; }
.type-tab.active { background:var(--primary); color:#fff; border-color:var(--primary); }
</style>

<div class="page-header">
  <div class="page-header-title">
    <h2>Phiếu Giao Vật tư</h2>
    <p>Quản lý giao nhận và theo dõi tình trạng</p>
  </div>
  <div class="page-header-actions">
    <a href="/warehouse/items" class="btn btn-outline"><i class="fas fa-boxes"></i> Danh sách vật tư</a>
    <a href="/warehouse" class="btn btn-outline"><i class="fas fa-th-large"></i> Tổng quan</a>
  </div>
</div>

<!-- Stats Strip -->
<div class="stat-strip">
  <div class="stat-strip-card">
    <div style="font-size:28px;font-weight:800;color:#1565C0"><%= activeCount %></div>
    <div style="font-size:13px;color:var(--text-3)">Đang giao</div>
  </div>
  <div class="stat-strip-card">
    <div style="font-size:28px;font-weight:800;color:<%= overdueCount > 0 ? '#C62828' : 'var(--text-3)' %>"><%= overdueCount %></div>
    <div style="font-size:13px;color:var(--text-3)">Quá hạn 30 ngày</div>
  </div>
  <div class="stat-strip-card">
    <div style="font-size:28px;font-weight:800;color:var(--success)"><%= returnedThisMonthCount %></div>
    <div style="font-size:13px;color:var(--text-3)">Đã trả tháng này</div>
  </div>
</div>

<!-- Status Tabs -->
<div class="type-tabs">
  <a href="/warehouse/assignments?status=active<%= filters.search ? '&search='+filters.search : '' %>" class="type-tab <%= (!filters.status || filters.status==='active') ? 'active' : '' %>">Đang giao</a>
  <a href="/warehouse/assignments?status=returned<%= filters.search ? '&search='+filters.search : '' %>" class="type-tab <%= filters.status==='returned' ? 'active' : '' %>">Đã trả</a>
  <a href="/warehouse/assignments?status=all<%= filters.search ? '&search='+filters.search : '' %>" class="type-tab <%= filters.status==='all' ? 'active' : '' %>">Tất cả</a>
</div>

<!-- Search -->
<form method="GET" style="display:flex;gap:8px;margin-bottom:16px">
  <input type="hidden" name="status" value="<%= filters.status || 'active' %>">
  <input type="text" name="search" class="form-control" placeholder="Tìm vật tư, người nhận..." value="<%= filters.search || '' %>" style="max-width:300px">
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
  <a href="/warehouse/assignments" class="btn btn-outline">Reset</a>
</form>

<div class="card">
  <% if (!assignments || assignments.length === 0) { %>
  <div class="empty-state" style="padding:48px">
    <div class="empty-state-icon"><i class="fas fa-clipboard-list"></i></div>
    <h3>Không có phiếu giao nào</h3>
  </div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>Vật tư</th>
          <th>Người nhận / Dự án</th>
          <th>SL</th>
          <th>Ngày giao</th>
          <th>Số ngày</th>
          <th>Chữ ký</th>
          <th>Trạng thái</th>
          <th style="width:80px"></th>
        </tr>
      </thead>
      <tbody>
      <% assignments.forEach(a => { %>
      <% const daysHeld = Math.floor((Date.now() - new Date(a.assigned_at).getTime()) / 86400000); %>
      <% const isOverdue = a.status === 'active' && daysHeld > 30; %>
      <% const safeName = (a.item_name || '').replace(/'/g, '&#39;'); %>
      <tr style="<%= isOverdue ? 'background:#FFF8E1' : '' %>">
        <td>
          <div style="font-weight:500"><a href="/warehouse/items/<%= a.item_id %>" style="color:var(--text)"><%= a.item_name %></a></div>
          <% const typeLabel = a.item_type==='tool' ? 'Dụng cụ' : a.item_type==='asset' ? 'Tài sản' : 'Vật tư'; %>
          <span style="font-size:11px;padding:1px 6px;border-radius:8px;background:#F5F5F5;color:var(--text-3)"><%= typeLabel %></span>
        </td>
        <td>
          <div style="font-weight:500"><%= a.assignee_name || '—' %></div>
          <% if (a.project_name) { %><div style="font-size:11px;color:var(--text-3)"><i class="fas fa-project-diagram" style="font-size:10px"></i> <%= a.project_name %></div><% } %>
          <div style="font-size:11px;color:var(--text-3)">Bởi: <%= a.assigner_name || '—' %></div>
        </td>
        <td style="font-weight:600"><%= a.quantity %></td>
        <td style="font-size:12px;color:var(--text-3)"><%= new Date(a.assigned_at).toLocaleDateString('vi-VN') %></td>
        <td>
          <span style="font-weight:600;color:<%= isOverdue ? 'var(--danger)' : daysHeld > 14 ? 'var(--warning)' : 'var(--text)' %>">
            <%= a.status === 'active' ? daysHeld + ' ngày' : '—' %>
          </span>
          <% if (isOverdue) { %><div style="font-size:10px;color:var(--danger)">Quá hạn!</div><% } %>
        </td>
        <td>
          <% if (a.recipient_signed_at || a.signature_data) { %>
          <span style="color:var(--success);font-size:12px"><i class="fas fa-check-circle"></i> Đã ký</span>
          <% } else { %>
          <span style="color:var(--text-3);font-size:12px"><i class="fas fa-clock"></i> Chưa ký</span>
          <% } %>
        </td>
        <td>
          <% if (a.status === 'returned') { %>
          <span class="status-chip chip-returned"><i class="fas fa-check" style="font-size:9px"></i> Đã trả</span>
          <% } else if (a.recipient_signed_at) { %>
          <span class="status-chip chip-signed"><i class="fas fa-check-circle" style="font-size:9px"></i> Đã ký nhận</span>
          <% } else if (isOverdue) { %>
          <span class="status-chip chip-overdue"><i class="fas fa-exclamation-circle" style="font-size:9px"></i> Quá hạn</span>
          <% } else { %>
          <span class="status-chip chip-active"><i class="fas fa-circle" style="font-size:7px"></i> Đang giao</span>
          <% } %>
        </td>
        <td style="white-space:nowrap">
          <a href="/warehouse/assignments/<%= a.id %>" class="btn btn-sm btn-outline" title="Xem"><i class="fas fa-eye"></i></a>
          <% if (a.status === 'active' && ['admin','warehouse','director'].includes(locals.userRole)) { %>
          <button onclick="confirmReturn('<%= a.id %>','<%= safeName %>')" class="btn btn-sm btn-outline" title="Thu hồi" style="color:var(--warning);border-color:var(--warning)"><i class="fas fa-undo"></i></button>
          <% } %>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Return Confirm Modal -->
<div class="modal-overlay" id="returnModal">
  <div class="modal" style="max-width:400px">
    <div class="modal-header">
      <span class="modal-title">Xác nhận thu hồi</span>
      <button class="modal-close" onclick="document.getElementById('returnModal').classList.remove('open')"><i class="fas fa-times"></i></button>
    </div>
    <form id="returnForm" method="POST">
      <div class="modal-body">
        <p>Thu hồi vật tư: <strong id="returnItemName"></strong>?</p>
        <div class="form-group mt-3">
          <label class="form-label">Ghi chú</label>
          <textarea name="notes" class="form-control" rows="2" placeholder="Lý do thu hồi..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('returnModal').classList.remove('open')">Hủy</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-undo"></i> Xác nhận thu hồi</button>
      </div>
    </form>
  </div>
</div>

<script>
function confirmReturn(id, name) {
  document.getElementById('returnItemName').textContent = name;
  document.getElementById('returnForm').action = '/warehouse/assignments/' + id + '/return';
  document.getElementById('returnModal').classList.add('open');
}
</script>
