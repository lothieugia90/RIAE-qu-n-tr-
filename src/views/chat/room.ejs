<div style="display:flex;gap:16px;height:calc(100vh - 160px)">
  <!-- Sidebar rooms -->
  <div style="width:250px;flex-shrink:0;background:var(--card);border-radius:var(--radius);border:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden">
    <div style="padding:12px 14px;border-bottom:1px solid var(--border);font-weight:600;font-size:13px">Phòng chat</div>
    <div style="flex:1;overflow-y:auto;padding:6px">
    <% rooms.forEach(r => { %>
    <a href="/chat/<%= r.id %>" style="display:block;padding:9px 10px;border-radius:6px;font-size:13px;text-decoration:none;color:<%= r.id === room.id ? 'var(--sidebar-text-active)' : 'var(--text)' %>;background:<%= r.id === room.id ? 'var(--primary)' : 'transparent' %>;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
      <i class="fas fa-<%= r.type==='direct' ? 'user' : 'users' %>" style="margin-right:6px;opacity:.7"></i><%= r.name %>
    </a>
    <% }) %>
    </div>
    <div style="padding:10px;border-top:1px solid var(--border)">
      <a href="/chat" class="btn btn-outline btn-sm btn-full"><i class="fas fa-plus"></i> Phòng mới</a>
    </div>
  </div>

  <!-- Chat area -->
  <div style="flex:1;background:var(--card);border-radius:var(--radius);border:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden">
    <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px">
      <div style="width:36px;height:36px;background:var(--primary);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px"><i class="fas fa-users"></i></div>
      <div><div style="font-size:15px;font-weight:600"><%= room.name %></div><div style="font-size:11px;color:var(--text-3)"><%= messages.length %> tin nhắn</div></div>
    </div>

    <!-- Messages -->
    <div style="flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px" id="messageList">
    <% messages.forEach(msg => { %>
    <%
      const isMe = msg.user_id === locals.currentUser.id;
    %>
    <div style="display:flex;gap:8px;align-items:flex-end;<%= isMe ? 'flex-direction:row-reverse' : '' %>" data-id="<%= msg.id %>">
      <% if (!isMe) { %>
      <div class="avatar avatar-sm" style="flex-shrink:0"><%= msg.full_name.charAt(0).toUpperCase() %></div>
      <% } %>
      <div style="max-width:70%">
        <% if (!isMe) { %><div style="font-size:11px;color:var(--text-3);margin-bottom:3px"><%= msg.full_name %></div><% } %>
        <div style="padding:10px 14px;border-radius:<%= isMe ? '16px 16px 4px 16px' : '16px 16px 16px 4px' %>;background:<%= isMe ? 'var(--primary)' : 'var(--border-light)' %>;color:<%= isMe ? '#fff' : 'var(--text)' %>;font-size:13.5px;line-height:1.5;word-break:break-word">
          <%= msg.content %>
        </div>
        <div style="font-size:10px;color:var(--text-3);margin-top:3px;text-align:<%= isMe ? 'right' : 'left' %>">
          <%= new Date(msg.created_at).toLocaleTimeString('vi-VN', {hour:'2-digit',minute:'2-digit'}) %>
        </div>
      </div>
    </div>
    <% }) %>
    </div>

    <!-- Input -->
    <form action="/chat/<%= room.id %>/messages" method="POST" id="chatForm" style="padding:12px 16px;border-top:1px solid var(--border);display:flex;gap:8px">
      <input type="text" name="content" id="msgInput" class="form-control" placeholder="Nhập tin nhắn..." autocomplete="off" style="flex:1" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();document.getElementById('chatForm').submit();}">
      <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i></button>
    </form>
  </div>
</div>

<script>
// Scroll to bottom
const list = document.getElementById('messageList');
list.scrollTop = list.scrollHeight;

// Auto-poll new messages every 5s
let lastMsg = '<%= messages.length > 0 ? messages[messages.length-1].created_at : new Date().toISOString() %>';
setInterval(() => {
  fetch('/chat/<%= room.id %>/poll?since=' + encodeURIComponent(lastMsg))
    .then(r => r.json())
    .then(data => {
      if (!data.messages.length) return;
      data.messages.forEach(msg => {
        const isMe = msg.user_id === '<%= locals.currentUser.id %>';
        const div = document.createElement('div');
        div.style.cssText = 'display:flex;gap:8px;align-items:flex-end;' + (isMe ? 'flex-direction:row-reverse' : '');
        div.innerHTML = (!isMe ? '<div class="avatar avatar-sm">' + msg.full_name.charAt(0) + '</div>' : '') +
          '<div style="max-width:70%">' +
          (!isMe ? '<div style="font-size:11px;color:var(--text-3);margin-bottom:3px">' + msg.full_name + '</div>' : '') +
          '<div style="padding:10px 14px;border-radius:' + (isMe ? '16px 16px 4px 16px' : '16px 16px 16px 4px') + ';background:' + (isMe ? 'var(--primary)' : 'var(--border-light)') + ';color:' + (isMe ? '#fff' : 'var(--text)') + ';font-size:13.5px">' + msg.content + '</div>' +
          '</div>';
        list.appendChild(div);
        lastMsg = msg.created_at;
      });
      list.scrollTop = list.scrollHeight;
    });
}, 5000);
</script>
