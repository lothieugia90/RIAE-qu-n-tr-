<div class="chat-layout">
  <!-- Cột trái: danh sách phòng -->
  <div class="chat-rooms card">
    <div class="chat-rooms-head">
      <strong>Phòng chat</strong>
      <button class="btn btn-sm btn-primary" onclick="document.getElementById('newRoomModal').showModal()" title="Tạo phòng"><i class="fas fa-plus"></i></button>
    </div>
    <div class="chat-rooms-list">
      <% rooms.forEach(r => { %>
      <a href="/chat?room=<%= r.id %>" class="chat-room-item <%= activeRoom && activeRoom.id === r.id ? 'active' : '' %>">
        <span class="cr-icon"><i class="fas <%= r.type === 'direct' ? 'fa-user' : 'fa-users' %>"></i></span>
        <span class="cr-info">
          <strong><%= r.name %></strong>
          <small><%= r.last_message ? r.last_message.slice(0, 40) : 'Chưa có tin nhắn' %></small>
        </span>
        <% if (r.unread > 0 && (!activeRoom || activeRoom.id !== r.id)) { %>
        <span class="nav-badge" style="position:static"><%= r.unread %></span>
        <% } %>
      </a>
      <% }) %>
    </div>
    <!-- Danh sách nhân viên + trạng thái online: click để nhắn riêng -->
    <div class="chat-users">
      <div class="chat-users-head">
        <strong><i class="fas fa-user-group"></i> Nhân viên</strong>
        <small><span id="onlineCount">0</span> đang online</small>
      </div>
      <div class="chat-users-list">
        <% allUsers.forEach(u => { const on = onlineIds.includes(u.id); %>
        <button type="button" class="chat-user-row" data-uid="<%= u.id %>" onclick="startDirect('<%= u.id %>')" title="Nhắn riêng với <%= u.full_name %>">
          <span class="cu-avatar">
            <% if (u.avatar_url) { %><img src="<%= u.avatar_url %>"><% } else { %><%= u.full_name.charAt(0).toUpperCase() %><% } %>
            <span class="cu-dot <%= on ? 'on' : '' %>"></span>
          </span>
          <span class="cu-info">
            <strong><%= u.full_name %></strong>
            <small><%= u.position || u.department || '—' %></small>
          </span>
          <i class="fas fa-paper-plane cu-send"></i>
        </button>
        <% }) %>
      </div>
      <form id="directForm" action="/chat/direct" method="POST" hidden>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="user_id" id="directUserId">
      </form>
    </div>
  </div>

  <!-- Cột phải: khung chat -->
  <div class="chat-main card">
    <% if (!activeRoom) { %>
    <div class="chat-empty">
      <i class="fas fa-comments"></i>
      <p>Chọn một phòng chat để bắt đầu</p>
    </div>
    <% } else { %>
    <div class="chat-head">
      <strong><i class="fas <%= activeRoom.type === 'direct' ? 'fa-user' : 'fa-users' %>"></i> <%= activeRoom.name %></strong>
      <small><%= members.length %> thành viên: <%= members.map(m => m.full_name).join(', ').slice(0, 80) %></small>
    </div>
    <div class="chat-messages" id="chatMessages">
      <% const isImg = f => /\.(jpe?g|png|gif|webp)$/i.test(f || ''); %>
      <% messages.forEach(m => { const mine = m.user_id === currentUser.id; %>
      <div class="msg <%= mine ? 'mine' : '' %>">
        <% if (!mine) { %>
        <span class="msg-avatar"><% if (m.avatar_url) { %><img src="<%= m.avatar_url %>"><% } else { %><%= m.full_name.charAt(0).toUpperCase() %><% } %></span>
        <% } %>
        <div class="msg-bubble">
          <% if (!mine) { %><small class="msg-author"><%= m.full_name %></small><% } %>
          <% if (m.file_url) { %>
            <% if (isImg(m.file_url)) { %>
            <a href="<%= m.file_url %>" target="_blank"><img src="<%= m.file_url %>" class="msg-file-img" alt="<%= m.file_name %>"></a>
            <% } else { %>
            <a href="<%= m.file_url %>" target="_blank" class="msg-file-row">
              <i class="fas fa-file-arrow-down"></i>
              <span class="msg-file-name"><%= m.file_name %></span>
              <small><%= ((m.file_size||0)/1024).toFixed(0) %> KB</small>
            </a>
            <% } %>
          <% } %>
          <% if (m.content) { %><p><%= m.content %></p><% } %>
          <small class="msg-time"><%= new Date(m.created_at).toLocaleTimeString('vi-VN', {hour:'2-digit',minute:'2-digit'}) %></small>
        </div>
      </div>
      <% }) %>
    </div>
    <form class="chat-input" id="chatForm">
      <input type="file" id="chatFile" hidden accept=".jpg,.jpeg,.png,.webp,.gif,.pdf,.doc,.docx,.xls,.xlsx,.zip,.rar">
      <button type="button" id="chatAttachBtn" class="btn btn-outline btn-icon" title="Đính kèm file"><i class="fas fa-paperclip"></i></button>
      <input type="text" id="chatText" class="form-control" placeholder="Nhắn tin tới <%= activeRoom.name %>..." autocomplete="off" maxlength="4000">
      <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i></button>
    </form>
    <div id="chatFileName" class="chat-file-pending" hidden>
      <i class="fas fa-paperclip"></i> <span></span>
      <button type="button" id="chatFileCancelBtn" aria-label="Bỏ file">&times;</button>
    </div>
    <% } %>
  </div>
</div>

<!-- Modal tạo phòng -->
<dialog id="newRoomModal" class="modal" style="max-width:440px">
  <button type="button" class="modal-x" onclick="this.closest('dialog').close()" aria-label="Đóng">&times;</button>
  <form action="/chat/rooms" method="POST" class="modal-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h3>Tạo phòng chat</h3>
    <div class="form-group">
      <label>Tên phòng *</label>
      <input type="text" name="name" class="form-control" required maxlength="100">
    </div>
    <div class="form-group">
      <label>Thành viên</label>
      <select name="member_ids" class="form-control" multiple size="6">
        <% allUsers.forEach(u => { %><option value="<%= u.id %>"><%= u.full_name %></option><% }) %>
      </select>
      <small style="color:var(--text-3);font-size:11.5px">Giữ Ctrl để chọn nhiều người. Bạn luôn là thành viên.</small>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="this.closest('dialog').close()">Hủy</button>
      <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Tạo phòng</button>
    </div>
  </form>
</dialog>

<script src="/socket.io/socket.io.js"></script>
<script>
// Nhắn riêng: click 1 nhân viên trong danh sách
function startDirect(uid) {
  document.getElementById('directUserId').value = uid;
  document.getElementById('directForm').submit();
}

(function() {
  const box = document.getElementById('chatMessages');
  if (box) box.scrollTop = box.scrollHeight;

  const socket = io();
  const ROOM_ID = '<%= activeRoom ? activeRoom.id : '' %>';
  const MY_ID = '<%= currentUser.id %>';

  // Trạng thái online realtime
  function refreshOnlineCount() {
    const el = document.getElementById('onlineCount');
    if (el) el.textContent = document.querySelectorAll('.chat-user-row .cu-dot.on').length;
  }
  refreshOnlineCount();
  socket.on('presence:update', ({ userId, online }) => {
    const dot = document.querySelector('.chat-user-row[data-uid="' + userId + '"] .cu-dot');
    if (dot) dot.classList.toggle('on', online);
    refreshOnlineCount();
  });

  function isImgFile(url) { return /\.(jpe?g|png|gif|webp)$/i.test(url || ''); }

  function renderMsg(m) {
    const mine = m.user_id === MY_ID;
    const el = document.createElement('div');
    el.className = 'msg' + (mine ? ' mine' : '');
    if (!mine) {
      const av = document.createElement('span');
      av.className = 'msg-avatar';
      if (m.avatar_url) { const img = document.createElement('img'); img.src = m.avatar_url; av.appendChild(img); }
      else av.textContent = (m.full_name || '?').charAt(0).toUpperCase();
      el.appendChild(av);
    }
    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';
    if (!mine) {
      const author = document.createElement('small');
      author.className = 'msg-author'; author.textContent = m.full_name;
      bubble.appendChild(author);
    }
    if (m.file_url) {
      if (isImgFile(m.file_url)) {
        const a = document.createElement('a');
        a.href = m.file_url; a.target = '_blank';
        const img = document.createElement('img');
        img.src = m.file_url; img.className = 'msg-file-img'; img.alt = m.file_name || '';
        a.appendChild(img); bubble.appendChild(a);
      } else {
        const a = document.createElement('a');
        a.href = m.file_url; a.target = '_blank'; a.className = 'msg-file-row';
        a.innerHTML = '<i class="fas fa-file-arrow-down"></i>';
        const nameSpan = document.createElement('span');
        nameSpan.className = 'msg-file-name'; nameSpan.textContent = m.file_name || '';
        const sizeSmall = document.createElement('small');
        sizeSmall.textContent = ((m.file_size || 0) / 1024).toFixed(0) + ' KB';
        a.appendChild(nameSpan); a.appendChild(sizeSmall);
        bubble.appendChild(a);
      }
    }
    if (m.content) {
      const p = document.createElement('p');
      p.textContent = m.content; // textContent chống XSS
      bubble.appendChild(p);
    }
    const time = document.createElement('small');
    time.className = 'msg-time';
    time.textContent = new Date(m.created_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
    bubble.appendChild(time);
    el.appendChild(bubble);
    return el;
  }

  socket.on('message:new', (m) => {
    if (m.room_id !== ROOM_ID || !box) return;
    box.appendChild(renderMsg(m));
    box.scrollTop = box.scrollHeight;
    if (m.user_id !== MY_ID) socket.emit('room:read', { roomId: ROOM_ID });
  });

  const form = document.getElementById('chatForm');
  const fileInput = document.getElementById('chatFile');
  const attachBtn = document.getElementById('chatAttachBtn');
  const filePending = document.getElementById('chatFileName');
  const fileCancelBtn = document.getElementById('chatFileCancelBtn');

  if (attachBtn) attachBtn.addEventListener('click', () => fileInput.click());
  if (fileInput) fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) {
      filePending.querySelector('span').textContent = fileInput.files[0].name;
      filePending.hidden = false;
    }
  });
  if (fileCancelBtn) fileCancelBtn.addEventListener('click', () => {
    fileInput.value = '';
    filePending.hidden = true;
  });

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = document.getElementById('chatText');
      const content = input.value.trim();
      const file = fileInput.files[0];
      if (!content && !file) return;
      if (file) {
        const fd = new FormData();
        fd.append('file', file);
        fd.append('caption', content);
        const csrf = document.querySelector('meta[name="csrf-token"]').content;
        try {
          const r = await fetch('/chat/rooms/' + ROOM_ID + '/upload', {
            method: 'POST', headers: { 'x-csrf-token': csrf }, body: fd
          });
          const j = await r.json();
          if (!r.ok) throw new Error(j.error || 'Lỗi gửi file');
        } catch (err) { alert(err.message); }
        fileInput.value = '';
        filePending.hidden = true;
      } else {
        socket.emit('message:send', { roomId: ROOM_ID, content });
      }
      input.value = '';
      input.focus();
    });
  }
})();
</script>

<style>
.chat-layout { display: grid; grid-template-columns: 290px 1fr; gap: 16px; height: calc(100vh - var(--header-h) - 76px); }
@media (max-width: 800px) { .chat-layout { grid-template-columns: 1fr; height: auto; } .chat-rooms { max-height: 260px; } }
.chat-rooms { display: flex; flex-direction: column; overflow: hidden; }
.chat-rooms-head { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; border-bottom: 1px solid var(--border); }
.chat-rooms-list { flex: 1; overflow-y: auto; }
.chat-room-item { display: flex; align-items: center; gap: 10px; padding: 11px 14px; text-decoration: none; transition: background .15s; }
.chat-room-item:hover { background: var(--bg); }
.chat-room-item.active { background: var(--primary-50); border-right: 3px solid var(--primary); }
.cr-icon { width: 34px; height: 34px; border-radius: 50%; background: var(--primary-50); color: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
.cr-info { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.cr-info strong { font-size: 13px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cr-info small { font-size: 11px; color: var(--text-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.chat-users { border-top: 1px solid var(--border); display: flex; flex-direction: column; max-height: 42%; }
.chat-users-head { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px 6px; }
.chat-users-head strong { font-size: 12px; color: var(--text-2); }
.chat-users-head strong i { font-size: 10.5px; margin-right: 4px; }
.chat-users-head small { font-size: 11px; color: var(--success); font-weight: 600; }
.chat-users-list { overflow-y: auto; padding-bottom: 6px; }
.chat-user-row {
  display: flex; align-items: center; gap: 10px; width: 100%; padding: 7px 14px;
  border: none; background: transparent; cursor: pointer; text-align: left; transition: background .15s;
}
.chat-user-row:hover { background: var(--bg); }
.chat-user-row:hover .cu-send { opacity: 1; }
.cu-avatar { position: relative; width: 30px; height: 30px; border-radius: 50%; background: var(--primary-50); color: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
.cu-avatar img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
.cu-dot { position: absolute; bottom: -1px; right: -1px; width: 10px; height: 10px; border-radius: 50%; background: #CBD5E1; border: 2px solid var(--card); }
.cu-dot.on { background: #22C55E; }
.cu-info { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.cu-info strong { font-size: 12.5px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cu-info small { font-size: 10.5px; color: var(--text-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.cu-send { font-size: 11px; color: var(--primary); opacity: 0; transition: opacity .15s; }
.chat-main { display: flex; flex-direction: column; overflow: hidden; }
.chat-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--text-3); gap: 10px; padding: 60px; }
.chat-empty i { font-size: 40px; }
.chat-head { padding: 13px 18px; border-bottom: 1px solid var(--border); display: flex; flex-direction: column; gap: 2px; }
.chat-head strong { font-size: 14.5px; color: var(--text); }
.chat-head small { font-size: 11.5px; color: var(--text-3); }
.chat-messages { flex: 1; overflow-y: auto; padding: 18px; display: flex; flex-direction: column; gap: 10px; background: var(--bg); }
.msg { display: flex; gap: 9px; max-width: 72%; }
.msg.mine { align-self: flex-end; flex-direction: row-reverse; }
.msg-avatar { width: 30px; height: 30px; border-radius: 50%; overflow: hidden; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
.msg-avatar img { width: 100%; height: 100%; object-fit: cover; }
.msg-bubble { background: var(--card); border-radius: 14px 14px 14px 4px; padding: 8px 13px; box-shadow: var(--shadow); }
.msg.mine .msg-bubble { background: var(--primary); color: #fff; border-radius: 14px 14px 4px 14px; }
.msg-author { font-size: 10.5px; color: var(--primary); font-weight: 700; display: block; margin-bottom: 2px; }
.msg-bubble p { font-size: 13.5px; line-height: 1.45; word-break: break-word; white-space: pre-line; }
.msg-time { font-size: 9.5px; color: var(--text-3); display: block; text-align: right; margin-top: 3px; }
.msg.mine .msg-time { color: rgba(255,255,255,.7); }
.msg-file-img { display: block; max-width: 220px; max-height: 220px; border-radius: 8px; margin-bottom: 4px; object-fit: cover; }
.msg-file-row { display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-radius: 8px; background: rgba(0,0,0,.05); text-decoration: none; color: inherit; margin-bottom: 4px; }
.msg.mine .msg-file-row { background: rgba(255,255,255,.15); }
.msg-file-row i { font-size: 14px; }
.msg-file-name { font-size: 12.5px; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 140px; }
.msg-file-row small { font-size: 10px; opacity: .8; white-space: nowrap; }
.chat-input { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-top: 1px solid var(--border); }
.chat-input .btn-outline { width: 38px; height: 38px; padding: 0; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.chat-file-pending { display: flex; align-items: center; gap: 8px; padding: 0 14px 10px; font-size: 12px; color: var(--text-2); }
.chat-file-pending[hidden] { display: none !important; }
.chat-file-pending span { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.chat-file-pending button { border: none; background: transparent; color: var(--text-3); cursor: pointer; font-size: 16px; }
.chat-file-pending button:hover { color: var(--danger); }
.modal { border: none; border-radius: var(--radius-lg); padding: 0; width: 100%; box-shadow: var(--shadow-lg); }
.modal::backdrop { background: rgba(13,27,62,.5); }
.modal-form { padding: 26px; }
.modal-form h3 { margin-bottom: 20px; font-size: 17px; color: var(--text); }
.modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 22px; }
</style>
