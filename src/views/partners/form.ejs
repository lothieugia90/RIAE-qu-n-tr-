<div style="max-width:800px;margin:0 auto">
  <div class="card">
    <div class="card-header">
      <span class="card-title"><%= partner ? 'Chỉnh sửa Đối tác' : 'Thêm Đối tác mới' %></span>
      <a href="/partners" class="btn btn-sm btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-body">
      <form action="<%= partner ? '/partners/' + partner.id + '?_method=PUT' : '/partners' %>" method="POST">
        <% if (partner) { %><input type="hidden" name="_method" value="PUT"><% } %>
        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">Loại đối tác <span class="req">*</span></label>
            <select name="type" class="form-control" required id="partnerType" onchange="toggleFields()">
              <option value="supplier" <%= (!partner || partner.type==='supplier') ? 'selected' : '' %>>Nhà cung ứng hàng hóa</option>
              <option value="contractor" <%= partner && partner.type==='contractor' ? 'selected' : '' %>>Tổ đội thi công</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Tên đối tác <span class="req">*</span></label>
            <input type="text" name="name" class="form-control" value="<%= partner ? partner.name : '' %>" required>
          </div>
          <div class="form-group">
            <label class="form-label">Người liên hệ</label>
            <input type="text" name="contact_person" class="form-control" value="<%= partner ? partner.contact_person||'' : '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Số điện thoại</label>
            <input type="text" name="phone" class="form-control" value="<%= partner ? partner.phone||'' : '' %>">
          </div>
          <div class="form-group">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" value="<%= partner ? partner.email||'' : '' %>">
          </div>
          <div class="form-group" id="taxCodeField">
            <label class="form-label">Mã số thuế</label>
            <input type="text" name="tax_code" class="form-control" value="<%= partner ? partner.tax_code||'' : '' %>">
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Địa chỉ</label>
            <input type="text" name="address" class="form-control" value="<%= partner ? partner.address||'' : '' %>">
          </div>
          <div class="form-group col-span-2">
            <label class="form-label">Ghi chú</label>
            <textarea name="notes" class="form-control"><%= partner ? partner.notes||'' : '' %></textarea>
          </div>
        </div>
        <div style="margin-top:20px;display:flex;gap:10px">
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> <%= partner ? 'Lưu thay đổi' : 'Thêm đối tác' %></button>
          <a href="/partners" class="btn btn-outline">Hủy</a>
        </div>
      </form>
    </div>
  </div>
</div>
