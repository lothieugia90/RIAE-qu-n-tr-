<div class="page-header">
  <div class="page-header-title">
    <h2>Quản trị Hệ thống</h2>
    <p>Quản lý tài khoản người dùng</p>
  </div>
  <div class="page-header-actions">
    <a href="/hr/create" class="btn btn-primary"><i class="fas fa-user-plus"></i> Tạo tài khoản</a>
  </div>
</div>

<div class="card">
  <div class="table-wrap" style="border:none;border-radius:var(--radius)">
    <% if (users.length === 0) { %>
    <div class="empty-state" style="padding:48px"><h3>Không có tài khoản</h3></div>
    <% } else { %>
    <table>
      <thead>
        <tr><th>Tài khoản</th><th>Vai trò</th><th>Phòng ban</th><th>Đăng nhập gần nhất</th><th>Trạng thái</th><th>Hành động</th></tr>
      </thead>
      <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td>
          <div style="display:flex;align-items:center;gap:10px">
            <div class="avatar avatar-sm"><%= u.full_name.charAt(0).toUpperCase() %></div>
            <div>
              <div style="font-weight:600"><%= u.full_name %></div>
              <div style="font-size:11px;color:var(--text-3)">@<%= u.username %> · <%= u.email %></div>
            </div>
          </div>
        </td>
        <td>
          <form action="/admin/users/<%= u.id %>/role" method="POST" style="display:flex;gap:6px;align-items:center">
            <select name="role" class="form-control" style="font-size:12px;padding:4px 8px;max-width:130px" onchange="this.form.submit()">
              <option value="admin" <%= u.role==='admin'?'selected':'' %>>admin</option>
              <option value="director" <%= u.role==='director'?'selected':'' %>>director</option>
              <option value="pm" <%= u.role==='pm'?'selected':'' %>>pm</option>
              <option value="engineer" <%= u.role==='engineer'?'selected':'' %>>engineer</option>
              <option value="warehouse" <%= u.role==='warehouse'?'selected':'' %>>warehouse</option>
            </select>
          </form>
        </td>
        <td style="font-size:13px"><%= u.department || '—' %></td>
        <td style="font-size:12px;color:var(--text-3)"><%= u.last_login_at ? new Date(u.last_login_at).toLocaleDateString('vi-VN') : 'Chưa đăng nhập' %></td>
        <td>
          <span class="badge" style="background:<%= u.is_active ? 'var(--success-bg)' : 'var(--danger-bg)' %>;color:<%= u.is_active ? 'var(--success)' : 'var(--danger)' %>">
            <%= u.is_active ? 'Hoạt động' : 'Khóa' %>
          </span>
        </td>
        <td>
          <div style="display:flex;gap:6px">
            <form action="/admin/users/<%= u.id %>/toggle" method="POST" style="display:inline">
              <button type="submit" class="btn btn-sm <%= u.is_active ? 'btn-warning' : 'btn-success' %>" title="<%= u.is_active ? 'Khóa' : 'Mở khóa' %>">
                <i class="fas fa-<%= u.is_active ? 'ban' : 'unlock' %>"></i>
              </button>
            </form>
            <form action="/admin/users/<%= u.id %>/reset-password" method="POST" style="display:inline">
              <button type="submit" class="btn btn-sm btn-outline" onclick="return confirm('Reset mật khẩu về Riae@2024?')" title="Reset mật khẩu">
                <i class="fas fa-key"></i>
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>
