<div class="page-header">
  <div class="page-header-title">
    <h1>Nhật ký hệ thống</h1>
    <p>Lịch sử thao tác của người dùng (mới nhất trước)</p>
  </div>
</div>

<div class="card">
  <div class="card-body" style="padding:0">
    <table class="table">
      <thead>
        <tr><th>Thời gian</th><th>Người dùng</th><th>Hành động</th><th>Chi tiết</th><th>IP</th></tr>
      </thead>
      <tbody>
        <% if (logs.length === 0) { %>
        <tr><td colspan="5" style="text-align:center;padding:36px;color:var(--text-3)">Chưa có nhật ký nào</td></tr>
        <% } %>
        <% logs.forEach(log => { %>
        <tr>
          <td style="white-space:nowrap"><%= new Date(log.created_at).toLocaleString('vi-VN') %></td>
          <td><%= log.full_name || '—' %><% if (log.username) { %> <small style="color:var(--text-3)">(<%= log.username %>)</small><% } %></td>
          <td><span class="badge badge-info"><%= log.action %></span></td>
          <td><%= log.description || '' %></td>
          <td><small><%= log.ip_address || '—' %></small></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<div class="pagination" style="margin-top:16px;display:flex;gap:6px;justify-content:center">
  <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
    <a href="/admin/audit?page=<%= p %>" class="btn btn-sm <%= p === page ? 'btn-primary' : 'btn-outline' %>"><%= p %></a>
  <% } %>
</div>
<% } %>
