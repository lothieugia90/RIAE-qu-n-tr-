<% const MONTH_NAMES = ['Tháng 1','Tháng 2','Tháng 3','Tháng 4','Tháng 5','Tháng 6','Tháng 7','Tháng 8','Tháng 9','Tháng 10','Tháng 11','Tháng 12'];
   const prevM = month === 1 ? 12 : month - 1, prevY = month === 1 ? year - 1 : year;
   const nextM = month === 12 ? 1 : month + 1, nextY = month === 12 ? year + 1 : year; %>

<div class="page-header">
  <div class="page-header-title">
    <h1>Bảng Chấm công</h1>
    <p><%= canEdit ? 'Click vào ô để chấm công' : 'Bảng công của bạn' %> · <%= MONTH_NAMES[month-1] %>/<%= year %></p>
  </div>
  <div class="att-nav">
    <a href="/attendance?month=<%= prevM %>&year=<%= prevY %><%= dept ? '&dept='+encodeURIComponent(dept) : '' %>" class="btn btn-outline"><i class="fas fa-chevron-left"></i></a>
    <strong><%= String(month).padStart(2,'0') %>/<%= year %></strong>
    <a href="/attendance?month=<%= nextM %>&year=<%= nextY %><%= dept ? '&dept='+encodeURIComponent(dept) : '' %>" class="btn btn-outline"><i class="fas fa-chevron-right"></i></a>
    <% if (canEdit && departments.length > 0) { %>
    <select class="form-control" style="max-width:170px" onchange="location.href='/attendance?month=<%= month %>&year=<%= year %>&dept='+encodeURIComponent(this.value)">
      <option value="">Mọi phòng ban</option>
      <% departments.forEach(d => { %>
      <option value="<%= d %>" <%= dept === d ? 'selected' : '' %>><%= d %></option>
      <% }) %>
    </select>
    <% } %>
  </div>
</div>

<!-- Chú thích -->
<div class="att-legend">
  <% Object.entries(statusMeta).forEach(([k, m]) => { %>
  <span class="att-legend-item"><span class="att-chip" style="background:<%= m.bg %>;color:<%= m.color %>"><%= m.short %></span> <%= m.label %></span>
  <% }) %>
</div>

<div class="card">
  <div class="card-body" style="padding:0;overflow-x:auto">
    <table class="att-table">
      <thead>
        <tr>
          <th class="att-name-col">Nhân viên</th>
          <% days.forEach(d => { %>
          <th class="att-day <%= d.isWeekend ? 'weekend' : '' %> <%= d.isHoliday ? 'holiday' : '' %>">
            <span class="att-dow"><%= ['CN','T2','T3','T4','T5','T6','T7'][d.dow] %></span>
            <%= d.day %>
          </th>
          <% }) %>
          <th class="att-sum" title="Ngày công / OT">Σ</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => {
          const recs = recordMap[u.id] || {};
          let workDays = 0, otTotal = 0;
          days.forEach(d => { const r = recs[d.day]; if (r) { if (['present','late','remote'].includes(r.status)) workDays++; otTotal += parseFloat(r.overtime_hours)||0; } });
        %>
        <tr>
          <td class="att-name-col">
            <strong><%= u.full_name %></strong>
            <% if (u.department) { %><small><%= u.department %></small><% } %>
          </td>
          <% days.forEach(d => {
            const r = recs[d.day];
            const m = r ? statusMeta[r.status] : null;
            const dateStr = year + '-' + String(month).padStart(2,'0') + '-' + String(d.day).padStart(2,'0');
          %>
          <td class="att-cell <%= d.isWeekend ? 'weekend' : '' %> <%= d.isHoliday ? 'holiday' : '' %> <%= canEdit ? 'editable' : '' %>"
              <% if (canEdit) { %>onclick="openCell('<%= u.id %>','<%= u.full_name %>','<%= dateStr %>','<%= r ? r.status : '' %>','<%= r ? (r.overtime_hours||0) : 0 %>',this)"<% } %>
              title="<%= u.full_name %> · <%= d.day %>/<%= month %><%= r ? ' · ' + m.label + (parseFloat(r.overtime_hours)>0 ? ' · OT '+r.overtime_hours+'h' : '') : '' %>">
            <% if (r) { %>
            <span class="att-chip" style="background:<%= m.bg %>;color:<%= m.color %>"><%= m.short %></span>
            <% if (parseFloat(r.overtime_hours) > 0) { %><span class="att-ot">+<%= r.overtime_hours %></span><% } %>
            <% } %>
          </td>
          <% }) %>
          <td class="att-sum"><strong><%= workDays %></strong><% if (otTotal > 0) { %><small><%= otTotal %>h</small><% } %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (canEdit) { %>
<!-- Modal chấm công 1 ô -->
<dialog id="cellModal" class="modal" style="max-width:380px">
  <div class="modal-form">
    <h3 id="cellTitle">Chấm công</h3>
    <div class="form-group">
      <label>Trạng thái</label>
      <select id="cellStatus" class="form-control">
        <option value="">— Xóa (không chấm) —</option>
        <% Object.entries(statusMeta).forEach(([k, m]) => { %>
        <option value="<%= k %>"><%= m.label %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Tăng ca (giờ)</label>
      <input type="number" id="cellOt" class="form-control" min="0" max="12" step="0.5" value="0">
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="document.getElementById('cellModal').close()">Hủy</button>
      <button type="button" class="btn btn-primary" onclick="saveCell()"><i class="fas fa-save"></i> Lưu</button>
    </div>
  </div>
</dialog>

<script>
const csrf = document.querySelector('meta[name="csrf-token"]').content;
let currentCell = null;

function openCell(userId, userName, date, status, ot, el) {
  currentCell = { userId, date, el };
  document.getElementById('cellTitle').textContent = userName + ' · ' + date.split('-').reverse().join('/');
  document.getElementById('cellStatus').value = status;
  document.getElementById('cellOt').value = ot;
  document.getElementById('cellModal').showModal();
}

async function saveCell() {
  const status = document.getElementById('cellStatus').value;
  const ot = document.getElementById('cellOt').value;
  try {
    const r = await fetch('/attendance/cell', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrf, 'Accept': 'application/json' },
      body: JSON.stringify({ user_id: currentCell.userId, work_date: currentCell.date, status, overtime_hours: ot })
    });
    const j = await r.json();
    if (!r.ok) throw new Error(j.error || 'Lỗi lưu');
    location.reload();
  } catch (err) { alert(err.message); }
}
</script>
<% } %>

<style>
.att-nav { display: flex; align-items: center; gap: 10px; }
.att-legend { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 14px; font-size: 12px; color: var(--text-2); }
.att-legend-item { display: inline-flex; align-items: center; gap: 6px; }
.att-table { border-collapse: collapse; width: 100%; font-size: 12px; }
.att-table th, .att-table td { border: 1px solid var(--border-light); text-align: center; }
.att-table thead th { background: var(--bg); padding: 6px 2px; font-size: 10.5px; color: var(--text-2); position: sticky; top: 0; }
.att-name-col { text-align: left !important; padding: 8px 12px !important; min-width: 160px; position: sticky; left: 0; background: var(--card); z-index: 1; }
.att-name-col strong { display: block; font-size: 12.5px; color: var(--text); white-space: nowrap; }
.att-name-col small { color: var(--text-3); font-size: 10.5px; }
.att-day { min-width: 34px; }
.att-dow { display: block; font-size: 9px; color: var(--text-3); font-weight: 400; }
.att-cell { height: 40px; min-width: 34px; position: relative; }
.att-cell.editable { cursor: pointer; }
.att-cell.editable:hover { background: var(--primary-50); }
.att-cell.weekend, .att-day.weekend { background: #F8FAFC; }
.att-cell.holiday, .att-day.holiday { background: #FFF7ED; }
.att-chip {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 22px; height: 22px; border-radius: 6px; font-weight: 700; font-size: 10.5px; padding: 0 4px;
}
.att-ot { display: block; font-size: 9px; color: var(--warning); font-weight: 700; }
.att-sum { min-width: 44px; background: var(--bg); }
.att-sum strong { color: var(--primary); }
.att-sum small { display: block; color: var(--warning); font-size: 10px; }
.modal { border: none; border-radius: var(--radius-lg); padding: 0; width: 100%; box-shadow: var(--shadow-lg); }
.modal::backdrop { background: rgba(13,27,62,.5); }
.modal-form { padding: 24px; }
.modal-form h3 { margin-bottom: 18px; font-size: 16px; color: var(--text); }
.modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
</style>
