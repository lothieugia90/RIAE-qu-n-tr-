<div style="max-width:860px;margin:0 auto">

  <!-- Breadcrumb -->
  <div style="display:flex;align-items:center;gap:8px;font-size:12.5px;color:var(--text-3);margin-bottom:14px">
    <a href="/announcements" style="color:var(--text-3);text-decoration:none;display:flex;align-items:center;gap:4px"><i class="fas fa-arrow-left"></i> Bảng tin</a>
    <span>/</span>
    <span style="color:var(--text-2);font-weight:500"><%= announcement.type === 'decision' ? 'Quyết định' : 'Thông báo' %></span>
  </div>

  <!-- Main card -->
  <div class="card" style="overflow:hidden">

    <!-- Type header bar -->
    <div class="ann-detail-bar ann-bar-<%= announcement.type %>">
      <span class="ann-type-badge ann-badge-<%= announcement.type %>" style="font-size:12px">
        <% const typeLabels = {general:'Thông báo chung',urgent:'Khẩn cấp',decision:'Quyết định',policy:'Chính sách',event:'Sự kiện'} %>
        <%= typeLabels[announcement.type] || announcement.type %>
      </span>
      <% if (announcement.is_pinned) { %>
      <span style="font-size:12px;color:var(--warning);display:flex;align-items:center;gap:4px"><i class="fas fa-thumbtack"></i> Đã ghim</span>
      <% } %>
      <div style="margin-left:auto;display:flex;gap:8px">
        <% if (['admin','director','pm'].includes(locals.userRole)) { %>
        <a href="/announcements/<%= announcement.id %>/edit" class="btn btn-sm btn-outline"><i class="fas fa-edit"></i> Chỉnh sửa</a>
        <form action="/announcements/<%= announcement.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Xóa thông báo này?')">
          <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
        </form>
        <% } %>
      </div>
    </div>

    <div style="padding:28px 32px">

      <!-- Title -->
      <h1 style="font-size:22px;font-weight:800;color:var(--text);line-height:1.4;margin:0 0 16px"><%= announcement.title %></h1>

      <!-- Author meta -->
      <div style="display:flex;align-items:center;gap:12px;padding-bottom:20px;border-bottom:1px solid var(--border);margin-bottom:24px;flex-wrap:wrap">
        <div style="display:flex;align-items:center;gap:10px">
          <% if (announcement.author_avatar) { %>
            <img src="<%= announcement.author_avatar %>" style="width:42px;height:42px;border-radius:50%;object-fit:cover" alt="">
          <% } else { %>
            <div style="width:42px;height:42px;border-radius:50%;background:var(--primary-50);color:var(--primary);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px"><%= (announcement.author_name||'?').charAt(0).toUpperCase() %></div>
          <% } %>
          <div>
            <div style="font-size:14px;font-weight:600;color:var(--text)"><%= announcement.author_name %></div>
            <div style="font-size:12px;color:var(--text-3)"><%= new Date(announcement.published_at||announcement.created_at).toLocaleDateString('vi-VN',{weekday:'long',day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
          </div>
        </div>
        <div style="display:flex;gap:16px;margin-left:auto;flex-wrap:wrap">
          <span style="font-size:12.5px;color:var(--text-3);display:flex;align-items:center;gap:5px"><i class="fas fa-eye"></i> <%= announcement.read_count %> lượt đọc</span>
          <span style="font-size:12.5px;color:var(--success);display:flex;align-items:center;gap:5px"><i class="fas fa-check-double"></i> <%= announcement.seen_count %> xác nhận đã xem</span>
        </div>
      </div>

      <!-- Content (rich text HTML) -->
      <div class="ann-rich-content">
        <%- announcement.content %>
      </div>

      <!-- Expiry warning -->
      <% if (announcement.expires_at) { %>
      <div style="margin-top:24px;padding:12px 16px;background:var(--warning-bg);border-radius:var(--radius-sm);border-left:3px solid var(--warning);font-size:13px;color:var(--warning);display:flex;align-items:center;gap:8px">
        <i class="fas fa-hourglass-end"></i>
        Thông báo này hết hạn vào: <strong><%= new Date(announcement.expires_at).toLocaleDateString('vi-VN') %></strong>
      </div>
      <% } %>
    </div>

    <!-- File attachments -->
    <% if (files && files.length > 0) { %>
    <div style="border-top:1px solid var(--border);padding:20px 32px">
      <h4 style="font-size:14px;font-weight:700;margin:0 0 14px;display:flex;align-items:center;gap:7px;color:var(--text)">
        <i class="fas fa-paperclip" style="color:var(--primary)"></i> Tệp đính kèm (<%= files.length %>)
      </h4>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px">
        <% files.forEach(f => { %>
        <% const isPdf = f.mime_type && f.mime_type.includes('pdf'); %>
        <% const isImg = f.mime_type && f.mime_type.includes('image'); %>
        <div class="ann-file-card">
          <% if (isImg) { %>
            <a href="<%= f.file_path %>" target="_blank" class="ann-file-thumb-link">
              <img src="<%= f.file_path %>" class="ann-file-thumb-img" alt="<%= f.original_name %>">
            </a>
          <% } else { %>
            <div class="ann-file-icon-wrap" style="background:<%= isPdf?'#fee2e2':'var(--border-light)' %>">
              <i class="fas fa-<%= isPdf ? 'file-pdf' : 'file-alt' %>" style="color:<%= isPdf?'#dc2626':'var(--text-3)' %>;font-size:28px"></i>
            </div>
          <% } %>
          <div class="ann-file-info">
            <span class="ann-file-name"><%= f.original_name %></span>
            <span class="ann-file-size"><%= f.file_size ? (f.file_size > 1048576 ? (f.file_size/1048576).toFixed(1)+'MB' : Math.round(f.file_size/1024)+'KB') : '' %></span>
          </div>
          <div style="display:flex;gap:6px">
            <% if (isPdf) { %>
            <button onclick="openPdfPreview('<%= f.file_path %>','<%= f.original_name %>')" class="ann-file-btn" title="Xem trước">
              <i class="fas fa-eye"></i>
            </button>
            <% } %>
            <a href="<%= f.file_path %>" download="<%= f.original_name %>" class="ann-file-btn" title="Tải về">
              <i class="fas fa-download"></i>
            </a>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Reaction bar -->
    <div style="border-top:1px solid var(--border);padding:16px 32px;display:flex;align-items:center;gap:20px;flex-wrap:wrap">
      <button id="seenBtn" onclick="toggleReact()" class="ann-seen-btn <%= announcement.has_reacted ? 'reacted' : '' %>">
        <i class="fas fa-check-circle"></i>
        <span id="seenBtnText"><%= announcement.has_reacted ? 'Đã xác nhận' : 'Xác nhận đã xem' %></span>
      </button>
      <% if (reactions && reactions.length > 0) { %>
      <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
        <span style="font-size:12.5px;color:var(--text-3)">Đã xác nhận:</span>
        <div style="display:flex">
          <% reactions.slice(0,8).forEach((r,i) => { %>
          <div title="<%= r.full_name %>"
            style="width:26px;height:26px;border-radius:50%;border:2px solid var(--card);margin-left:<%= i?'-8px':'0' %>;overflow:hidden;background:var(--primary-50);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--primary)">
            <% if (r.avatar_url) { %><img src="<%= r.avatar_url %>" style="width:100%;height:100%;object-fit:cover" alt="">
            <% } else { %><%= r.full_name.charAt(0).toUpperCase() %><% } %>
          </div>
          <% }) %>
        </div>
        <% if (reactions.length > 8) { %><span style="font-size:12px;color:var(--text-3)">+<%= reactions.length-8 %></span><% } %>
      </div>
      <% } %>
      <a href="/announcements" class="btn btn-outline btn-sm" style="margin-left:auto"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
  </div>
</div>

<!-- PDF Preview Modal -->
<div id="pdfModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closePdfPreview()">
  <div style="width:min(900px,96vw);height:min(88vh,860px);background:var(--card);border-radius:var(--radius-lg);display:flex;flex-direction:column;box-shadow:0 25px 50px -12px rgba(0,0,0,.4);overflow:hidden">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid var(--border);flex-shrink:0">
      <span id="pdfTitle" style="font-size:14px;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;margin-right:12px"></span>
      <div style="display:flex;gap:8px;flex-shrink:0">
        <a id="pdfDownloadBtn" href="#" download class="btn btn-sm btn-outline"><i class="fas fa-download"></i> Tải về</a>
        <button onclick="closePdfPreview()" class="modal-close" style="width:32px;height:32px"><i class="fas fa-times"></i></button>
      </div>
    </div>
    <iframe id="pdfFrame" src="" style="flex:1;border:none;width:100%" title="PDF viewer"></iframe>
  </div>
</div>

<style>
.ann-detail-bar { padding:12px 24px;display:flex;align-items:center;gap:12px;flex-wrap:wrap }
.ann-bar-urgent { background:linear-gradient(90deg,#fee2e2,var(--card)) }
.ann-bar-decision { background:linear-gradient(90deg,#ede9fe,var(--card)) }
.ann-bar-policy { background:linear-gradient(90deg,#e0f2fe,var(--card)) }
.ann-bar-event { background:linear-gradient(90deg,#dcfce7,var(--card)) }
.ann-bar-general { background:linear-gradient(90deg,var(--primary-50),var(--card)) }

.ann-type-badge { padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:600 }
.ann-badge-urgent { background:#fee2e2;color:#dc2626 }
.ann-badge-decision { background:#ede9fe;color:#7c3aed }
.ann-badge-policy { background:#e0f2fe;color:#0891b2 }
.ann-badge-event { background:#dcfce7;color:#16a34a }
.ann-badge-general { background:var(--primary-50);color:var(--primary) }

.ann-rich-content { font-size:14.5px;line-height:1.8;color:var(--text) }
.ann-rich-content h1,.ann-rich-content h2,.ann-rich-content h3 { font-weight:700;color:var(--text);margin:20px 0 10px }
.ann-rich-content h1 { font-size:20px } .ann-rich-content h2 { font-size:18px } .ann-rich-content h3 { font-size:16px }
.ann-rich-content p { margin:0 0 14px }
.ann-rich-content ul,.ann-rich-content ol { padding-left:24px;margin:0 0 14px }
.ann-rich-content li { margin-bottom:6px }
.ann-rich-content strong { font-weight:700 } .ann-rich-content em { font-style:italic }
.ann-rich-content blockquote { border-left:3px solid var(--primary);padding:8px 16px;color:var(--text-2);background:var(--border-light);border-radius:0 var(--radius-sm) var(--radius-sm) 0;margin:16px 0 }
.ann-rich-content a { color:var(--primary);text-decoration:underline }

.ann-file-card { display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius-sm);transition:var(--transition) }
.ann-file-card:hover { border-color:var(--primary-50);background:var(--card) }
.ann-file-icon-wrap { width:42px;height:42px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;flex-shrink:0 }
.ann-file-thumb-link { width:42px;height:42px;border-radius:var(--radius-sm);overflow:hidden;display:flex;flex-shrink:0 }
.ann-file-thumb-img { width:100%;height:100%;object-fit:cover }
.ann-file-info { flex:1;min-width:0 }
.ann-file-name { display:block;font-size:12.5px;font-weight:500;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap }
.ann-file-size { font-size:11px;color:var(--text-3) }
.ann-file-btn { width:30px;height:30px;border-radius:var(--radius-sm);background:var(--card);border:1.5px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-2);font-size:13px;text-decoration:none;transition:var(--transition);flex-shrink:0 }
.ann-file-btn:hover { border-color:var(--primary);color:var(--primary) }

.ann-seen-btn { display:flex;align-items:center;gap:8px;padding:10px 20px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--card);cursor:pointer;font-size:13.5px;font-weight:600;color:var(--text-2);transition:var(--transition) }
.ann-seen-btn:hover { border-color:var(--success);color:var(--success) }
.ann-seen-btn.reacted { border-color:var(--success);background:#dcfce7;color:#16a34a }
</style>

<script>
async function toggleReact() {
  const btn = document.getElementById('seenBtn');
  const txt = document.getElementById('seenBtnText');
  try {
    const r = await fetch('/announcements/<%= announcement.id %>/react', {
      method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'},
      body: JSON.stringify({reaction:'seen'})
    });
    const data = await r.json();
    if (data.success) {
      if (data.toggled) { btn.classList.add('reacted'); txt.textContent='Đã xác nhận'; }
      else { btn.classList.remove('reacted'); txt.textContent='Xác nhận đã xem'; }
    }
  } catch(e) {}
}

function openPdfPreview(url, name) {
  document.getElementById('pdfTitle').textContent = name;
  document.getElementById('pdfFrame').src = url;
  document.getElementById('pdfDownloadBtn').href = url;
  document.getElementById('pdfDownloadBtn').download = name;
  const m = document.getElementById('pdfModal');
  m.style.display = 'flex';
}
function closePdfPreview() {
  document.getElementById('pdfModal').style.display = 'none';
  document.getElementById('pdfFrame').src = '';
}
</script>
