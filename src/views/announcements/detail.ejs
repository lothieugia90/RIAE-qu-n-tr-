<% const m = typeMeta[announcement.type] || typeMeta.general; %>

<div class="page-header">
  <div class="page-header-title">
    <h1><%= announcement.title %></h1>
    <p>
      <span class="ann-type-badge" style="background:<%= m.bg %>;color:<%= m.color %>"><i class="fas <%= m.icon %>"></i> <%= m.label %></span>
      <% if (announcement.is_pinned) { %><span class="badge badge-warning"><i class="fas fa-thumbtack"></i> Đã ghim</span><% } %>
      · Đăng bởi <strong><%= announcement.author_name || 'Hệ thống' %></strong> · <%= fmtDateTime(announcement.published_at) %>
    </p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <a href="/announcements" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Về Bảng tin</a>
    <% if (['edit','full'].includes(permLevel)) { %>
    <a href="/announcements/<%= announcement.id %>/edit" class="btn btn-outline"><i class="fas fa-pen"></i> Sửa</a>
    <form action="/announcements/<%= announcement.id %>/delete" method="POST" data-confirm="Gỡ thông báo này khỏi bảng tin?">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-outline" style="color:var(--danger)"><i class="fas fa-trash-alt"></i> Gỡ</button>
    </form>
    <% } %>
  </div>
</div>

<%
  // Phân loại file: ảnh và PDF nhúng thẳng vào trang (dạng tờ A4), còn lại giữ dạng link
  const isImage = f => /\.(jpe?g|png|gif|webp)$/i.test(f.file_path);
  const isPdf   = f => /\.pdf$/i.test(f.file_path);
  const live    = files.filter(f => !f.missing);      // file còn trên đĩa
  const missing = files.filter(f => f.missing);       // file đã mất (không nhúng)
  const embeds  = live.filter(f => isImage(f) || isPdf(f));
  const others  = live.filter(f => !isImage(f) && !isPdf(f));
%>

<!-- Nội dung dạng tờ giấy A4, căn giữa -->
<div class="ann-paper">
  <div class="ann-content"><%= announcement.content %></div>

  <% embeds.forEach(f => { %>
  <div class="ann-embed">
    <% if (isImage(f)) { %>
    <img src="<%= f.file_path %>" alt="<%= f.original_name %>" loading="lazy">
    <% } else { %>
    <iframe src="<%= f.file_path %>#toolbar=0&navpanes=0" title="<%= f.original_name %>" loading="lazy"></iframe>
    <% } %>
    <a href="<%= f.file_path %>" target="_blank" class="ann-embed-caption">
      <i class="fas <%= isImage(f) ? 'fa-image' : 'fa-file-pdf' %>"></i> <%= f.original_name %>
      <small>· mở bản gốc</small>
    </a>
  </div>
  <% }) %>

  <% if (others.length > 0) { %>
  <div class="ann-files">
    <label>File đính kèm khác</label>
    <% others.forEach(f => { %>
    <a href="<%= f.file_path %>" target="_blank" class="ann-file-row">
      <i class="fas fa-paperclip"></i> <%= f.original_name %>
      <small>(<%= (f.file_size / 1024).toFixed(0) %> KB)</small>
    </a>
    <% }) %>
  </div>
  <% } %>

  <% if (missing.length > 0) { %>
  <div class="ann-files">
    <label>File không còn khả dụng</label>
    <% missing.forEach(f => { %>
    <span class="ann-file-missing"><i class="fas fa-triangle-exclamation"></i> <%= f.original_name %> — đã bị xóa hoặc thất lạc</span>
    <% }) %>
  </div>
  <% } %>

  <% if (announcement.expires_at) { %>
  <p class="ann-expiry"><i class="fas fa-hourglass-half"></i> Hết hiệu lực: <%= fmtDate(announcement.expires_at) %></p>
  <% } %>

  <% if (['edit','full'].includes(permLevel)) { %>
  <p class="ann-readcount"><i class="fas fa-eye"></i> <%= announcement.read_count %> người đã xem</p>
  <% } %>
</div>

<style>
.ann-type-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 11.5px; font-weight: 700; }
/* Tờ giấy A4: 794px = bề ngang A4 ở 96dpi, căn giữa trang */
.ann-paper {
  max-width: 794px; margin: 0 auto; background: var(--card);
  border: 1px solid var(--border-light); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md); padding: 48px 56px;
}
@media (max-width: 700px) { .ann-paper { padding: 24px 18px; } }
.ann-content { font-size: 14.5px; color: var(--text); line-height: 1.8; white-space: pre-line; }
.ann-embed { margin-top: 28px; text-align: center; }
.ann-embed img { max-width: 100%; height: auto; border-radius: 6px; border: 1px solid var(--border-light); box-shadow: var(--shadow); }
.ann-embed iframe {
  width: 100%; aspect-ratio: 210 / 297; /* đúng tỷ lệ tờ A4 dọc */
  border: 1px solid var(--border-light); border-radius: 6px; background: #fff; box-shadow: var(--shadow);
}
.ann-embed-caption { display: inline-flex; align-items: center; gap: 6px; margin-top: 8px; font-size: 12px; color: var(--text-2); text-decoration: none; }
.ann-embed-caption:hover { color: var(--primary); }
.ann-embed-caption small { color: var(--text-3); }
.ann-files { margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-light); }
.ann-files label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-3); margin-bottom: 8px; }
.ann-file-row { display: block; font-size: 13px; color: var(--primary); text-decoration: none; padding: 6px 0; }
.ann-file-row:hover { text-decoration: underline; }
.ann-file-row small { color: var(--text-3); margin-left: 4px; }
.ann-file-missing { display: block; font-size: 12.5px; color: var(--text-3); padding: 5px 0; }
.ann-file-missing i { color: var(--warning); margin-right: 4px; }
.ann-expiry { margin-top: 16px; font-size: 12.5px; color: var(--warning); }
.ann-readcount { margin-top: 10px; font-size: 12px; color: var(--text-3); }
</style>
