<div class="page-header">
  <div class="page-header-title">
    <h1>Bảng tin công ty</h1>
    <p><%= announcements.length %> thông báo · <%= unreadCount %> chưa đọc</p>
  </div>
  <% if (['edit','full'].includes(permLevel)) { %>
  <a href="/announcements/create" data-modal class="btn btn-primary"><i class="fas fa-plus"></i> Đăng thông báo</a>
  <% } %>
</div>

<div class="ann-filter-bar">
  <a href="/announcements" class="ann-filter-chip <%= !filters.type ? 'active' : '' %>">Tất cả</a>
  <% Object.entries(typeMeta).forEach(([k, m]) => { %>
  <a href="/announcements?type=<%= k %>" class="ann-filter-chip <%= filters.type === k ? 'active' : '' %>" style="<%= filters.type === k ? `background:${m.bg};color:${m.color};border-color:${m.color}` : '' %>">
    <i class="fas <%= m.icon %>"></i> <%= m.label %>
  </a>
  <% }) %>
</div>

<% if (announcements.length === 0) { %>
<div class="card"><div class="card-body" style="text-align:center;padding:48px;color:var(--text-3)">
  <i class="fas fa-bullhorn" style="font-size:32px;margin-bottom:12px;display:block;opacity:.4"></i>
  Chưa có thông báo nào
</div></div>
<% } %>

<div class="ann-feed">
  <% announcements.forEach(a => { const m = typeMeta[a.type] || typeMeta.general; %>
  <a href="/announcements/<%= a.id %>" class="card ann-card <%= a.is_read ? '' : 'unread' %>">
    <% if (a.is_pinned) { %><div class="ann-pin"><i class="fas fa-thumbtack"></i> Đã ghim</div><% } %>
    <div class="ann-card-head">
      <span class="ann-type-badge" style="background:<%= m.bg %>;color:<%= m.color %>"><i class="fas <%= m.icon %>"></i> <%= m.label %></span>
      <% if (!a.is_read) { %><span class="ann-unread-dot"></span><% } %>
    </div>
    <h3 class="ann-title"><%= a.title %></h3>
    <p class="ann-excerpt"><%= a.content.replace(/<[^>]*>/g, '').slice(0, 160) %><%= a.content.length > 160 ? '…' : '' %></p>
    <div class="ann-card-foot">
      <span><i class="fas fa-user"></i> <%= a.author_name || 'Hệ thống' %></span>
      <span><i class="fas fa-clock"></i> <%= fmtDate(a.published_at) %></span>
      <% if (a.file_count > 0) { %><span><i class="fas fa-paperclip"></i> <%= a.file_count %> file</span><% } %>
      <% if (['edit','full'].includes(permLevel)) { %><span><i class="fas fa-eye"></i> <%= a.read_count %> đã xem</span><% } %>
    </div>
  </a>
  <% }) %>
</div>

<style>
.ann-filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
.ann-filter-chip {
  display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: 20px;
  border: 1.5px solid var(--border); font-size: 12.5px; font-weight: 600; color: var(--text-2);
  text-decoration: none; transition: var(--transition); background: var(--card);
}
.ann-filter-chip:hover { border-color: var(--primary); color: var(--primary); }
.ann-filter-chip.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.ann-feed { display: flex; flex-direction: column; gap: 14px; }
.ann-card { display: block; padding: 18px 20px; text-decoration: none; position: relative; transition: var(--transition); }
.ann-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
.ann-card.unread { border-left: 3px solid var(--primary); }
.ann-pin { font-size: 11px; font-weight: 700; color: var(--warning); margin-bottom: 8px; display: flex; align-items: center; gap: 5px; }
.ann-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.ann-type-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 20px; font-size: 11.5px; font-weight: 700; }
.ann-unread-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--primary); }
.ann-title { font-size: 15.5px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
.ann-excerpt { font-size: 13px; color: var(--text-2); line-height: 1.55; margin-bottom: 12px; }
.ann-card-foot { display: flex; gap: 16px; font-size: 11.5px; color: var(--text-3); flex-wrap: wrap; }
.ann-card-foot i { margin-right: 4px; }
</style>
