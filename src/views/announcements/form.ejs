<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<div style="max-width:820px;margin:0 auto">
  <div class="card">
    <div class="card-header">
      <span class="card-title"><i class="fas fa-<%= announcement ? 'edit' : 'paper-plane' %>" style="margin-right:8px;color:var(--primary)"></i><%= announcement ? 'Chỉnh sửa Thông báo' : 'Đăng Thông báo mới' %></span>
      <a href="/announcements" class="btn btn-sm btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-body">
      <form id="annForm" action="<%= announcement ? '/announcements/' + announcement.id + '/edit' : '/announcements' %>" method="POST" enctype="multipart/form-data">
        <% if (announcement) { %><input type="hidden" name="_method" value="PUT"><% } %>
        <input type="hidden" name="content" id="contentInput">

        <!-- Row 1: Type + Pin + Expires -->
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px">
          <div class="form-group" style="margin:0">
            <label class="form-label">Loại thông báo</label>
            <select name="type" id="typeSelect" class="form-control">
              <option value="general"   <%= (!announcement||announcement.type==='general') ?'selected':'' %>>📢 Thông báo chung</option>
              <option value="urgent"    <%= announcement&&announcement.type==='urgent'    ?'selected':'' %>>🔴 Khẩn cấp</option>
              <option value="decision"  <%= announcement&&announcement.type==='decision'  ?'selected':'' %>>⚖️ Quyết định</option>
              <option value="policy"    <%= announcement&&announcement.type==='policy'    ?'selected':'' %>>📋 Chính sách</option>
              <option value="event"     <%= announcement&&announcement.type==='event'     ?'selected':'' %>>📅 Sự kiện</option>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Ngày hết hạn <span style="color:var(--text-3);font-weight:400">(tuỳ chọn)</span></label>
            <input type="date" name="expires_at" class="form-control" value="<%= announcement&&announcement.expires_at ? new Date(announcement.expires_at).toISOString().split('T')[0] : '' %>">
          </div>
          <div class="form-group" style="margin:0;justify-content:flex-end">
            <label class="form-label">&nbsp;</label>
            <label class="ann-pin-toggle">
              <input type="checkbox" name="is_pinned" id="isPinned" <%= announcement&&announcement.is_pinned?'checked':'' %>>
              <span class="ann-pin-track"><span class="ann-pin-thumb"></span></span>
              <span style="font-size:13.5px;font-weight:500"><i class="fas fa-thumbtack" style="color:var(--warning);margin-right:4px"></i> Ghim lên đầu</span>
            </label>
          </div>
        </div>

        <!-- Tiêu đề -->
        <div class="form-group" style="margin-bottom:16px">
          <label class="form-label">Tiêu đề <span class="req">*</span></label>
          <input type="text" name="title" class="form-control" id="titleInput"
            value="<%= announcement ? announcement.title : '' %>"
            placeholder="Nhập tiêu đề thông báo..." required
            style="font-size:16px;font-weight:600;padding:12px 14px">
        </div>

        <!-- Rich text editor -->
        <div class="form-group" style="margin-bottom:16px">
          <label class="form-label">Nội dung <span class="req">*</span></label>
          <div id="quillEditor" style="min-height:220px;font-size:14px"><%= announcement ? announcement.content : '' %></div>
          <div style="font-size:11.5px;color:var(--text-3);margin-top:6px"><i class="fas fa-info-circle"></i> Hỗ trợ định dạng: <strong>đậm</strong>, <em>nghiêng</em>, danh sách, tiêu đề, màu chữ</div>
        </div>

        <!-- File dropzone -->
        <div class="form-group" style="margin-bottom:20px">
          <label class="form-label"><i class="fas fa-paperclip" style="margin-right:5px"></i>Tệp đính kèm <span style="color:var(--text-3);font-weight:400">(ảnh, PDF, Word, Excel — tối đa 20MB/file)</span></label>
          <div id="dropzone" class="ann-dropzone" onclick="document.getElementById('fileInput').click()">
            <input type="file" name="files" id="fileInput" multiple accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx" style="display:none" onchange="handleFiles(this.files)">
            <div id="dropzoneHint">
              <i class="fas fa-cloud-upload-alt" style="font-size:28px;color:var(--border);margin-bottom:8px"></i>
              <p style="font-size:13.5px;font-weight:500;color:var(--text-2);margin:0">Kéo thả file vào đây hoặc <span style="color:var(--primary);cursor:pointer">chọn từ máy tính</span></p>
              <p style="font-size:12px;color:var(--text-3);margin:4px 0 0">JPG, PNG, PDF, DOC, XLS</p>
            </div>
            <div id="filePreviewList" style="display:none;width:100%"></div>
          </div>

          <% if (locals.existingFiles && existingFiles.length > 0) { %>
          <div style="margin-top:12px">
            <p style="font-size:12.5px;font-weight:600;color:var(--text-2);margin-bottom:8px">File hiện tại:</p>
            <div style="display:flex;flex-wrap:wrap;gap:8px">
              <% existingFiles.forEach(f => { %>
              <div style="display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--border-light);border-radius:var(--radius-sm);border:1px solid var(--border);font-size:12.5px">
                <i class="fas fa-<%= f.mime_type&&f.mime_type.includes('pdf')?'file-pdf':f.mime_type&&f.mime_type.includes('image')?'image':'file-alt' %>" style="color:var(--primary)"></i>
                <span style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= f.original_name %></span>
                <form action="/announcements/<%= announcement.id %>/files/<%= f.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Xóa file này?')">
                  <button type="submit" style="background:none;border:none;color:var(--danger);cursor:pointer;padding:0;font-size:12px"><i class="fas fa-times"></i></button>
                </form>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>

        <div style="display:flex;gap:10px">
          <button type="submit" class="btn btn-primary" id="submitBtn">
            <i class="fas fa-<%= announcement ? 'save' : 'paper-plane' %>"></i>
            <%= announcement ? 'Lưu thay đổi' : 'Đăng thông báo' %>
          </button>
          <a href="/announcements" class="btn btn-outline">Hủy</a>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
#quillEditor { border:1.5px solid var(--border);border-radius:0 0 var(--radius-sm) var(--radius-sm);background:var(--card) }
.ql-toolbar { border:1.5px solid var(--border);border-radius:var(--radius-sm) var(--radius-sm) 0 0;background:var(--border-light) }
.ql-container { font-family:inherit;font-size:14px }
.ql-editor { min-height:200px;padding:16px }

.ann-dropzone {
  border:2px dashed var(--border);border-radius:var(--radius);
  padding:28px;text-align:center;cursor:pointer;
  transition:var(--transition);background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.ann-dropzone.drag-over { border-color:var(--primary);background:var(--primary-50) }
.ann-dropzone:hover { border-color:var(--primary-dark) }

.ann-file-preview { display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:6px }
.ann-file-preview .remove-file { margin-left:auto;background:none;border:none;color:var(--danger);cursor:pointer;font-size:14px;padding:0 }

.ann-pin-toggle { display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 14px;background:var(--border-light);border-radius:var(--radius-sm);border:1.5px solid var(--border);user-select:none }
.ann-pin-toggle input { display:none }
.ann-pin-track { width:36px;height:20px;background:var(--border);border-radius:20px;position:relative;transition:.2s;flex-shrink:0 }
.ann-pin-thumb { width:16px;height:16px;background:#fff;border-radius:50%;position:absolute;top:2px;left:2px;transition:.2s;box-shadow:0 1px 3px rgba(0,0,0,.2) }
.ann-pin-toggle input:checked ~ .ann-pin-track { background:var(--warning) }
.ann-pin-toggle input:checked ~ .ann-pin-track .ann-pin-thumb { left:18px }
</style>

<script>
// Init Quill
const quill = new Quill('#quillEditor', {
  theme: 'snow',
  placeholder: 'Nhập nội dung thông báo...',
  modules: {
    toolbar: [
      [{ header: [1, 2, 3, false] }],
      ['bold', 'italic', 'underline', 'strike'],
      [{ color: [] }, { background: [] }],
      [{ list: 'ordered' }, { list: 'bullet' }],
      [{ align: [] }],
      ['blockquote', 'link'],
      ['clean']
    ]
  }
});

// Set existing content
<% if (announcement && announcement.content) { %>
quill.clipboard.dangerouslyPasteHTML('<%= announcement.content.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'\\n') %>');
<% } %>

// On submit: write Quill HTML to hidden input
document.getElementById('annForm').addEventListener('submit', function(e) {
  const html = quill.root.innerHTML;
  if (html === '<p><br></p>' || !html.trim()) {
    e.preventDefault();
    quill.root.focus();
    return alert('Vui lòng nhập nội dung thông báo');
  }
  document.getElementById('contentInput').value = html;
});

// File handling
let selectedFiles = [];

function handleFiles(fileList) {
  for (const f of fileList) selectedFiles.push(f);
  renderFilePreviews();
}

function renderFilePreviews() {
  const list = document.getElementById('filePreviewList');
  const hint = document.getElementById('dropzoneHint');
  if (!selectedFiles.length) { list.style.display='none'; hint.style.display=''; return; }
  hint.style.display = 'none';
  list.style.display = 'block';
  list.innerHTML = selectedFiles.map((f, i) => {
    const icon = f.type.includes('pdf') ? 'file-pdf' : f.type.includes('image') ? 'image' : 'file-alt';
    const size = f.size > 1048576 ? (f.size/1048576).toFixed(1)+'MB' : Math.round(f.size/1024)+'KB';
    return `<div class="ann-file-preview">
      <i class="fas fa-${icon}" style="color:var(--primary);font-size:16px"></i>
      <span style="font-size:13px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${f.name}</span>
      <span style="font-size:12px;color:var(--text-3)">${size}</span>
      <button type="button" class="remove-file" onclick="removeFile(${i})"><i class="fas fa-times"></i></button>
    </div>`;
  }).join('');
  // Rebuild input files
  const dt = new DataTransfer();
  selectedFiles.forEach(f => dt.items.add(f));
  document.getElementById('fileInput').files = dt.files;
}

function removeFile(idx) {
  selectedFiles.splice(idx, 1);
  renderFilePreviews();
}

// Drag & drop
const dz = document.getElementById('dropzone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('drag-over');
  handleFiles(e.dataTransfer.files);
});
</script>
