<div class="error-page">
  <div class="error-code">500</div>
  <h2>Lỗi hệ thống</h2>
  <p>Đã xảy ra lỗi. Vui lòng thử lại hoặc liên hệ quản trị viên.</p>
  <% if (error && error.message) { %>
  <pre class="error-detail"><%= error.message %></pre>
  <% } %>
  <a href="/dashboard" class="btn btn-primary"><i class="fas fa-home"></i> Về Dashboard</a>
</div>
<style>
.error-page { text-align: center; padding: 80px 20px; }
.error-code { font-size: 84px; font-weight: 800; color: var(--danger); line-height: 1; margin-bottom: 12px; }
.error-page h2 { font-size: 22px; color: var(--text); margin-bottom: 8px; }
.error-page p { color: var(--text-3); margin-bottom: 26px; }
.error-detail {
  max-width: 640px; margin: 0 auto 26px; text-align: left; background: var(--danger-bg);
  color: var(--danger); padding: 14px; border-radius: var(--radius-sm); font-size: 12px; overflow-x: auto;
}
</style>
