<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - RIAE Management</title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #1565C0;
      --primary-dark: #0D47A1;
      --primary-light: #42A5F5;
      --sky: #7EC3F7;
      --navy: #0D1B3E;
      --navy-2: #12275A;
      --text: #1E293B;
      --text-2: #475569;
      --text-3: #64748B;
      --border: #E2E8F0;
      --danger: #DC2626;
      --danger-bg: #FEE2E2;
      --success: #16A34A;
      --success-bg: #DCFCE7;
      --font-display: 'Chakra Petch', 'Inter', sans-serif;
      --font-body: 'Inter', -apple-system, sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-body); min-height: 100vh; display: flex; background: #F0F4F8; }

    /* ============ PANEL THƯƠNG HIỆU (trái) ============ */
    .brand-panel {
      flex: 1.15; position: relative; overflow: hidden;
      background:
        radial-gradient(1100px 600px at 85% -10%, rgba(21,101,192,.35), transparent 60%),
        radial-gradient(900px 700px at -15% 110%, rgba(66,165,245,.18), transparent 55%),
        linear-gradient(165deg, var(--navy) 0%, var(--navy-2) 55%, var(--primary-dark) 100%);
      color: #fff; display: flex; flex-direction: column;
      align-items: center; justify-content: center; padding: 60px 48px;
    }
    /* lưới chấm mờ nền */
    .brand-panel::before {
      content: ''; position: absolute; inset: 0; opacity: .13; pointer-events: none;
      background-image: radial-gradient(rgba(126,195,247,.9) 1px, transparent 1.5px);
      background-size: 34px 34px;
    }
    .brand-inner { position: relative; z-index: 1; max-width: 480px; width: 100%; text-align: center; }

    /* ---- Lockup: vòm mạng lưới + wordmark ---- */
    .lockup { display: inline-flex; flex-direction: column; align-items: center; }
    .wm-dome { width: min(340px, 78%); height: auto; display: block; margin-bottom: -6px; overflow: visible; }
    .wm-dome .net-line {
      stroke: var(--primary-light); stroke-width: 1.3; fill: none; opacity: .8;
      stroke-dasharray: 1; stroke-dashoffset: 1;
    }
    .wm-dome .net-arc {
      stroke: var(--sky); stroke-width: 2.4; fill: none; stroke-linecap: round;
      stroke-dasharray: 1; stroke-dashoffset: 1;
    }
    .wm-dome .net-node { fill: var(--primary-light); opacity: 0; }
    .wm-dome .net-node.bright { fill: var(--sky); }

    .wm-text {
      font-family: var(--font-display); font-weight: 700; line-height: 1;
      font-size: clamp(64px, 9vw, 96px); letter-spacing: .01em; display: flex; align-items: baseline;
    }
    .wm-text .l { color: #fff; opacity: 0; transform: translateY(16px); }
    .wm-text .l-a { color: var(--primary-light); }
    /* Chữ ı không chấm (U+0131) + chấm vẽ tay — tránh chấm của font bị nhân đôi */
    .wm-text .l-i { position: relative; color: #fff; }
    .wm-text .l-i::after {
      content: ''; position: absolute; left: 50%; transform: translateX(-50%);
      top: .06em; width: .16em; height: .16em; border-radius: 50%;
      background: var(--primary-light); box-shadow: 0 0 14px rgba(66,165,245,.8);
    }

    .wm-subline {
      margin-top: 22px; display: flex; align-items: center; gap: 14px; width: 100%;
      font-family: var(--font-display); font-weight: 500;
      font-size: clamp(10.5px, 1.2vw, 12.5px); letter-spacing: .32em; text-indent: .32em;
      color: #B9C6E4; white-space: nowrap; opacity: 0;
    }
    .wm-subline::before, .wm-subline::after {
      content: ''; height: 1.5px; flex: 1; min-width: 22px;
      background: linear-gradient(90deg, transparent, var(--primary-light));
    }
    .wm-subline::after { background: linear-gradient(90deg, var(--primary-light), transparent); }

    .brand-tagline {
      margin-top: 34px; font-size: 14.5px; line-height: 1.7; color: #C7D3EC; opacity: 0;
    }
    .brand-points {
      margin-top: 34px; display: flex; justify-content: center; gap: 0; opacity: 0;
    }
    .brand-point {
      display: flex; flex-direction: column; align-items: center; gap: 9px;
      padding: 0 26px; font-size: 12px; color: #AFC0E2; max-width: 150px; line-height: 1.45;
    }
    .brand-point + .brand-point { border-left: 1px solid rgba(126,195,247,.22); }
    .brand-point i { font-size: 17px; color: var(--sky); }

    /* ============ PANEL FORM (phải) ============ */
    .form-panel { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px 24px; }
    .login-card { width: 100%; max-width: 396px; opacity: 0; transform: translateY(14px); }

    .mobile-mark { display: none; text-align: center; margin-bottom: 26px; }
    .mobile-mark .wm-text { font-size: 54px; justify-content: center; }
    .mobile-mark .l { color: var(--navy); opacity: 1; transform: none; }
    .mobile-mark .l-a { color: var(--primary); }
    .mobile-mark .l-i { color: var(--navy); }
    .mobile-mark .l-i::after { background: var(--primary); box-shadow: none; }
    .mobile-mark .m-sub {
      margin-top: 8px; font-family: var(--font-display); font-weight: 500; font-size: 10px;
      letter-spacing: .3em; text-indent: .3em; color: var(--text-3);
    }

    .login-card h2 {
      font-family: var(--font-display); font-weight: 700; font-size: 26px;
      color: var(--text); letter-spacing: .01em; margin-bottom: 6px;
    }
    .login-card .sub { font-size: 13.5px; color: var(--text-3); margin-bottom: 30px; }

    .flash { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-radius: 10px; font-size: 13.5px; margin-bottom: 18px; }
    .flash-error { background: var(--danger-bg); color: var(--danger); }
    .flash-success { background: var(--success-bg); color: var(--success); }

    .form-group { margin-bottom: 18px; }
    .form-group label {
      display: block; font-size: 11px; font-weight: 600; letter-spacing: .08em;
      text-transform: uppercase; color: var(--text-2); margin-bottom: 8px;
    }
    .input-wrap { position: relative; }
    .input-wrap .icon {
      position: absolute; left: 15px; top: 50%; transform: translateY(-50%);
      color: var(--text-3); font-size: 14px; transition: color .18s;
    }
    .input-wrap input {
      width: 100%; padding: 13px 15px 13px 42px; border: 1.5px solid var(--border);
      border-radius: 11px; font-size: 14.5px; font-family: inherit; color: var(--text);
      background: #fff; transition: border-color .18s, box-shadow .18s;
    }
    .input-wrap input:focus {
      outline: none; border-color: var(--primary);
      box-shadow: 0 0 0 3.5px rgba(21,101,192,.13);
    }
    .input-wrap input:focus ~ .icon, .input-wrap:focus-within .icon { color: var(--primary); }
    .toggle-pw {
      position: absolute; right: 7px; top: 50%; transform: translateY(-50%);
      border: none; background: transparent; color: var(--text-3); cursor: pointer;
      width: 34px; height: 34px; border-radius: 8px; font-size: 13px;
    }
    .toggle-pw:hover { color: var(--primary); }

    .btn-login {
      width: 100%; padding: 14px; border: none; border-radius: 11px; cursor: pointer;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: #fff; font-size: 13.5px; font-weight: 600; font-family: var(--font-display);
      letter-spacing: .14em; text-indent: .14em; text-transform: uppercase;
      transition: filter .18s, transform .12s, box-shadow .18s;
      display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 8px;
    }
    .btn-login:hover { filter: brightness(1.08); box-shadow: 0 8px 22px rgba(13,71,161,.32); }
    .btn-login:active { transform: scale(.985); }
    .btn-login:focus-visible { outline: 3px solid var(--primary-light); outline-offset: 2px; }

    .login-footer { margin-top: 32px; text-align: center; font-size: 11.5px; color: var(--text-3); line-height: 1.6; }
    .login-footer strong { font-family: var(--font-display); font-weight: 600; letter-spacing: .05em; color: var(--text-2); }

    @media (max-width: 900px) {
      .brand-panel { display: none; }
      .mobile-mark { display: block; }
    }

    /* ============ CHUYỂN ĐỘNG (một nhịp mở màn, tôn trọng reduced-motion) ============ */
    @media (prefers-reduced-motion: no-preference) {
      .wm-dome .net-arc  { animation: draw 1s cubic-bezier(.4,0,.2,1) .1s forwards; }
      .wm-dome .net-line { animation: draw .9s ease-out .5s forwards; }
      .wm-dome .net-node { animation: pop .4s ease-out forwards; }
      <% for (let n = 1; n <= 12; n++) { %>.wm-dome .net-node:nth-of-type(<%= n %>) { animation-delay: <%= (0.55 + n * 0.06).toFixed(2) %>s; }
      <% } %>
      .wm-text .l { animation: rise .55s cubic-bezier(.2,.7,.3,1) forwards; }
      .wm-text .l:nth-child(1) { animation-delay: .15s; }
      .wm-text .l:nth-child(2) { animation-delay: .24s; }
      .wm-text .l:nth-child(3) { animation-delay: .33s; }
      .wm-text .l:nth-child(4) { animation-delay: .42s; }
      .wm-subline   { animation: fade .6s ease-out .75s forwards; }
      .brand-tagline{ animation: riseSoft .6s ease-out .9s forwards; }
      .brand-points { animation: riseSoft .6s ease-out 1.05s forwards; }
      .login-card   { animation: riseSoft .55s ease-out .25s forwards; }
      @keyframes draw     { to { stroke-dashoffset: 0; } }
      @keyframes pop      { from { opacity: 0; } to { opacity: 1; } }
      @keyframes rise     { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
      @keyframes riseSoft { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
      @keyframes fade     { to { opacity: 1; } }
    }
    @media (prefers-reduced-motion: reduce) {
      .wm-dome .net-arc, .wm-dome .net-line { stroke-dashoffset: 0; }
      .wm-dome .net-node, .wm-text .l, .wm-subline, .brand-tagline, .brand-points, .login-card {
        opacity: 1; transform: none;
      }
    }
  </style>
</head>
<body>
  <div class="brand-panel">
    <div class="brand-inner">
      <div class="lockup">
        <!-- Vòm mạng lưới — tái hiện quả cầu kết nối của logo RIAE -->
        <svg class="wm-dome" viewBox="0 0 340 170" aria-hidden="true">
          <path class="net-arc" pathLength="1" d="M14 166 A158 158 0 0 1 326 166"/>
          <g>
            <path class="net-line" pathLength="1" d="M62 106 L118 58 L170 92 L226 46 L281 104"/>
            <path class="net-line" pathLength="1" d="M118 58 L96 128 L170 92 M96 128 L62 106"/>
            <path class="net-line" pathLength="1" d="M96 128 L162 142 L170 92 M162 142 L226 46"/>
            <path class="net-line" pathLength="1" d="M162 142 L238 122 L281 104 M238 122 L226 46"/>
            <path class="net-line" pathLength="1" d="M170 20 L118 58 M170 20 L226 46"/>
          </g>
          <g>
            <circle class="net-node" cx="62"  cy="106" r="5"/>
            <circle class="net-node bright" cx="118" cy="58"  r="7"/>
            <circle class="net-node" cx="170" cy="92"  r="6"/>
            <circle class="net-node bright" cx="226" cy="46"  r="6"/>
            <circle class="net-node" cx="281" cy="104" r="5.5"/>
            <circle class="net-node" cx="96"  cy="128" r="7"/>
            <circle class="net-node bright" cx="162" cy="142" r="8"/>
            <circle class="net-node" cx="238" cy="122" r="5.5"/>
            <circle class="net-node" cx="170" cy="20"  r="5"/>
          </g>
        </svg>
        <!-- Wordmark RiAE bằng font Chakra Petch -->
        <div class="wm-text" role="img" aria-label="RiAE">
          <span class="l">R</span><span class="l l-i">&#305;</span><span class="l l-a">A</span><span class="l">E</span>
        </div>
        <div class="wm-subline">CÔNG TY TNHH KỸ THUẬT CÔNG NGHỆ</div>
      </div>

      <p class="brand-tagline">
        Nền tảng quản trị nội bộ tập trung — dự án, nhân sự,<br>kho vật tư và phê duyệt trong một hệ thống.
      </p>

      <div class="brand-points">
        <div class="brand-point"><i class="fas fa-diagram-project"></i>Dự án &amp; quy trình</div>
        <div class="brand-point"><i class="fas fa-shield-halved"></i>Phân quyền theo vai trò</div>
        <div class="brand-point"><i class="fas fa-file-signature"></i>Phê duyệt &amp; chữ ký số</div>
      </div>
    </div>
  </div>

  <div class="form-panel">
    <main class="login-card">
      <div class="mobile-mark">
        <div class="wm-text" role="img" aria-label="RiAE">
          <span class="l">R</span><span class="l l-i">&#305;</span><span class="l l-a">A</span><span class="l">E</span>
        </div>
        <div class="m-sub">KỸ THUẬT CÔNG NGHỆ</div>
      </div>

      <h2>Đăng nhập</h2>
      <p class="sub">Sử dụng tài khoản nội bộ được cấp bởi quản trị viên</p>

      <% if (messages && messages.error && messages.error.length > 0) { %>
      <div class="flash flash-error" role="alert"><i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %></div>
      <% } %>
      <% if (messages && messages.success && messages.success.length > 0) { %>
      <div class="flash flash-success" role="status"><i class="fas fa-check-circle"></i> <%= messages.success[0] %></div>
      <% } %>

      <form action="/auth/login" method="POST" autocomplete="on">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="username">Tên đăng nhập / Email</label>
          <div class="input-wrap">
            <i class="fas fa-user icon" aria-hidden="true"></i>
            <input type="text" id="username" name="username" required autofocus
                   autocomplete="username" placeholder="vd: nguyenvana">
          </div>
        </div>
        <div class="form-group">
          <label for="password">Mật khẩu</label>
          <div class="input-wrap">
            <i class="fas fa-lock icon" aria-hidden="true"></i>
            <input type="password" id="password" name="password" required
                   autocomplete="current-password" placeholder="••••••••">
            <button type="button" class="toggle-pw" aria-label="Hiện/ẩn mật khẩu"
                    onclick="var p=document.getElementById('password');p.type=p.type==='password'?'text':'password';this.firstElementChild.classList.toggle('fa-eye-slash')">
              <i class="fas fa-eye" aria-hidden="true"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn-login">Đăng nhập <i class="fas fa-arrow-right" aria-hidden="true"></i></button>
      </form>

      <p class="login-footer">
        © <%= new Date().getFullYear() %> <strong>RiAE</strong> · Công ty TNHH Kỹ thuật Công nghệ
      </p>
    </main>
  </div>
</body>
</html>
