<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - RIAE Management</title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #1565C0;
      --primary-dark: #0D47A1;
      --primary-light: #42A5F5;
      --sky: #7EC3F7;
      --navy: #0D1B3E;
      --navy-2: #12275A;
      --danger: #F87171;
      --danger-bg: rgba(220,38,38,.18);
      --success: #4ADE80;
      --success-bg: rgba(22,163,74,.18);
      --font-display: 'Chakra Petch', 'Inter', sans-serif;
      --font-body: 'Inter', -apple-system, sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: var(--font-body); min-height: 100vh; overflow: hidden;
      background:
        radial-gradient(1200px 700px at 80% -10%, rgba(21,101,192,.4), transparent 60%),
        radial-gradient(1000px 800px at -10% 110%, rgba(66,165,245,.16), transparent 55%),
        linear-gradient(160deg, #060D22 0%, var(--navy) 45%, var(--navy-2) 100%);
    }

    /* ===== Cảnh 3D nền (Three.js) ===== */
    #bg3d { position: fixed; inset: 0; width: 100%; height: 100%; display: block; z-index: 0; }
    /* vignette nhẹ để card nổi khối */
    .vignette {
      position: fixed; inset: 0; z-index: 1; pointer-events: none;
      background: radial-gradient(120% 90% at 50% 45%, transparent 55%, rgba(4,9,24,.55) 100%);
    }

    /* ===== Lớp giao diện phủ trên cảnh 3D ===== */
    .stage {
      position: relative; z-index: 2; min-height: 100vh;
      display: flex; align-items: center; justify-content: flex-start;
      padding: 36px clamp(24px, 7vw, 120px);
    }

    /* ---- Cột trái: logo trên, khung đăng nhập dưới; nửa phải dành cho cảnh 3D ---- */
    .side-col { display: flex; flex-direction: column; gap: 26px; width: min(400px, 100%); }

    .brand { color: #fff; }
    .wm-text {
      font-family: var(--font-display); font-weight: 700; line-height: 1;
      font-size: clamp(54px, 6vw, 76px); letter-spacing: .01em;
      display: flex; align-items: baseline;
      filter: drop-shadow(0 0 26px rgba(66,165,245,.45));
    }
    .wm-text .l { color: #fff; opacity: 0; transform: translateY(18px); }
    .wm-text .l-a { color: var(--primary-light); }
    .wm-text .l-i { position: relative; color: #fff; }
    .wm-text .l-i::after {
      content: ''; position: absolute; left: 50%; transform: translateX(-50%);
      top: .06em; width: .16em; height: .16em; border-radius: 50%;
      background: var(--primary-light);
      box-shadow: 0 0 16px rgba(66,165,245,.95), 0 0 34px rgba(66,165,245,.5);
      animation: iPulse 2.6s ease-in-out 1.4s infinite;
    }
    @keyframes iPulse {
      0%, 100% { box-shadow: 0 0 16px rgba(66,165,245,.95), 0 0 34px rgba(66,165,245,.5); }
      50%      { box-shadow: 0 0 26px rgba(126,195,247,1), 0 0 60px rgba(66,165,245,.85); }
    }
    .wm-subline {
      margin-top: 14px; display: flex; align-items: center; gap: 14px;
      font-family: var(--font-display); font-weight: 500;
      font-size: clamp(10px, 1vw, 11.5px); letter-spacing: .26em; text-indent: .26em;
      color: #B9C6E4; white-space: nowrap; opacity: 0;
    }
    .wm-subline::after {
      content: ''; height: 1.5px; flex: 1; min-width: 30px;
      background: linear-gradient(90deg, var(--primary-light), transparent);
    }
    .brand-tagline { display: none; }

    .brand-chips { margin-top: 18px; display: flex; flex-wrap: wrap; gap: 8px; opacity: 0; }
    .chip {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 6px 12px; border-radius: 20px; font-size: 11.5px; color: #CBD8F2;
      border: 1px solid rgba(126,195,247,.28);
      background: rgba(18,39,90,.42); backdrop-filter: blur(6px);
      transition: border-color .25s, color .25s, transform .25s;
    }
    .chip i { color: var(--sky); font-size: 12px; }
    .chip:hover { border-color: var(--sky); color: #fff; transform: translateY(-2px); }

    /* ---- Card đăng nhập kính mờ (dưới logo) ---- */
    .login-card {
      width: 100%; flex-shrink: 0;
      background: rgba(11, 24, 56, .62);
      border: 1px solid rgba(126,195,247,.22);
      border-radius: 20px; padding: 38px 34px;
      backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
      box-shadow: 0 24px 70px rgba(2,6,18,.55), inset 0 1px 0 rgba(255,255,255,.07);
      opacity: 0; transform: translateY(16px);
    }
    .card-mark { display: flex; align-items: center; gap: 13px; margin-bottom: 26px; }
    .card-logo {
      width: 46px; height: 46px; border-radius: 12px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 700; font-size: 21px; color: #fff;
      box-shadow: 0 0 22px rgba(66,165,245,.55);
    }
    .card-mark small { display: block; font-size: 10.5px; letter-spacing: .22em; color: #8FA5CE; font-family: var(--font-display); }
    .card-mark strong { display: block; font-size: 16px; color: #fff; font-family: var(--font-display); letter-spacing: .04em; }

    .login-card h2 { font-family: var(--font-display); font-weight: 700; font-size: 23px; color: #fff; margin-bottom: 4px; }
    .login-card .sub { font-size: 13px; color: #93A7CF; margin-bottom: 26px; }

    .flash { display: flex; align-items: center; gap: 10px; padding: 12px 14px; border-radius: 10px; font-size: 13px; margin-bottom: 18px; border: 1px solid transparent; }
    .flash-error { background: var(--danger-bg); color: var(--danger); border-color: rgba(248,113,113,.3); }
    .flash-success { background: var(--success-bg); color: var(--success); border-color: rgba(74,222,128,.3); }

    .form-group { margin-bottom: 17px; }
    .form-group label {
      display: block; font-size: 10.5px; font-weight: 600; letter-spacing: .1em;
      text-transform: uppercase; color: #8FA5CE; margin-bottom: 8px;
    }
    .input-wrap { position: relative; }
    .input-wrap .icon {
      position: absolute; left: 15px; top: 50%; transform: translateY(-50%);
      color: #6B82B4; font-size: 14px; transition: color .18s;
    }
    .input-wrap input {
      width: 100%; padding: 13px 15px 13px 42px;
      border: 1.5px solid rgba(126,195,247,.22); border-radius: 11px;
      font-size: 14.5px; font-family: inherit; color: #fff;
      background: rgba(6,13,34,.55); transition: border-color .2s, box-shadow .2s, background .2s;
    }
    .input-wrap input::placeholder { color: #55688F; }
    .input-wrap input:focus {
      outline: none; border-color: var(--primary-light);
      background: rgba(6,13,34,.8);
      box-shadow: 0 0 0 3.5px rgba(66,165,245,.18), 0 0 24px rgba(66,165,245,.12);
    }
    .input-wrap:focus-within .icon { color: var(--primary-light); }
    .toggle-pw {
      position: absolute; right: 7px; top: 50%; transform: translateY(-50%);
      border: none; background: transparent; color: #6B82B4; cursor: pointer;
      width: 34px; height: 34px; border-radius: 8px; font-size: 13px;
    }
    .toggle-pw:hover { color: var(--sky); }

    .btn-login {
      width: 100%; padding: 14px; border: none; border-radius: 11px; cursor: pointer;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: #fff; font-size: 13.5px; font-weight: 600; font-family: var(--font-display);
      letter-spacing: .14em; text-indent: .14em; text-transform: uppercase;
      transition: filter .18s, transform .15s cubic-bezier(.32,.72,0,1), box-shadow .2s;
      display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 8px;
      box-shadow: 0 10px 30px rgba(13,71,161,.45);
    }
    .btn-login:hover { filter: brightness(1.12); box-shadow: 0 12px 36px rgba(21,101,192,.6), 0 0 24px rgba(66,165,245,.35); }
    .btn-login:active { transform: scale(.97); }
    .btn-login:focus-visible { outline: 3px solid var(--primary-light); outline-offset: 2px; }

    .login-footer { margin-top: 28px; text-align: center; font-size: 11.5px; color: #6B82B4; line-height: 1.6; }
    .login-footer strong { font-family: var(--font-display); font-weight: 600; letter-spacing: .05em; color: #93A7CF; }

    /* ---- Responsive: màn hẹp → cột vào giữa, cảnh 3D làm nền ---- */
    @media (max-width: 980px) {
      body { overflow: auto; }
      .stage { justify-content: center; padding: 36px 20px; }
      .brand { text-align: center; }
      .wm-text { justify-content: center; }
      .wm-subline { justify-content: center; }
      .wm-subline::after { display: none; }
      .brand-chips { justify-content: center; }
    }
    @media (max-height: 760px) {
      .side-col { gap: 18px; }
      .wm-text { font-size: 48px; }
      .brand-chips { display: none; }
    }

    /* ---- Mở màn ---- */
    @media (prefers-reduced-motion: no-preference) {
      .wm-text .l { animation: rise .55s cubic-bezier(.2,.7,.3,1) forwards; }
      .wm-text .l:nth-child(1) { animation-delay: .15s; }
      .wm-text .l:nth-child(2) { animation-delay: .24s; }
      .wm-text .l:nth-child(3) { animation-delay: .33s; }
      .wm-text .l:nth-child(4) { animation-delay: .42s; }
      .wm-subline   { animation: fade .6s ease-out .65s forwards; }
      .brand-tagline{ animation: riseSoft .6s ease-out .8s forwards; }
      .brand-chips  { animation: riseSoft .6s ease-out .95s forwards; }
      .login-card   { animation: riseSoft .6s cubic-bezier(.32,.72,0,1) .3s forwards; }
      @keyframes rise     { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
      @keyframes riseSoft { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
      @keyframes fade     { to { opacity: 1; } }
    }
    @media (prefers-reduced-motion: reduce) {
      .wm-text .l, .wm-subline, .brand-tagline, .brand-chips, .login-card { opacity: 1; transform: none; }
      .wm-text .l-i::after { animation: none; }
    }
  </style>
</head>
<body>
  <canvas id="bg3d" aria-hidden="true"></canvas>
  <div class="vignette" aria-hidden="true"></div>

  <div class="stage">
    <div class="side-col">
      <!-- Logo + ngành nghề điện nhẹ (trên) -->
      <div class="brand">
        <div class="wm-text" role="img" aria-label="RiAE">
          <span class="l">R</span><span class="l l-i">&#305;</span><span class="l l-a">A</span><span class="l">E</span>
        </div>
        <div class="wm-subline">CÔNG TY TNHH KỸ THUẬT CÔNG NGHỆ</div>
        <div class="brand-chips">
          <span class="chip"><i class="fas fa-video"></i>Camera giám sát</span>
          <span class="chip"><i class="fas fa-network-wired"></i>Hạ tầng mạng</span>
          <span class="chip"><i class="fas fa-fingerprint"></i>Kiểm soát ra vào</span>
          <span class="chip"><i class="fas fa-volume-high"></i>Âm thanh PA</span>
          <span class="chip"><i class="fas fa-bell"></i>Báo cháy</span>
        </div>
      </div>

      <!-- Card đăng nhập (dưới) -->
      <main class="login-card">
      <h2>Đăng nhập</h2>
      <p class="sub">Sử dụng tài khoản nội bộ được cấp bởi quản trị viên</p>

      <% if (messages && messages.error && messages.error.length > 0) { %>
      <div class="flash flash-error" role="alert"><i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %></div>
      <% } %>
      <% if (messages && messages.success && messages.success.length > 0) { %>
      <div class="flash flash-success" role="status"><i class="fas fa-check-circle"></i> <%= messages.success[0] %></div>
      <% } %>

      <form action="/auth/login" method="POST" autocomplete="on">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="username">Tên đăng nhập / Email</label>
          <div class="input-wrap">
            <i class="fas fa-user icon" aria-hidden="true"></i>
            <input type="text" id="username" name="username" required autofocus
                   autocomplete="username" placeholder="vd: nguyenvana">
          </div>
        </div>
        <div class="form-group">
          <label for="password">Mật khẩu</label>
          <div class="input-wrap">
            <i class="fas fa-lock icon" aria-hidden="true"></i>
            <input type="password" id="password" name="password" required
                   autocomplete="current-password" placeholder="••••••••">
            <button type="button" class="toggle-pw" aria-label="Hiện/ẩn mật khẩu"
                    onclick="var p=document.getElementById('password');p.type=p.type==='password'?'text':'password';this.firstElementChild.classList.toggle('fa-eye-slash')">
              <i class="fas fa-eye" aria-hidden="true"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn-login">Đăng nhập <i class="fas fa-arrow-right" aria-hidden="true"></i></button>
      </form>

      <p class="login-footer">
        © <%= new Date().getFullYear() %> <strong>RiAE</strong> · Công ty TNHH Kỹ thuật Công nghệ
      </p>
      </main>
    </div><!-- /side-col -->
  </div>

  <script src="https://cdn.jsdelivr.net/npm/three@0.147.0/build/three.min.js"></script>
  <script>
  // ============================================================
  // Cảnh 3D "tòa nhà thông minh — điện nhẹ": tòa nhà wireframe với
  // các thiết bị ELV (camera, AP wifi, đầu đọc thẻ, loa...) là những
  // nút phát sáng, nối nhau bằng luồng dữ liệu chạy — tái hiện quả
  // cầu kết nối của logo RiAE trong không gian 3 chiều.
  // ============================================================
  (function () {
    if (typeof THREE === 'undefined') return; // CDN lỗi → giữ nền gradient
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var canvas = document.getElementById('bg3d');
    var renderer;
    try {
      renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: true, alpha: true });
    } catch (e) { return; } // không có WebGL → giữ nền gradient
    var isMobile = window.innerWidth < 700;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    var scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x0a1633, 0.055);

    var camera = new THREE.PerspectiveCamera(55, 1, 0.1, 100);
    var CAM_BASE = { x: 0, y: 3.4, z: 11.5 };
    camera.position.set(CAM_BASE.x, CAM_BASE.y, CAM_BASE.z);

    // ---------- Texture chấm sáng (vẽ canvas, không cần tải ảnh) ----------
    function glowTexture(inner, outer) {
      var c = document.createElement('canvas'); c.width = c.height = 64;
      var g = c.getContext('2d');
      var grad = g.createRadialGradient(32, 32, 0, 32, 32, 32);
      grad.addColorStop(0, inner);
      grad.addColorStop(0.35, outer);
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      g.fillStyle = grad; g.fillRect(0, 0, 64, 64);
      return new THREE.CanvasTexture(c);
    }
    var texNode = glowTexture('rgba(255,255,255,1)', 'rgba(126,195,247,.85)');
    var texPulse = glowTexture('rgba(255,255,255,1)', 'rgba(66,165,245,.9)');

    var world = new THREE.Group();
    scene.add(world);

    // ---------- Sàn lưới (Tron) ----------
    var grid = new THREE.GridHelper(60, 60, 0x1565C0, 0x11275a);
    grid.material.transparent = true;
    grid.material.opacity = 0.32;
    world.add(grid);

    // ---------- Tòa nhà wireframe ----------
    var lineMat = new THREE.LineBasicMaterial({ color: 0x42A5F5, transparent: true, opacity: 0.5 });
    var lineMatDim = new THREE.LineBasicMaterial({ color: 0x2a5fa8, transparent: true, opacity: 0.3 });

    function wireBox(w, h, d, x, z, mat) {
      var geo = new THREE.BoxGeometry(w, h, d);
      var edges = new THREE.LineSegments(new THREE.EdgesGeometry(geo), mat);
      edges.position.set(x, h / 2, z);
      world.add(edges);
      // vạch các tầng
      var floors = Math.max(2, Math.round(h / 0.62));
      for (var i = 1; i < floors; i++) {
        var y = (h / floors) * i;
        var fg = new THREE.BufferGeometry().setFromPoints([
          new THREE.Vector3(-w / 2, y, d / 2), new THREE.Vector3(w / 2, y, d / 2),
          new THREE.Vector3(w / 2, y, -d / 2), new THREE.Vector3(-w / 2, y, -d / 2)
        ]);
        var fl = new THREE.Line(fg, lineMatDim);
        fl.position.set(x, 0, z);
        world.add(fl);
      }
      return edges;
    }
    wireBox(3.2, 5.6, 3.2, 0, 0, lineMat);        // tháp chính
    wireBox(2.2, 3.4, 2.2, -3.4, 0.6, lineMatDim); // khối phụ trái
    wireBox(2.0, 2.4, 2.6, 3.3, -0.4, lineMatDim); // khối phụ phải

    // ---------- Cửa sổ sáng (nhấp nháy nhẹ) ----------
    var winGeo = new THREE.PlaneGeometry(0.3, 0.18);
    var windows = [];
    function addWindows(cx, cz, w, h, d, count) {
      for (var i = 0; i < count; i++) {
        var m = new THREE.MeshBasicMaterial({
          color: Math.random() > 0.75 ? 0x7EC3F7 : 0x1e88e5,
          transparent: true, opacity: 0.25 + Math.random() * 0.5, side: THREE.DoubleSide
        });
        var win = new THREE.Mesh(winGeo, m);
        var face = Math.floor(Math.random() * 4);
        var fx = (Math.random() - 0.5) * (w - 0.5);
        var fy = 0.4 + Math.random() * (h - 0.8);
        if (face === 0)      win.position.set(cx + fx, fy, cz + d / 2 + 0.01);
        else if (face === 1) { win.position.set(cx + fx, fy, cz - d / 2 - 0.01); }
        else if (face === 2) { win.position.set(cx + w / 2 + 0.01, fy, cz + fx * (d / w)); win.rotation.y = Math.PI / 2; }
        else                 { win.position.set(cx - w / 2 - 0.01, fy, cz + fx * (d / w)); win.rotation.y = Math.PI / 2; }
        win.userData.phase = Math.random() * Math.PI * 2;
        win.userData.base = m.opacity;
        world.add(win); windows.push(win);
      }
    }
    addWindows(0, 0, 3.2, 5.6, 3.2, isMobile ? 22 : 46);
    addWindows(-3.4, 0.6, 2.2, 3.4, 2.2, isMobile ? 8 : 18);
    addWindows(3.3, -0.4, 2.0, 2.4, 2.6, isMobile ? 6 : 14);

    // ---------- Nút thiết bị điện nhẹ (quanh + trên tòa nhà) ----------
    var NODES = [
      [ 1.7, 5.75,  1.7], [-1.7, 5.75, -1.7],           // camera góc mái
      [ 0,   6.3,   0],                                  // anten/AP trung tâm
      [-3.4, 3.55,  1.7], [ 3.3, 2.55, -1.6],           // AP các khối
      [ 1.75, 1.2,  1.75], [-1.75, 2.4, -1.75],         // đầu đọc thẻ / cảm biến
      [-5.6, 0.9,  -2.2], [ 5.7, 1.1,  2.4],            // trụ camera ngoài
      [ 4.6, 4.4,  -3.6], [-4.9, 5.0,   3.2]            // nút "vệ tinh" như logo
    ];
    var nodeSprites = [];
    NODES.forEach(function (p, idx) {
      var mat = new THREE.SpriteMaterial({ map: texNode, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false });
      var s = new THREE.Sprite(mat);
      s.position.set(p[0], p[1], p[2]);
      var big = idx === 2 || idx >= 9;
      s.scale.setScalar(big ? 0.55 : 0.38);
      s.userData.phase = Math.random() * Math.PI * 2;
      s.userData.base = big ? 0.55 : 0.38;
      world.add(s); nodeSprites.push(s);
    });

    // ---------- Đường kết nối cong + gói dữ liệu chạy ----------
    var LINKS = [[2,0],[2,1],[2,3],[2,4],[0,5],[1,6],[3,7],[4,8],[2,9],[2,10],[9,4],[10,3],[7,8]];
    var curves = [];
    LINKS.forEach(function (lk) {
      var a = new THREE.Vector3().fromArray(NODES[lk[0]]);
      var b = new THREE.Vector3().fromArray(NODES[lk[1]]);
      var mid = a.clone().add(b).multiplyScalar(0.5);
      mid.y += a.distanceTo(b) * 0.28; // vồng lên như dây tín hiệu
      var curve = new THREE.QuadraticBezierCurve3(a, mid, b);
      curves.push(curve);
      var pts = curve.getPoints(36);
      var lg = new THREE.BufferGeometry().setFromPoints(pts);
      world.add(new THREE.Line(lg, new THREE.LineBasicMaterial({
        color: 0x42A5F5, transparent: true, opacity: 0.28
      })));
    });
    // các "gói dữ liệu" phát sáng chạy dọc đường nối
    var pulses = [];
    var PULSES_PER_LINK = isMobile ? 1 : 2;
    curves.forEach(function (curve) {
      for (var i = 0; i < PULSES_PER_LINK; i++) {
        var mat = new THREE.SpriteMaterial({ map: texPulse, transparent: true, blending: THREE.AdditiveBlending, depthWrite: false });
        var s = new THREE.Sprite(mat);
        s.scale.setScalar(0.22);
        s.userData.curve = curve;
        s.userData.t = Math.random();
        s.userData.speed = 0.0016 + Math.random() * 0.0022;
        world.add(s); pulses.push(s);
      }
    });

    // ---------- Hạt lơ lửng ----------
    var pGeo = new THREE.BufferGeometry();
    var P_COUNT = isMobile ? 90 : 220;
    var pos = new Float32Array(P_COUNT * 3);
    for (var i = 0; i < P_COUNT; i++) {
      pos[i * 3] = (Math.random() - 0.5) * 44;
      pos[i * 3 + 1] = Math.random() * 14;
      pos[i * 3 + 2] = (Math.random() - 0.5) * 44;
    }
    pGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    var particles = new THREE.Points(pGeo, new THREE.PointsMaterial({
      map: texNode, color: 0x7EC3F7, size: 0.14, transparent: true, opacity: 0.5,
      blending: THREE.AdditiveBlending, depthWrite: false
    }));
    world.add(particles);

    // ---------- Parallax theo chuột + quay chậm ----------
    var mouse = { x: 0, y: 0 };
    window.addEventListener('pointermove', function (e) {
      mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
      mouse.y = (e.clientY / window.innerHeight) * 2 - 1;
    });

    function resize() {
      var w = window.innerWidth, h = window.innerHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      // Màn rộng: cột đăng nhập bên trái → dịch cả cảnh 3D sang nửa phải;
      // màn hẹp: cột vào giữa → cảnh 3D quay lại làm nền trung tâm
      world.position.x = w > 980 ? 4.6 : 0;
    }
    window.addEventListener('resize', resize);
    resize();

    var clock = new THREE.Clock();
    function frame() {
      var t = clock.getElapsedTime();

      if (!reduced) {
        world.rotation.y = t * 0.055 + mouse.x * 0.12;
        camera.position.y = CAM_BASE.y - mouse.y * 0.7;
        camera.lookAt(0, 2.4, 0);

        // gói dữ liệu chạy dọc đường nối
        for (var i = 0; i < pulses.length; i++) {
          var p = pulses[i];
          p.userData.t = (p.userData.t + p.userData.speed) % 1;
          var v = p.userData.curve.getPoint(p.userData.t);
          p.position.copy(v);
          p.material.opacity = 0.55 + 0.45 * Math.sin(p.userData.t * Math.PI);
        }
        // nút thở nhẹ
        for (var j = 0; j < nodeSprites.length; j++) {
          var n = nodeSprites[j];
          n.scale.setScalar(n.userData.base * (1 + 0.16 * Math.sin(t * 1.8 + n.userData.phase)));
        }
        // cửa sổ nhấp nháy
        for (var k = 0; k < windows.length; k++) {
          var wn = windows[k];
          wn.material.opacity = wn.userData.base * (0.75 + 0.25 * Math.sin(t * 0.9 + wn.userData.phase));
        }
        particles.rotation.y = -t * 0.012;
      } else {
        camera.lookAt(0, 2.4, 0);
      }

      renderer.render(scene, camera);
      if (!reduced) requestAnimationFrame(frame);
    }
    frame(); // reduced-motion: render đúng 1 khung tĩnh
  })();
  </script>
</body>
</html>
