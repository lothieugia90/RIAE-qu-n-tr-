<%
const ROLE_LABELS = {
  admin:'Quản trị viên', director:'Ban lãnh đạo', pm:'Quản lý Dự án',
  head_tech:'Trưởng phòng KT', head_hr:'Trưởng phòng NS', head_sales:'Trưởng phòng KD',
  engineer:'Kỹ sư', field_supervisor:'Giám sát hiện trường', tech_deploy:'Kỹ thuật triển khai',
  hr:'Nhân sự', warehouse:'Nhân viên Kho', warehouse_keeper:'Thủ kho', accountant:'Kế toán'
};
const CONTRACT_LABELS = { 'Thử việc':'Thử việc', 'Chính thức':'Chính thức', 'Thời vụ':'Thời vụ', 'Cộng tác viên':'Cộng tác viên' };
%>

<div class="page-header">
  <div class="page-header-title">
    <h1>Hồ sơ cá nhân</h1>
    <p>Thông tin tài khoản, công việc và bảo mật</p>
  </div>
</div>

<!-- ===== Hero: avatar + tên + liên hệ (1 form dùng chung) ===== -->
<div class="card profile-hero">
  <form action="/auth/profile?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="hero-row">
      <button type="button" class="avatar-edit" onclick="document.getElementById('avatarInput').click()" title="Đổi ảnh đại diện" aria-label="Đổi ảnh đại diện">
        <img id="avatarPreview" src="<%= profile.avatar_url || '' %>" alt="" style="display:<%= profile.avatar_url ? 'block' : 'none' %>">
        <span id="avatarInitial" style="display:<%= profile.avatar_url ? 'none' : 'flex' %>"><%= profile.full_name.charAt(0).toUpperCase() %></span>
        <span class="avatar-cam"><i class="fas fa-camera"></i></span>
      </button>
      <input type="file" id="avatarInput" name="avatar" accept=".jpg,.jpeg,.png,.webp" style="display:none" onchange="previewAvatar(this)">

      <div class="hero-info">
        <input type="text" name="full_name" class="hero-name-input" value="<%= profile.full_name %>" required maxlength="100" placeholder="Họ và tên">
        <div class="hero-badges">
          <span class="badge badge-info"><%= ROLE_LABELS[profile.role] || profile.role %></span>
          <% if (profile.department) { %><span class="badge badge-info" style="background:var(--border-light);color:var(--text-2)"><%= profile.department %></span><% } %>
          <% if (profile.position) { %><span class="badge badge-info" style="background:var(--border-light);color:var(--text-2)"><%= profile.position %></span><% } %>
        </div>
        <div class="hero-meta">
          <span><i class="fas fa-envelope"></i> <%= profile.email %></span>
          <% if (profile.employee_code) { %><span><i class="fas fa-id-badge"></i> <%= profile.employee_code %></span><% } %>
          <% if (profile.hire_date) { %><span><i class="fas fa-calendar-check"></i> Vào làm <%= fmtDate(profile.hire_date) %></span><% } %>
          <span><i class="fas fa-clock"></i> Hoạt động <%= profile.last_seen_at ? fmtDateTime(profile.last_seen_at) : '—' %></span>
        </div>
      </div>

      <div class="hero-phone form-group">
        <label for="phone">Số điện thoại</label>
        <input type="tel" id="phone" name="phone" class="form-control" value="<%= profile.phone || '' %>" placeholder="Chưa cập nhật">
      </div>
    </div>
    <div class="hero-actions">
      <small style="color:var(--text-3);margin-right:auto">Bấm vào ảnh để đổi ảnh đại diện (JPG/PNG/WebP, tối đa 2MB)</small>
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu thay đổi</button>
    </div>
  </form>
</div>

<!-- ===== Thống kê nhanh ===== -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--primary-50);color:var(--primary)"><i class="fas fa-list-check"></i></div>
    <div class="stat-value"><%= taskStats.done %>/<%= taskStats.total %></div>
    <div class="stat-label">Task hoàn thành</div>
    <% if (taskStats.overdue > 0) { %><div class="stat-sub" style="color:var(--danger)"><%= taskStats.overdue %> quá hạn</div><% } %>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--info-bg);color:var(--info)"><i class="fas fa-folder-open"></i></div>
    <div class="stat-value"><%= projectCount %></div>
    <div class="stat-label">Dự án tham gia</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--success-bg);color:var(--success)"><i class="fas fa-calendar-check"></i></div>
    <div class="stat-value"><%= attendanceSummary.work_days %></div>
    <div class="stat-label">Công tháng này</div>
    <% if (attendanceSummary.ot_hours > 0) { %><div class="stat-sub" style="color:var(--success)">+<%= attendanceSummary.ot_hours %>h tăng ca</div><% } %>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:<%= attendanceSummary.late_days > 0 ? 'var(--warning-bg)' : 'var(--success-bg)' %>;color:<%= attendanceSummary.late_days > 0 ? 'var(--warning)' : 'var(--success)' %>"><i class="fas fa-user-clock"></i></div>
    <div class="stat-value"><%= attendanceSummary.late_days %></div>
    <div class="stat-label">Lần đi trễ tháng này</div>
  </div>
</div>

<div class="profile-grid">
  <div class="profile-main">
    <!-- Thông tin công việc (chỉ đọc — sửa tại module Nhân sự) -->
    <div class="card">
      <div class="card-header"><h3>Thông tin công việc</h3></div>
      <div class="card-body">
        <div class="pd-info-grid">
          <div><label>Tên đăng nhập</label><span><%= profile.username %></span></div>
          <div><label>Phòng ban</label><span><%= profile.department || '—' %></span></div>
          <div><label>Chức vụ</label><span><%= profile.position || '—' %></span></div>
          <div><label>Loại hợp đồng</label><span><%= CONTRACT_LABELS[profile.contract_type] || profile.contract_type || '—' %></span></div>
          <div><label>Ngày sinh</label><span><%= fmtDate(profile.date_of_birth) %></span></div>
          <div><label>Ngày vào làm</label><span><%= fmtDate(profile.hire_date) %></span></div>
          <div><label>Địa chỉ</label><span><%= profile.address || '—' %></span></div>
          <div><label>Tài khoản NH</label><span><%= [profile.bank_account, profile.bank_name].filter(Boolean).join(' · ') || '—' %></span></div>
        </div>
        <p class="pd-note"><i class="fas fa-circle-info"></i> Thông tin hồ sơ nhân sự do phòng Nhân sự cập nhật. Liên hệ HR nếu cần chỉnh sửa.</p>
      </div>
    </div>

    <!-- Hoạt động gần đây -->
    <div class="card">
      <div class="card-header"><h3>Hoạt động gần đây</h3></div>
      <div class="card-body" style="padding:0">
        <% if (recentActivity.length === 0) { %>
        <p style="text-align:center;padding:24px;color:var(--text-3)">Chưa có hoạt động nào được ghi nhận</p>
        <% } %>
        <% recentActivity.forEach(log => { %>
        <div class="activity-row">
          <span class="badge badge-info"><%= log.action %></span>
          <span class="activity-desc"><%= log.description %></span>
          <small class="activity-time"><%= fmtDateTime(log.created_at) %></small>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <div class="profile-side">
    <div class="card">
      <div class="card-header"><h3>Chữ ký nội bộ</h3></div>
      <div class="card-body">
        <% if (profile.signature_url) { %>
        <div style="margin-bottom:12px">
          <label style="font-size:11px;font-weight:600;text-transform:uppercase;color:var(--text-3)">Chữ ký hiện tại</label>
          <div style="border:1.5px solid var(--border);border-radius:10px;padding:8px;background:#fff;margin-top:6px">
            <img src="<%= profile.signature_url %>" alt="Chữ ký" style="max-height:80px">
          </div>
        </div>
        <% } %>
        <label style="font-size:11px;font-weight:600;text-transform:uppercase;color:var(--text-3)">Vẽ chữ ký mới</label>
        <canvas id="sigPad" width="440" height="140"
                style="border:1.5px dashed var(--border);border-radius:10px;background:#fff;width:100%;touch-action:none;cursor:crosshair;margin-top:6px"></canvas>
        <div style="display:flex;gap:8px;margin-top:10px">
          <button type="button" class="btn btn-outline btn-sm" onclick="clearSig()"><i class="fas fa-eraser"></i> Xóa</button>
          <form action="/auth/signature" method="POST" id="sigForm" style="margin-left:auto">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="signature_data" id="sigData">
            <button type="submit" class="btn btn-primary btn-sm" onclick="return prepareSig()"><i class="fas fa-save"></i> Lưu chữ ký</button>
          </form>
        </div>
        <small style="color:var(--text-3);font-size:11.5px;display:block;margin-top:8px">
          Chữ ký hiển thị trên các bước phê duyệt bạn đã ký duyệt.
        </small>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h3>Đổi mật khẩu</h3></div>
      <div class="card-body">
        <form action="/auth/change-password" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-group">
            <label for="current_password">Mật khẩu hiện tại</label>
            <input type="password" id="current_password" name="current_password" class="form-control" required autocomplete="current-password">
          </div>
          <div class="form-group">
            <label for="new_password">Mật khẩu mới (tối thiểu 8 ký tự)</label>
            <input type="password" id="new_password" name="new_password" class="form-control" required minlength="8" autocomplete="new-password">
          </div>
          <div class="form-group">
            <label for="confirm_password">Xác nhận mật khẩu mới</label>
            <input type="password" id="confirm_password" name="confirm_password" class="form-control" required minlength="8" autocomplete="new-password">
          </div>
          <button type="submit" class="btn btn-primary"><i class="fas fa-key"></i> Đổi mật khẩu</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
function previewAvatar(input) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  if (file.size > 2 * 1024 * 1024) { alert('Ảnh vượt quá 2MB, vui lòng chọn ảnh nhỏ hơn'); input.value = ''; return; }
  const url = URL.createObjectURL(file);
  const img = document.getElementById('avatarPreview');
  img.src = url;
  img.style.display = 'block';
  document.getElementById('avatarInitial').style.display = 'none';
}

(function() {
  const canvas = document.getElementById('sigPad');
  const ctx = canvas.getContext('2d');
  ctx.strokeStyle = '#0D1B3E'; ctx.lineWidth = 2.2; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  let drawing = false, hasInk = false;

  function pos(e) {
    const r = canvas.getBoundingClientRect();
    const p = e.touches ? e.touches[0] : e;
    return { x: (p.clientX - r.left) * (canvas.width / r.width), y: (p.clientY - r.top) * (canvas.height / r.height) };
  }
  function start(e) { drawing = true; hasInk = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); e.preventDefault(); }
  function move(e) { if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); e.preventDefault(); }
  function end() { drawing = false; }

  canvas.addEventListener('mousedown', start); canvas.addEventListener('mousemove', move);
  window.addEventListener('mouseup', end);
  canvas.addEventListener('touchstart', start); canvas.addEventListener('touchmove', move);
  canvas.addEventListener('touchend', end);

  window.clearSig = function() { ctx.clearRect(0, 0, canvas.width, canvas.height); hasInk = false; };
  window.prepareSig = function() {
    if (!hasInk) { alert('Vui lòng vẽ chữ ký trước khi lưu'); return false; }
    document.getElementById('sigData').value = canvas.toDataURL('image/png');
    return true;
  };
})();
</script>

<style>
.profile-hero { margin-bottom: 20px; }
.profile-hero form { padding: 22px 24px; }
.hero-row { display: flex; align-items: center; gap: 22px; flex-wrap: wrap; }
.avatar-edit {
  position: relative; width: 92px; height: 92px; border-radius: 50%; flex-shrink: 0;
  border: none; padding: 0; cursor: pointer; background: var(--primary); color: #fff;
  display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 700;
  overflow: hidden;
}
.avatar-edit img { width: 100%; height: 100%; object-fit: cover; }
.avatar-cam {
  position: absolute; inset: 0; background: rgba(13,27,62,.55); color: #fff; opacity: 0;
  display: flex; align-items: center; justify-content: center; font-size: 18px; transition: opacity .15s;
}
.avatar-edit:hover .avatar-cam { opacity: 1; }
.hero-info { flex: 1; min-width: 220px; display: flex; flex-direction: column; gap: 6px; }
.hero-name-input {
  border: none; background: transparent; font-size: 21px; font-weight: 700; color: var(--text);
  padding: 4px 6px; margin-left: -6px; border-radius: 6px; max-width: 100%;
}
.hero-name-input:hover, .hero-name-input:focus { background: var(--bg); outline: none; }
.hero-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.hero-meta { display: flex; gap: 16px; flex-wrap: wrap; font-size: 12.5px; color: var(--text-3); margin-top: 2px; }
.hero-meta i { margin-right: 4px; color: var(--text-3); }
.hero-phone { min-width: 200px; margin: 0; }
.hero-actions { display: flex; align-items: center; gap: 12px; margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--border-light); }

.profile-grid { display: grid; grid-template-columns: 1fr 340px; gap: 20px; align-items: start; }
@media (max-width: 1000px) { .profile-grid { grid-template-columns: 1fr; } }
.profile-main, .profile-side { display: flex; flex-direction: column; gap: 20px; }

.pd-info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; }
.pd-info-grid label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-3); margin-bottom: 3px; }
.pd-info-grid span { font-size: 13.5px; color: var(--text); }
.pd-note { margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border-light); font-size: 12px; color: var(--text-3); }

.activity-row { display: flex; align-items: center; gap: 12px; padding: 10px 20px; }
.activity-row + .activity-row { border-top: 1px solid var(--border-light); }
.activity-desc { flex: 1; font-size: 12.5px; color: var(--text-2); }
.activity-time { font-size: 11px; color: var(--text-3); white-space: nowrap; }

@media (max-width: 700px) {
  .hero-row { flex-direction: column; align-items: flex-start; }
  .hero-phone { width: 100%; }
}
</style>
