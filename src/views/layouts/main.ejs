<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title><%= title %> - RIAE Management</title>
  <link rel="icon" type="image/png" href="/images/logo.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script>
    // Trang full-layout không bao giờ được hiển thị bên trong iframe của popup
    // "thêm mới" — khi form trong popup submit xong và redirect tới trang kết quả,
    // thoát khỏi iframe và điều hướng cả trang tới đó (đóng popup tự nhiên).
    if (window.self !== window.top) { window.top.location = window.location; }
  </script>
</head>
<body class="app-body">
  <div class="app-wrapper" id="appWrapper">
    <%- include('../partials/sidebar') %>
    <div class="main-content" id="mainContent">
      <%- include('../partials/header') %>
      <div class="page-body">
        <%- include('../partials/flash') %>
        <%- body %>
      </div>
    </div>
  </div>
  <%- include('../partials/chatWidget') %>
  <script src="/js/main.js"></script>
</body>
</html>
