<!-- ===== PART 1: HEADER ===== -->
<div class="um-header">
  <div class="um-header-left">
    <h1 class="um-title"><i class="fas fa-users-cog"></i> Quản lý Nhân viên</h1>
    <p class="um-sub">Tổng cộng <strong id="totalCount"><%= users.length %></strong> nhân viên</p>
  </div>
  <% if (['admin','director'].includes(locals.userRole)) { %>
  <a href="/hr/create" class="btn btn-primary btn-lg">
    <i class="fas fa-user-plus"></i> Thêm nhân viên mới
  </a>
  <% } %>
</div>

<!-- Role stat chips -->
<div class="um-role-chips">
  <% const roleInfo = {
    admin:     { label:'Admin',       desc:'Toàn quyền hệ thống' },
    director:  { label:'Giám đốc',    desc:'Xem báo cáo, duyệt chiến lược' },
    pm:        { label:'PM',          desc:'Tạo dự án, giao task, duyệt timesheet' },
    engineer:  { label:'Kỹ sư',       desc:'Xem & cập nhật task được giao' },
    warehouse: { label:'Kho bãi',     desc:'Quản lý vật tư, xuất nhập kho' },
    guest:     { label:'Khách',       desc:'Chỉ xem, không chỉnh sửa' }
  };
  %>
  <% roleStats.forEach(rs => { %>
  <div class="role-chip role-chip-<%= rs.role %>" data-filter-role="<%= rs.role %>" onclick="setRoleFilter('<%= rs.role %>')" title="<%= (roleInfo[rs.role]||{}).desc || '' %>">
    <span class="role-chip-count"><%= rs.count %></span>
    <span class="role-chip-label"><%= (roleInfo[rs.role]||{}).label || rs.role %></span>
  </div>
  <% }) %>
  <div class="role-chip role-chip-all active" id="chip-all" onclick="setRoleFilter('')">
    <span class="role-chip-count"><%= users.length %></span>
    <span class="role-chip-label">Tất cả</span>
  </div>
</div>

<!-- ===== PART 1B: SEARCH + FILTER BAR ===== -->
<div class="um-toolbar">
  <div class="um-search-wrap">
    <i class="fas fa-search um-search-icon"></i>
    <input type="text" id="searchInput" class="um-search" placeholder="Tìm theo tên, email, phòng ban..." value="<%= filters.search || '' %>" oninput="filterTable()">
    <button class="um-search-clear" id="searchClear" onclick="clearSearch()" style="display:<%= filters.search ? 'flex' : 'none' %>"><i class="fas fa-times"></i></button>
  </div>
  <div class="um-status-tabs" id="statusTabs">
    <button class="um-tab active" data-status="" onclick="setStatusFilter(this,'')">Tất cả</button>
    <button class="um-tab" data-status="active" onclick="setStatusFilter(this,'active')">
      <span class="status-dot active-dot"></span> Đang hoạt động
    </button>
    <button class="um-tab" data-status="inactive" onclick="setStatusFilter(this,'inactive')">
      <span class="status-dot inactive-dot"></span> Vô hiệu hóa
    </button>
  </div>
  <% if (departments.length > 0) { %>
  <select id="deptFilter" class="form-input" style="width:160px;font-size:13px" onchange="filterTable()">
    <option value="">Tất cả phòng ban</option>
    <% departments.forEach(d => { %>
    <option value="<%= d.department %>" <%= filters.department===d.department?'selected':'' %>><%= d.department %></option>
    <% }) %>
  </select>
  <% } %>
</div>

<!-- ===== PART 2: DATA TABLE ===== -->
<div class="card">
  <div id="emptyState" class="empty-state" style="padding:56px;display:none">
    <div class="empty-state-icon"><i class="fas fa-user-slash"></i></div>
    <h3>Không tìm thấy nhân viên</h3>
    <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
  </div>

  <!-- Desktop table -->
  <div class="um-table-wrap" id="umTableWrap">
    <table id="umTable">
      <thead>
        <tr>
          <th style="width:44px"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" class="um-checkbox"></th>
          <th>Nhân viên</th>
          <th style="width:160px">
            Vai trò
            <span class="role-help-icon" title="Di chuột vào role để xem mô tả"><i class="fas fa-question-circle"></i></span>
          </th>
          <th style="width:140px">Phòng ban</th>
          <th style="width:110px">Vào làm</th>
          <th style="width:120px">Trạng thái</th>
          <th style="width:140px;text-align:center">Hành động</th>
        </tr>
      </thead>
      <tbody id="umTableBody">
      <% users.forEach(u => {
        const ri = roleInfo[u.role] || { label: u.role, desc: '' };
      %>
      <tr class="um-row"
          data-name="<%= u.full_name.toLowerCase() %>"
          data-email="<%= (u.email||'').toLowerCase() %>"
          data-dept="<%= (u.department||'').toLowerCase() %>"
          data-role="<%= u.role %>"
          data-active="<%= u.is_active ? 'active' : 'inactive' %>"
          data-id="<%= u.id %>">
        <td><input type="checkbox" class="um-checkbox row-check" value="<%= u.id %>"></td>
        <td>
          <div class="um-user-cell">
            <div class="um-avatar <%= u.is_active ? '' : 'um-avatar-dim' %>">
              <% if (u.avatar_url) { %>
                <img src="<%= u.avatar_url %>" alt="">
              <% } else { %>
                <span><%= u.full_name.charAt(0).toUpperCase() %></span>
              <% } %>
              <span class="um-online-dot <%= u.last_seen_at && (new Date() - new Date(u.last_seen_at)) < 15*60*1000 ? 'is-online' : '' %>"></span>
            </div>
            <div>
              <a href="/hr/<%= u.id %>" class="um-user-name"><%= u.full_name %></a>
              <div class="um-user-email"><%= u.email %></div>
              <% if (u.employee_code) { %><div class="um-user-code"><i class="fas fa-id-badge"></i> <%= u.employee_code %></div><% } %>
            </div>
          </div>
        </td>
        <td>
          <div class="role-tag-wrap">
            <span class="role-tag role-tag-<%= u.role %>" data-tooltip="<%= ri.desc %>">
              <span class="role-tag-dot"></span>
              <%= ri.label %>
            </span>
            <% if (['admin','director'].includes(locals.userRole)) { %>
            <button class="role-edit-btn" onclick="openRoleModal('<%= u.id %>','<%= u.full_name %>','<%= u.role %>')" title="Đổi vai trò">
              <i class="fas fa-pen"></i>
            </button>
            <% } %>
          </div>
        </td>
        <td class="um-cell-muted"><%= u.department || '—' %></td>
        <td class="um-cell-muted"><%= u.hire_date ? new Date(u.hire_date).toLocaleDateString('vi-VN') : '—' %></td>
        <td>
          <% if (['admin','director'].includes(locals.userRole)) { %>
          <label class="um-switch" title="<%= u.is_active ? 'Nhấn để vô hiệu hóa' : 'Nhấn để kích hoạt' %>">
            <input type="checkbox" <%= u.is_active ? 'checked' : '' %>
                   onchange="toggleUser(this,'<%= u.id %>','<%= u.full_name %>')"
                   class="um-switch-input">
            <span class="um-switch-track">
              <span class="um-switch-thumb"></span>
            </span>
            <span class="um-switch-label"><%= u.is_active ? 'Hoạt động' : 'Bị khóa' %></span>
          </label>
          <% } else { %>
          <span class="status-pill <%= u.is_active ? 'pill-active' : 'pill-inactive' %>">
            <span class="status-dot"></span>
            <%= u.is_active ? 'Hoạt động' : 'Bị khóa' %>
          </span>
          <% } %>
        </td>
        <td>
          <div class="um-actions">
            <a href="/hr/<%= u.id %>" class="um-action-btn" title="Xem hồ sơ">
              <i class="fas fa-eye"></i>
            </a>
            <% if (['admin','director'].includes(locals.userRole)) { %>
            <a href="/hr/<%= u.id %>/edit" class="um-action-btn" title="Chỉnh sửa">
              <i class="fas fa-edit"></i>
            </a>
            <% } %>
            <button class="um-action-btn um-history-btn" onclick="openHistory('<%= u.id %>','<%= u.full_name %>')" title="Lịch sử hoạt động">
              <i class="fas fa-history"></i>
            </button>
          </div>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Mobile card view -->
  <div class="um-cards-wrap" id="umCardsWrap">
    <% users.forEach(u => {
      const ri = roleInfo[u.role] || { label: u.role, desc: '' };
    %>
    <div class="um-mobile-card"
         data-name="<%= u.full_name.toLowerCase() %>"
         data-email="<%= (u.email||'').toLowerCase() %>"
         data-dept="<%= (u.department||'').toLowerCase() %>"
         data-role="<%= u.role %>"
         data-active="<%= u.is_active ? 'active' : 'inactive' %>">
      <div style="display:flex;gap:12px;align-items:flex-start">
        <div class="um-avatar">
          <% if (u.avatar_url) { %><img src="<%= u.avatar_url %>" alt=""><% } else { %><span><%= u.full_name.charAt(0).toUpperCase() %></span><% } %>
          <span class="um-online-dot <%= u.last_seen_at && (new Date() - new Date(u.last_seen_at)) < 15*60*1000 ? 'is-online' : '' %>"></span>
        </div>
        <div style="flex:1;min-width:0">
          <a href="/hr/<%= u.id %>" style="font-weight:700;font-size:14px;color:var(--text);text-decoration:none"><%= u.full_name %></a>
          <div style="font-size:12px;color:var(--text-3)"><%= u.email %></div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px">
            <span class="role-tag role-tag-<%= u.role %>"><span class="role-tag-dot"></span><%= ri.label %></span>
            <span class="status-pill <%= u.is_active ? 'pill-active' : 'pill-inactive' %>"><span class="status-dot"></span><%= u.is_active ? 'Hoạt động' : 'Bị khóa' %></span>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <a href="/hr/<%= u.id %>" class="um-action-btn"><i class="fas fa-eye"></i></a>
          <button class="um-action-btn" onclick="openHistory('<%= u.id %>','<%= u.full_name %>')"><i class="fas fa-history"></i></button>
        </div>
      </div>
      <% if (u.department) { %><div style="font-size:11px;color:var(--text-3);margin-top:8px;padding-top:8px;border-top:1px solid var(--border)"><i class="fas fa-building" style="margin-right:4px"></i><%= u.department %></div><% } %>
    </div>
    <% }) %>
  </div>

  <!-- Bulk actions bar -->
  <div class="um-bulk-bar" id="bulkBar" style="display:none">
    <span id="bulkCount">0 đã chọn</span>
    <% if (['admin','director'].includes(locals.userRole)) { %>
    <button class="btn btn-sm btn-warning" onclick="bulkAction('deactivate')"><i class="fas fa-ban"></i> Khóa tất cả</button>
    <button class="btn btn-sm btn-success" onclick="bulkAction('activate')"><i class="fas fa-check"></i> Kích hoạt tất cả</button>
    <% } %>
    <button class="btn btn-sm btn-outline" onclick="clearSelection()"><i class="fas fa-times"></i> Bỏ chọn</button>
  </div>
</div>

<!-- ===== PART 3: ROLE EDIT MODAL ===== -->
<div id="roleModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeRoleModal()">
  <div class="modal-box" style="max-width:440px;width:92%">
    <div class="modal-header">
      <h3><i class="fas fa-user-tag" style="margin-right:8px;color:var(--primary)"></i>Đổi vai trò</h3>
      <button class="modal-close" onclick="closeRoleModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:12px;background:var(--bg);border-radius:8px">
        <div class="um-avatar um-avatar-sm"><span id="roleModalInitial">?</span></div>
        <div>
          <div style="font-weight:600;font-size:14px" id="roleModalName"></div>
          <div style="font-size:12px;color:var(--text-3)">Vai trò hiện tại: <span id="roleModalCurrent" class="badge" style="font-size:11px"></span></div>
        </div>
      </div>
      <div class="form-group" style="margin:0">
        <label class="form-label">Chọn vai trò mới</label>
        <div class="role-selector" id="roleSelector">
          <% [
            {key:'admin',     label:'Admin',       desc:'Toàn quyền hệ thống', icon:'shield-alt'},
            {key:'director',  label:'Giám đốc',    desc:'Quản lý chiến lược, xem báo cáo', icon:'user-tie'},
            {key:'pm',        label:'PM',          desc:'Tạo dự án, giao task, duyệt timesheet', icon:'project-diagram'},
            {key:'engineer',  label:'Kỹ sư',       desc:'Xem & cập nhật task được giao', icon:'hard-hat'},
            {key:'warehouse', label:'Kho bãi',     desc:'Quản lý vật tư, xuất nhập kho', icon:'boxes'},
            {key:'guest',     label:'Khách',       desc:'Chỉ xem, không chỉnh sửa', icon:'eye'}
          ].forEach(r => { %>
          <label class="role-option" data-role="<%= r.key %>">
            <input type="radio" name="newRole" value="<%= r.key %>" style="display:none">
            <span class="role-option-icon role-tag-<%= r.key %>"><i class="fas fa-<%= r.icon %>"></i></span>
            <div class="role-option-text">
              <span class="role-option-name"><%= r.label %></span>
              <span class="role-option-desc"><%= r.desc %></span>
            </div>
            <i class="fas fa-check role-option-check"></i>
          </label>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-outline" onclick="closeRoleModal()">Hủy</button>
      <button type="button" class="btn btn-primary" onclick="saveRole()" id="saveRoleBtn">
        <i class="fas fa-save" style="margin-right:6px"></i>Lưu thay đổi
      </button>
    </div>
  </div>
</div>

<!-- ===== HISTORY MODAL ===== -->
<div id="historyModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeHistory()">
  <div class="modal-box" style="max-width:500px;width:92%">
    <div class="modal-header">
      <h3 id="historyTitle"><i class="fas fa-history" style="margin-right:8px;color:var(--primary)"></i>Lịch sử hoạt động</h3>
      <button class="modal-close" onclick="closeHistory()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" id="historyBody" style="padding:16px;min-height:120px">
      <div style="text-align:center;padding:32px;color:var(--text-3)"><i class="fas fa-spinner fa-spin" style="font-size:24px"></i></div>
    </div>
  </div>
</div>

<!-- ===== CONFIRM MODAL ===== -->
<div id="confirmModal" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:380px;width:92%;text-align:center">
    <div class="modal-body" style="padding:28px 24px 20px">
      <div id="confirmIcon" style="font-size:40px;margin-bottom:12px"></div>
      <div style="font-size:15px;font-weight:600;color:var(--text)" id="confirmMsg"></div>
      <div style="font-size:13px;color:var(--text-3);margin-top:6px" id="confirmSub"></div>
    </div>
    <div class="modal-footer" style="justify-content:center">
      <button class="btn btn-outline" onclick="closeConfirm()">Hủy</button>
      <button class="btn" id="confirmOkBtn">Xác nhận</button>
    </div>
  </div>
</div>

<style>
/* ===== Layout ===== */
.um-header { display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:20px;flex-wrap:wrap; }
.um-title { font-size:22px;font-weight:700;color:var(--text);margin:0 0 3px;display:flex;align-items:center;gap:10px; }
.um-sub { font-size:13px;color:var(--text-3);margin:0; }

/* ===== Role chips ===== */
.um-role-chips { display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px; }
.role-chip {
  display:flex;align-items:center;gap:6px;padding:6px 14px;border-radius:20px;cursor:pointer;
  border:1.5px solid transparent;transition:all .15s;user-select:none;
  background:var(--card);border-color:var(--border);
}
.role-chip:hover { border-color:var(--primary); }
.role-chip.active { background:var(--primary);border-color:var(--primary);color:#fff; }
.role-chip-count { font-size:16px;font-weight:700; }
.role-chip-label { font-size:12px; }
.role-chip-admin     { border-color:rgba(220,38,38,0.3); }
.role-chip-director  { border-color:rgba(139,92,246,0.3); }
.role-chip-pm        { border-color:rgba(59,130,246,0.3); }
.role-chip-engineer  { border-color:rgba(22,163,74,0.3); }
.role-chip-warehouse { border-color:rgba(245,158,11,0.3); }
.role-chip-all       { border-color:var(--border); }

/* ===== Toolbar ===== */
.um-toolbar { display:flex;gap:10px;align-items:center;margin-bottom:16px;flex-wrap:wrap; }
.um-search-wrap { position:relative;flex:1;min-width:200px;max-width:360px; }
.um-search { width:100%;padding:8px 32px 8px 34px;border:1px solid var(--border);border-radius:8px;background:var(--card);color:var(--text);font-size:13px;transition:border-color .15s; }
.um-search:focus { outline:none;border-color:var(--primary); }
.um-search-icon { position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-3);font-size:13px;pointer-events:none; }
.um-search-clear { position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-3);display:flex;align-items:center;justify-content:center;width:20px;height:20px;border-radius:50%; }
.um-search-clear:hover { background:var(--bg);color:var(--text); }
.um-status-tabs { display:flex;background:var(--bg);border-radius:8px;padding:3px;gap:2px;border:1px solid var(--border); }
.um-tab { background:none;border:none;padding:5px 12px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;color:var(--text-2);display:flex;align-items:center;gap:5px;transition:all .15s; }
.um-tab.active { background:var(--card);color:var(--text);box-shadow:0 1px 4px rgba(0,0,0,.08); }
.status-dot { width:7px;height:7px;border-radius:50%;display:inline-block; }
.active-dot { background:#16a34a; }
.inactive-dot { background:#dc2626; }

/* ===== Table ===== */
.um-table-wrap { overflow-x:auto; }
.um-cards-wrap { display:none;padding:12px; }
.um-checkbox { width:16px;height:16px;cursor:pointer;accent-color:var(--primary); }
.um-row { transition:background .1s; }
.um-row:hover td { background:var(--bg); }
.um-row[data-active="inactive"] { opacity:0.65; }

/* ===== User cell ===== */
.um-user-cell { display:flex;align-items:center;gap:12px; }
.um-avatar {
  width:40px;height:40px;border-radius:50%;overflow:hidden;flex-shrink:0;position:relative;
  background:linear-gradient(135deg,var(--primary),var(--primary-light));
  display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:16px;
}
.um-avatar img { width:100%;height:100%;object-fit:cover; }
.um-avatar-sm { width:32px;height:32px;font-size:13px; }
.um-avatar-dim { filter:grayscale(0.6); }
.um-online-dot {
  position:absolute;bottom:1px;right:1px;width:9px;height:9px;
  border-radius:50%;border:1.5px solid var(--card);background:var(--border);
}
.um-online-dot.is-online { background:#16a34a; }
.um-user-name { font-weight:600;font-size:14px;color:var(--text);text-decoration:none; }
.um-user-name:hover { color:var(--primary); }
.um-user-email { font-size:11px;color:var(--text-3);margin-top:1px; }
.um-user-code { font-size:10px;color:var(--text-3);margin-top:2px; }
.um-cell-muted { font-size:12px;color:var(--text-2); }

/* ===== Role tags ===== */
.role-tag-wrap { display:flex;align-items:center;gap:6px; }
.role-tag {
  display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:12px;
  font-size:12px;font-weight:600;cursor:default;position:relative;
}
.role-tag-dot { width:6px;height:6px;border-radius:50%;flex-shrink:0; }
.role-tag-admin     { background:rgba(220,38,38,.12);color:#dc2626; }  .role-tag-admin     .role-tag-dot { background:#dc2626; }
.role-tag-director  { background:rgba(139,92,246,.12);color:#7c3aed; } .role-tag-director  .role-tag-dot { background:#7c3aed; }
.role-tag-pm        { background:rgba(59,130,246,.12);color:#2563eb; } .role-tag-pm        .role-tag-dot { background:#2563eb; }
.role-tag-engineer  { background:rgba(22,163,74,.12);color:#15803d; }  .role-tag-engineer  .role-tag-dot { background:#15803d; }
.role-tag-warehouse { background:rgba(245,158,11,.12);color:#b45309; } .role-tag-warehouse .role-tag-dot { background:#b45309; }
.role-tag-guest     { background:rgba(148,163,184,.12);color:#64748b; }.role-tag-guest     .role-tag-dot { background:#64748b; }
/* tooltip */
.role-tag[data-tooltip]:hover::after {
  content: attr(data-tooltip);
  position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);
  background:#1e293b;color:#fff;font-size:11px;font-weight:400;padding:4px 8px;border-radius:5px;
  white-space:nowrap;pointer-events:none;z-index:99;box-shadow:0 2px 8px rgba(0,0,0,.2);
}
.role-tag[data-tooltip]:hover::before {
  content:'';position:absolute;bottom:calc(100% + 1px);left:50%;transform:translateX(-50%);
  border:5px solid transparent;border-top-color:#1e293b;pointer-events:none;z-index:99;
}
.role-edit-btn {
  background:none;border:none;cursor:pointer;color:var(--text-3);padding:3px 5px;
  border-radius:4px;font-size:11px;opacity:0;transition:opacity .15s,color .15s;
}
.um-row:hover .role-edit-btn { opacity:1; }
.role-edit-btn:hover { color:var(--primary); }
.role-help-icon { color:var(--text-3);font-size:12px;margin-left:4px; }

/* ===== Toggle switch ===== */
.um-switch { display:flex;align-items:center;gap:7px;cursor:pointer;user-select:none; }
.um-switch-input { display:none; }
.um-switch-track {
  width:38px;height:21px;background:var(--border);border-radius:12px;position:relative;
  transition:background .2s;flex-shrink:0;
}
.um-switch-input:checked ~ .um-switch-track { background:#16a34a; }
.um-switch-input:disabled ~ .um-switch-track { opacity:0.5;cursor:not-allowed; }
.um-switch-thumb {
  position:absolute;top:2.5px;left:2.5px;width:16px;height:16px;
  background:#fff;border-radius:50%;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);
}
.um-switch-input:checked ~ .um-switch-track .um-switch-thumb { transform:translateX(17px); }
.um-switch-label { font-size:12px;color:var(--text-2); }

/* ===== Status pill ===== */
.status-pill { display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:12px;font-size:12px;font-weight:500; }
.pill-active   { background:rgba(22,163,74,.1);color:#15803d; }  .pill-active   .status-dot { background:#16a34a; }
.pill-inactive { background:rgba(220,38,38,.1);color:#dc2626; }  .pill-inactive .status-dot { background:#dc2626; }

/* ===== Action buttons ===== */
.um-actions { display:flex;gap:4px;justify-content:center; }
.um-action-btn {
  width:30px;height:30px;border-radius:7px;background:var(--bg);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;color:var(--text-2);
  font-size:12px;cursor:pointer;transition:all .15s;text-decoration:none;
}
.um-action-btn:hover { background:var(--primary);border-color:var(--primary);color:#fff; }
.um-history-btn:hover { background:#6366f1;border-color:#6366f1;color:#fff; }

/* ===== Bulk bar ===== */
.um-bulk-bar {
  padding:10px 16px;border-top:1px solid var(--border);
  display:flex;align-items:center;gap:10px;flex-wrap:wrap;
  background:rgba(59,130,246,.05);
}

/* ===== Mobile card ===== */
.um-mobile-card { padding:14px;border-bottom:1px solid var(--border); }
.um-mobile-card:last-child { border-bottom:none; }

/* ===== Role selector (modal) ===== */
.role-selector { display:grid;gap:6px; }
.role-option {
  display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:8px;cursor:pointer;
  border:1.5px solid var(--border);transition:all .15s;
}
.role-option:hover { border-color:var(--primary);background:var(--bg); }
.role-option.selected { border-color:var(--primary);background:rgba(59,130,246,.06); }
.role-option-icon { width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0; }
.role-option-text { flex:1; }
.role-option-name { display:block;font-size:13px;font-weight:600;color:var(--text); }
.role-option-desc { display:block;font-size:11px;color:var(--text-3);margin-top:1px; }
.role-option-check { color:var(--primary);font-size:14px;opacity:0;transition:opacity .15s; }
.role-option.selected .role-option-check { opacity:1; }

/* ===== History modal ===== */
.hist-project { display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border); }
.hist-project:last-child { border-bottom:none; }
.hist-stat-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px; }
.hist-stat { text-align:center;padding:10px;background:var(--bg);border-radius:8px; }
.hist-stat-val { font-size:20px;font-weight:700;color:var(--primary); }
.hist-stat-label { font-size:11px;color:var(--text-3);margin-top:2px; }

/* ===== Responsive ===== */
@media (max-width: 768px) {
  .um-table-wrap { display:none; }
  .um-cards-wrap { display:block; }
  .um-toolbar { gap:8px; }
  .um-status-tabs { width:100%; }
}
@media (max-width: 480px) {
  .um-header { flex-direction:column; }
  .um-search-wrap { max-width:100%; }
}
</style>

<script>
/* ===== STATE ===== */
let currentFilter = { search:'', status:'', role:'', dept:'' };
let roleModalUserId = null;

/* ===== FILTER LOGIC ===== */
function filterTable() {
  currentFilter.search = document.getElementById('searchInput').value.toLowerCase().trim();
  currentFilter.dept = (document.getElementById('deptFilter')?.value || '').toLowerCase();
  const clear = document.getElementById('searchClear');
  if (clear) clear.style.display = currentFilter.search ? 'flex' : 'none';
  applyFilter();
}

function setStatusFilter(btn, status) {
  currentFilter.status = status;
  document.querySelectorAll('.um-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  applyFilter();
}

function setRoleFilter(role) {
  currentFilter.role = role;
  document.querySelectorAll('.role-chip').forEach(c => c.classList.remove('active'));
  if (role) {
    document.querySelector(`.role-chip[data-filter-role="${role}"]`)?.classList.add('active');
  } else {
    document.getElementById('chip-all')?.classList.add('active');
  }
  applyFilter();
}

function applyFilter() {
  let visibleRows = 0;
  const rows = document.querySelectorAll('.um-row');
  rows.forEach(row => {
    const nameMatch = !currentFilter.search || row.dataset.name.includes(currentFilter.search) || row.dataset.email.includes(currentFilter.search) || row.dataset.dept.includes(currentFilter.search);
    const statusMatch = !currentFilter.status || row.dataset.active === currentFilter.status;
    const roleMatch = !currentFilter.role || row.dataset.role === currentFilter.role;
    const deptMatch = !currentFilter.dept || row.dataset.dept.includes(currentFilter.dept);
    const show = nameMatch && statusMatch && roleMatch && deptMatch;
    row.style.display = show ? '' : 'none';
    if (show) visibleRows++;
  });
  document.querySelectorAll('.um-mobile-card').forEach(card => {
    const nameMatch = !currentFilter.search || card.dataset.name.includes(currentFilter.search) || card.dataset.email.includes(currentFilter.search);
    const statusMatch = !currentFilter.status || card.dataset.active === currentFilter.status;
    const roleMatch = !currentFilter.role || card.dataset.role === currentFilter.role;
    card.style.display = (nameMatch && statusMatch && roleMatch) ? '' : 'none';
  });
  document.getElementById('totalCount').textContent = visibleRows;
  document.getElementById('emptyState').style.display = visibleRows === 0 ? 'block' : 'none';
}

function clearSearch() {
  document.getElementById('searchInput').value = '';
  currentFilter.search = '';
  document.getElementById('searchClear').style.display = 'none';
  applyFilter();
}

/* ===== SELECT ALL ===== */
function toggleSelectAll(cb) {
  document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
  updateBulkBar();
}
document.addEventListener('change', e => {
  if (e.target.classList.contains('row-check')) updateBulkBar();
});
function updateBulkBar() {
  const checked = document.querySelectorAll('.row-check:checked');
  const bar = document.getElementById('bulkBar');
  bar.style.display = checked.length ? 'flex' : 'none';
  document.getElementById('bulkCount').textContent = checked.length + ' đã chọn';
}
function clearSelection() {
  document.querySelectorAll('.row-check,.um-checkbox[id=selectAll]').forEach(c => c.checked = false);
  document.getElementById('bulkBar').style.display = 'none';
}

/* ===== INLINE TOGGLE ACTIVE ===== */
async function toggleUser(checkbox, userId, name) {
  const isChecked = checkbox.checked;
  const label = checkbox.closest('.um-switch').querySelector('.um-switch-label');
  checkbox.disabled = true;
  try {
    const r = await fetch(`/hr/${userId}/toggle-active`, {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json',
                 'X-Requested-With': 'XMLHttpRequest' }
    });
    const data = await r.json();
    if (data.success) {
      label.textContent = data.is_active ? 'Hoạt động' : 'Bị khóa';
      const row = checkbox.closest('tr');
      if (row) row.dataset.active = data.is_active ? 'active' : 'inactive';
      showToast(data.is_active ? `✅ Đã kích hoạt: ${name}` : `🔒 Đã khóa: ${name}`,
                data.is_active ? 'success' : 'warning');
    } else {
      checkbox.checked = !isChecked;
      showToast('Lỗi: ' + (data.error || 'Không thể thực hiện'), 'error');
    }
  } catch(e) {
    checkbox.checked = !isChecked;
    showToast('Lỗi kết nối', 'error');
  }
  checkbox.disabled = false;
}

/* ===== BULK ACTIONS ===== */
async function bulkAction(action) {
  const ids = [...document.querySelectorAll('.row-check:checked')].map(c => c.value);
  if (!ids.length) return;
  showConfirm(
    action === 'deactivate' ? '⚠️' : '✅',
    action === 'deactivate' ? `Khóa ${ids.length} tài khoản?` : `Kích hoạt ${ids.length} tài khoản?`,
    'Hành động này sẽ thay đổi trạng thái tất cả tài khoản đã chọn',
    action === 'deactivate' ? 'btn-warning' : 'btn-success',
    async () => {
      for (const id of ids) {
        await fetch(`/hr/${id}/toggle-active`, {
          method:'POST', headers:{'Accept':'application/json','X-Requested-With':'XMLHttpRequest'}
        });
      }
      showToast(`Đã xử lý ${ids.length} tài khoản`, 'success');
      setTimeout(() => location.reload(), 1200);
    }
  );
}

/* ===== ROLE MODAL ===== */
function openRoleModal(userId, name, currentRole) {
  roleModalUserId = userId;
  document.getElementById('roleModalName').textContent = name;
  document.getElementById('roleModalInitial').textContent = name.charAt(0).toUpperCase();
  const curBadge = document.getElementById('roleModalCurrent');
  curBadge.textContent = currentRole;
  curBadge.className = 'badge role-tag role-tag-' + currentRole;
  document.querySelectorAll('.role-option').forEach(opt => {
    opt.classList.remove('selected');
    opt.querySelector('input').checked = false;
    if (opt.dataset.role === currentRole) {
      opt.classList.add('selected');
      opt.querySelector('input').checked = true;
    }
    opt.onclick = () => {
      document.querySelectorAll('.role-option').forEach(o => { o.classList.remove('selected'); o.querySelector('input').checked = false; });
      opt.classList.add('selected');
      opt.querySelector('input').checked = true;
    };
  });
  document.getElementById('roleModal').style.display = 'flex';
}
function closeRoleModal() { document.getElementById('roleModal').style.display = 'none'; }

async function saveRole() {
  const selected = document.querySelector('.role-option.selected');
  if (!selected) return showToast('Vui lòng chọn vai trò', 'warning');
  const newRole = selected.dataset.role;
  const btn = document.getElementById('saveRoleBtn');
  btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang lưu...';
  try {
    const r = await fetch(`/hr/${roleModalUserId}/quick-role`, {
      method:'POST',
      headers:{'Content-Type':'application/json','Accept':'application/json'},
      body: JSON.stringify({ role: newRole })
    });
    const data = await r.json();
    if (data.success) {
      // Update UI in row
      const row = document.querySelector(`tr[data-id="${roleModalUserId}"]`);
      if (row) {
        row.dataset.role = newRole;
        const tag = row.querySelector('.role-tag');
        const ri = { admin:'Admin',director:'Giám đốc',pm:'PM',engineer:'Kỹ sư',warehouse:'Kho bãi',guest:'Khách' };
        const descs = { admin:'Toàn quyền hệ thống',director:'Xem báo cáo, duyệt chiến lược',pm:'Tạo dự án, giao task, duyệt timesheet',engineer:'Xem & cập nhật task được giao',warehouse:'Quản lý vật tư, xuất nhập kho',guest:'Chỉ xem, không chỉnh sửa' };
        tag.className = `role-tag role-tag-${newRole}`;
        tag.dataset.tooltip = descs[newRole] || '';
        tag.innerHTML = `<span class="role-tag-dot"></span>${ri[newRole]||newRole}`;
      }
      closeRoleModal();
      showToast('✅ Đã cập nhật vai trò', 'success');
    } else showToast('Lỗi: ' + (data.error || 'Thất bại'), 'error');
  } catch(e) { showToast('Lỗi kết nối', 'error'); }
  btn.disabled = false; btn.innerHTML = '<i class="fas fa-save" style="margin-right:6px"></i>Lưu thay đổi';
}

/* ===== HISTORY MODAL ===== */
async function openHistory(userId, name) {
  document.getElementById('historyTitle').innerHTML = `<i class="fas fa-history" style="margin-right:8px;color:var(--primary)"></i>Lịch sử: ${name}`;
  document.getElementById('historyBody').innerHTML = '<div style="text-align:center;padding:32px;color:var(--text-3)"><i class="fas fa-spinner fa-spin" style="font-size:24px"></i></div>';
  document.getElementById('historyModal').style.display = 'flex';
  try {
    const r = await fetch(`/hr/${userId}/history-json`);
    const data = await r.json();
    if (data.error) { document.getElementById('historyBody').innerHTML = `<p style="color:var(--danger)">${data.error}</p>`; return; }
    const t = data.taskStats;
    let html = `
      <div class="hist-stat-grid">
        <div class="hist-stat"><div class="hist-stat-val">${data.projects.length}</div><div class="hist-stat-label">Dự án</div></div>
        <div class="hist-stat"><div class="hist-stat-val">${t.total||0}</div><div class="hist-stat-label">Tổng task</div></div>
        <div class="hist-stat"><div class="hist-stat-val" style="color:#16a34a">${t.done||0}</div><div class="hist-stat-label">Hoàn thành</div></div>
      </div>`;
    if (data.projects.length) {
      html += '<div style="font-size:12px;font-weight:600;color:var(--text-3);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px">Dự án tham gia</div>';
      data.projects.forEach(p => {
        const statusCls = { active:'#16a34a', completed:'#2563eb', on_hold:'#d97706', planning:'#94a3b8', cancelled:'#dc2626' };
        html += `<div class="hist-project">
          <span style="width:8px;height:8px;border-radius:50%;background:${statusCls[p.status]||'#94a3b8'};flex-shrink:0"></span>
          <div style="flex:1;min-width:0">
            <a href="/projects/${p.id}" style="font-size:13px;font-weight:600;color:var(--text);text-decoration:none">${p.name}</a>
            <div style="font-size:11px;color:var(--text-3)">${p.code} · ${p.project_role||'member'}</div>
          </div>
          <span class="badge badge-${p.status}" style="font-size:10px">${p.status}</span>
        </div>`;
      });
    } else {
      html += '<p style="font-size:13px;color:var(--text-3);text-align:center;padding:16px">Chưa tham gia dự án nào</p>';
    }
    if (data.recentActions?.length) {
      html += '<div style="font-size:12px;font-weight:600;color:var(--text-3);margin:16px 0 8px;text-transform:uppercase;letter-spacing:.5px">Hoạt động gần đây</div>';
      data.recentActions.forEach(a => {
        html += `<div style="display:flex;gap:8px;font-size:12px;padding:5px 0;border-bottom:1px solid var(--border)">
          <span style="color:var(--text-3);white-space:nowrap">${new Date(a.created_at).toLocaleDateString('vi-VN')}</span>
          <span style="color:var(--text)">${a.description||a.action}</span>
        </div>`;
      });
    }
    document.getElementById('historyBody').innerHTML = html;
  } catch(e) { document.getElementById('historyBody').innerHTML = '<p style="color:var(--danger)">Lỗi tải dữ liệu</p>'; }
}
function closeHistory() { document.getElementById('historyModal').style.display = 'none'; }

/* ===== CONFIRM MODAL ===== */
let confirmCallback = null;
function showConfirm(icon, msg, sub, btnClass, cb) {
  document.getElementById('confirmIcon').textContent = icon;
  document.getElementById('confirmMsg').textContent = msg;
  document.getElementById('confirmSub').textContent = sub;
  const btn = document.getElementById('confirmOkBtn');
  btn.className = 'btn ' + btnClass;
  btn.textContent = 'Xác nhận';
  confirmCallback = cb;
  document.getElementById('confirmModal').style.display = 'flex';
}
function closeConfirm() { document.getElementById('confirmModal').style.display = 'none'; confirmCallback = null; }
document.getElementById('confirmOkBtn').addEventListener('click', () => { if(confirmCallback) { confirmCallback(); closeConfirm(); } });

/* ===== TOAST ===== */
function showToast(msg, type='info') {
  let container = document.getElementById('toastContainer');
  if (!container) {
    container = document.createElement('div');
    container.id = 'toastContainer';
    container.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;';
    document.body.appendChild(container);
  }
  const colors = { success:'#16a34a', error:'#dc2626', warning:'#d97706', info:'#2563eb' };
  const toast = document.createElement('div');
  toast.style.cssText = `padding:10px 16px;background:var(--card);color:var(--text);border-radius:8px;
    box-shadow:0 4px 16px rgba(0,0,0,.15);font-size:13px;border-left:3px solid ${colors[type]||colors.info};
    animation:slideIn .2s ease;max-width:320px;`;
  toast.textContent = msg;
  container.appendChild(toast);
  setTimeout(() => { toast.style.opacity='0'; toast.style.transition='opacity .3s'; setTimeout(()=>toast.remove(),300); }, 3000);
}

/* ===== ESC to close modals ===== */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeRoleModal(); closeHistory(); closeConfirm(); }
});

/* ===== Toast animation ===== */
const style = document.createElement('style');
style.textContent = '@keyframes slideIn{from{transform:translateX(20px);opacity:0}to{transform:translateX(0);opacity:1}}';
document.head.appendChild(style);
</script>
