<div class="page-header">
  <div class="page-header-title">
    <h1>Quản lý Nhân sự</h1>
    <p><%= users.length %> nhân viên</p>
  </div>
  <% if (['edit','full'].includes(permLevel)) { %>
  <a href="/hr/create" class="btn btn-primary"><i class="fas fa-user-plus"></i> Thêm nhân viên</a>
  <% } %>
</div>

<form method="GET" action="/hr" class="filter-bar">
  <input type="text" name="search" class="form-control" placeholder="Tìm theo tên, email, mã NV..."
         value="<%= filters.search || '' %>" style="max-width:250px">
  <select name="role" class="form-control" style="max-width:190px">
    <option value="">Mọi vai trò</option>
    <% roles.forEach(r => { %>
    <option value="<%= r.value %>" <%= filters.role === r.value ? 'selected' : '' %>><%= r.label %></option>
    <% }) %>
  </select>
  <select name="department" class="form-control" style="max-width:170px">
    <option value="">Mọi phòng ban</option>
    <% departments.forEach(d => { %>
    <option value="<%= d %>" <%= filters.department === d ? 'selected' : '' %>><%= d %></option>
    <% }) %>
  </select>
  <button type="submit" class="btn btn-outline"><i class="fas fa-filter"></i> Lọc</button>
</form>

<div class="card">
  <div class="card-body" style="padding:0">
    <table class="table">
      <thead>
        <tr><th>Nhân viên</th><th>Mã NV</th><th>Vai trò</th><th>Phòng ban</th><th>Vào làm</th><th>Trạng thái</th></tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td>
            <a href="/hr/<%= u.id %>" class="hr-person">
              <span class="hr-avatar">
                <% if (u.avatar_url) { %><img src="<%= u.avatar_url %>" alt=""><% } else { %><%= u.full_name.charAt(0).toUpperCase() %><% } %>
              </span>
              <span>
                <strong><%= u.full_name %></strong>
                <small><%= u.email %></small>
              </span>
            </a>
          </td>
          <td><%= u.employee_code || '—' %></td>
          <td><span class="badge badge-info"><%= roleLabels[u.role] || u.role %></span></td>
          <td><%= u.department || '—' %><% if (u.position) { %><br><small style="color:var(--text-3)"><%= u.position %></small><% } %></td>
          <td style="white-space:nowrap"><%= fmtDate(u.hire_date) %></td>
          <td>
            <% if (u.is_active) { %><span class="badge badge-success">Hoạt động</span>
            <% } else { %><span class="badge badge-danger">Đã khóa</span><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<style>
.filter-bar { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
.hr-person { display: flex; align-items: center; gap: 11px; text-decoration: none; }
.hr-person > span:last-child { display: flex; flex-direction: column; }
.hr-person strong { font-size: 13.5px; color: var(--text); }
.hr-person:hover strong { color: var(--primary); }
.hr-person small { font-size: 11.5px; color: var(--text-3); }
.hr-avatar {
  width: 36px; height: 36px; border-radius: 50%; overflow: hidden; flex-shrink: 0;
  background: var(--primary); color: #fff; display: flex; align-items: center;
  justify-content: center; font-weight: 600; font-size: 14px;
}
.hr-avatar img { width: 100%; height: 100%; object-fit: cover; }
</style>
