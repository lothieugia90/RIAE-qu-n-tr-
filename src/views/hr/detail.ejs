<div class="page-header">
  <div class="page-header-title">
    <h1><%= employee.full_name %></h1>
    <p>
      <span class="badge badge-info"><%= roleLabels[employee.role] || employee.role %></span>
      <% if (employee.is_active) { %><span class="badge badge-success">Hoạt động</span>
      <% } else { %><span class="badge badge-danger">Đã khóa</span><% } %>
      <% if (employee.employee_code) { %> · Mã NV: <%= employee.employee_code %><% } %>
    </p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <% if (['edit','full'].includes(permLevel)) { %>
    <a href="/hr/<%= employee.id %>/edit" class="btn btn-primary"><i class="fas fa-pen"></i> Sửa hồ sơ</a>
    <% } %>
    <% if (permLevel === 'full' && employee.id !== currentUser.id) { %>
    <form action="/hr/<%= employee.id %>/toggle-active" method="POST" style="display:inline"
          data-confirm="<%= employee.is_active ? 'Khóa tài khoản này?' : 'Mở khóa tài khoản này?' %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-outline" style="color:<%= employee.is_active ? 'var(--danger)' : 'var(--success)' %>">
        <i class="fas fa-<%= employee.is_active ? 'lock' : 'lock-open' %>"></i> <%= employee.is_active ? 'Khóa TK' : 'Mở khóa' %>
      </button>
    </form>
    <% } %>
  </div>
</div>

<div class="detail-grid">
  <div class="detail-main">
    <div class="card">
      <div class="card-header"><h3>Thông tin cá nhân</h3></div>
      <div class="card-body">
        <div class="pd-info-grid">
          <div><label>Email</label><span><%= employee.email %></span></div>
          <div><label>Điện thoại</label><span><%= employee.phone || '—' %></span></div>
          <div><label>Ngày sinh</label><span><%= fmtDate(employee.date_of_birth) %></span></div>
          <div><label>Phòng ban</label><span><%= employee.department || '—' %></span></div>
          <div><label>Chức vụ</label><span><%= employee.position || '—' %></span></div>
          <div><label>Ngày vào làm</label><span><%= fmtDate(employee.hire_date) %></span></div>
          <div><label>Hợp đồng</label><span><%= employee.contract_type || '—' %></span></div>
          <% if (['edit','full'].includes(permLevel)) { %>
          <div><label>Lương cơ bản</label><span><%= employee.salary ? Number(employee.salary).toLocaleString('vi-VN') + ' ₫' : '—' %></span></div>
          <div><label>Ngân hàng</label><span><%= [employee.bank_account, employee.bank_name].filter(Boolean).join(' · ') || '—' %></span></div>
          <% } %>
          <div><label>Địa chỉ</label><span><%= employee.address || '—' %></span></div>
          <div><label>Khẩn cấp</label><span><%= [employee.emergency_contact_name, employee.emergency_contact_phone].filter(Boolean).join(' · ') || '—' %></span></div>
        </div>
      </div>
    </div>

    <div class="card" style="margin-top:20px">
      <div class="card-header"><h3>Dự án tham gia (<%= projects.length %>)</h3></div>
      <div class="card-body" style="padding:0">
        <% if (projects.length === 0) { %>
        <p style="text-align:center;padding:24px;color:var(--text-3)">Chưa tham gia dự án nào</p>
        <% } else { %>
        <table class="table">
          <thead><tr><th>Dự án</th><th>Vai trò</th><th>Trạng thái</th></tr></thead>
          <tbody>
            <% projects.forEach(p => { %>
            <tr>
              <td><a href="/projects/<%= p.id %>"><span class="project-code"><%= p.code %></span> <%= p.name %></a></td>
              <td><%= p.project_role === 'manager' ? 'Quản lý' : 'Thành viên' %></td>
              <td><span class="badge badge-<%= p.status %>"><%= PROJECT_STATUS_LABELS[p.status] %></span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>

    <div class="card" style="margin-top:20px">
      <div class="card-header"><h3>Yêu cầu gần đây</h3></div>
      <div class="card-body" style="padding:0">
        <% if (recentRequests.length === 0) { %>
        <p style="text-align:center;padding:24px;color:var(--text-3)">Chưa có yêu cầu nào</p>
        <% } else { %>
        <table class="table">
          <thead><tr><th>Yêu cầu</th><th>Loại</th><th>Ngày gửi</th><th>Trạng thái</th></tr></thead>
          <tbody>
            <% recentRequests.forEach(r => { %>
            <tr>
              <td><a href="/requests/<%= r.id %>"><%= r.title %></a></td>
              <td><%= r.form_name %></td>
              <td style="white-space:nowrap"><%= fmtDate(r.created_at) %></td>
              <td>
                <% if (r.status === 'approved') { %><span class="badge badge-success">Đã duyệt</span>
                <% } else if (r.status === 'rejected') { %><span class="badge badge-danger">Từ chối</span>
                <% } else { %><span class="badge badge-warning">Chờ duyệt</span><% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <div class="detail-side">
    <div class="card">
      <div class="card-header"><h3>Tháng này</h3></div>
      <div class="card-body">
        <div class="hr-stats">
          <div><strong><%= attendanceSummary.present %></strong><small>Ngày công</small></div>
          <div><strong><%= attendanceSummary.late %></strong><small>Đi trễ</small></div>
          <div><strong><%= attendanceSummary.leave %></strong><small>Nghỉ</small></div>
        </div>
        <div class="hr-stats" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border-light)">
          <div><strong><%= taskStats.total %></strong><small>Task</small></div>
          <div><strong><%= taskStats.in_progress %></strong><small>Đang làm</small></div>
          <div><strong><%= taskStats.done %></strong><small>Hoàn thành</small></div>
        </div>
      </div>
    </div>

    <div class="card" style="margin-top:20px">
      <div class="card-header"><h3>Tài liệu (<%= documents.length %>)</h3></div>
      <div class="card-body">
        <% documents.forEach(d => { %>
        <div class="doc-row">
          <i class="fas fa-file-alt"></i>
          <div class="doc-info">
            <a href="<%= d.file_url %>" target="_blank"><%= d.name %></a>
            <small><%= d.doc_type %> · <%= fmtDate(d.created_at) %></small>
          </div>
          <% if (['edit','full'].includes(permLevel)) { %>
          <form action="/hr/<%= employee.id %>/documents/<%= d.id %>/delete" method="POST" data-confirm="Xóa tài liệu này?">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="doc-del" aria-label="Xóa"><i class="fas fa-times"></i></button>
          </form>
          <% } %>
        </div>
        <% }) %>

        <% if (['edit','full'].includes(permLevel)) { %>
        <form action="/hr/<%= employee.id %>/documents?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data" class="doc-upload">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <select name="doc_type" class="form-control" style="margin-bottom:8px">
            <option value="contract">Hợp đồng</option>
            <option value="cv">CV / Hồ sơ</option>
            <option value="degree">Bằng cấp / Chứng chỉ</option>
            <option value="id">CCCD / Giấy tờ</option>
            <option value="other">Khác</option>
          </select>
          <input type="text" name="name" class="form-control" placeholder="Tên tài liệu" style="margin-bottom:8px">
          <input type="file" name="file" class="form-control" required accept=".jpg,.jpeg,.png,.webp,.pdf,.doc,.docx,.xls,.xlsx" style="margin-bottom:8px">
          <button type="submit" class="btn btn-primary btn-sm" style="width:100%"><i class="fas fa-upload"></i> Tải lên</button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<style>
.detail-grid { display: grid; grid-template-columns: 1fr 320px; gap: 20px; align-items: start; }
@media (max-width: 1000px) { .detail-grid { grid-template-columns: 1fr; } }
.pd-info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 14px; }
.pd-info-grid label { display: block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--text-3); margin-bottom: 3px; }
.pd-info-grid span { font-size: 13.5px; color: var(--text); }
.hr-stats { display: grid; grid-template-columns: repeat(3, 1fr); text-align: center; }
.hr-stats strong { display: block; font-size: 20px; color: var(--primary); font-weight: 700; }
.hr-stats small { font-size: 11px; color: var(--text-3); }
.doc-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; }
.doc-row + .doc-row { border-top: 1px solid var(--border-light); }
.doc-row > i { color: var(--primary); font-size: 16px; }
.doc-info { flex: 1; display: flex; flex-direction: column; }
.doc-info a { font-size: 13px; font-weight: 500; }
.doc-info small { font-size: 11px; color: var(--text-3); }
.doc-del { border: none; background: transparent; color: var(--text-3); cursor: pointer; width: 26px; height: 26px; border-radius: 6px; }
.doc-del:hover { background: var(--danger-bg); color: var(--danger); }
.doc-upload { margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border); }
</style>
