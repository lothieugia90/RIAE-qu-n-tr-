<div class="page-header">
  <div class="page-header-title">
    <h1><%= employee ? 'Chỉnh sửa Nhân viên' : 'Thêm Nhân viên mới' %></h1>
    <p><%= employee ? employee.full_name : 'Tạo tài khoản + hồ sơ nhân sự' %></p>
  </div>
</div>

<div class="card" style="max-width:820px">
  <div class="card-body">
    <form action="<%= employee ? '/hr/' + employee.id : '/hr/create' %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <h4 class="hr-section">Tài khoản</h4>
      <div class="form-row">
        <div class="form-group">
          <label>Họ và tên *</label>
          <input type="text" name="full_name" class="form-control" required value="<%= employee ? employee.full_name : '' %>">
        </div>
        <div class="form-group">
          <label>Vai trò *</label>
          <select name="role" class="form-control" required>
            <% let lastGroup = ''; roles.forEach(r => { %>
              <% if (r.group !== lastGroup) { if (lastGroup) { %></optgroup><% } %><optgroup label="<%= r.group %>"><% lastGroup = r.group; } %>
              <option value="<%= r.value %>" <%= employee && employee.role === r.value ? 'selected' : '' %>><%= r.label %></option>
            <% }) %></optgroup>
          </select>
        </div>
      </div>
      <% if (!employee) { %>
      <div class="form-row">
        <div class="form-group">
          <label>Tên đăng nhập *</label>
          <input type="text" name="username" class="form-control" required pattern="[a-zA-Z0-9._-]{3,50}">
        </div>
        <div class="form-group">
          <label>Email *</label>
          <input type="email" name="email" class="form-control" required>
        </div>
      </div>
      <div class="form-group">
        <label>Mật khẩu (bỏ trống để hệ thống tự sinh, ≥8 ký tự)</label>
        <input type="password" name="password" class="form-control" minlength="8" autocomplete="new-password">
      </div>
      <% } %>
      <div class="form-row">
        <div class="form-group">
          <label>Số điện thoại</label>
          <input type="tel" name="phone" class="form-control" value="<%= employee ? (employee.phone || '') : '' %>">
        </div>
        <div class="form-group">
          <label>Mã nhân viên</label>
          <input type="text" name="employee_code" class="form-control" value="<%= employee ? (employee.employee_code || '') : '' %>" placeholder="vd: RIAE-001">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Phòng ban</label>
          <input type="text" name="department" class="form-control" value="<%= employee ? (employee.department || '') : '' %>" placeholder="vd: Kỹ thuật">
        </div>
        <div class="form-group">
          <label>Chức vụ</label>
          <input type="text" name="position" class="form-control" value="<%= employee ? (employee.position || '') : '' %>">
        </div>
      </div>

      <h4 class="hr-section">Hồ sơ nhân sự</h4>
      <div class="form-row">
        <div class="form-group">
          <label>Ngày sinh</label>
          <input type="date" name="date_of_birth" class="form-control"
                 value="<%= employee && employee.date_of_birth ? new Date(employee.date_of_birth).toISOString().split('T')[0] : '' %>">
        </div>
        <div class="form-group">
          <label>Ngày vào làm</label>
          <input type="date" name="hire_date" class="form-control"
                 value="<%= employee && employee.hire_date ? new Date(employee.hire_date).toISOString().split('T')[0] : '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Loại hợp đồng</label>
          <select name="contract_type" class="form-control">
            <option value="">— Chọn —</option>
            <% ['Thử việc','Chính thức','Thời vụ','Cộng tác viên'].forEach(t => { %>
            <option value="<%= t %>" <%= employee && employee.contract_type === t ? 'selected' : '' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Lương cơ bản (VNĐ)</label>
          <input type="number" name="salary" class="form-control" min="0" step="100000"
                 value="<%= employee ? (employee.salary || '') : '' %>">
        </div>
      </div>
      <div class="form-group">
        <label>Địa chỉ</label>
        <input type="text" name="address" class="form-control" value="<%= employee ? (employee.address || '') : '' %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Số tài khoản ngân hàng</label>
          <input type="text" name="bank_account" class="form-control" value="<%= employee ? (employee.bank_account || '') : '' %>">
        </div>
        <div class="form-group">
          <label>Ngân hàng</label>
          <input type="text" name="bank_name" class="form-control" value="<%= employee ? (employee.bank_name || '') : '' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Liên hệ khẩn cấp — Tên</label>
          <input type="text" name="emergency_contact_name" class="form-control" value="<%= employee ? (employee.emergency_contact_name || '') : '' %>">
        </div>
        <div class="form-group">
          <label>Liên hệ khẩn cấp — SĐT</label>
          <input type="tel" name="emergency_contact_phone" class="form-control" value="<%= employee ? (employee.emergency_contact_phone || '') : '' %>">
        </div>
      </div>

      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:8px">
        <a href="<%= employee ? '/hr/' + employee.id : '/hr' %>" class="btn btn-outline">Hủy</a>
        <button type="submit" class="btn btn-primary">
          <i class="fas fa-save"></i> <%= employee ? 'Lưu thay đổi' : 'Thêm nhân viên' %>
        </button>
      </div>
    </form>
  </div>
</div>

<style>
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
.hr-section {
  font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em;
  color: var(--primary); margin: 22px 0 14px; padding-bottom: 7px;
  border-bottom: 1.5px solid var(--border);
}
.hr-section:first-of-type { margin-top: 0; }
</style>
