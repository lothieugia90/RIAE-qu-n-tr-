<!-- AUDIT LOG PAGE -->
<div class="ps-header">
  <div>
    <h1 class="ps-title"><i class="fas fa-history"></i> Nhật ký thay đổi lương</h1>
    <p class="ps-sub">Toàn bộ lịch sử thay đổi tiêu chí lương, phụ cấp và khấu trừ</p>
  </div>
  <a href="/payroll-settings" class="ps-btn ps-btn-ghost"><i class="fas fa-arrow-left"></i> Quay lại</a>
</div>

<!-- FILTERS -->
<div class="ps-panel" style="margin-bottom:16px">
  <div class="ps-panel-head" style="border-left:none">
    <form method="GET" action="/payroll-settings/audit" style="display:flex;gap:10px;flex-wrap:wrap;width:100%;align-items:flex-end">
      <div style="flex:1;min-width:160px">
        <label class="form-label" style="font-size:11px">Tiêu chí</label>
        <select name="criteria_id" class="form-input" style="font-size:12.5px">
          <option value="">Tất cả tiêu chí</option>
          <% criteriaList.forEach(c=>{ %>
          <option value="<%= c.id %>" <%= filters.criteria_id===c.id?'selected':'' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div style="min-width:130px">
        <label class="form-label" style="font-size:11px">Hành động</label>
        <select name="action" class="form-input" style="font-size:12.5px">
          <option value="">Tất cả</option>
          <option value="CREATE" <%= filters.action==='CREATE'?'selected':'' %>>Tạo mới</option>
          <option value="UPDATE" <%= filters.action==='UPDATE'?'selected':'' %>>Cập nhật</option>
          <option value="DELETE" <%= filters.action==='DELETE'?'selected':'' %>>Xóa</option>
        </select>
      </div>
      <div style="min-width:130px">
        <label class="form-label" style="font-size:11px">Từ ngày</label>
        <input type="date" name="from" class="form-input" value="<%= filters.from||'' %>" style="font-size:12.5px">
      </div>
      <div style="min-width:130px">
        <label class="form-label" style="font-size:11px">Đến ngày</label>
        <input type="date" name="to" class="form-input" value="<%= filters.to||'' %>" style="font-size:12.5px">
      </div>
      <div style="display:flex;gap:6px">
        <button type="submit" class="ps-btn ps-btn-primary" style="height:38px"><i class="fas fa-search"></i> Lọc</button>
        <a href="/payroll-settings/audit" class="ps-btn ps-btn-ghost" style="height:38px"><i class="fas fa-times"></i></a>
      </div>
    </form>
  </div>
</div>

<!-- LOG TABLE -->
<div class="ps-panel">
  <div class="ps-panel-head" style="border-left:4px solid #64748b">
    <div style="display:flex;align-items:center;gap:10px">
      <div class="ps-cat-ico" style="background:#f1f5f9;color:#64748b"><i class="fas fa-history"></i></div>
      <div>
        <div class="ps-panel-title">Nhật ký kiểm toán</div>
        <div class="ps-panel-sub"><%= pagination.total %> bản ghi</div>
      </div>
    </div>
  </div>

  <% if (!logs.length) { %>
  <div class="ps-empty">
    <i class="fas fa-history" style="font-size:32px;opacity:.3"></i>
    <p>Không có bản ghi phù hợp với bộ lọc</p>
  </div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table class="ps-table">
      <thead><tr>
        <th>Thời gian</th>
        <th>Tiêu chí</th>
        <th>Danh mục</th>
        <th>Hành động</th>
        <th>Thay đổi</th>
        <th>Hiệu lực từ</th>
        <th>Người thực hiện</th>
        <th>IP</th>
      </tr></thead>
      <tbody>
      <% logs.forEach(l => {
        const actionColor = {CREATE:'#16a34a',UPDATE:'#2563eb',DELETE:'#dc2626'}[l.action]||'#64748b';
        const actionLabel = {CREATE:'Tạo mới',UPDATE:'Cập nhật',DELETE:'Xóa'}[l.action]||l.action;
        const catLabel = {allowance:'Phụ cấp',overtime:'Tăng ca',deduction:'Khấu trừ'}[l.category]||l.category||'—';
      %>
      <tr class="ps-tr">
        <td style="white-space:nowrap;font-size:12px">
          <div style="font-weight:600;color:var(--text)"><%= new Date(l.changed_at).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric'}) %></div>
          <div style="color:var(--text-3)"><%= new Date(l.changed_at).toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit',second:'2-digit'}) %></div>
        </td>
        <td>
          <div class="ps-item-name"><%= l.criteria_name||'—' %></div>
          <% if(l.criteria_key){ %><div class="ps-item-key"><code><%= l.criteria_key %></code></div><% } %>
        </td>
        <td><span style="font-size:12px;color:var(--text-2)"><%= catLabel %></span></td>
        <td><span class="ps-action-badge" style="background:<%=actionColor%>20;color:<%=actionColor%>"><%= actionLabel %></span></td>
        <td>
          <% if (l.field_changed && l.old_value!==null && l.new_value!==null) { %>
          <div style="font-size:11px;color:var(--text-3);margin-bottom:2px"><%= l.field_changed %></div>
          <div style="display:flex;align-items:center;gap:5px">
            <span class="ps-old-val"><%= l.old_value %></span>
            <i class="fas fa-arrow-right" style="font-size:9px;color:#94a3b8"></i>
            <span class="ps-new-val"><%= l.new_value %></span>
          </div>
          <% } else if(l.action==='CREATE') { %>
          <span style="font-size:12px;color:#16a34a;font-weight:500">Tạo mới</span>
          <% } else if(l.action==='DELETE') { %>
          <span style="font-size:12px;color:#dc2626;font-weight:500">Đã xóa</span>
          <% } %>
          <% if(l.note){ %><div style="margin-top:3px;font-size:11px;color:#64748b;font-style:italic"><i class="fas fa-comment-alt"></i> <%= l.note %></div><% } %>
        </td>
        <td>
          <% if(l.effective_from){ %>
          <span style="font-size:12px;font-weight:500;color:var(--text-2)"><%= new Date(l.effective_from).toLocaleDateString('vi-VN',{month:'2-digit',year:'numeric'}) %></span>
          <% } else { %><span class="ps-item-key">—</span><% } %>
        </td>
        <td>
          <div style="font-size:13px;font-weight:600;color:var(--text)"><%= l.changer_name||l.changed_by_name||'—' %></div>
        </td>
        <td style="font-size:11.5px;color:var(--text-3);font-family:monospace"><%= l.ip_address||'—' %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>

  <!-- PAGINATION -->
  <% if (pagination.pages > 1) { %>
  <div style="display:flex;justify-content:center;align-items:center;gap:6px;padding:14px;border-top:1px solid var(--border)">
    <% const q = new URLSearchParams(filters).toString() %>
    <% if (pagination.page > 1) { %>
    <a href="?page=<%= pagination.page-1 %>&<%= q %>" class="ps-btn ps-btn-ghost ps-btn-sm"><i class="fas fa-chevron-left"></i></a>
    <% } %>
    <% for(let p=Math.max(1,pagination.page-2); p<=Math.min(pagination.pages,pagination.page+2); p++) { %>
    <a href="?page=<%= p %>&<%= q %>" class="ps-btn ps-btn-sm" style="<%= p===pagination.page?'background:var(--primary);color:#fff;border-color:var(--primary)':'' %>"><%= p %></a>
    <% } %>
    <% if (pagination.page < pagination.pages) { %>
    <a href="?page=<%= pagination.page+1 %>&<%= q %>" class="ps-btn ps-btn-ghost ps-btn-sm"><i class="fas fa-chevron-right"></i></a>
    <% } %>
  </div>
  <% } %>
  <% } %>
</div>

<style>
.ps-header { display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:18px;flex-wrap:wrap }
.ps-title { font-size:22px;font-weight:800;color:var(--text);margin:0 0 4px;display:flex;align-items:center;gap:10px }
.ps-title i { color:var(--primary) }
.ps-sub { font-size:13px;color:var(--text-3);margin:0 }
.ps-btn { display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;border:1.5px solid transparent;transition:var(--transition) }
.ps-btn-primary { background:var(--primary);color:#fff;border-color:var(--primary) }
.ps-btn-ghost { background:transparent;color:var(--text-2);border-color:var(--border) }
.ps-btn-ghost:hover { border-color:var(--primary);color:var(--primary) }
.ps-btn-sm { padding:5px 12px;font-size:12px }
.ps-panel { background:var(--card);border-radius:var(--radius);border:1.5px solid var(--border);box-shadow:var(--shadow);overflow:hidden }
.ps-panel-head { display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-bottom:1.5px solid var(--border) }
.ps-cat-ico { width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0 }
.ps-panel-title { font-size:14px;font-weight:700;color:var(--text) }
.ps-panel-sub { font-size:11.5px;color:var(--text-3);margin-top:2px }
.ps-empty { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:40px;color:var(--text-3);font-size:13px }
.ps-table { width:100%;border-collapse:collapse }
.ps-table thead tr { background:var(--bg) }
.ps-table th { padding:9px 14px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text-3);text-align:left;border-bottom:1.5px solid var(--border);white-space:nowrap }
.ps-tr { border-bottom:1px solid var(--border) }
.ps-tr:last-child { border-bottom:none }
.ps-tr:hover td { background:rgba(37,99,235,.025) }
.ps-table td { padding:10px 14px;vertical-align:middle }
.ps-item-name { font-size:13.5px;font-weight:600;color:var(--text) }
.ps-item-key { font-size:11px;color:var(--text-3);margin-top:2px }
.ps-item-key code { background:var(--bg);padding:1px 5px;border-radius:3px;font-size:10.5px }
.ps-action-badge { padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700 }
.ps-old-val { font-size:12px;color:#dc2626;font-weight:600 }
.ps-new-val { font-size:12px;color:#16a34a;font-weight:600 }
</style>
