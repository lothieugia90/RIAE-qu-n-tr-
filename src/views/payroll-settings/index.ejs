<%
const catMeta = {
  allowance: { label: 'Phụ cấp cố định',     icon: 'hand-holding-usd', color: '#2563EB', bg: '#EFF6FF' },
  overtime:  { label: 'Hệ số tăng ca',       icon: 'clock',            color: '#D97706', bg: '#FEF3C7' },
  deduction: { label: 'Khấu trừ & Bảo hiểm', icon: 'minus-circle',     color: '#DC2626', bg: '#FEE2E2' }
};
const canEdit = ['edit','full'].includes(permLevel);
const canFull = permLevel === 'full';
%>

<div class="page-header">
  <div class="page-header-title">
    <h1>Cấu hình Lương &amp; Phụ cấp</h1>
    <p>Quản lý tiêu chí phụ cấp, hệ số tăng ca và khấu trừ áp dụng khi tính lương</p>
  </div>
  <div style="display:flex;gap:10px">
    <a href="/payroll-settings/audit" class="btn btn-outline"><i class="fas fa-history"></i> Nhật ký thay đổi</a>
    <% if (canEdit) { %>
    <button class="btn btn-primary" onclick="openAddModal()"><i class="fas fa-plus"></i> Thêm tiêu chí</button>
    <% } %>
  </div>
</div>

<div class="ps-notice">
  <i class="fas fa-shield-alt"></i>
  Trang này chỉ dành cho <strong>Admin, HR và Ban lãnh đạo</strong>. Mọi thay đổi được ghi lại đầy đủ vào nhật ký kiểm toán.
</div>

<div class="ps-tabs">
  <button class="ps-tab active" data-cat="allowance" onclick="switchTab('allowance',this)">
    <i class="fas fa-hand-holding-usd"></i> Phụ cấp <span class="ps-tab-count"><%= grouped.allowance.length %></span>
  </button>
  <button class="ps-tab" data-cat="overtime" onclick="switchTab('overtime',this)">
    <i class="fas fa-clock"></i> Tăng ca <span class="ps-tab-count"><%= grouped.overtime.length %></span>
  </button>
  <button class="ps-tab" data-cat="deduction" onclick="switchTab('deduction',this)">
    <i class="fas fa-minus-circle"></i> Khấu trừ <span class="ps-tab-count"><%= grouped.deduction.length %></span>
  </button>
  <button class="ps-tab" data-cat="log" onclick="switchTab('log',this)">
    <i class="fas fa-history"></i> Lịch sử gần đây <span class="ps-tab-count"><%= recentLogs.length %></span>
  </button>
</div>

<% ['allowance','overtime','deduction'].forEach(cat => {
   const meta = catMeta[cat];
   const items = grouped[cat];
%>
<div class="card ps-panel" id="panel-<%= cat %>" style="<%= cat !== 'allowance' ? 'display:none' : '' %>">
  <div class="ps-panel-head" style="border-left:4px solid <%= meta.color %>">
    <div style="display:flex;align-items:center;gap:10px">
      <div class="ps-cat-ico" style="background:<%= meta.bg %>;color:<%= meta.color %>"><i class="fas fa-<%= meta.icon %>"></i></div>
      <div>
        <div class="ps-panel-title"><%= meta.label %></div>
        <div class="ps-panel-sub"><%= items.length %> tiêu chí · Hiệu lực theo kỳ lương</div>
      </div>
    </div>
    <% if (canEdit) { %>
    <button class="btn btn-sm btn-outline" style="border-color:<%= meta.color %>;color:<%= meta.color %>" onclick="openAddModal('<%= cat %>')">
      <i class="fas fa-plus"></i> Thêm
    </button>
    <% } %>
  </div>

  <% if (!items.length) { %>
  <div class="ps-empty">
    <i class="fas fa-<%= meta.icon %>" style="font-size:28px;color:<%= meta.color %>;opacity:.3"></i>
    <p>Chưa có tiêu chí nào</p>
  </div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table class="table ps-table">
      <thead><tr>
        <th style="width:28%">Tên tiêu chí</th><th>Đơn vị</th><th>Giá trị</th><th>Đối tượng</th>
        <th>Hiệu lực</th><th>Trạng thái</th><% if (canEdit) { %><th style="width:110px">Thao tác</th><% } %>
      </tr></thead>
      <tbody>
      <% items.forEach(item => { const isOT = cat === 'overtime'; const eff = new Date(item.effective_from); const isFuture = eff > new Date(); %>
      <tr class="<%= item.is_active ? '' : 'ps-tr-inactive' %>" id="row-<%= item.id %>">
        <td>
          <div class="ps-item-name"><%= item.name %></div>
          <div class="ps-item-key"><code><%= item.key %></code></div>
          <% if (item.description) { %><div class="ps-item-desc"><%= item.description %></div><% } %>
        </td>
        <td><span class="ps-unit-badge"><%= item.unit === 'percent' ? '%' : 'VNĐ' %></span></td>
        <td>
          <% if (item.unit === 'percent') { %>
          <span class="ps-value-num"><%= item.default_value %>%</span>
          <% if (isOT) { %><span class="ps-ot-coeff">×<%= (item.default_value/100).toFixed(2) %></span><% } %>
          <% } else { %>
          <span class="ps-value-num"><%= parseInt(item.default_value).toLocaleString('vi-VN') %>đ</span>
          <% } %>
        </td>
        <td><span class="badge badge-info"><%= item.applies_to === 'all' ? 'Tất cả' : (roles.find(r => r.value === item.applies_to)?.label || item.applies_to) %></span></td>
        <td>
          <% if (isFuture) { %><span class="ps-eff-future"><i class="fas fa-calendar-alt"></i> Từ <%= eff.toLocaleDateString('vi-VN',{month:'2-digit',year:'numeric'}) %></span>
          <% } else { %><span class="ps-eff-now"><i class="fas fa-check-circle"></i> Đang áp dụng</span><% } %>
        </td>
        <td>
          <% if (canEdit) { %>
          <label class="ps-toggle" title="<%= item.is_active ? 'Đang hoạt động' : 'Đã tắt' %>">
            <input type="checkbox" <%= item.is_active ? 'checked' : '' %> onchange="toggleActive('<%= item.id %>', this.checked)">
            <span class="ps-toggle-slider"></span>
          </label>
          <% } else { %>
          <span class="badge <%= item.is_active ? 'badge-success' : 'badge-danger' %>"><%= item.is_active ? 'Bật' : 'Tắt' %></span>
          <% } %>
        </td>
        <% if (canEdit) { %>
        <td>
          <div style="display:flex;gap:4px">
            <button class="btn btn-sm btn-outline" title="Chỉnh sửa" onclick='openEditModal(<%- JSON.stringify(item) %>)'><i class="fas fa-pencil-alt"></i></button>
            <button class="btn btn-sm btn-outline" title="Xem trước tác động" onclick="openPreview('<%= item.id %>','<%= item.name.replace(/'/g,"\\'") %>','<%= item.unit %>',<%= item.default_value %>)"><i class="fas fa-eye"></i></button>
            <% if (canFull) { %>
            <button class="btn btn-sm btn-outline" style="color:var(--danger)" title="Xóa" onclick="confirmDelete('<%= item.id %>','<%= item.name.replace(/'/g,"\\'") %>')"><i class="fas fa-trash-alt"></i></button>
            <% } %>
          </div>
        </td>
        <% } %>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<% }) %>

<div class="card ps-panel" id="panel-log" style="display:none">
  <div class="ps-panel-head" style="border-left:4px solid #64748B">
    <div style="display:flex;align-items:center;gap:10px">
      <div class="ps-cat-ico" style="background:#F1F5F9;color:#64748B"><i class="fas fa-history"></i></div>
      <div><div class="ps-panel-title">Lịch sử thay đổi gần đây</div><div class="ps-panel-sub">30 thay đổi gần nhất</div></div>
    </div>
    <a href="/payroll-settings/audit" class="btn btn-sm btn-outline">Xem toàn bộ <i class="fas fa-arrow-right"></i></a>
  </div>
  <% if (!recentLogs.length) { %>
  <div class="ps-empty"><i class="fas fa-history" style="font-size:28px;opacity:.3"></i><p>Chưa có thay đổi nào</p></div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table class="table ps-table">
      <thead><tr><th>Tiêu chí</th><th>Hành động</th><th>Thay đổi</th><th>Người thực hiện</th><th>Thời gian</th></tr></thead>
      <tbody>
      <% recentLogs.forEach(l => {
         const actionMeta = { CREATE: ['badge-success','Tạo mới'], UPDATE: ['badge-info','Cập nhật'], DELETE: ['badge-danger','Xóa'] }[l.action] || ['badge-info', l.action];
      %>
      <tr>
        <td>
          <div class="ps-item-name"><%= l.criteria_name || '—' %></div>
          <% if (l.criteria_key) { %><div class="ps-item-key"><code><%= l.criteria_key %></code></div><% } %>
        </td>
        <td><span class="badge <%= actionMeta[0] %>"><%= actionMeta[1] %></span></td>
        <td>
          <% if (l.field_changed && l.old_value !== null && l.new_value !== null) { %>
          <div style="font-size:12px"><span style="color:var(--danger);font-weight:600"><%= l.old_value %></span>
            <i class="fas fa-arrow-right" style="font-size:9px;color:var(--text-3);margin:0 4px"></i>
            <span style="color:var(--success);font-weight:600"><%= l.new_value %></span></div>
          <div style="font-size:11px;color:var(--text-3)"><%= l.field_changed %></div>
          <% } else if (l.action === 'CREATE') { %><span style="font-size:12px;color:var(--success)">Tạo tiêu chí mới</span>
          <% } else if (l.action === 'DELETE') { %><span style="font-size:12px;color:var(--danger)">Xóa tiêu chí</span><% } %>
          <% if (l.note) { %><div style="font-size:11px;color:var(--text-3);margin-top:2px"><i class="fas fa-comment-alt"></i> <%= l.note %></div><% } %>
        </td>
        <td><%= l.changer_name || l.changed_by_name || '—' %></td>
        <td style="white-space:nowrap;font-size:12px"><%= fmtDateTime(l.changed_at) %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<% if (canEdit) { %>
<!-- Modal thêm/sửa tiêu chí -->
<dialog id="editModal" class="modal" style="max-width:580px">
  <form id="editForm" method="POST" class="modal-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="_method" id="editMethod" value="POST">
    <h3 id="editModalTitle">Thêm tiêu chí mới</h3>

    <div class="form-row">
      <div class="form-group"><label>Tên tiêu chí *</label><input type="text" name="name" id="editName" class="form-control" required></div>
      <div class="form-group">
        <label>Danh mục *</label>
        <select name="category" id="editCategory" class="form-control" required>
          <option value="allowance">Phụ cấp</option>
          <option value="overtime">Tăng ca</option>
          <option value="deduction">Khấu trừ</option>
        </select>
      </div>
    </div>
    <div class="form-group" id="keyRow">
      <label>Key (không đổi được sau khi tạo)</label>
      <input type="text" name="key" id="editKey" class="form-control" placeholder="vd: lunch_allowance" style="font-family:monospace" oninput="this.value=this.value.toLowerCase().replace(/[^a-z0-9_]/g,'_')">
    </div>
    <div class="form-group"><label>Mô tả</label><input type="text" name="description" id="editDesc" class="form-control" placeholder="Ghi chú thêm..."></div>

    <div class="form-row" style="grid-template-columns:1fr 1fr 1fr">
      <div class="form-group">
        <label>Đơn vị *</label>
        <select name="unit" id="editUnit" class="form-control" onchange="updateValueHint()">
          <option value="VND">VNĐ (đồng)</option>
          <option value="percent">% (phần trăm)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Giá trị *</label>
        <div style="position:relative">
          <input type="number" name="default_value" id="editValue" class="form-control" step="0.01" min="0" required oninput="triggerPreview()">
        </div>
      </div>
      <div class="form-group">
        <label>Đối tượng</label>
        <select name="applies_to" id="editAppliesTo" class="form-control">
          <option value="all">Tất cả</option>
          <% roles.forEach(r => { %><option value="<%= r.value %>"><%= r.label %></option><% }) %>
        </select>
      </div>
    </div>

    <div id="previewBox" class="ps-preview-box" style="display:none">
      <div class="ps-preview-title"><i class="fas fa-calculator"></i> Ước tính tác động thay đổi</div>
      <div class="ps-preview-stats" id="previewStats"></div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Thời điểm hiệu lực</label>
        <select name="effective_when" id="editEffective" class="form-control">
          <option value="current">Áp dụng từ tháng này</option>
          <option value="next">Áp dụng từ tháng sau</option>
        </select>
      </div>
      <div class="form-group"><label>Ghi chú thay đổi</label><input type="text" name="note" id="editNote" class="form-control" placeholder="Lý do thay đổi..."></div>
    </div>

    <div class="modal-actions">
      <button type="button" class="btn btn-outline" onclick="document.getElementById('editModal').close()">Hủy</button>
      <button type="submit" class="btn btn-primary" id="editSubmitBtn"><i class="fas fa-save"></i> <span id="editSubmitLabel">Tạo tiêu chí</span></button>
    </div>
  </form>
</dialog>

<!-- Modal xem trước tác động (mở nhanh từ bảng) -->
<dialog id="previewModal" class="modal" style="max-width:480px">
  <div class="modal-form">
    <h3><i class="fas fa-calculator" style="color:#7C3AED"></i> Xem trước tác động</h3>
    <div id="pmBody"><div style="text-align:center;padding:24px;color:var(--text-3)"><i class="fas fa-circle-notch fa-spin fa-lg"></i></div></div>
    <div class="modal-actions"><button type="button" class="btn btn-outline" onclick="document.getElementById('previewModal').close()">Đóng</button></div>
  </div>
</dialog>

<% if (canFull) { %>
<!-- Modal xóa -->
<dialog id="deleteModal" class="modal" style="max-width:420px">
  <div class="modal-form">
    <h3>Xác nhận xóa</h3>
    <p style="font-size:13.5px;color:var(--text-2);margin-bottom:6px">Bạn có chắc muốn xóa tiêu chí:</p>
    <p id="deleteItemName" style="font-size:15px;font-weight:700;color:var(--danger);margin-bottom:10px"></p>
    <p style="font-size:12.5px;color:var(--text-3)">Hành động này không thể hoàn tác và sẽ được ghi vào nhật ký kiểm toán.</p>
    <form id="deleteForm" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="_method" value="DELETE">
      <div class="modal-actions">
        <button type="button" class="btn btn-outline" onclick="document.getElementById('deleteModal').close()">Hủy</button>
        <button type="submit" class="btn btn-primary" style="background:var(--danger)"><i class="fas fa-trash-alt"></i> Xóa tiêu chí</button>
      </div>
    </form>
  </div>
</dialog>
<% } %>

<script>
const csrf = document.querySelector('meta[name="csrf-token"]').content;
let currentEditId = null, previewTimer = null;

function switchTab(cat, el) {
  document.querySelectorAll('.ps-tab').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  ['allowance','overtime','deduction','log'].forEach(c => {
    const p = document.getElementById('panel-' + c);
    if (p) p.style.display = c === cat ? 'block' : 'none';
  });
}

function openAddModal(cat) {
  currentEditId = null;
  document.getElementById('editForm').action = '/payroll-settings';
  document.getElementById('editMethod').value = 'POST';
  document.getElementById('editModalTitle').textContent = 'Thêm tiêu chí mới';
  document.getElementById('editSubmitLabel').textContent = 'Tạo tiêu chí';
  document.getElementById('keyRow').style.display = 'block';
  document.getElementById('editName').value = '';
  document.getElementById('editKey').value = '';
  document.getElementById('editDesc').value = '';
  document.getElementById('editValue').value = '';
  document.getElementById('editNote').value = '';
  document.getElementById('editCategory').value = cat || 'allowance';
  document.getElementById('editUnit').value = 'VND';
  document.getElementById('editAppliesTo').value = 'all';
  document.getElementById('editEffective').value = 'current';
  document.getElementById('previewBox').style.display = 'none';
  document.getElementById('editModal').showModal();
}

function openEditModal(item) {
  currentEditId = item.id;
  document.getElementById('editForm').action = '/payroll-settings/' + item.id;
  document.getElementById('editMethod').value = 'PUT';
  document.getElementById('editModalTitle').textContent = 'Chỉnh sửa: ' + item.name;
  document.getElementById('editSubmitLabel').textContent = 'Lưu thay đổi';
  document.getElementById('keyRow').style.display = 'none';
  document.getElementById('editName').value = item.name;
  document.getElementById('editDesc').value = item.description || '';
  document.getElementById('editCategory').value = item.category;
  document.getElementById('editUnit').value = item.unit;
  document.getElementById('editAppliesTo').value = item.applies_to || 'all';
  document.getElementById('editValue').value = item.default_value;
  document.getElementById('editEffective').value = 'current';
  document.getElementById('editNote').value = '';
  document.getElementById('previewBox').style.display = 'none';
  document.getElementById('editModal').showModal();
}

function updateValueHint() { /* giữ chỗ cho hậu tố nếu cần mở rộng */ }

function triggerPreview() {
  if (!currentEditId) return;
  clearTimeout(previewTimer);
  previewTimer = setTimeout(async () => {
    const newVal = document.getElementById('editValue').value;
    if (!newVal) return;
    const box = document.getElementById('previewBox');
    try {
      const r = await fetch('/payroll-settings/' + currentEditId + '/preview?new_value=' + encodeURIComponent(newVal));
      const d = await r.json();
      if (d.error) { box.style.display = 'none'; return; }
      box.style.display = 'block';
      const color = d.diff_total >= 0 ? 'var(--success)' : 'var(--danger)';
      const sign = d.diff_per_person >= 0 ? '+' : '';
      document.getElementById('previewStats').innerHTML =
        '<div class="ps-preview-stat"><div class="ps-preview-stat-val" style="color:' + color + '">' + sign + Math.round(d.diff_per_person).toLocaleString('vi-VN') + 'đ</div><div class="ps-preview-stat-label">Thay đổi / người</div></div>' +
        '<div class="ps-preview-stat"><div class="ps-preview-stat-val" style="color:' + color + '">' + sign + Math.round(d.diff_total).toLocaleString('vi-VN') + 'đ</div><div class="ps-preview-stat-label">Tổng / tháng (' + d.affected + ' người)</div></div>';
    } catch (e) { box.style.display = 'none'; }
  }, 500);
}

async function openPreview(id, name, unit, currentVal) {
  const promptLabel = unit === 'percent' ? `Nhập hệ số mới cho "${name}" (hiện tại: ${currentVal}%):` : `Nhập giá trị mới cho "${name}" (hiện tại: ${parseInt(currentVal).toLocaleString('vi-VN')} đ):`;
  const input = prompt(promptLabel, currentVal);
  const newVal = parseFloat(input);
  if (input === null || isNaN(newVal)) return;
  document.getElementById('previewModal').showModal();
  const body = document.getElementById('pmBody');
  body.innerHTML = '<div style="text-align:center;padding:24px;color:var(--text-3)"><i class="fas fa-circle-notch fa-spin fa-lg"></i></div>';
  try {
    const r = await fetch('/payroll-settings/' + id + '/preview?new_value=' + encodeURIComponent(newVal));
    const d = await r.json();
    if (d.error) { body.innerHTML = '<p style="color:var(--danger)">' + d.error + '</p>'; return; }
    const color = d.diff_total >= 0 ? 'var(--success)' : 'var(--danger)';
    const bg = d.diff_total >= 0 ? 'var(--success-bg)' : 'var(--danger-bg)';
    const sign = d.diff_total >= 0 ? '+' : '';
    body.innerHTML =
      '<div style="text-align:center;margin-bottom:16px"><div style="font-size:13px;color:var(--text-3)">Thay đổi tiêu chí</div>' +
      '<div style="font-size:17px;font-weight:800">' + d.criteria_name + '</div>' +
      '<div style="margin-top:8px;font-size:14px;font-weight:700"><span style="color:var(--danger)">' + currentVal + (unit === 'percent' ? '%' : ' đ') + '</span> → <span style="color:var(--success)">' + newVal + (unit === 'percent' ? '%' : ' đ') + '</span></div></div>' +
      '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">' +
      '<div style="text-align:center;padding:12px;background:' + bg + ';border-radius:8px"><div style="font-size:20px;font-weight:800;color:' + color + '">' + sign + Math.round(d.diff_per_person).toLocaleString('vi-VN') + 'đ</div><div style="font-size:11.5px;color:var(--text-3);margin-top:4px">Thay đổi / người / tháng</div></div>' +
      '<div style="text-align:center;padding:12px;background:' + bg + ';border-radius:8px"><div style="font-size:20px;font-weight:800;color:' + color + '">' + sign + Math.round(d.diff_total).toLocaleString('vi-VN') + 'đ</div><div style="font-size:11.5px;color:var(--text-3);margin-top:4px">Tổng toàn công ty / tháng</div></div></div>' +
      '<div style="background:var(--bg);border-radius:8px;padding:10px 12px;font-size:12.5px"><strong><i class="fas fa-users"></i> ' + d.affected + ' nhân viên bị ảnh hưởng</strong>' +
      (d.employees || []).map(e => '<div style="padding:4px 0;border-top:1px solid var(--border-light)">' + e.full_name + '</div>').join('') +
      (d.affected > 10 ? '<div style="color:var(--text-3);padding-top:6px">+' + (d.affected - 10) + ' người khác...</div>' : '') + '</div>';
  } catch (e) { body.innerHTML = '<p style="color:var(--danger)">Lỗi tải dữ liệu</p>'; }
}

function confirmDelete(id, name) {
  document.getElementById('deleteItemName').textContent = name;
  document.getElementById('deleteForm').action = '/payroll-settings/' + id;
  document.getElementById('deleteModal').showModal();
}

async function toggleActive(id, active) {
  try {
    const r = await fetch('/payroll-settings/' + id, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrf, 'Accept': 'application/json' },
      body: JSON.stringify({ is_active: active, effective_when: 'current', note: (active ? 'Bật' : 'Tắt') + ' tiêu chí' })
    });
    const d = await r.json();
    if (!d.success) location.reload();
    else document.getElementById('row-' + id).classList.toggle('ps-tr-inactive', !active);
  } catch (e) { location.reload(); }
}
</script>
<% } %>

