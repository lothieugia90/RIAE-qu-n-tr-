<%
const catMeta = {
  allowance: { label:'Phụ cấp cố định',    icon:'hand-holding-usd', color:'#2563eb', bg:'#eff6ff' },
  overtime:  { label:'Hệ số tăng ca',      icon:'clock',            color:'#d97706', bg:'#fef3c7' },
  deduction: { label:'Khấu trừ & Bảo hiểm',icon:'minus-circle',    color:'#dc2626', bg:'#fee2e2' }
};
const roleLabels = { all:'Tất cả', admin:'Quản trị', director:'Giám đốc', hr:'HR', pm:'Quản lý DA', engineer:'Kỹ sư', warehouse:'Kho', guest:'Khách' };
const unitLabels  = { VND:'VNĐ', percent:'%' };
%>

<!-- PAGE HEADER -->
<div class="ps-header">
  <div>
    <h1 class="ps-title"><i class="fas fa-sliders-h"></i> Cấu hình Lương & Phụ cấp</h1>
    <p class="ps-sub">Quản lý các tiêu chí lương, phụ cấp và khấu trừ áp dụng cho kỳ lương</p>
  </div>
  <div style="display:flex;gap:10px">
    <a href="/payroll-settings/audit" class="ps-btn ps-btn-ghost"><i class="fas fa-history"></i> Nhật ký thay đổi</a>
    <button class="ps-btn ps-btn-primary" onclick="openAddModal()"><i class="fas fa-plus"></i> Thêm tiêu chí</button>
  </div>
</div>

<!-- ACCESS NOTICE -->
<div class="ps-notice">
  <i class="fas fa-shield-alt"></i>
  Trang này chỉ dành cho <strong>Admin, HR và Ban lãnh đạo</strong>. Mọi thay đổi được ghi lại đầy đủ vào nhật ký kiểm toán.
</div>

<!-- CATEGORY TABS -->
<div class="ps-tabs" id="psTabs">
  <button class="ps-tab active" data-cat="allowance" onclick="switchTab('allowance',this)">
    <i class="fas fa-hand-holding-usd"></i> Phụ cấp
    <span class="ps-tab-count"><%= grouped.allowance.length %></span>
  </button>
  <button class="ps-tab" data-cat="overtime" onclick="switchTab('overtime',this)">
    <i class="fas fa-clock"></i> Tăng ca
    <span class="ps-tab-count"><%= grouped.overtime.length %></span>
  </button>
  <button class="ps-tab" data-cat="deduction" onclick="switchTab('deduction',this)">
    <i class="fas fa-minus-circle"></i> Khấu trừ
    <span class="ps-tab-count"><%= grouped.deduction.length %></span>
  </button>
  <button class="ps-tab" data-cat="log" onclick="switchTab('log',this)">
    <i class="fas fa-history"></i> Lịch sử gần đây
    <span class="ps-tab-count"><%= recentLogs.length %></span>
  </button>
</div>

<!-- ─── CRITERIA TABLES ─────────────────────────────────────────────────── -->
<% ['allowance','overtime','deduction'].forEach(cat => {
   const meta = catMeta[cat];
   const items = grouped[cat];
%>
<div class="ps-panel" id="panel-<%= cat %>" style="<%= cat!=='allowance'?'display:none':'' %>">
  <div class="ps-panel-head" style="border-left: 4px solid <%= meta.color %>">
    <div style="display:flex;align-items:center;gap:10px">
      <div class="ps-cat-ico" style="background:<%= meta.bg %>;color:<%= meta.color %>">
        <i class="fas fa-<%= meta.icon %>"></i>
      </div>
      <div>
        <div class="ps-panel-title"><%= meta.label %></div>
        <div class="ps-panel-sub"><%= items.length %> tiêu chí · Hiệu lực từ kỳ lương</div>
      </div>
    </div>
    <button class="ps-btn ps-btn-sm" style="border-color:<%= meta.color %>;color:<%= meta.color %>"
      onclick="openAddModal('<%= cat %>')">
      <i class="fas fa-plus"></i> Thêm
    </button>
  </div>

  <% if (!items.length) { %>
  <div class="ps-empty">
    <i class="fas fa-<%= meta.icon %>" style="font-size:28px;color:<%= meta.color %>;opacity:.3"></i>
    <p>Chưa có tiêu chí nào</p>
    <button class="ps-btn ps-btn-sm" onclick="openAddModal('<%= cat %>')"><i class="fas fa-plus"></i> Thêm ngay</button>
  </div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table class="ps-table">
      <thead>
        <tr>
          <th style="width:28%">Tên tiêu chí</th>
          <th>Đơn vị</th>
          <th style="width:18%">Giá trị</th>
          <th>Đối tượng</th>
          <th>Hiệu lực</th>
          <th>Trạng thái</th>
          <th style="width:100px">Thao tác</th>
        </tr>
      </thead>
      <tbody>
      <% items.forEach(item => {
        const isOT = cat === 'overtime';
      %>
      <tr class="ps-tr <%= item.is_active ? '' : 'ps-tr-inactive' %>" id="row-<%= item.id %>">
        <td>
          <div class="ps-item-name"><%= item.name %></div>
          <div class="ps-item-key"><code><%= item.key %></code></div>
          <% if (item.description) { %><div class="ps-item-desc"><%= item.description %></div><% } %>
        </td>
        <td><span class="ps-unit-badge"><%= item.unit === 'percent' ? '%' : 'VNĐ' %></span></td>
        <td>
          <div class="ps-value-display" id="val-<%= item.id %>">
            <% if (item.unit === 'percent') { %>
              <span class="ps-value-num"><%= item.default_value %>%</span>
              <% if (isOT) { %><span class="ps-ot-coeff">×<%= (item.default_value/100).toFixed(2) %></span><% } %>
            <% } else { %>
              <span class="ps-value-num"><%= parseInt(item.default_value).toLocaleString('vi-VN') %>đ</span>
            <% } %>
          </div>
        </td>
        <td><span class="ps-role-chip"><%= roleLabels[item.applies_to] || item.applies_to %></span></td>
        <td>
          <span class="ps-eff-date">
            <% const eff = new Date(item.effective_from); const now = new Date(); %>
            <% if (eff > now) { %><span class="ps-eff-future"><i class="fas fa-calendar-alt"></i> Từ <%= eff.toLocaleDateString('vi-VN',{month:'2-digit',year:'numeric'}) %></span>
            <% } else { %><span class="ps-eff-now"><i class="fas fa-check-circle"></i> Đang áp dụng</span>
            <% } %>
          </span>
        </td>
        <td>
          <label class="ps-toggle" title="<%= item.is_active?'Đang hoạt động':'Đã tắt' %>">
            <input type="checkbox" <%= item.is_active?'checked':'' %>
              onchange="toggleActive('<%= item.id %>','<%= item.name %>',this.checked)">
            <span class="ps-toggle-slider"></span>
          </label>
        </td>
        <td>
          <div style="display:flex;gap:4px">
            <button class="ps-row-btn ps-row-edit" title="Chỉnh sửa"
              onclick="openEditModal(<%= JSON.stringify(item) %>)">
              <i class="fas fa-pencil-alt"></i>
            </button>
            <button class="ps-row-btn ps-row-preview" title="Xem trước tác động"
              onclick="openPreview('<%= item.id %>','<%= item.name %>','<%= item.unit %>',<%= item.default_value %>)">
              <i class="fas fa-eye"></i>
            </button>
            <button class="ps-row-btn ps-row-del" title="Xóa"
              onclick="confirmDelete('<%= item.id %>','<%= item.name %>')">
              <i class="fas fa-trash-alt"></i>
            </button>
          </div>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
<% }) %>

<!-- ─── RECENT AUDIT LOG ─────────────────────────────────────────────────── -->
<div class="ps-panel" id="panel-log" style="display:none">
  <div class="ps-panel-head" style="border-left:4px solid #64748b">
    <div style="display:flex;align-items:center;gap:10px">
      <div class="ps-cat-ico" style="background:#f1f5f9;color:#64748b"><i class="fas fa-history"></i></div>
      <div>
        <div class="ps-panel-title">Lịch sử thay đổi gần đây</div>
        <div class="ps-panel-sub">30 thay đổi gần nhất</div>
      </div>
    </div>
    <a href="/payroll-settings/audit" class="ps-btn ps-btn-ghost ps-btn-sm">Xem toàn bộ <i class="fas fa-arrow-right"></i></a>
  </div>
  <% if (!recentLogs.length) { %>
  <div class="ps-empty"><i class="fas fa-history" style="font-size:28px;opacity:.3"></i><p>Chưa có thay đổi nào</p></div>
  <% } else { %>
  <div style="overflow-x:auto">
    <table class="ps-table">
      <thead><tr>
        <th>Tiêu chí</th><th>Hành động</th><th>Thay đổi</th><th>Người thực hiện</th><th>Thời gian</th>
      </tr></thead>
      <tbody>
      <% recentLogs.forEach(l => {
        const actionColor = {CREATE:'#16a34a',UPDATE:'#2563eb',DELETE:'#dc2626'}[l.action]||'#64748b';
        const actionLabel = {CREATE:'Tạo mới',UPDATE:'Cập nhật',DELETE:'Xóa'}[l.action]||l.action;
      %>
      <tr class="ps-tr">
        <td>
          <div class="ps-item-name"><%= l.criteria_name || '—' %></div>
          <% if (l.criteria_key) { %><div class="ps-item-key"><code><%= l.criteria_key %></code></div><% } %>
        </td>
        <td><span class="ps-action-badge" style="background:<%=actionColor%>20;color:<%=actionColor%>"><%= actionLabel %></span></td>
        <td>
          <% if (l.field_changed && l.old_value !== null && l.new_value !== null) { %>
          <div style="font-size:12px">
            <span class="ps-old-val"><%= l.old_value %></span>
            <i class="fas fa-arrow-right" style="font-size:9px;color:#94a3b8;margin:0 4px"></i>
            <span class="ps-new-val"><%= l.new_value %></span>
          </div>
          <div style="font-size:11px;color:var(--text-3)"><%= l.field_changed %></div>
          <% } else if (l.action === 'CREATE') { %>
          <span style="font-size:12px;color:#16a34a">Tạo tiêu chí mới</span>
          <% } else if (l.action === 'DELETE') { %>
          <span style="font-size:12px;color:#dc2626">Xóa tiêu chí</span>
          <% } %>
          <% if (l.note) { %><div style="font-size:11px;color:#64748b;margin-top:2px"><i class="fas fa-comment-alt"></i> <%= l.note %></div><% } %>
        </td>
        <td>
          <div style="font-size:12.5px;font-weight:600;color:var(--text)"><%= l.changer_name || l.changed_by_name || '—' %></div>
          <% if (l.ip_address) { %><div style="font-size:11px;color:var(--text-3)"><i class="fas fa-network-wired"></i> <%= l.ip_address %></div><% } %>
        </td>
        <td style="white-space:nowrap;font-size:12px;color:var(--text-2)">
          <%= new Date(l.changed_at).toLocaleString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- ═══ EDIT / CREATE MODAL ═════════════════════════════════════════════════ -->
<div id="editModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeEditModal()">
  <div class="modal-box" style="max-width:580px;width:95%">
    <div class="modal-header">
      <h3 id="editModalTitle" style="margin:0;font-size:16px;font-weight:700;display:flex;align-items:center;gap:9px">
        <span id="editModalIco" style="width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px"></span>
        <span id="editModalTitleText">Chỉnh sửa tiêu chí</span>
      </h3>
      <button class="modal-close" onclick="closeEditModal()"><i class="fas fa-times"></i></button>
    </div>
    <form id="editForm" method="POST">
      <input type="hidden" name="_method" id="editMethod" value="PUT">
      <div class="modal-body" style="padding:0">

        <!-- Section 1: Basic info -->
        <div style="padding:18px 22px 14px;display:grid;gap:13px">
          <div style="display:flex;align-items:center;gap:6px">
            <span style="width:3px;height:13px;background:var(--primary);border-radius:2px"></span>
            <span style="font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Thông tin tiêu chí</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr auto;gap:12px;align-items:end">
            <div class="form-group" style="margin:0">
              <label class="form-label">Tên tiêu chí <span style="color:#dc2626">*</span></label>
              <input type="text" name="name" id="editName" class="form-input" required>
            </div>
            <div class="form-group" style="margin:0;min-width:120px">
              <label class="form-label">Danh mục <span style="color:#dc2626">*</span></label>
              <select name="category" id="editCategory" class="form-input" required>
                <option value="allowance">Phụ cấp</option>
                <option value="overtime">Tăng ca</option>
                <option value="deduction">Khấu trừ</option>
              </select>
            </div>
          </div>
          <div id="keyRow" style="display:none">
            <label class="form-label">Key (không đổi được sau khi tạo)</label>
            <div style="display:flex;align-items:center;gap:5px">
              <input type="text" name="key" id="editKey" class="form-input" placeholder="vd: lunch_allowance"
                style="font-family:monospace;font-size:13px" oninput="sanitizeKey(this)">
              <span style="font-size:11px;color:var(--text-3);white-space:nowrap">chỉ a-z, 0-9, _</span>
            </div>
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Mô tả</label>
            <input type="text" name="description" id="editDesc" class="form-input" placeholder="Ghi chú thêm...">
          </div>
        </div>

        <div style="height:1px;background:var(--border);margin:0 22px"></div>

        <!-- Section 2: Value & scope -->
        <div style="padding:14px 22px 16px;display:grid;gap:13px">
          <div style="display:flex;align-items:center;gap:6px">
            <span style="width:3px;height:13px;background:#d97706;border-radius:2px"></span>
            <span style="font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Giá trị & Phạm vi</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Đơn vị <span style="color:#dc2626">*</span></label>
              <select name="unit" id="editUnit" class="form-input" onchange="updateValueHint()">
                <option value="VND">VNĐ (đồng)</option>
                <option value="percent">% (phần trăm)</option>
              </select>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Giá trị <span style="color:#dc2626">*</span></label>
              <div style="position:relative">
                <input type="number" name="default_value" id="editValue" class="form-input"
                  step="0.01" min="0" required style="padding-right:38px"
                  oninput="triggerPreview()">
                <span id="editUnitSuffix" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);font-size:12px;color:var(--text-3);pointer-events:none">đ</span>
              </div>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Đối tượng</label>
              <select name="applies_to" id="editAppliesTo" class="form-input">
                <option value="all">Tất cả</option>
                <option value="admin">Quản trị</option>
                <option value="director">Giám đốc</option>
                <option value="hr">HR</option>
                <option value="pm">Quản lý DA</option>
                <option value="engineer">Kỹ sư</option>
                <option value="warehouse">Kho</option>
              </select>
            </div>
          </div>

          <!-- Preview impact -->
          <div id="previewBox" class="ps-preview-box" style="display:none">
            <div class="ps-preview-loading" id="previewLoading"><i class="fas fa-circle-notch fa-spin"></i> Đang tính tác động...</div>
            <div id="previewResult" style="display:none">
              <div class="ps-preview-title"><i class="fas fa-calculator"></i> Ước tính tác động thay đổi</div>
              <div class="ps-preview-stats" id="previewStats"></div>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="form-group" style="margin:0">
              <label class="form-label"><i class="fas fa-calendar-alt" style="color:#2563eb"></i> Thời điểm hiệu lực</label>
              <select name="effective_when" id="editEffective" class="form-input">
                <option value="current">Áp dụng từ tháng này</option>
                <option value="next">Áp dụng từ tháng sau</option>
              </select>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Ghi chú thay đổi</label>
              <input type="text" name="note" id="editNote" class="form-input" placeholder="Lý do thay đổi...">
            </div>
          </div>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" onclick="closeEditModal()" style="padding:9px 18px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:transparent;color:var(--text-2);font-size:13.5px;font-weight:500;cursor:pointer">Hủy</button>
        <button type="submit" id="editSubmitBtn" style="padding:9px 22px;border-radius:var(--radius-sm);border:none;background:var(--primary);color:#fff;font-size:13.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:7px;box-shadow:0 2px 8px rgba(21,101,192,.3)">
          <i class="fas fa-save"></i> <span id="editSubmitLabel">Lưu thay đổi</span>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- ═══ PREVIEW MODAL ═══════════════════════════════════════════════════════ -->
<div id="previewModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closePreviewModal()">
  <div class="modal-box" style="max-width:500px;width:95%">
    <div class="modal-header">
      <h3 style="margin:0;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px">
        <span style="width:30px;height:30px;background:#7c3aed20;border-radius:8px;display:flex;align-items:center;justify-content:center"><i class="fas fa-calculator" style="color:#7c3aed;font-size:13px"></i></span>
        Xem trước tác động
      </h3>
      <button class="modal-close" onclick="closePreviewModal()"><i class="fas fa-times"></i></button>
    </div>
    <div id="previewModalBody" style="padding:22px">
      <div id="pmLoading" style="text-align:center;padding:30px;color:var(--text-3)"><i class="fas fa-circle-notch fa-spin fa-2x"></i></div>
      <div id="pmContent" style="display:none"></div>
    </div>
    <div class="modal-footer">
      <button onclick="closePreviewModal()" style="padding:9px 18px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:transparent;color:var(--text-2);font-size:13.5px;font-weight:500;cursor:pointer">Đóng</button>
    </div>
  </div>
</div>

<!-- ═══ DELETE CONFIRM MODAL ════════════════════════════════════════════════ -->
<div id="deleteModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeDeleteModal()">
  <div class="modal-box" style="max-width:420px;width:95%">
    <div class="modal-header">
      <h3 style="margin:0;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px">
        <span style="width:30px;height:30px;background:#fee2e2;border-radius:8px;display:flex;align-items:center;justify-content:center"><i class="fas fa-trash-alt" style="color:#dc2626;font-size:13px"></i></span>
        Xác nhận xóa
      </h3>
      <button class="modal-close" onclick="closeDeleteModal()"><i class="fas fa-times"></i></button>
    </div>
    <div style="padding:22px">
      <p style="margin:0 0 8px;font-size:14px;color:var(--text)">Bạn có chắc muốn xóa tiêu chí:</p>
      <p id="deleteItemName" style="margin:0;font-size:15px;font-weight:700;color:#dc2626"></p>
      <p style="margin:12px 0 0;font-size:13px;color:var(--text-3)">Hành động này không thể hoàn tác và sẽ được ghi vào nhật ký kiểm toán.</p>
    </div>
    <div class="modal-footer">
      <button onclick="closeDeleteModal()" style="padding:9px 18px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:transparent;color:var(--text-2);font-size:13.5px;font-weight:500;cursor:pointer">Hủy</button>
      <form id="deleteForm" method="POST">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" style="padding:9px 22px;border-radius:var(--radius-sm);border:none;background:#dc2626;color:#fff;font-size:13.5px;font-weight:600;cursor:pointer">
          <i class="fas fa-trash-alt"></i> Xóa tiêu chí
        </button>
      </form>
    </div>
  </div>
</div>

<style>
/* ── PAGE ─────────────────────────────────────────────────────── */
.ps-header { display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:18px;flex-wrap:wrap }
.ps-title { font-size:22px;font-weight:800;color:var(--text);margin:0 0 4px;display:flex;align-items:center;gap:10px }
.ps-title i { color:var(--primary) }
.ps-sub { font-size:13px;color:var(--text-3);margin:0 }
.ps-notice { background:#eff6ff;border:1px solid #bfdbfe;border-radius:var(--radius-sm);padding:10px 16px;margin-bottom:18px;font-size:13px;color:#1e40af;display:flex;align-items:center;gap:8px }

/* ── BUTTONS ─────────────────────────────────────────────────── */
.ps-btn { display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;border:1.5px solid transparent;transition:var(--transition) }
.ps-btn-primary { background:var(--primary);color:#fff;border-color:var(--primary);box-shadow:0 2px 6px rgba(37,99,235,.2) }
.ps-btn-primary:hover { background:var(--primary-dark) }
.ps-btn-ghost { background:transparent;color:var(--text-2);border-color:var(--border) }
.ps-btn-ghost:hover { border-color:var(--primary);color:var(--primary) }
.ps-btn-sm { padding:5px 12px;font-size:12px;background:transparent;border:1.5px solid var(--border);color:var(--text-2) }
.ps-btn-sm:hover { border-color:var(--primary);color:var(--primary) }

/* ── TABS ─────────────────────────────────────────────────────── */
.ps-tabs { display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:18px }
.ps-tab { display:inline-flex;align-items:center;gap:7px;padding:10px 20px;background:none;border:none;font-size:13px;font-weight:500;color:var(--text-3);cursor:pointer;position:relative;transition:color .15s }
.ps-tab::after { content:'';position:absolute;bottom:-2px;left:0;right:0;height:2px;background:var(--primary);transform:scaleX(0);transition:transform .2s }
.ps-tab.active { color:var(--primary);font-weight:700 }
.ps-tab.active::after { transform:scaleX(1) }
.ps-tab:hover { color:var(--primary) }
.ps-tab-count { background:var(--border-light);color:var(--text-3);font-size:11px;font-weight:700;padding:1px 7px;border-radius:20px }
.ps-tab.active .ps-tab-count { background:var(--primary-50);color:var(--primary) }

/* ── PANEL ───────────────────────────────────────────────────── */
.ps-panel { background:var(--card);border-radius:var(--radius);border:1.5px solid var(--border);box-shadow:var(--shadow);overflow:hidden;margin-bottom:0 }
.ps-panel-head { display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-bottom:1.5px solid var(--border);gap:12px }
.ps-cat-ico { width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0 }
.ps-panel-title { font-size:14px;font-weight:700;color:var(--text) }
.ps-panel-sub { font-size:11.5px;color:var(--text-3);margin-top:2px }
.ps-empty { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:40px;color:var(--text-3);font-size:13px }

/* ── TABLE ───────────────────────────────────────────────────── */
.ps-table { width:100%;border-collapse:collapse }
.ps-table thead tr { background:var(--bg) }
.ps-table th { padding:9px 14px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--text-3);text-align:left;border-bottom:1.5px solid var(--border);white-space:nowrap;position:sticky;top:0;background:var(--bg);z-index:1 }
.ps-tr { border-bottom:1px solid var(--border);transition:background .1s }
.ps-tr:last-child { border-bottom:none }
.ps-tr:hover td { background:rgba(37,99,235,.025) }
.ps-tr-inactive td { opacity:.55 }
.ps-table td { padding:10px 14px;vertical-align:middle }
.ps-item-name { font-size:13.5px;font-weight:600;color:var(--text) }
.ps-item-key { font-size:11px;color:var(--text-3);margin-top:2px }
.ps-item-key code { background:var(--bg);padding:1px 5px;border-radius:3px;font-size:10.5px }
.ps-item-desc { font-size:11px;color:var(--text-3);margin-top:3px }
.ps-unit-badge { padding:2px 8px;border-radius:4px;font-size:11.5px;font-weight:600;background:#f1f5f9;color:#475569 }
.ps-value-num { font-size:14px;font-weight:700;color:var(--text);font-family:monospace }
.ps-ot-coeff { margin-left:6px;font-size:11px;font-weight:600;color:#d97706;background:#fef3c7;padding:1px 6px;border-radius:4px }
.ps-role-chip { padding:3px 9px;border-radius:20px;font-size:11.5px;font-weight:600;background:var(--bg);color:var(--text-2) }
.ps-eff-now { font-size:12px;color:#16a34a;display:flex;align-items:center;gap:4px;font-weight:500 }
.ps-eff-future { font-size:12px;color:#d97706;display:flex;align-items:center;gap:4px;font-weight:500 }
.ps-action-badge { padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700 }
.ps-old-val { font-size:12px;color:#dc2626;font-weight:600 }
.ps-new-val { font-size:12px;color:#16a34a;font-weight:600 }

/* ── TOGGLE ──────────────────────────────────────────────────── */
.ps-toggle { position:relative;display:inline-block;width:40px;height:22px;cursor:pointer }
.ps-toggle input { opacity:0;width:0;height:0;position:absolute }
.ps-toggle-slider { position:absolute;inset:0;border-radius:22px;background:#d1d5db;transition:.25s }
.ps-toggle-slider::before { content:'';position:absolute;width:16px;height:16px;left:3px;bottom:3px;border-radius:50%;background:#fff;transition:.25s;box-shadow:0 1px 3px rgba(0,0,0,.2) }
.ps-toggle input:checked+.ps-toggle-slider { background:#16a34a }
.ps-toggle input:checked+.ps-toggle-slider::before { transform:translateX(18px) }

/* ── ROW BUTTONS ─────────────────────────────────────────────── */
.ps-row-btn { width:28px;height:28px;border-radius:6px;border:1.5px solid var(--border);background:transparent;display:flex;align-items:center;justify-content:center;font-size:11.5px;cursor:pointer;color:var(--text-3);transition:var(--transition) }
.ps-row-edit:hover    { border-color:var(--primary);color:var(--primary);background:var(--primary-50) }
.ps-row-preview:hover { border-color:#7c3aed;color:#7c3aed;background:#7c3aed15 }
.ps-row-del:hover     { border-color:#dc2626;color:#dc2626;background:#fee2e2 }

/* ── PREVIEW BOX ─────────────────────────────────────────────── */
.ps-preview-box { background:#faf5ff;border:1px solid #ddd6fe;border-radius:8px;padding:12px 16px;margin-top:4px }
.ps-preview-title { font-size:12px;font-weight:700;color:#7c3aed;margin-bottom:8px;display:flex;align-items:center;gap:5px }
.ps-preview-stats { display:grid;grid-template-columns:1fr 1fr;gap:8px }
.ps-preview-stat { text-align:center;padding:8px;background:#fff;border-radius:6px;border:1px solid #ddd6fe }
.ps-preview-stat-val { font-size:16px;font-weight:800;color:var(--text) }
.ps-preview-stat-label { font-size:10.5px;color:var(--text-3);margin-top:2px }
</style>

<script>
/* ── TAB SWITCHING ───────────────────────────────────────────── */
function switchTab(cat, el) {
  document.querySelectorAll('.ps-tab').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  ['allowance','overtime','deduction','log'].forEach(c=>{
    const p=document.getElementById('panel-'+c);
    if(p) p.style.display = c===cat?'block':'none';
  });
}

/* ── MODAL HELPERS ───────────────────────────────────────────── */
let currentEditId = null;
let previewTimer = null;

const catMeta = {
  allowance:{ label:'Thêm phụ cấp',  bg:'#2563eb', ico:'hand-holding-usd' },
  overtime: { label:'Thêm hệ số tăng ca', bg:'#d97706', ico:'clock' },
  deduction:{ label:'Thêm khấu trừ', bg:'#dc2626', ico:'minus-circle' }
};

function openAddModal(cat='allowance') {
  currentEditId = null;
  document.getElementById('editForm').action = '/payroll-settings';
  document.getElementById('editMethod').value = 'POST';
  document.getElementById('editModalTitleText').textContent = 'Thêm tiêu chí mới';
  const m=catMeta[cat]||catMeta.allowance;
  const ico=document.getElementById('editModalIco');
  ico.style.background=m.bg+'20'; ico.style.color=m.bg;
  ico.innerHTML=`<i class="fas fa-${m.ico}"></i>`;
  document.getElementById('editSubmitLabel').textContent='Tạo tiêu chí';
  document.getElementById('keyRow').style.display='block';
  document.getElementById('editName').value='';
  document.getElementById('editKey').value='';
  document.getElementById('editDesc').value='';
  document.getElementById('editValue').value='';
  document.getElementById('editNote').value='';
  document.getElementById('editCategory').value=cat;
  document.getElementById('editUnit').value='VND';
  document.getElementById('editAppliesTo').value='all';
  document.getElementById('editEffective').value='current';
  document.getElementById('editUnitSuffix').textContent='đ';
  document.getElementById('previewBox').style.display='none';
  document.getElementById('editModal').style.display='flex';
  setTimeout(()=>document.getElementById('editName').focus(),50);
}

function openEditModal(item) {
  currentEditId = item.id;
  document.getElementById('editForm').action = '/payroll-settings/'+item.id;
  document.getElementById('editMethod').value = 'PUT';
  document.getElementById('editModalTitleText').textContent = 'Chỉnh sửa: '+item.name;
  const m=catMeta[item.category]||catMeta.allowance;
  const ico=document.getElementById('editModalIco');
  ico.style.background=m.bg+'20'; ico.style.color=m.bg;
  ico.innerHTML=`<i class="fas fa-${m.ico}"></i>`;
  document.getElementById('editSubmitLabel').textContent='Lưu thay đổi';
  document.getElementById('keyRow').style.display='none';
  document.getElementById('editName').value=item.name;
  document.getElementById('editDesc').value=item.description||'';
  document.getElementById('editCategory').value=item.category;
  document.getElementById('editUnit').value=item.unit;
  document.getElementById('editAppliesTo').value=item.applies_to||'all';
  document.getElementById('editValue').value=item.default_value;
  document.getElementById('editEffective').value='current';
  document.getElementById('editNote').value='';
  document.getElementById('editUnitSuffix').textContent=item.unit==='percent'?'%':'đ';
  document.getElementById('previewBox').style.display='none';
  document.getElementById('editModal').style.display='flex';
  setTimeout(()=>document.getElementById('editValue').focus(),50);
}

function closeEditModal() { document.getElementById('editModal').style.display='none'; }

function sanitizeKey(el) {
  el.value = el.value.toLowerCase().replace(/[^a-z0-9_]/g,'_');
}
document.getElementById('editName').addEventListener('input', function() {
  const keyEl = document.getElementById('editKey');
  if (!currentEditId && keyEl) {
    keyEl.value = this.value.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/[^a-z0-9 ]/g,'').replace(/ +/g,'_').replace(/_+/g,'_');
  }
});
function updateValueHint() {
  document.getElementById('editUnitSuffix').textContent = document.getElementById('editUnit').value==='percent'?'%':'đ';
}

/* ── INLINE PREVIEW ──────────────────────────────────────────── */
function triggerPreview() {
  if (!currentEditId) return;
  clearTimeout(previewTimer);
  previewTimer = setTimeout(async()=>{
    const newVal = document.getElementById('editValue').value;
    if (!newVal) return;
    const box = document.getElementById('previewBox');
    box.style.display='block';
    document.getElementById('previewLoading').style.display='block';
    document.getElementById('previewResult').style.display='none';
    try {
      const r = await fetch(`/payroll-settings/${currentEditId}/preview?new_value=${encodeURIComponent(newVal)}`);
      const d = await r.json();
      if (d.error) { box.style.display='none'; return; }
      document.getElementById('previewLoading').style.display='none';
      document.getElementById('previewResult').style.display='block';
      const sign = d.diff_per_person >= 0 ? '+' : '';
      document.getElementById('previewStats').innerHTML=`
        <div class="ps-preview-stat">
          <div class="ps-preview-stat-val" style="color:${d.diff_total>=0?'#16a34a':'#dc2626'}">${sign}${Math.round(d.diff_per_person).toLocaleString('vi-VN')}đ</div>
          <div class="ps-preview-stat-label">Thay đổi / người</div>
        </div>
        <div class="ps-preview-stat">
          <div class="ps-preview-stat-val" style="color:${d.diff_total>=0?'#16a34a':'#dc2626'}">${sign}${Math.round(d.diff_total).toLocaleString('vi-VN')}đ</div>
          <div class="ps-preview-stat-label">Tổng / tháng (${d.affected} người)</div>
        </div>`;
    } catch(e) { box.style.display='none'; }
  }, 600);
}

/* ── STANDALONE PREVIEW MODAL ────────────────────────────────── */
async function openPreview(id, name, unit, currentVal) {
  document.getElementById('previewModal').style.display='flex';
  document.getElementById('pmLoading').style.display='block';
  document.getElementById('pmContent').style.display='none';
  const prompt = unit==='percent'
    ? parseFloat(prompt(`Nhập hệ số mới cho "${name}" (hiện tại: ${currentVal}%):`, currentVal))
    : parseFloat(prompt(`Nhập giá trị mới cho "${name}" (hiện tại: ${parseInt(currentVal).toLocaleString('vi-VN')} đ):`, currentVal));
  if (!prompt || isNaN(prompt)) { closePreviewModal(); return; }
  try {
    const r = await fetch(`/payroll-settings/${id}/preview?new_value=${encodeURIComponent(prompt)}`);
    const d = await r.json();
    document.getElementById('pmLoading').style.display='none';
    document.getElementById('pmContent').style.display='block';
    if (d.error) { document.getElementById('pmContent').innerHTML=`<p style="color:#dc2626">${d.error}</p>`; return; }
    const sign = d.diff_total>=0?'+':'';
    document.getElementById('pmContent').innerHTML=`
      <div style="text-align:center;margin-bottom:18px">
        <div style="font-size:13px;color:var(--text-3);margin-bottom:4px">Thay đổi tiêu chí</div>
        <div style="font-size:18px;font-weight:800;color:var(--text)">${d.criteria_name}</div>
        <div style="margin-top:8px;display:flex;align-items:center;justify-content:center;gap:10px;font-size:15px;font-weight:700">
          <span style="color:#dc2626">${currentVal}${unit==='percent'?'%':' đ'}</span>
          <i class="fas fa-arrow-right" style="color:#94a3b8;font-size:12px"></i>
          <span style="color:#16a34a">${prompt}${unit==='percent'?'%':' đ'}</span>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">
        <div style="text-align:center;padding:14px;background:${d.diff_total>=0?'#dcfce7':'#fee2e2'};border-radius:10px">
          <div style="font-size:22px;font-weight:800;color:${d.diff_total>=0?'#16a34a':'#dc2626'}">${sign}${Math.round(d.diff_per_person).toLocaleString('vi-VN')}đ</div>
          <div style="font-size:12px;color:var(--text-3);margin-top:4px">Thay đổi / người / tháng</div>
        </div>
        <div style="text-align:center;padding:14px;background:${d.diff_total>=0?'#dcfce7':'#fee2e2'};border-radius:10px">
          <div style="font-size:22px;font-weight:800;color:${d.diff_total>=0?'#16a34a':'#dc2626'}">${sign}${Math.round(d.diff_total).toLocaleString('vi-VN')}đ</div>
          <div style="font-size:12px;color:var(--text-3);margin-top:4px">Tổng toàn công ty / tháng</div>
        </div>
      </div>
      <div style="background:var(--bg);border-radius:8px;padding:12px;font-size:12.5px">
        <div style="font-weight:700;color:var(--text);margin-bottom:6px"><i class="fas fa-users"></i> ${d.affected} nhân viên bị ảnh hưởng</div>
        ${(d.employees||[]).map(e=>`<div style="display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:1px solid var(--border)"><div style="width:24px;height:24px;border-radius:50%;background:var(--primary-50);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--primary)">${e.full_name.charAt(0)}</div><span>${e.full_name}</span></div>`).join('')}
        ${d.affected>10?`<div style="text-align:center;padding-top:6px;color:var(--text-3)">+${d.affected-10} người khác...</div>`:''}
      </div>`;
  } catch(e) { document.getElementById('pmContent').innerHTML=`<p style="color:#dc2626">Lỗi: ${e.message}</p>`; }
}
function closePreviewModal() { document.getElementById('previewModal').style.display='none'; }

/* ── DELETE ──────────────────────────────────────────────────── */
function confirmDelete(id, name) {
  document.getElementById('deleteItemName').textContent = name;
  document.getElementById('deleteForm').action = '/payroll-settings/'+id;
  document.getElementById('deleteModal').style.display='flex';
}
function closeDeleteModal() { document.getElementById('deleteModal').style.display='none'; }

/* ── TOGGLE ACTIVE ───────────────────────────────────────────── */
async function toggleActive(id, name, active) {
  try {
    const r = await fetch('/payroll-settings/'+id, {
      method:'PUT',
      headers:{'Content-Type':'application/json','Accept':'application/json'},
      body: JSON.stringify({ is_active: active, effective_when:'current', note:`${active?'Bật':'Tắt'} tiêu chí` })
    });
    const d = await r.json();
    if (!d.success) { location.reload(); }
  } catch(e) { location.reload(); }
}

document.addEventListener('keydown', e=>{ if(e.key==='Escape'){ closeEditModal(); closePreviewModal(); closeDeleteModal(); } });
</script>
