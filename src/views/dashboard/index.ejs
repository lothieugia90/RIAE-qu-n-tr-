<%
  const overdueCount  = taskStats.overdue || 0;
  const lowStockCount = warehouseStats.low_stock || 0;
  const taskIsAlert   = overdueCount > 0;
  const stockIsAlert  = lowStockCount > 0;
  const todayStr = new Date().toISOString().split('T')[0];
  const myTodayCount = (myTasks||[]).filter(t => t.due_date && new Date(t.due_date).toISOString().split('T')[0] === todayStr).length;
%>

<!-- ═══ KPI STRIP ═══════════════════════════════════════════════ -->
<div class="kpi-strip">

  <div class="kpi-card">
    <div class="kpi-icon kpi-blue"><i class="fas fa-layer-group"></i></div>
    <div class="kpi-body">
      <div class="kpi-label">Dự án hoạt động</div>
      <div class="kpi-value"><%= projectStats.active || 0 %></div>
      <div class="kpi-sub"><%= projectStats.total || 0 %> tổng dự án</div>
    </div>
  </div>

  <div class="kpi-card <%= taskIsAlert ? 'kpi-alert kpi-breathe' : '' %>">
    <% if (taskIsAlert) { %><div class="kpi-chip-alert"><i class="fas fa-exclamation-triangle"></i> <%= overdueCount %> quá hạn</div><% } %>
    <div class="kpi-icon <%= taskIsAlert ? 'kpi-red' : 'kpi-orange' %>"><i class="fas fa-check-square"></i></div>
    <div class="kpi-body">
      <div class="kpi-label">Task đang thực hiện</div>
      <div class="kpi-value"><%= taskStats.in_progress || 0 %></div>
      <div class="kpi-sub <%= taskIsAlert ? 'kpi-sub-danger' : '' %>">
        <% if (taskIsAlert) { %><i class="fas fa-clock"></i> <%= overdueCount %> quá hạn<% } else { %><i class="fas fa-check"></i> Đúng tiến độ<% } %>
      </div>
    </div>
  </div>

  <div class="kpi-card">
    <div class="kpi-icon kpi-green"><i class="fas fa-users"></i></div>
    <div class="kpi-body">
      <div class="kpi-label">Nhân viên</div>
      <div class="kpi-value"><%= userStats.active || 0 %></div>
      <div class="kpi-sub"><%= userStats.total || 0 %> tài khoản</div>
    </div>
  </div>

  <div class="kpi-card <%= stockIsAlert ? 'kpi-alert kpi-breathe' : '' %>">
    <% if (stockIsAlert) { %><div class="kpi-chip-alert"><i class="fas fa-exclamation-triangle"></i> Cần bổ sung</div><% } %>
    <div class="kpi-icon <%= stockIsAlert ? 'kpi-red' : 'kpi-purple' %>"><i class="fas fa-<%= stockIsAlert ? 'exclamation-triangle' : 'boxes' %>"></i></div>
    <div class="kpi-body">
      <div class="kpi-label">Vật tư sắp hết</div>
      <div class="kpi-value"><%= lowStockCount %></div>
      <div class="kpi-sub <%= stockIsAlert ? 'kpi-sub-danger' : '' %>">
        <% if (stockIsAlert) { %><i class="fas fa-box-open"></i> Cần nhập kho<% } else { %><%= warehouseStats.total_items || 0 %> mặt hàng<% } %>
      </div>
    </div>
  </div>

</div>

<!-- ═══ VIỆC CẦN LÀM (ACTION ITEMS) ════════════════════════════ -->
<%
  const totalActionItems = (pendingApprovals||[]).length + (needsSignature||[]).length
    + (pendingReturns||[]).length + (approvedRequests||[]).length;
  const isWarehouseRole = ['admin','director','warehouse','warehouse_keeper'].includes(locals.userRole);
%>
<% if (totalActionItems > 0) { %>
<div class="action-strip">
  <div class="action-strip-header">
    <span class="action-strip-title"><i class="fas fa-bolt"></i> Việc cần làm</span>
    <span class="action-strip-badge"><%= totalActionItems %></span>
  </div>
  <div class="action-strip-items">

    <% (pendingApprovals||[]).forEach(r => { %>
    <a href="/requests/<%= r.id %>" class="action-item action-item-approval">
      <div class="action-item-icon"><i class="fas fa-check-circle"></i></div>
      <div class="action-item-body">
        <div class="action-item-label">Phê duyệt</div>
        <div class="action-item-text"><%= r.title %></div>
        <div class="action-item-meta"><i class="fas fa-user"></i> <%= r.requester_name %></div>
      </div>
      <div class="action-item-arrow"><i class="fas fa-chevron-right"></i></div>
    </a>
    <% }) %>

    <% (needsSignature||[]).forEach(wa => { %>
    <a href="/warehouse/assignments/<%= wa.id %>" class="action-item action-item-sign">
      <div class="action-item-icon"><i class="fas fa-signature"></i></div>
      <div class="action-item-body">
        <div class="action-item-label">Cần ký nhận</div>
        <div class="action-item-text"><%= wa.item_name %></div>
        <div class="action-item-meta"><i class="fas fa-box"></i> <%= wa.quantity %> <%= wa.unit %></div>
      </div>
      <div class="action-item-arrow"><i class="fas fa-chevron-right"></i></div>
    </a>
    <% }) %>

    <% if (isWarehouseRole) { %>
    <% (pendingReturns||[]).forEach(wa => { %>
    <a href="/signatures/warehouse-return/<%= wa.id %>" class="action-item action-item-return">
      <div class="action-item-icon"><i class="fas fa-undo"></i></div>
      <div class="action-item-body">
        <div class="action-item-label">Chờ ký thu hồi</div>
        <div class="action-item-text"><%= wa.item_name %></div>
        <div class="action-item-meta"><i class="fas fa-user"></i> <%= wa.assignee_name %></div>
      </div>
      <div class="action-item-arrow"><i class="fas fa-chevron-right"></i></div>
    </a>
    <% }) %>
    <% } %>

    <% (approvedRequests||[]).forEach(r => { %>
    <a href="/requests/<%= r.id %>" class="action-item action-item-approved">
      <div class="action-item-icon"><i class="fas fa-check-double"></i></div>
      <div class="action-item-body">
        <div class="action-item-label">Đã được duyệt</div>
        <div class="action-item-text"><%= r.title %></div>
        <div class="action-item-meta"><i class="fas fa-clock"></i> <%= new Date(r.updated_at).toLocaleDateString('vi-VN') %></div>
      </div>
      <div class="action-item-arrow"><i class="fas fa-chevron-right"></i></div>
    </a>
    <% }) %>

  </div>
</div>
<% } %>

<style>
.action-strip { background:var(--card); border:1.5px solid var(--border); border-radius:12px; margin-bottom:16px; overflow:hidden; }
.action-strip-header { display:flex; align-items:center; gap:8px; padding:11px 18px; border-bottom:1px solid var(--border); background:var(--bg); }
.action-strip-title { font-size:13px; font-weight:700; color:var(--text); }
.action-strip-badge { background:var(--primary); color:#fff; border-radius:12px; padding:1px 9px; font-size:12px; font-weight:700; margin-left:4px; }
.action-strip-items { display:flex; gap:0; overflow-x:auto; }
.action-item { display:flex; align-items:center; gap:10px; padding:12px 16px; text-decoration:none; border-right:1px solid var(--border); min-width:200px; flex:1; transition:background .15s; }
.action-item:last-child { border-right:none; }
.action-item:hover { background:var(--border-light); }
.action-item-icon { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:14px; }
.action-item-approval .action-item-icon { background:#ede9fe; color:#7c3aed; }
.action-item-sign .action-item-icon { background:#dbeafe; color:#2563eb; }
.action-item-return .action-item-icon { background:#fff7ed; color:#ea580c; }
.action-item-approved .action-item-icon { background:#dcfce7; color:#16a34a; }
.action-item-body { flex:1; min-width:0; }
.action-item-label { font-size:10px; font-weight:700; letter-spacing:.4px; text-transform:uppercase; color:var(--text-3); margin-bottom:2px; }
.action-item-text { font-size:13px; font-weight:600; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.action-item-meta { font-size:11px; color:var(--text-3); margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.action-item-arrow { color:var(--text-3); font-size:11px; flex-shrink:0; }
@media (max-width:768px) { .action-strip-items { flex-direction:column; } .action-item { border-right:none; border-bottom:1px solid var(--border); min-width:unset; } .action-item:last-child { border-bottom:none; } }
</style>

<!-- ═══ PERSONAL ALERT BANNER ════════════════════════════════════ -->
<% if (overdueCount > 0 || myTodayCount > 0) { %>
<div style="display:flex;align-items:center;justify-content:space-between;gap:12px;background:#fef2f2;border:1px solid #fecaca;border-left:4px solid #dc2626;border-radius:10px;padding:12px 18px;margin-bottom:16px;flex-wrap:wrap">
  <div style="display:flex;align-items:center;gap:10px">
    <i class="fas fa-exclamation-triangle" style="color:#dc2626;font-size:18px;flex-shrink:0"></i>
    <div>
      <div style="font-size:14px;font-weight:700;color:#b91c1c">
        <% if (overdueCount > 0) { %>Bạn có <strong><%= overdueCount %> task quá hạn</strong><% } %>
        <% if (overdueCount > 0 && myTodayCount > 0) { %> và <% } %>
        <% if (myTodayCount > 0) { %><strong><%= myTodayCount %> task</strong> cần hoàn thành hôm nay<% } %>
      </div>
      <div style="font-size:12px;color:#dc2626;margin-top:2px">Xem danh sách công việc để xử lý ngay</div>
    </div>
  </div>
  <a href="/tasks/my-tasks" style="white-space:nowrap;background:#dc2626;color:#fff;border-radius:8px;padding:7px 16px;font-size:13px;font-weight:600;text-decoration:none;display:flex;align-items:center;gap:6px">
    <i class="fas fa-tasks"></i> Xem công việc của tôi
  </a>
</div>
<% } %>

<!-- ═══ DASHBOARD BODY ══════════════════════════════════════════ -->
<div class="db-layout">

  <!-- ──── LEFT COLUMN ─────────────────────────────────────────── -->
  <div class="db-left">

    <!-- PANEL 1: BÁO CÁO & THỐNG KÊ ──────────────────────────── -->
    <div class="db-panel">
      <div class="db-panel-head">
        <div class="db-panel-title-wrap">
          <div class="db-panel-icon" style="background:#faf5ff;color:#7c3aed"><i class="fas fa-chart-pie"></i></div>
          <div>
            <div class="db-panel-title">Báo cáo & Thống kê</div>
            <div class="db-panel-sub">Tổng quan dự án & công việc</div>
          </div>
        </div>
      </div>
      <div class="db-panel-body">
        <div class="db-dual-donut">
          <!-- Donut: Dự án -->
          <div class="db-donut-col">
            <div class="db-donut-title">Dự án</div>
            <div class="db-donut-center-wrap">
              <canvas id="projectDonut2" width="140" height="140"></canvas>
              <div class="db-donut-center-label">
                <span class="db-donut-center-num"><%= projectStats.total||0 %></span>
                <span class="db-donut-center-sub">tổng</span>
              </div>
            </div>
            <div class="db-donut-legend-col">
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#16a34a"></span><span class="db-dl-label">Đang chạy</span><span class="db-dl-val" style="color:#16a34a"><%= projectStats.active||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#3b82f6"></span><span class="db-dl-label">Kế hoạch</span><span class="db-dl-val" style="color:#3b82f6"><%= projectStats.planning||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#0284c7"></span><span class="db-dl-label">Hoàn thành</span><span class="db-dl-val" style="color:#0284c7"><%= projectStats.completed||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#d97706"></span><span class="db-dl-label">Tạm dừng</span><span class="db-dl-val" style="color:#d97706"><%= projectStats.on_hold||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#dc2626"></span><span class="db-dl-label">Quá hạn</span><span class="db-dl-val" style="color:#dc2626"><%= projectStats.overdue||0 %></span></div>
            </div>
          </div>

          <div class="db-donut-divider"></div>

          <!-- Donut: Task -->
          <div class="db-donut-col">
            <div class="db-donut-title">Task</div>
            <div class="db-donut-center-wrap">
              <canvas id="taskDonut" width="140" height="140"></canvas>
              <div class="db-donut-center-label">
                <span class="db-donut-center-num"><%= taskStats.total||0 %></span>
                <span class="db-donut-center-sub">tổng</span>
              </div>
            </div>
            <div class="db-donut-legend-col">
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#94a3b8"></span><span class="db-dl-label">Chờ làm</span><span class="db-dl-val"><%= taskStats.todo||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#3b82f6"></span><span class="db-dl-label">Đang làm</span><span class="db-dl-val" style="color:#3b82f6"><%= taskStats.in_progress||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#d97706"></span><span class="db-dl-label">Review</span><span class="db-dl-val" style="color:#d97706"><%= taskStats.review||0 %></span></div>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#16a34a"></span><span class="db-dl-label">Hoàn thành</span><span class="db-dl-val" style="color:#16a34a"><%= taskStats.done||0 %></span></div>
              <% if (overdueCount>0) { %>
              <div class="db-dl-row"><span class="db-dl-dot" style="background:#dc2626"></span><span class="db-dl-label">Quá hạn</span><span class="db-dl-val" style="color:#dc2626"><%= overdueCount %></span></div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PANEL 2: DỰ ÁN GẦN ĐÂY ───────────────────────────────── -->
    <div class="db-panel">
      <div class="db-panel-head">
        <div class="db-panel-title-wrap">
          <div class="db-panel-icon" style="background:#f0fdf4;color:#16a34a"><i class="fas fa-folder-open"></i></div>
          <div>
            <div class="db-panel-title">Dự án gần đây</div>
            <div class="db-panel-sub"><%= recentProjects.length %> dự án đang theo dõi</div>
          </div>
        </div>
        <a href="/projects" class="db-link-btn">Xem tất cả <i class="fas fa-arrow-right"></i></a>
      </div>
      <div class="db-panel-scroll" style="max-height:360px">
        <% if (!recentProjects.length) { %>
        <div class="db-empty-sm"><i class="fas fa-folder-open"></i> Chưa có dự án nào</div>
        <% } else { %>
        <table class="db-table">
          <thead><tr>
            <th style="width:38%">Dự án</th>
            <th>Trạng thái</th>
            <th style="width:28%">Tiến độ</th>
            <th>Hạn cuối</th>
          </tr></thead>
          <tbody>
          <% recentProjects.forEach(p => {
            const end = p.end_date ? new Date(p.end_date) : null;
            const pOver = end && end < new Date() && p.status !== 'completed';
            const dLeft = end ? Math.ceil((end - new Date()) / 86400000) : null;
          %>
          <tr class="db-tr">
            <td>
              <a href="/projects/<%= p.id %>" class="db-proj-link">
                <div class="db-proj-name"><%= p.name %></div>
                <div class="db-proj-code"><%= p.code %></div>
              </a>
            </td>
            <td><span class="db-chip db-chip-<%= p.status %>">
              <%= {planning:'Kế hoạch',active:'Đang chạy',on_hold:'Tạm dừng',completed:'Hoàn thành',cancelled:'Hủy'}[p.status]||p.status %>
            </span></td>
            <td>
              <div class="db-prog-row">
                <div class="db-prog-bar"><div class="db-prog-fill" style="width:<%= p.progress_percent||0 %>%;background:<%= (p.progress_percent||0)>=100?'#16a34a':(p.progress_percent||0)>=60?'#2563eb':'#d97706' %>"></div></div>
                <span class="db-prog-pct"><%= p.progress_percent||0 %>%</span>
              </div>
            </td>
            <td>
              <% if (end) { %>
              <span class="db-due <%= pOver?'db-due-over':dLeft<=7?'db-due-soon':'' %>">
                <% if(pOver){%><i class="fas fa-exclamation-circle"></i> <%}%>
                <%= end.toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'}) %>
              </span>
              <% } else { %><span class="db-muted">—</span><% } %>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ──── RIGHT SIDEBAR ───────────────────────────────────────── -->
  <div class="db-right">

    <!-- PANEL: CÔNG VIỆC CỦA TÔI ───────────────────────────────── -->
    <div class="db-panel">
      <div class="db-panel-head">
        <div class="db-panel-title-wrap">
          <div class="db-panel-icon" style="background:#eff6ff;color:#2563eb"><i class="fas fa-check-square"></i></div>
          <div>
            <div class="db-panel-title">Công việc của tôi</div>
            <div class="db-panel-sub" style="display:flex;gap:5px;margin-top:3px">
              <span class="db-badge-sm db-badge-blue"><%= urgentTasks.length %> công việc</span>
              <% if(overdueCount>0){%><span class="db-badge-sm db-badge-red"><%= overdueCount %> quá hạn</span><%}%>
            </div>
          </div>
        </div>
        <button class="db-btn-add" onclick="openQuickTask()"><i class="fas fa-plus"></i> Tạo nhanh</button>
      </div>
      <div class="db-panel-scroll" style="max-height:220px">
        <% if (!urgentTasks.length) { %>
        <div class="db-empty-sm" style="flex-direction:column;padding:30px;gap:8px">
          <i class="fas fa-check-double" style="font-size:26px;color:#16a34a;opacity:.5"></i>
          <span>Không có task cần xử lý</span>
        </div>
        <% } else { urgentTasks.forEach(t => {
          const now = new Date();
          const due  = t.due_date ? new Date(t.due_date) : null;
          const isOver = due && due < now && t.status !== 'done';
          const isSoon = due && !isOver && (due - now) < 3*24*60*60*1000;
          const prioColor = {urgent:'#dc2626',high:'#d97706',medium:'#2563eb',low:'#64748b'}[t.priority]||'#64748b';
          const prioBg    = {urgent:'#fee2e2',high:'#fef3c7',medium:'#eff6ff',low:'#f1f5f9'}[t.priority]||'#f1f5f9';
          const prioLabel = {urgent:'Khẩn',high:'Cao',medium:'TB',low:'Thấp'}[t.priority]||t.priority;
          const statusLabel = {todo:'Chờ làm',in_progress:'Đang làm',review:'Review',done:'Hoàn thành'}[t.status]||t.status;
        %>
        <div class="db-task-card <%= isOver?'db-task-card-over':isSoon?'db-task-card-soon':'' %>">
          <div class="db-tc-stripe" style="background:<%= prioColor %>"></div>
          <div class="db-tc-body">
            <div class="db-tc-top">
              <span class="db-tc-prio" style="background:<%= prioBg %>;color:<%= prioColor %>">
                <% if(t.priority==='urgent'){%><i class="fas fa-bolt"></i> <%}%><%= prioLabel %>
              </span>
              <span class="db-chip db-chip-<%= t.status %>" style="font-size:10px;padding:1px 6px"><%= statusLabel %></span>
            </div>
            <div class="db-tc-title"><%= t.title %></div>
            <div class="db-tc-meta">
              <span><i class="fas fa-folder" style="opacity:.5"></i> <%= t.project_name||'—' %></span>
              <% if(due){%>
              <span class="<%= isOver?'db-due-over':isSoon?'db-due-soon':'' %>" style="display:flex;align-items:center;gap:3px">
                <%if(isOver){%><i class="fas fa-exclamation-circle"></i><%}else{%><i class="fas fa-calendar-alt" style="opacity:.5"></i><%}%>
                <%= due.toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'}) %>
              </span>
              <%}%>
            </div>
            <div class="db-tc-foot">
              <a href="/projects/<%= t.project_id %>/kanban" class="db-tc-btn">
                <i class="fas fa-columns"></i> Kanban
              </a>
            </div>
          </div>
        </div>
        <% }) } %>
      </div>
      <div style="padding:8px 14px;border-top:1px solid var(--border)">
        <button class="db-btn-add" onclick="openQuickTask()" style="width:100%;justify-content:center">
          <i class="fas fa-plus"></i> Tạo task nhanh
        </button>
      </div>
    </div>

    <!-- PANEL: QUẢN TRỊ NHANH ──────────────────────────────────── -->
    <% if (locals.userRole === 'admin' || locals.userRole === 'director') { %>
    <div class="db-panel">
      <div class="db-panel-head">
        <div class="db-panel-title-wrap">
          <div class="db-panel-icon" style="background:#fef9c3;color:#ca8a04"><i class="fas fa-bolt"></i></div>
          <div>
            <div class="db-panel-title">Quản trị nhanh</div>
            <div class="db-panel-sub">Thao tác thường dùng</div>
          </div>
        </div>
      </div>
      <div class="db-panel-body" style="padding:8px 10px;display:grid;gap:2px">
        <% [
          {href:'/hr/create',       icon:'user-plus',      c:'#2563eb', bg:'#eff6ff', label:'Thêm nhân viên mới'},
          {href:'/projects/create', icon:'folder-plus',    c:'#16a34a', bg:'#f0fdf4', label:'Tạo dự án mới'},
          {href:'/admin',           icon:'user-cog',       c:'#d97706', bg:'#fef3c7', label:'Phân quyền tài khoản'},
          {href:'/admin/audit',     icon:'history',        c:'#7c3aed', bg:'#faf5ff', label:'Nhật ký thao tác'},
          {href:'/requests',        icon:'clipboard-check',c:'#dc2626', bg:'#fee2e2', label:'Duyệt yêu cầu'},
        ].forEach(s => { %>
        <a href="<%= s.href %>" class="db-shortcut">
          <div class="db-shortcut-ico" style="background:<%= s.bg %>;color:<%= s.c %>"><i class="fas fa-<%= s.icon %>"></i></div>
          <span class="db-shortcut-label"><%= s.label %></span>
          <i class="fas fa-chevron-right db-shortcut-arr"></i>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- PANEL: ĐANG TRỰC TUYẾN ─────────────────────────────────── -->
    <div class="db-panel">
      <div class="db-panel-head">
        <div class="db-panel-title-wrap">
          <span class="db-online-pulse"></span>
          <div>
            <div class="db-panel-title">Đang trực tuyến</div>
            <div class="db-panel-sub"><%= (locals.onlineUsers||[]).length %> thành viên</div>
          </div>
        </div>
        <span class="db-badge-sm db-badge-green" style="font-size:11px;padding:2px 8px"><%= (locals.onlineUsers||[]).length %></span>
      </div>
      <div class="db-panel-scroll" style="max-height:130px">
        <% if (!(locals.onlineUsers||[]).length) { %>
        <div class="db-empty-sm"><i class="fas fa-wifi-slash" style="opacity:.4"></i> Chưa có ai trực tuyến</div>
        <% } else { (locals.onlineUsers||[]).forEach(u => {
          const minAgo = Math.floor((Date.now()-new Date(u.last_seen_at))/60000);
          const roleLabel = {admin:'Quản trị',director:'Giám đốc',pm:'Quản lý DA',engineer:'Kỹ sư',warehouse:'Kho',guest:'Khách'}[u.role]||u.role;
        %>
        <div class="db-online-row">
          <div class="db-av-wrap">
            <div class="db-av">
              <% if(u.avatar_url){%><img src="<%= u.avatar_url %>" alt=""><%}else{%><%= u.full_name.charAt(0).toUpperCase() %><%}%>
            </div>
            <span class="db-av-dot"></span>
          </div>
          <div style="flex:1;min-width:0">
            <div class="db-on-name"><%= u.full_name %></div>
            <div class="db-on-role"><%= roleLabel %> · <%if(minAgo<1){%>vừa xong<%}else{%><%= minAgo %>p trước<%}%></div>
          </div>
        </div>
        <% }) } %>
      </div>
    </div>

  </div>
</div>

<!-- ═══ QUICK TASK MODAL ════════════════════════════════════════ -->
<div id="quickTaskModal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeQuickTask()">
  <div class="modal-box" style="max-width:560px;width:94%">
    <div class="modal-header">
      <h3 style="margin:0;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px">
        <span style="width:30px;height:30px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center"><i class="fas fa-plus" style="color:#fff;font-size:13px"></i></span>
        Tạo task nhanh
      </h3>
      <button class="modal-close" onclick="closeQuickTask()"><i class="fas fa-times"></i></button>
    </div>
    <form action="/tasks/create" method="POST">
      <div class="modal-body" style="padding:0">
        <div style="padding:20px 22px 16px;display:grid;gap:14px">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:-4px">
            <span style="width:3px;height:14px;background:var(--primary);border-radius:2px;display:inline-block"></span>
            <span style="font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Thông tin cơ bản</span>
          </div>
          <div class="form-group" style="margin:0">
            <label class="form-label">Tiêu đề task <span style="color:var(--danger)">*</span></label>
            <input type="text" name="title" class="form-input" placeholder="Nhập tiêu đề task..." required autofocus>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Dự án <span style="color:var(--danger)">*</span></label>
              <select name="project_id" class="form-input" required id="quickProjectSelect" onchange="loadQuickMembers(this.value)">
                <option value="">-- Chọn dự án --</option>
                <% (locals.activeProjects||[]).forEach(p=>{%><option value="<%= p.id %>"><%= p.name %></option><%})%>
              </select>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Giao cho</label>
              <select name="assignee_id" class="form-input" id="quickAssigneeSelect">
                <option value="">-- Chọn thành viên --</option>
              </select>
            </div>
          </div>
        </div>
        <div style="height:1px;background:var(--border);margin:0 22px"></div>
        <div style="padding:16px 22px 20px;display:grid;gap:12px">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:-4px">
            <span style="width:3px;height:14px;background:var(--warning);border-radius:2px;display:inline-block"></span>
            <span style="font-size:11px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em">Phân loại</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div class="form-group" style="margin:0">
              <label class="form-label">Ưu tiên</label>
              <select name="priority" class="form-input">
                <option value="medium">🟡 Bình thường</option>
                <option value="high">🟠 Cao</option>
                <option value="urgent">🔴 Khẩn cấp</option>
                <option value="low">🔵 Thấp</option>
              </select>
            </div>
            <div class="form-group" style="margin:0">
              <label class="form-label">Hạn chót</label>
              <input type="date" name="due_date" class="form-input">
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="closeQuickTask()"
          style="padding:9px 18px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:transparent;color:var(--text-2);font-size:13.5px;font-weight:500;cursor:pointer">Hủy</button>
        <button type="submit"
          style="padding:9px 22px;border-radius:var(--radius-sm);border:none;background:var(--primary);color:#fff;font-size:13.5px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:7px;box-shadow:0 2px 8px rgba(21,101,192,.3)">
          <i class="fas fa-check"></i> Tạo task
        </button>
      </div>
    </form>
  </div>
</div>

<style>
/* ══ KPI STRIP ════════════════════════════════════════════════ */
.kpi-strip { display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px }
.kpi-card {
  background:var(--card);border-radius:var(--radius);border:1.5px solid var(--border);
  border-bottom:3px solid transparent;padding:16px 18px;
  display:flex;align-items:flex-start;gap:12px;
  box-shadow:var(--shadow);transition:var(--transition);position:relative;overflow:hidden;
}
.kpi-card:hover { box-shadow:var(--shadow-md);transform:translateY(-2px) }
.kpi-card.kpi-alert { border-bottom-color:#ef4444;background:linear-gradient(135deg,var(--card),#fff5f5) }
.kpi-card.kpi-breathe { animation:kpiBreathe 2.4s ease-in-out infinite }
@keyframes kpiBreathe { 0%,100%{box-shadow:var(--shadow)} 50%{box-shadow:0 0 0 4px rgba(239,68,68,.15),var(--shadow-md)} }
.kpi-chip-alert { position:absolute;top:8px;right:8px;background:#fee2e2;color:#b91c1c;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;display:flex;align-items:center;gap:3px }
.kpi-icon { width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0 }
.kpi-blue   { background:#eff6ff;color:#2563eb } .kpi-green  { background:#f0fdf4;color:#16a34a }
.kpi-orange { background:#fff7ed;color:#ea580c } .kpi-purple { background:#faf5ff;color:#7c3aed } .kpi-red { background:#fee2e2;color:#dc2626 }
.kpi-body { flex:1;min-width:0 }
.kpi-label { font-size:11px;color:var(--text-3);font-weight:500 }
.kpi-value { font-size:26px;font-weight:800;color:var(--text);line-height:1.1;margin-top:2px }
.kpi-card.kpi-alert .kpi-value { color:#b91c1c }
.kpi-sub { font-size:11px;color:var(--text-3);margin-top:4px;display:flex;align-items:center;gap:4px }
.kpi-sub-danger { color:#b91c1c!important;font-weight:600 }

/* ══ DASHBOARD LAYOUT ════════════════════════════════════════ */
.db-layout { display:grid;grid-template-columns:1fr 340px;gap:16px;align-items:start }
.db-left { display:flex;flex-direction:column;gap:14px;min-width:0 }
.db-right { display:flex;flex-direction:column;gap:14px;min-width:0;position:sticky;top:16px;height:calc(100vh - 96px);overflow-y:auto;padding-right:2px }
.db-right::-webkit-scrollbar { width:4px }
.db-right::-webkit-scrollbar-track { background:transparent }
.db-right::-webkit-scrollbar-thumb { background:var(--border);border-radius:2px }

/* ══ PANEL (shared card style) ═══════════════════════════════ */
.db-panel {
  background:var(--card);border-radius:var(--radius);
  border:1.5px solid var(--border);box-shadow:var(--shadow);overflow:hidden;
}
.db-panel-head {
  display:flex;justify-content:space-between;align-items:center;
  padding:13px 18px;border-bottom:1px solid var(--border);gap:10px;flex-wrap:wrap;
}
.db-panel-title-wrap { display:flex;align-items:center;gap:9px }
.db-panel-icon { width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0 }
.db-panel-title { font-size:13.5px;font-weight:700;color:var(--text);line-height:1.2 }
.db-panel-sub { font-size:11px;color:var(--text-3);margin-top:2px }
.db-panel-body { padding:14px 18px }
.db-panel-scroll { overflow-y:auto }
.db-panel-scroll::-webkit-scrollbar { width:4px }
.db-panel-scroll::-webkit-scrollbar-track { background:transparent }
.db-panel-scroll::-webkit-scrollbar-thumb { background:var(--border);border-radius:2px }

/* ══ TAB BUTTONS ════════════════════════════════════════════ */
.db-tab-btn { padding:5px 12px;border-radius:6px;border:1.5px solid var(--border);background:transparent;font-size:12px;font-weight:500;color:var(--text-2);cursor:pointer;transition:var(--transition) }
.db-tab-btn.active { background:var(--primary);color:#fff;border-color:var(--primary) }
.db-tab-btn:hover:not(.active) { border-color:var(--primary);color:var(--primary) }

/* ══ DUAL DONUT ═════════════════════════════════════════════ */
.db-dual-donut { display:grid;grid-template-columns:1fr 1px 1fr;gap:0;align-items:start }
.db-donut-divider { background:var(--border);width:1px;align-self:stretch;margin:8px 0 }
.db-donut-col { padding:8px 16px 12px;display:flex;flex-direction:column;align-items:center;gap:10px }
.db-donut-title { font-size:12px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em }
.db-donut-center-wrap { position:relative;display:flex;align-items:center;justify-content:center }
.db-donut-center-label { position:absolute;display:flex;flex-direction:column;align-items:center;pointer-events:none }
.db-donut-center-num { font-size:22px;font-weight:800;color:var(--text);line-height:1 }
.db-donut-center-sub { font-size:10px;color:var(--text-3);margin-top:2px }
.db-donut-legend-col { width:100%;display:flex;flex-direction:column;gap:5px }
