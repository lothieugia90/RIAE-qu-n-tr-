.db-shortcut-arr { font-size:10px;color:var(--text-3);opacity:0;transition:opacity .1s }
.db-shortcut:hover .db-shortcut-arr { opacity:1 }

/* ══ RESPONSIVE ══════════════════════════════════════════════ */
@media (max-width:1200px) { .db-layout { grid-template-columns:1fr 300px } }
@media (max-width:1024px) { .db-layout { grid-template-columns:1fr } .db-right { position:static } }
@media (max-width:768px)  { .kpi-strip { grid-template-columns:repeat(2,1fr) } }
@media (max-width:480px)  { .kpi-strip { grid-template-columns:1fr } }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const pData  = <%- JSON.stringify(projectsByStatus) %>;
  const tStats = <%- JSON.stringify(taskStats) %>;
  const pColors = { planning:'#3B82F6',active:'#16A34A',on_hold:'#D97706',completed:'#0284C7',cancelled:'#DC2626' };
  const donutOpts = (centerLabel) => ({
    responsive:false,
    cutout:'68%',
    plugins:{
      legend:{display:false},
      tooltip:{callbacks:{label:ctx=>' '+ctx.label+': '+ctx.parsed}}
    },
    animation:{ animateRotate:true, duration:700 }
  });

  /* Project Donut (center panel) */
  const p2Ctx = document.getElementById('projectDonut2');
  if (p2Ctx) {
    const hasData = pData.some(d=>d.count>0);
    new Chart(p2Ctx, {
      type:'doughnut',
      data:{
        labels: pData.map(d=>({planning:'Kế hoạch',active:'Đang chạy',on_hold:'Tạm dừng',completed:'Hoàn thành',cancelled:'Hủy'}[d.status]||d.status)),
        datasets:[{
          data: hasData ? pData.map(d=>d.count) : [1],
          backgroundColor: hasData ? pData.map(d=>pColors[d.status]||'#94A3B8') : ['#e2e8f0'],
          borderWidth:0, borderRadius:4
        }]
      },
      options: donutOpts()
    });
  }

  /* Task Donut (center panel) */
  const tCtx = document.getElementById('taskDonut');
  if (tCtx) {
    const tVals = [tStats.todo||0, tStats.in_progress||0, tStats.review||0, tStats.done||0];
    const hasT  = tVals.some(v=>v>0);
    new Chart(tCtx, {
      type:'doughnut',
      data:{
        labels:['Chờ làm','Đang làm','Review','Hoàn thành'],
        datasets:[{
          data: hasT ? tVals : [1],
          backgroundColor: hasT ? ['#94A3B8','#3B82F6','#D97706','#16A34A'] : ['#e2e8f0'],
          borderWidth:0, borderRadius:4
        }]
      },
      options: donutOpts()
    });
  }
});

/* Quick task modal */
function openQuickTask() {
  document.getElementById('quickTaskModal').style.display='flex';
  setTimeout(()=>{ const el = document.querySelector('#quickTaskModal input[name=title]'); if(el) el.focus(); },50);
}
function closeQuickTask() { document.getElementById('quickTaskModal').style.display='none'; }
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeQuickTask(); });

async function loadQuickMembers(pid) {
  const sel = document.getElementById('quickAssigneeSelect');
  if(!pid){sel.innerHTML='<option value="">-- Chọn thành viên --</option>';return;}
  sel.innerHTML='<option value="">-- Đang tải... --</option>';
  try {
    const r = await fetch('/projects/'+pid+'/members-json');
    const d = await r.json();
    sel.innerHTML='<option value="">-- Chọn thành viên --</option>'+(d.members||[]).map(m=>`<option value="${m.id}">${m.full_name}</option>`).join('');
  } catch(e){sel.innerHTML='<option value="">-- Chọn thành viên --</option>';}
}
</script>
