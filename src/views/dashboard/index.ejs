.db-dl-val { font-size:12px;font-weight:700;color:var(--text) }

/* ══ TASK CARDS (sidebar) ════════════════════════════════════ */
.db-task-card { display:flex;gap:0;margin:0;border-bottom:1px solid var(--border);transition:background .1s }
.db-task-card:last-child { border-bottom:none }
.db-task-card:hover { background:rgba(37,99,235,.025) }
.db-task-card-over { background:#fff8f8 }
.db-task-card-soon { background:#fffbf0 }
.db-tc-stripe { width:4px;flex-shrink:0 }
.db-tc-body { flex:1;padding:10px 12px;min-width:0 }
.db-tc-top { display:flex;align-items:center;gap:5px;margin-bottom:5px }
.db-tc-prio { padding:1px 7px;border-radius:20px;font-size:10.5px;font-weight:700;display:flex;align-items:center;gap:3px }
.db-tc-title { font-size:13px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.db-tc-meta { display:flex;align-items:center;justify-content:space-between;gap:6px;font-size:11.5px;color:var(--text-3);margin-bottom:7px }
.db-tc-foot { display:flex;justify-content:flex-end }
.db-tc-btn { display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;color:var(--primary);text-decoration:none;padding:3px 9px;border-radius:5px;border:1.5px solid var(--primary-50);transition:var(--transition) }
.db-tc-btn:hover { background:var(--primary-50) }

/* ══ TABLE ══════════════════════════════════════════════════ */
.db-table { width:100%;border-collapse:collapse }
.db-table thead tr { border-bottom:1.5px solid var(--border);background:var(--bg) }
.db-table thead th { padding:8px 14px;font-size:10.5px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.05em;text-align:left;white-space:nowrap;position:sticky;top:0;background:var(--bg);z-index:1 }
.db-table tbody .db-tr { border-bottom:1px solid var(--border);transition:background .1s }
.db-table tbody .db-tr:last-child { border-bottom:none }
.db-table tbody .db-tr:hover td { background:rgba(37,99,235,.03) }
.db-table td { padding:9px 14px;vertical-align:middle }

/* ══ CHIP / BADGE ═══════════════════════════════════════════ */
.db-chip { display:inline-block;padding:2px 7px;border-radius:20px;font-size:10.5px;font-weight:600 }
.db-chip-todo        { background:#f1f5f9;color:#64748b }
.db-chip-in_progress { background:#eff6ff;color:#2563eb }
.db-chip-review      { background:#fef3c7;color:#d97706 }
.db-chip-done        { background:#dcfce7;color:#16a34a }
.db-chip-planning    { background:#eff6ff;color:#2563eb }
.db-chip-active      { background:#dcfce7;color:#16a34a }
.db-chip-on_hold     { background:#fef3c7;color:#d97706 }
.db-chip-completed   { background:#dcfce7;color:#16a34a }
.db-chip-cancelled   { background:#fee2e2;color:#dc2626 }

.db-badge-sm { padding:2px 7px;border-radius:20px;font-size:10.5px;font-weight:600 }
.db-badge-blue  { background:#eff6ff;color:#2563eb }
.db-badge-red   { background:#fee2e2;color:#dc2626 }
.db-badge-green { background:#dcfce7;color:#16a34a }

/* ══ PRIORITY ═══════════════════════════════════════════════ */
.db-prio { padding:2px 7px;border-radius:4px;font-size:10.5px;font-weight:700 }
.db-prio-urgent { background:#fee2e2;color:#dc2626 }
.db-prio-high   { background:#fff7ed;color:#d97706 }
.db-prio-medium { background:#eff6ff;color:#2563eb }
.db-prio-low    { background:#f1f5f9;color:#64748b }

/* ══ MISC ════════════════════════════════════════════════════ */
.db-task-name { font-size:13px;font-weight:600;color:var(--text);line-height:1.3 }
.db-proj-link { text-decoration:none }
.db-proj-name { font-size:13px;font-weight:600;color:var(--text) }
.db-proj-code { font-size:10.5px;color:var(--text-3);margin-top:1px }
.db-proj-link:hover .db-proj-name { color:var(--primary) }
.db-proj-sm { font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;display:block }
.db-muted { font-size:12px;color:var(--text-3) }
.db-due { font-size:12px;font-weight:500;color:var(--text-2);display:flex;align-items:center;gap:3px }
.db-due-over { color:#dc2626!important;font-weight:700 }
.db-due-soon { color:#d97706!important;font-weight:600 }
.db-prog-row { display:flex;align-items:center;gap:7px }
.db-prog-bar { flex:1;height:5px;background:var(--border-light);border-radius:3px;overflow:hidden;min-width:50px }
.db-prog-fill { height:100%;border-radius:3px;transition:width .3s }
.db-prog-pct { font-size:10.5px;font-weight:600;color:var(--text-2);min-width:28px }
.db-row-btn { width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--text-3);font-size:11px;text-decoration:none;transition:var(--transition) }
.db-row-btn:hover { background:var(--border-light);color:var(--primary) }
.db-empty-sm { display:flex;align-items:center;justify-content:center;gap:8px;padding:24px;font-size:12.5px;color:var(--text-3) }
.db-link-btn { display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:var(--primary);text-decoration:none;padding:5px 10px;border-radius:6px;border:1.5px solid var(--primary-50);transition:var(--transition) }
.db-link-btn:hover { background:var(--primary-50) }
.db-btn-add { display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:var(--radius-sm);border:none;background:var(--primary);color:#fff;font-size:12.5px;font-weight:600;cursor:pointer;transition:var(--transition);white-space:nowrap;text-decoration:none }
.db-btn-add:hover { background:var(--primary-dark) }

/* ══ NOTIFICATIONS ═══════════════════════════════════════════ */
.db-notif-row { display:flex;gap:9px;align-items:flex-start;padding:9px 14px;text-decoration:none;border-bottom:1px solid var(--border);transition:background .1s }
.db-notif-row:last-child { border-bottom:none }
.db-notif-row:hover { background:var(--bg) }
.db-notif-ico { width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0 }
