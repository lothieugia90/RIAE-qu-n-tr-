.db-notif-sub { font-size:11px;color:var(--text-3);margin-top:1px }

/* ══ ONLINE ══════════════════════════════════════════════════ */
.db-online-pulse { display:inline-block;width:9px;height:9px;background:#16a34a;border-radius:50%;margin-right:7px;animation:onlinePulse 2s infinite }
@keyframes onlinePulse { 0%,100%{box-shadow:0 0 0 0 rgba(22,163,74,.4)} 50%{box-shadow:0 0 0 5px rgba(22,163,74,0)} }
.db-online-row { display:flex;align-items:center;gap:9px;padding:7px 14px;transition:background .1s }
.db-online-row:hover { background:var(--bg) }
.db-av-wrap { position:relative;flex-shrink:0 }
.db-av { width:32px;height:32px;border-radius:50%;overflow:hidden;background:var(--primary-50);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:var(--primary) }
.db-av img { width:100%;height:100%;object-fit:cover }
.db-av-dot { position:absolute;bottom:0;right:0;width:8px;height:8px;background:#16a34a;border:2px solid var(--card);border-radius:50% }
.db-on-name { font-size:12.5px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.db-on-role { font-size:10.5px;color:var(--text-3) }

/* ══ SHORTCUTS ════════════════════════════════════════════════ */
.db-shortcut { display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;text-decoration:none;color:var(--text);font-size:12.5px;font-weight:500;transition:background .1s }
.db-shortcut:hover { background:var(--bg) }
.db-shortcut-ico { width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0 }
