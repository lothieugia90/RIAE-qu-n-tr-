<div class="page-header">
  <div class="page-header-title">
    <h1>Xin chào, <%= currentUser.full_name %></h1>
    <p>Tổng quan hệ thống quản lý nội bộ RIAE</p>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--primary-50);color:var(--primary)"><i class="fas fa-folder-open"></i></div>
    <div class="stat-value"><%= projectStats.active %></div>
    <div class="stat-label">Dự án đang chạy</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:<%= myTaskStats.overdue > 0 ? 'var(--danger-bg)' : 'var(--warning-bg)' %>;color:<%= myTaskStats.overdue > 0 ? 'var(--danger)' : 'var(--warning)' %>">
      <i class="fas fa-list-check"></i>
    </div>
    <div class="stat-value"><%= myTaskStats.pending %></div>
    <div class="stat-label">Việc của tôi<% if (myTaskStats.overdue > 0) { %> · <span style="color:var(--danger)"><%= myTaskStats.overdue %> quá hạn</span><% } %></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--success-bg);color:var(--success)"><i class="fas fa-user-check"></i></div>
    <div class="stat-value"><%= stats.active %></div>
    <div class="stat-label">Tài khoản hoạt động</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:var(--info-bg);color:var(--info)"><i class="fas fa-circle-dot"></i></div>
    <div class="stat-value"><%= stats.online %></div>
    <div class="stat-label">Trực tuyến (10 phút)</div>
  </div>
</div>

<% if (quickActions.length > 0) { %>
<div class="card" style="margin-top:20px">
  <div class="card-header"><h3>Thao tác nhanh</h3></div>
  <div class="card-body">
    <div class="quick-actions-grid">
      <% quickActions.forEach(a => { %>
      <a href="<%= a.href %>" class="quick-action">
        <span class="qa-icon"><i class="fas <%= a.icon %>"></i></span>
        <span class="qa-text">
          <strong><%= a.label %></strong>
          <small><%= a.desc %></small>
        </span>
      </a>
      <% }) %>
    </div>
  </div>
</div>
<% } %>

<% if (recentActivity.length > 0) { %>
<div class="card" style="margin-top:20px">
  <div class="card-header"><h3>Hoạt động gần đây</h3></div>
  <div class="card-body" style="padding:0">
    <table class="table">
      <thead>
        <tr><th>Thời gian</th><th>Người dùng</th><th>Hành động</th><th>Chi tiết</th></tr>
      </thead>
      <tbody>
        <% recentActivity.forEach(log => { %>
        <tr>
          <td style="white-space:nowrap"><%= new Date(log.created_at).toLocaleString('vi-VN') %></td>
          <td><%= log.full_name || '—' %></td>
          <td><span class="badge badge-info"><%= log.action %></span></td>
          <td><%= log.description || '' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<style>
.quick-actions-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
.quick-action {
  display: flex; align-items: center; gap: 14px; padding: 16px; border: 1.5px solid var(--border);
  border-radius: var(--radius); text-decoration: none; transition: var(--transition); background: var(--card);
}
.quick-action:hover { border-color: var(--primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
.qa-icon {
  width: 44px; height: 44px; border-radius: 10px; background: var(--primary-50); color: var(--primary);
  display: flex; align-items: center; justify-content: center; font-size: 17px; flex-shrink: 0;
}
.qa-text { display: flex; flex-direction: column; gap: 2px; }
.qa-text strong { font-size: 14px; color: var(--text); font-weight: 600; }
.qa-text small { font-size: 12px; color: var(--text-3); }
</style>
