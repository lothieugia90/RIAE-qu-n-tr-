# ===== RIAE Management System v2 =====
# Copy thành .env và điền giá trị thật. KHÔNG commit file .env.

NODE_ENV=development
PORT=3000

# PostgreSQL (hoặc dùng DATABASE_URL cho managed DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=riae_site
DB_USER=postgres
DB_PASSWORD=

# BẮT BUỘC ở production. Sinh chuỗi ngẫu nhiên:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Mật khẩu tài khoản admin khi chạy npm run seed (đổi ngay sau lần đăng nhập đầu)
ADMIN_PASSWORD=Admin@2026
